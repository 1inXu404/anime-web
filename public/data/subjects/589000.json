:"ファンワークス","count":1,"total_cont":0},{"name":"WEB","count":1,"total_cont":0},{"name":"短片","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"泡面","count":1,"total_cont":0}],"infobox":[{"key":"话数","value":"26"},{"key":"放送开始","value":"2025年10月6日"},{"key":"放送星期","value":"星期一"},{"key":"原作","value":"サンエックス、ファンワークス"},{"key":"导演","value":"宇佐美葉子"},{"key":"系列构成","value":"加藤陽一"},{"key":"脚本","value":"加藤陽一"},{"key":"企划制作人","value":"諏訪道彦"},{"key":"动画制作","value":"ファンワークス"},{"key":"官方网站","value":"https://www.san-x.co.jp/tomanto/"},{"key":"Copyright","value":"ⒸSAN-X , FANWORKS / トマント探偵事務所"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":0,"7":0,"8":0,"9":0,"10":0},"score":4},"total_episodes":26,"collection":{"on_hold":0,"dropped":6,"wish":0,"collect":2,"doing":1},"id":589793,"eps":26,"meta_tags":["日本","原创"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2025-10-06","name":"うそ探偵トマント誕生","name_cn":"","duration":"00:00:56","desc":"トマントの仲良しのおばあちゃんは伝説の名探偵。\r\nしかし、ある日、突然いなくなってしまった。\r\nおばあちゃんの行方をトマントが心配していると、そこにオニオンがやってきて……。","ep":1,"sort":1,"id":1571305,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-10-13","name":"トマトは野菜? 果物?","name_cn":"","duration":"00:00:56","desc":"トマトは野菜か果物か気になるトマント。敏腕助手のプッチーはトマントの気にしぃな性格を見かねて、そんなこと誰も気にしませんよと元気づけようとしますが…。","ep":2,"sort":2,"id":1571306,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-10-20","name":"犯人は何人!?","name_cn":"","duration":"00:00:56","desc":"とある事件が発生し、現場を調べるトマントとプッチー。犯人は3人組との情報と聞いていましたが、そこにいたのは1人だけ…。トマントはこの謎を解くことができるのか！？","ep":3,"sort":3,"id":1571307,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-10-27","name":"ライバル!? 名探偵ベリリー","name_cn":"","duration":"00:00:56","desc":"トマントの後をつける謎の影。ファンかと思いきや、預かった手紙には「探偵ヤメロ」の文字が。果たしてその正体とは…！？","ep":4,"sort":4,"id":1571308,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-11-10","name":"バー ママンゴ 第1夜","name_cn":"","duration":"00:00:56","desc":"「ジュースバー ママンゴ」に足を運ぶトマント。プッチーもおらず、いつになく大人な雰囲気。ママンゴが作ってくれたジュースを飲みながら、トマントはまたひとつまっ赤なうそを見抜きます。","ep":5,"sort":5,"id":1571309,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-11-17","name":"ワイルドなメロン？","name_cn":"","duration":"00:00:56","desc":"プッチーとべリリーが「ワイルドな人ってステキだよねー！」と盛り上がっていたところに、ワイルドに登場したメロボン。彼に隠されたまっ赤なうそとは！？","ep":6,"sort":6,"id":1571310,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-11-23","name":"ももちゃんはぴちぴちピーチ","name_cn":"","duration":"00:00:56","desc":"事務所で平和な時間を過ごしていたトマントとプッチー。しかし、そこにももちゃんが「事件なんだけど」と、依頼にやってきて…。トマントは解決することができるのか？","ep":7,"sort":7,"id":1571311,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-11-30","name":"ナスンボ警部は問題ナス","name_cn":"","duration":"00:00:56","desc":"色んなことを「問題ナス」と言ってスルーしてしまう、ナスンボ警部。トマントとプッチーが炎天下の中で登山をしていると、ナスンボの様子がおかしくて…！？","ep":8,"sort":8,"id":1571312,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-12-07","name":"しみる！ レモネード刑事","name_cn":"","duration":"00:00:56","desc":"レモネード刑事のステージはファンでいっぱい。しかし、ステージの途中で次々に風船が割れる事件が発生！みんなが慌てている中、トマントは何かに気付いたようです。","ep":9,"sort":9,"id":1571313,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-12-14","name":"鑑識しめじは疲れタケ","name_cn":"","duration":"00:00:56","desc":"働き者の鑑識しめじたち。今日もたくさん働いて疲れてしまった彼らが、とんでもないことに！　ナスンボ警部が目にした衝撃の光景とは!?","ep":10,"sort":10,"id":1571314,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-12-21","name":"引退!? ポテト署長","name_cn":"","duration":"00:00:56","desc":"大事件と聞いてべジタウン警察署に来たトマントとプッチー。そこでポテト署長から聞いたのは、突然の引退宣言！？しかし、引退の理由を聞いたトマントは、まっ赤なうそに気づきました。","ep":11,"sort":11,"id":1571315,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2025-12-28","name":"キャベ名人とレタンス名人","name_cn":"","duration":"00:00:56","desc":"将棋の対局を見に来たトマントとプッチー。キャベ名人とレタンス名人は良きライバルで、今回はキャベ名人の勝利。キャベ名人の強さには、驚きの理由がありました。","ep":12,"sort":12,"id":1571316,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-01-04","name":"妻りんこの逃避行？","name_cn":"","duration":"00:00:56","desc":"またもやポテト署長に呼び出されたトマントとプッチー。今度は旅行で妻のりんこさんに置いていかれてしまったようです。署長は落ち込んでいますが、りんこさんには何か理由があったようで…？","ep":13,"sort":13,"id":1571317,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-01-11","name":"あこがれのトマント！","name_cn":"","duration":"00:00:56","desc":"トマントに憧れる5きょうだいが探偵事務所に遊びに来ました。本人を前にしてワイワイする小さなトマトのきょうだいたちですが、トマントは何か違和感を覚えているようです。","ep":14,"sort":14,"id":1571318,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-01-18","name":"うそを見抜く才能","name_cn":"","duration":"00:00:56","desc":"勢いで探偵を始めてしまったトマントは、自分が探偵として上手くやれているか気にしています。トマントについてどう思っているか、街のみんなに聞いてみると、各々がまっ赤なうそを！？","ep":15,"sort":15,"id":1571319,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-01-25","name":"油はもう問題ナス","name_cn":"","duration":"00:00:56","desc":"カフェで休憩中のトマントとプッチー。一緒に来たナスンボ警部が飲んでいるのは、カロリーが凄そうなギトギトのごま油ジュース！？警部の発言にまたもやトマントはうそを見つけたようです。","ep":16,"sort":16,"id":1571320,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-02-01","name":"しみすぎ！ レモネード刑事","name_cn":"","duration":"00:00:56","desc":"レモネード刑事のステージは今日もファンでいっぱい。しかし、今日のステージはいつもより目がしみるようです。はたして原因は…！？","ep":17,"sort":17,"id":1571321,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-02-08","name":"トマントさんと出会った日","name_cn":"","duration":"00:00:56","desc":"探偵事務所を掃除中に、とある段ボール箱を見つけたプッチー。どうやら、その箱にはトマントとプッチーがはじめて会った頃の思い出が詰まっているようです。","ep":18,"sort":18,"id":1571322,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-02-15","name":"コーンなもんじゃろ","name_cn":"","duration":"00:00:56","desc":"書道家のもろこじいに素敵な書を書いてもらったトマントとプッチー。もろこじいに素敵な字を書ける秘訣を聞いたトマントですが…！？","ep":19,"sort":19,"id":1571323,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-02-22","name":"ピーマンのピーマー","name_cn":"","duration":"00:00:56","desc":"いつもネガティブなピーマンのピーマー。苦みのせいでピーマンが嫌われているという記事を見て、今日もいじけている様子。しかしトマントは、その解決策を知っているようです。","ep":20,"sort":20,"id":1571324,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-03-01","name":"バー ママンゴ 第２夜","name_cn":"","duration":"00:00:56","desc":"「ジュースバー ママンゴ」に再び足を運ぶトマント。大人な雰囲気でいつものジュースを頼んだトマントですが、ママンゴの様子はいつもと違いました。","ep":21,"sort":21,"id":1571325,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-03-08","name":"ベリリーはストロングベリー？","name_cn":"","duration":"00:00:56","desc":"トマントをベジフル一番の探偵だと褒め称えるミニパプリカきょうだい。そこにトマントに対抗意識を燃やしているベリリーがやってきて…！？","ep":22,"sort":22,"id":1571326,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-03-15","name":"野菜たちの浮き沈み","name_cn":"","duration":"00:00:56","desc":"べジタウン署のメンバーと一緒に、プールに遊びに来たトマントとプッチー。水に飛び込んでみんなが浮かんでいる中、ポテト署長だけが沈んでいく！？","ep":23,"sort":23,"id":1571327,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-03-22","name":"バナナでアー","name_cn":"","duration":"00:00:56","desc":"書を書いているもろこじいのところに、ブロ美・イナップル・スベールのヤンキートリオがやってきました。もろこじいの才能を称賛するスベールですが、実は彼にも意外なアートの才能が…！？","ep":24,"sort":24,"id":1571328,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-03-29","name":"怪盗パプリカあらわる！","name_cn":"","duration":"00:00:56","desc":"フルシティ美術館から名画が盗まれた！ぶどう姉妹の目撃証言。そして、それと食い違う証言をする謎の野菜。その裏には、世を騒がす怪盗が！？","ep":25,"sort":25,"id":1571329,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56},{"airdate":"2026-04-06","name":"トメイトウ・トマートウ","name_cn":"","duration":"00:00:56","desc":"トマトは野菜か果物か、まだ気にしているトマント。しかし、昔おばあちゃんが言ってくれたとある言葉を思い出しました。","ep":26,"sort":26,"id":1571330,"subject_id":589793,"comment":0,"type":0,"disc":0,"duration_seconds":56}],"updatedAt":"2026-05-01T19:26:36.526Z"},"589808":{"detail":{"date":