4,"sort":4,"id":1624234,"subject_id":571555,"comment":32,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-01","name":"がんばった","name_cn":"","duration":"","desc":"瀧村家に迎えられた鉄男は、ひと月前に母を亡くした少女・矧音と出会う。彼女は鉄男に、母の工房で作った“ある物”を見せるがー。一方その頃、大佐と呼ばれる謎の男が率いる組織「E-RDEの灯〈ヴィエルデ〉」が、鉄男の生存を知り不穏な動きを見せていた。新たな敵の影が、静かにミシマ・モールに迫りくる！","ep":5,"sort":5,"id":1624235,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-08","name":"","name_cn":"","duration":"","desc":"","ep":6,"sort":6,"id":1624236,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-15","name":"","name_cn":"","duration":"","desc":"","ep":7,"sort":7,"id":1624237,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-22","name":"","name_cn":"","duration":"","desc":"","ep":8,"sort":8,"id":1624238,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-29","name":"","name_cn":"","duration":"","desc":"","ep":9,"sort":9,"id":1624239,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-05","name":"","name_cn":"","duration":"","desc":"","ep":10,"sort":10,"id":1624240,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-12","name":"","name_cn":"","duration":"","desc":"","ep":11,"sort":11,"id":1624241,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-19","name":"","name_cn":"","duration":"","desc":"","ep":12,"sort":12,"id":1624242,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-26","name":"","name_cn":"","duration":"","desc":"","ep":13,"sort":13,"id":1666249,"subject_id":571555,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T14:37:21.941Z"},"571784":{"detail":{"date":null,"platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/6f/42/571784_7YeK7.jpg","grid":"https://lain.bgm.tv