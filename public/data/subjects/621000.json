r/l/e8/70/621449_01rvb.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e8/70/621449_01rvb.jpg","large":"https://lain.bgm.tv/pic/cover/l/e8/70/621449_01rvb.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e8/70/621449_01rvb.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e8/70/621449_01rvb.jpg"},"summary":"超爱吃甜食的小朋友——糖糖，她的嘴里住着一个叫『凯莉丝』的蛀牙！\r\n凯莉丝称呼糖糖为「妈妈」，不仅会把牙齿当家具，还会控制糖糖的身体，而糖糖总是拿她没辙，被耍得团团转。\r\n「我才不是你的妈妈！」\r\n「就是妈妈呀♡ 你准备了房间给我住，还总是吃甜食把我养大嘛」\r\n糖糖与凯莉丝，这对有点怪异的母女组合!? 将带来一连串的慌乱日常喜剧！\r\n\r\n\r\n[简介原文]\r\n甘いものが大好きな子ども・アメ。口の中には虫歯の『カリエス』が暮らしていた！\r\nアメのことを「ママ」と呼び、歯を家具にしたり身体を乗っ取ったりと自由奔放なカリエスに、アメはいつも振り回されてばかりで…。\r\n「わたし、ママじゃない！」\r\n「ママでしょ♡あたしのためにお部屋用意してくれてるし、いつも甘いもの食べて育ててくれてるじゃん」\r\nアメとカリエス――ちょっぴり変わった親子！？のドタバタ日常コメディ！","name":"キャンディーカリエス","name_cn":"Candy Caries 蛀在糖糖里","tags":[{"name":"原创","count":22,"total_cont":0},{"name":"WITSTUDIO","count":17,"total_cont":0},{"name":"2026年4月","count":14,"total_cont":0},{"name":"2026","count":14,"total_cont":0},{"name":"TV","count":12,"total_cont":0},{"name":"泡面番","count":11,"total_cont":0},{"name":"见里朝希","count":9,"total_cont":0},{"name":"日本","count":8,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"WIT-STUDIO","count":2,"total_cont":0},{"name":"喜剧","count":2,"total_cont":0},{"name":"2020s","count":2,"total_cont":0},{"name":"日常","count":1,"total_cont":0},{"name":"定格","count":1,"total_cont":0},{"name":"Q2","count":1,"total_cont":0},{"name":"周四","count":1,"total_cont":0},{"name":"森井健史郎","count":1,"total_cont":0},{"name":"2026年","count":1,"total_cont":0},{"name":"見里朝希","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"Candy Caries 蛀在糖糖里"},{"key":"别名","value":[{"v":"Candy Caries"}]},{"key":"话数","value":"*"},{"key":"放送开始","value":"2026年4月15日"},{"key":"放送星期","value":"星期三"},{"key":"官方网站","value":"https://www.candycaries.com/"},{"key":"播放电视台","value":"TBS"},{"key":"导演","value":"見里朝希"},{"key":"Copyright","value":"© Tomoki Misato/WIT STUDIO/トゥースフェアリーズ"},{"key":"原作","value":"見里朝希／WIT STUDIO"},{"key":"副导演","value":"森