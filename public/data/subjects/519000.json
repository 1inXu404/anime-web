otal":224,"count":{"1":1,"2":0,"3":2,"4":8,"5":29,"6":75,"7":87,"8":19,"9":1,"10":2},"score":6.4},"total_episodes":5,"collection":{"on_hold":19,"dropped":40,"wish":143,"collect":363,"doing":63},"id":519958,"eps":5,"meta_tags":["TV","日本","漫画改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2025-08-21","name":"かわいい人","name_cn":"可爱的人","duration":"00:23:40","desc":"中高一貫の男子校・鐘亀高校に通う江間譲二は、\r\nここ最近、風変わりなクラスメート・林美良から変な絡まれ方をされている。\r\nきっかけは体育祭。借り物競走で「かわいい人」というお題を引いた江間は、\r\nなぜか林のことが気にかかり、一緒にゴールしたのだった。","ep":1,"sort":1,"id":1525271,"subject_id":519958,"comment":19,"type":0,"disc":0,"duration_seconds":1420},{"airdate":"2025-08-28","name":"友達になってくれませんか＆描く派","name_cn":"你愿意和我做朋友吗＆画画派","duration":"00:23:40","desc":"読書好きの松屋めぐみは、小説の感想をSNSに投稿していた。\r\nそこからハンドルネーム「仮釈放」との思いがけない交流が始まる。\r\n一方、鐘亀の中等部3年で美術部の小松豊は、なんとなくスケッチした\r\n高等部の林が気になり、モデルになってほしいと声をかける。","ep":2,"sort":2,"id":1528910,"subject_id":519958,"comment":21,"type":0,"disc":0,"duration_seconds":1420},{"airdate":"2025-09-04","name":"走れ、山田！","name_cn":"快跑，山田！","duration":"00:23:40","desc":"鐘亀高校1年の山田章太郎は、あるきっかけで2年の妹尾正広のパシリとなり、\r\n専属宅配弁当屋として昼飯を奢らされていた。\r\n妹尾からの理不尽な扱いに憤りを募らせる山田だが、\r\nその思いはいつも非常階段から自分たちを眺めている林にも向けられた……。","ep":3,"sort":3,"id":1528911,"subject_id":519958,"comment":17,"type":0,"disc":0,"duration_seconds":1420},{"airdate":"2025-09-11","name":"うしろの二階堂","name_cn":"身后的二阶堂","duration":"00:23:40","desc":"共学の戸塚高校に通う目高優一は、校内で忌み嫌われている\r\n不気味キャラ・二階堂明が後ろの席になり、憂鬱な気分を抱えていた。\r\n思いきって話しかけても、二階堂の反応は無愛想なまま。\r\nそんな時、目高は中学時代の二階堂が、今とは別人のようだったと知る……。","ep":4,"sort":4,"id":1528912,"subject_id":519958,"comment":23,"type":0,"disc":0,"duration_seconds":1420},{"airdate":"2025-09-18","name":"うしろの二階堂　恐怖の修学旅行編","name_cn":"身后的二阶堂 恐怖的校外旅行篇","duration":"00:23:40","desc":"沖縄への修学旅行で、二階堂を自分と同じグループに入れた目高。\r\n二階堂は沖縄でも暗い表情と低いテンションを保ち目高を感心させるが、\r\nホテルのロビーではソフトクリームを堪能し、「ふつう」でいようとメガネを外す。\r\nだが、逆にその姿で注目されてしまう。","ep":5,"sort":5,"id":1528913,"subject_id":519958,"comment":17,"type":0,"disc":0,"duration_seconds":1420}],"updatedAt":"2026-05-01T19:25:13.224Z"}}