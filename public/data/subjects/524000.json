彼の父から、カルエゴのもとに電話がかかってきて…。\r\n\r\n脚本：筆安一幸　\r\n絵コンテ：森脇真琴　\r\n演出：長島広季","ep":4,"sort":4,"id":1654746,"subject_id":524486,"comment":9,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-02","name":"おしゃべり","name_cn":"谈天说地","duration":"","desc":"ソイの自主退学を告げられた問題児（アブノーマル）クラス。しかし、ソイは実家に戻っておらず、行方不明となっているらしい。ソイは音楽祭本番までに必ず戻ってくる。そう信じ、問題児クラスは練習を続ける。そして音楽祭の前日、クラスメートと別れた入間は1人で王の教室（ロイヤル・ワン）に残ることにした…。\r\n\r\n脚本：大島のぞむ　\r\n絵コンテ：辻橋綾佳　\r\n演出：辻橋綾佳","ep":5,"sort":5,"id":1654747,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-09","name":"","name_cn":"","duration":"","desc":"","ep":6,"sort":6,"id":1654748,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-16","name":"","name_cn":"","duration":"","desc":"","ep":7,"sort":7,"id":1654749,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-23","name":"","name_cn":"","duration":"","desc":"","ep":8,"sort":8,"id":1654750,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-30","name":"","name_cn":"","duration":"","desc":"","ep":9,"sort":9,"id":1654751,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-06","name":"","name_cn":"","duration":"","desc":"","ep":10,"sort":10,"id":1654752,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-13","name":"","name_cn":"","duration":"","desc":"","ep":11,"sort":11,"id":1654753,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-20","name":"","name_cn":"","duration":"","desc":"","ep":12,"sort":12,"id":1654754,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-27","name":"","name_cn":"","duration":"","desc":"","ep":13,"sort":13,"id":1654755,"subject_id":524486,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-07-04","name":"","name_cn":"","duration":"","desc":"","ep":14