alue":"刘少阳"},{"key":"人物设定","value":"颜闽灼、王珊、戴旦松、金超、陆斌、肖舟"},{"key":"道具设计","value":"戴旦松、肖舟、熊美玲"},{"key":"模型","value":"刘文龙、陈飞、陈明明、邵红旭"},{"key":"分镜","value":"张永清、郑飞虎"},{"key":"动画","value":"于世杰、李宇霞、颜闽灼、胡广、倪旭宇"},{"key":"渲染","value":"金雪蒙、颜闽灼"},{"key":"特效","value":"金雪蒙、孔立"},{"key":"后期","value":"孔立"},{"key":"制片","value":"王珊、刘文龙、于世杰"},{"key":"出品人","value":"刘敏"},{"key":"主题歌作曲","value":"薛禾"},{"key":"主题歌作词","value":"刘敏"},{"key":"音乐制作","value":"陈哲超、林光强、薛禾，BNC music、vocal、郑亚菁、文汐岚"},{"key":"音效制作","value":"上海艺史文化传播有限公司"},{"key":"特别鸣谢","value":"文化部、新闻出版署、广电总局、上海美术电影制片厂、水晶石、金鹰卡通、玄机科技、IDMT、文化部高级产业研修班、北京电影学院、中国传媒大学、浙江传媒大学、中国美院、浙江大学、万籁鸣、万古蟾、万超尘、万涤寰、戴铁郎、凌纾、彼岸天、娃娃鱼、其卡通、皮三、朴桦、L-key、青青树、李献计、武寒青、王云飞、张昭乐、赵勇、周湛文、周彩虹"}],"rating":{"rank":0,"total":13,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":5,"7":3,"8":3,"9":1,"10":0},"score":6.8},"total_episodes":1,"collection":{"on_hold":4,"dropped":4,"wish":12,"collect":21,"doing":1},"id":65855,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2012-05-08","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":575155,"subject_id":65855,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:38:06.962Z"},"65856":{"detail":{"date":"2010-07-09","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/4e/d1/65856_QKRit.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/4e/d1/65856_QKRit.jpg","large":"https://lain.bgm.tv/pic/cover/l/4e/d1/65856_QKRit.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/4e/d1/65856_QKRit.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/4e/d1/65856_QKRit.jpg"},"summary":"       狄爸以在建筑工地打散工养家，为了栽培儿子成材，省吃俭用把小狄送入一流学府。小狄每天身处富家子弟之中，看别人玩最新的玩具、吃最奢侈的佳肴，心中难免不是滋味。他痴痴地期盼父亲可以送他梦寐以求的智慧玩具“长江一号”。\r\n       狄爸固然买不起新玩具送小狄，却在垃圾堆里意外捡到神秘外星生物七仔。流落地球的七仔身负神奇的治愈能量，能够制造出许多功能奇特的法宝。虽然每每撞板收场，但小狄也从中汲取教训，明白了万事不可依赖他人，要自强不息才能成功的道理。同时，父子二人与七仔渐渐培养出深厚的感情。\r\n       小狄同学蛋挞头的父亲无意中发现了七仔超乎寻常的能量，为实现自己的野心，开出高价欲收买七仔，未料小狄父子不为金钱所动，情急之下绑架七仔到自家研究中心，并榨取七仔身上的能量。\r\n小狄父子冒险潜入蛋家研究中心，历尽险阻，终于救出奄奄一息的七仔，一家再次团聚。\r\n       蛋爸虽获得七仔能量，却无力控制，导致研究中心爆炸倒塌，无数致命化学污染物疯狂外泄。七仔为挽救大自然，毅然奉献出自己最后的能量。","name":"长江7号爱地球","name_cn":"长江7号爱地球","tags":[{"name":"国产","count":36,"total_cont":0},{"name":"剧场版","count":28,"total_cont":0},{"name":"动画电影","count":21,"total_cont":0},{"name":"童年","count":18,"total_cont":0},{"name":"香港","count":16,"total_cont":0},{"name":"搞笑","count":10,"total_cont":0},{"name":"2010","count":9,"total_cont":0},{"name":"国产动画电影","count":7,"total_cont":0},{"name":"日常","count":6,"total_cont":0},{"name":"印象深刻","count":4,"total_cont":0},{"name":"治愈","count":4,"total_cont":0},{"name":"动画","count":3,"total_cont":0},{"name":"原创","count":2,"total_cont":0},{"name":"中国","count":1,"total_cont":0},{"name":"剧情","count":1,"total_cont":0},{"name":"亲情","count":1,"total_cont":0},{"name":"设定","count":1,"total_cont":0},{"name":"家庭","count":1,"total_cont":0},{"name":"奇幻","count":1,"total_cont":0},{"name":"中国动画","count":1,"total_cont":0},{"name":"非续作","count":1,"total_cont":0},{"name":"环保","count":1,"total_cont":0},{"name":"IP","count":1,"total_cont":0},{"name":"电审动字（2010）第4号","count":1,"total_cont":0},{"name":"电影","count":1,"total_cont":0},{"name":"国产童年","count":1,"total_cont":0},{"name":"无分-特殊","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"长江7号爱地球"},{"key":"别名","value":[{"v":"长江7号动画版"},{"v":"长江七号爱地球"},{"v":"长江7号：动画版"},{"v":"CJ7：The Cartoon"}]},{"key":"上映年度","value":"2010年7月9日"},{"key":"片长","value":"82分钟"},{"key":"话数","value":"1"},{"key":"出品","value":"中国电影集团公司、星辉海外"},{"key":"联合出品","value":"英皇影业有限公司、幸福蓝海影视文化集团有限责任公司"},{"key":"出品人","value":"韩三平、周星驰"},{"key":"联合出品人","value":"杨受成、周莉"},{"key":"总监制","value":"韩晓黎、姜涛、王雅琳"},{"key":"总策划","value":"史东明、利雅博、陈辉"},{"key":"制片人","value":"赵海城"},{"key":"策划","value":"彭鸣宇"},{"key":"监制","value":"袁建滔、王日平、张红生"},{"key":"营销统筹","value":"蒋德富"},{"key":"发行统筹","value":"许兵"},{"key":"脚本","value":"李敏"},{"key":"音乐","value":"作曲：韦启良、夏森美、周博贤"},{"key":"导演","value":"袁建滔"},{"key":"执行制片","value":"于军"},{"key":"执行导演","value":"陈恩凯"},{"