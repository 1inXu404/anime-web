":"2017-08-30","name":"","name_cn":"","duration":"","desc":"","ep":4,"sort":4,"id":645234,"subject_id":157922,"comment":1,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T18:05:15.034Z"},"157973":{"detail":{"date":"2011-11-01","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/07/74/157973_2C8vV.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/07/74/157973_2C8vV.jpg","large":"https://lain.bgm.tv/pic/cover/l/07/74/157973_2C8vV.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/07/74/157973_2C8vV.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/07/74/157973_2C8vV.jpg"},"summary":"一对兄妹骑着牛头大马来到海边，象头妹妹奥斯卡劝阻马头哥哥艾利克斯不要下水游泳。可是艾利克斯根本没听妹妹的话，一头跳进海水中独自一人开始游泳。巨浪把他打翻在海里，艾利克斯挣扎着沉了下去。一旁暗自生气的奥斯卡发现哥哥久久未归，开始有些担心。牛头大马一直安慰着她，两人还是决定去寻找哥哥艾利克斯。在海底世界，他们看见了黑色的巨型鲸鱼。奥斯卡上前询问无果。两人爬上了鲸鱼背，钻进鲸鱼的气孔中，来到一个神奇的世界。他们看见深陷沙滩里的海豚，也发现了艾利克斯。然而牛头大马却深陷岩石之中，还失去了手臂。他叫奥斯卡赶紧离开这里，伤心的奥斯卡还是离开了这里。回到现实世界的兄妹，寂寞的漂浮在海面上，正是日落时。 \r\n　　这部标新立异的超现实主义动画短片，以其与众不同的画风构建出了一个令人惶惶不安的怪异世界。","name":"Belly","name_cn":"鲸鱼的腹部","tags":[{"name":"短片","count":6,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"WEB","count":1,"total_cont":0},{"name":"英国","count":1,"total_cont":0},{"name":"2011","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"鲸鱼的腹部"},{"key":"别名","value":[{"v":"谜一样的鲸鱼肚"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"2011-11"},{"key":"官方网站","value":"www.juliapott.com/Belly"},{"key":"导演","value":"朱丽亚·波特"},{"key":"类型","value":"动画 / 短片"},{"key":"制片国家/地区","value":"英国"},{"key":"片长","value":"7分29秒"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":1,"8":0,"9":0,"10":0},"score":6},"total_episodes":1,"collection":{"on_hold":1,"dropped":4,"wish":3,"collect":15,"doing":0},"id":157973,"eps":1,"meta_tags":["WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":588140,"subject_id":157973,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:35:47.181Z"},"157974":{"detail":{"date":"2012-03-11","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/39/5f/157974_GbLgo.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/39/5f/157974_GbLgo.jpg","large":"https://lain.bgm.tv/pic/cover/l/39/5f/157974_GbLgo.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/39/5f/157974_GbLgo.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/39/5f/157974_GbLgo.jpg"},"summary":"赖精神药物生活的女孩眼中，是一个模糊不清的分裂世界。那些幻想中的人和事，总是萦绕在女孩眼前，让她久久难以忘怀。就在这个边缘化的世界里，女孩游走在幻想和现实的两端，无法分清哪个才是真实的世界。\r\n　　这部试图探索现实与生死本质的动画短片，以一个年轻女孩的视角，描绘了一个精神病人眼中的世界。故事最初的构思想法是受到了导演父亲的影响。这位饱受精神疾病折磨的父亲，口中常常冒出诸如“在土星环形山上跳舞”、“和天使对话”一类让人难以领会的呓语。然而正是这个不被大众所认知的奇妙精神世界，导演把这些场景还原到了本片的镜头中。《巨火山口》不仅是一部献给患病父亲的作品，导演更希望借此片，来向那些拥有异于常人思维的“精神病人”致敬。","name":"Caldera","name_cn":"巨火山口","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"精神病","count":1,"total_cont":0},{"name":"2012","count":1,"total_cont":0},{"name":"WEB","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"巨火山口"},{"key":"别名","value":[{"v":"火山湖"},{"v":"卡尔德拉"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"2012-03-11"},{"key":"导演","value":"Evan Viera"},{"key":"类型","value":"动画 / 短片"},{"key":"制片国家/地区","value":"美国"},{"key":"片长","value":"11分钟"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":0,"8":0,"9":0,"10":0},"score":5.7},"total_episodes":1,"collection":{"on_hold":1,"dropped":4,"wish":6,"collect":8,"doing":1},"id":157974,"eps":1,"meta_tags":["WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":588141,"subject_id":157974,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:37:02.975Z"},"157975":{"detail":{"date":"2009-05-26","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/5f/70/157975_dnavp.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/5f/70/157975_dnavp.jpg","large":"https://lain.bgm.tv/pic/cover/l/5f/70/157975_dnavp.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/5f/70/157975_dnavp.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/5f/70/157975_dnavp.jpg"},"summary":"这部超现实主义实验动画短片，由一个在水面上苦苦挣扎着的男人开始描写。镜头切换，一个在空旷的房间里独自跳绳的小女孩，不断进出这样的房间。躲在角落里的西服男，偷偷爬上楼，跟其他男人一样，为女人掉下来的暗红色异物趋之若鹜。镜头又回到跳绳小女孩的房间里，这次，西服男尾随小女孩一同跳绳。就在这苍白抽象的空间里，控制一切的是走马灯般循环往复的迷宫，人物和场景都机械的不断重复着。西服男围坐成圈，逐一尝试上吊自杀，均未成功。然后他们脱去衣服，被安装上头颅，在热炭上行走，被凶残的剥皮……为野餐准备的蛋糕上，爬满了密密麻麻的蚂蚁。一家三口居然在屋内野餐着。人物和场景再次快速的机械重复着，不同的是，一家三口都消失了，留下的只有一堆为野餐准备的食物，就像一场梦一样。","name":"Nice Day for a Picnic","name_cn":"去野餐的好天气","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"低于7","count":1,"total_cont":0},{"name":"WEB","count":1,"total_cont":0},{"name":"英国","count":1,"total_cont":0},{"name":"2009","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"去野餐的好天气"},{"key":"别名","value":[{"v":"野餐的好日子"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"2009-05-26"},{"key":"导演","value":"Monica Gallab"},{"key":"类型","value":"动画 / 短片"},{"key":"制片国家/地区","value":"英国"},{"key":"片长","value":"4分17秒"}],"rating":{"rank":0,"total":2,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":1,"collection":{"on_hold":3,"dropped":4,"wish":9,"collect":8,"doing":1},"id":157975,"eps":1,"meta_tags":["WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":588142,"subject_id":157975,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:25:26.751Z"},"157990":{"detail":{"date":"2016-04-22","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/07/42/157990_MUMjj.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/07/42/157990_MUMjj.jpg","large":"https://lain.bgm.tv/pic/cover/l/07/42/157990_MUMjj.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/07/42