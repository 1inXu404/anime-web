22,"comment":4,"type":0,"disc":0,"duration_seconds":239}],"updatedAt":"2026-05-01T17:57:26.498Z"},"157715":{"detail":{"date":"2014-05-05","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/5c/cc/157715_b0SS4.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/5c/cc/157715_b0SS4.jpg","large":"https://lain.bgm.tv/pic/cover/l/5c/cc/157715_b0SS4.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/5c/cc/157715_b0SS4.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/5c/cc/157715_b0SS4.jpg"},"summary":"破败老旧的公寓内，少年和爱狗史丹利紧紧拥抱。因为城市遭到丧尸病毒的污染，大街小巷逡巡着可怕的食人恶魔，所以妈妈带着小主人慌张地收拾行李，也顾不上胖乎乎的狗狗，开着车夺路而逃。史丹利从门口张望开去，数架直升飞机在城市上空盘旋，远处传来了刺耳的警笛声。小主人临走时遗落了一只鞋子，史丹利觉得无论如何也要将鞋子还给主人，于是它踏上了凶险的旅途。 \r\n　　一路上，恐怖丧尸到处游走。史丹利好不容易熬过了黑夜，总算找到主人的车。悲哀的是主人的妈妈已经被丧尸杀害感染，而小主人似乎还活着并躲藏在某个地方…… ","name":"Steadfast Stanley","name_cn":"坚定的史丹利","tags":[{"name":"短片","count":7,"total_cont":0},{"name":"WEB","count":1,"total_cont":0},{"name":"10","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"坚定的史丹利"},{"key":"话数","value":"1"},{"key":"放送开始","value":"2014-05-05"},{"key":"官方网站","value":"http://johncodykim.blogspot.com/"},{"key":"导演","value":"John Cody Kim"},{"key":"制片国家/地区","value":"美国"},{"key":"片长","value":"4分钟"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":3,"7":1,"8":0,"9":0,"10":0},"score":6},"total_episodes":1,"collection":{"on_hold":1,"dropped":5,"wish":6,"collect":13,"doing":0},"id":157715,"eps":1,"meta_tags":["WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":587855,"subject_id":157715,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:48:47.173Z"},"157718":{"detail":{"date":"2010-08-26","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/08/d6/157718_01aTR.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/08/d6/157718_01aTR.jpg","large":"https://lain.bgm.tv/pic/cover/l/08/d6/157718_01aTR.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/08/d6/157718_01aTR.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/08/d6/157718_01aTR.jpg"},"summary":"末日后的世界，女人和孩子都因为疾病死光了，疾病已经肆虐了十年，一对好朋友挣扎着试图在这个黑暗的世界生存下去。 \r\n　　Albert and his best friend Jonas are orphans. They live in the future in a harsh dystopia where the women and children are all dead. The men have begun to change in their yearning for a woman.","name":"To venner","name_cn":"两个朋友","tags":[{"name":"短片","count":3,"total_cont":0},{"name":"WEB","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"两个朋友"},{"key":"别名","value":[{"v":"Two Friends"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"2010-08-26"},{"key":"导演","value":"Paw Charlie Ravn"},{"key":"类型","value":"短片/动画"},{"key":"片长","value":"8分钟"}],"rating":{"rank":0,"total":2,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":1,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":1,"collection":{"on_hold":2,"dropped":4,"wish":2,"collect":7,"doing":1},"id":157718,"eps":1,"meta_tags":["WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":587856,"subject_id":157718,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:29:57.565Z"},"157733":{"detail":{"date":"2012-08-06","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/48/8d/157733_5W9B6.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/48/8d/157733_5W9B6.jpg","large":"https://lain.bgm.tv/pic/cover/l/48/8d/157733_5W9B6.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/48/8d/157733_5W9B6.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/48/8d/157733_5W9B6.jpg"},"summary":"灰白色冰冷的荧光灯，孤独的男人点燃了一支烟。电话铃声突然响起，他并没有接通。幽暗的实验室里，只有铃声响个不停。大厦办公室内，男人依旧寂寞的依靠在窗边，电话铃声再次响起。火车上，男人还是颓废的抽着烟，一旁旅人的脸上似乎都写满故事，然而却都沉默不语。电话铃声又响了，他看了看手机，依旧没有接听。当男人穿越嘈杂的街头，与熙熙攘攘的行人擦肩而过时，他绝望的躺在草坪上，无望而挣扎。百货大楼里，任人声鼎沸，于他，还是只有惨淡的苍白荧光。当男人来到酒吧，默默聆听女人唱歌之后，他还是躲到黑暗的角落里抽着烟。当电话又一次响起时，男人忿然摔碎了它。无数孤单的心灵，在这一片废墟之中，等待阳光慢慢洒进这座寂寞之城。 \r\n　　这部由以色列导演Tim Razumovsky和Eyal Oren制作的长达13分钟的无对白动画短片，以犀利的笔触和冷峻的音乐，营造了一个彷徨无助的孤独心灵世界，描画出以色列仍处在动荡中的社会现实。","name":"Fluorescent","name_cn":"荧光","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"2012","count":3,"total_cont":0},{"name":"以色列","count":2,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"2012年","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"WEB","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"荧光"},{"key":"话数","value":"1"},{"key":"放送开始","value":"2012-08-06"},{"key":"导演","value":"Tim Razumovsky / Eyal Oren"},{"key":"类型","value":"动画 / 短片"},{"key":"制片国家/地区","value":"以色列"},{"key":"片长","value":"13分钟"}],"rating":{"rank":0,"total":8,"count":{"1":0,"2":0,"3":1,"4":0,"5":1,"6":3,"7":0,"8":2,"9":1,"10":0},"score":6.4},"total_episodes":1,"collection":{"on_hold":2,"dropped":4,"wish":6,"collect":11,"doing":1},"id":157733,"eps":1,"meta_tags":["WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":587861,"subject_id":157733,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:39:18.935Z"},"157735":{"detail":{"date":"2011-08-11","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/57/3b/157735_Nd4ko.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/57/3b/157735_Nd4ko.jpg","large":"https://lain.bgm.tv/pic/cover/l/57/3b/157735_Nd4ko.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/57/3b/157735_Nd4ko.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/57/3b/157735_Nd4ko.jpg"},"summary":"正在楼顶边抽烟边浇花的中年男人，一不小心从楼上掉了下去。死前的瞬间，他仿佛看见了自己短暂的一生。“你就要死了”、“所以这里就是你最好最快的去处”在他的脑海里不断浮现。1961年，那时他还是刚刚出生的婴儿。然而随着日历上不断翻滚着的时间，男人的生活从多姿多彩变得枯燥乏味。直到2011年，他终于崩溃在自己的电脑面前。如此单调的日子真的要一如既往地过下去么？男人在即将落地的前一秒，忽然释然，悠然地点燃了一支烟。 \r\n　　这部颇有迪士尼早期作品风格的黑色幽默动画短片，由伦敦自由艺术家史蒂夫·卡兹执导。他曾为可口可乐、百加得、丰田、锐步、索尼PSP、菲利普等诸多世界知名品牌制作动画。 ","name":"In the Fall","name_cn":"坠楼","tags":[{"name":"短片","count":8,"total_cont":0},{"name":"欧美","count":3,"total_cont":0},{"name":"2011","count":3,"total_cont":0},{"name":"英国","count":2,"total_cont":0},{"name":"7(+2)","count":1,"total_cont":0},{"name":"2010s","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"致郁","count":1,"total_cont":0},{"name":"WEB","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"坠楼"},{"key":"话数","value":"1"},{"key":"放送开始","value":"2011年8月11日"},{"key":"官方网站","value":"www.stevecutts.com"},{"key":"导演","value":"Steve Cutts"},{"key":"类型","value":"动画 / 短片"},{"key":"制片国家/地区","value":"英国"},{"key":"片长","value":"1分44秒"}],"rating":{"rank":0,"total":9,"count":{"1":0,"2":0,"3":1,"4":0,"5":1,"6":2,"7":2,"8":2,"9":1,"10":0},"score":6.6},"total_episodes":1,"collection":{"on_hold":1,"dropped":4,"wish":2,"collect":22,"doing":0},"id":157735,"eps":1,"meta_tags":["WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":587862,"subject_id":157735,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:34:36.602Z"},"157793":{"detail":{"date":"2014-02-01","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/36/5f/157793_52Dmd.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/36/5f/157793_52Dmd.jpg","large":"https://lain.bgm.tv/pic/cover/l/36/5f/157793_52Dmd.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/36/5f/157793_52Dmd.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/36/5f/157793_52Dmd.jpg"},"summary":"自打亚当和夏娃吃了禁果后，老祖宗和他的子孙们除了有了智商和羞耻的意识外，似乎还对审美提出了花样百出的要求。不同年代有不同年代的观念的审美观，所悲的是女性被动或自主地成为了手术台上的试验品，将活生生的生命与躯体变成了医者与男性随意摆弄的玩物。为了让胳膊和脖子变得更细，可以毫无顾虑地注射来路不明的针。为了拥有撩人的小蛮腰，不惜扯掉两根与生俱来的肋骨。为了拥有媚人姣好的面容，随便涂抹这张脸之余还斗胆动刀切切割割。为了保持身材，干脆做了绝育手术。 \r\n　　每个时代都在打造超级维纳斯，谁知到头来只有血肉模糊……","name":"Supervenus","name_cn":"超级维纳斯","tags":[{"name":