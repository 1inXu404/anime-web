{"608049":{"detail":{"date":"2026-03-03","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/6b/d4/608049_8CyB6.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/6b/d4/608049_8CyB6.jpg","large":"https://lain.bgm.tv/pic/cover/l/6b/d4/608049_8CyB6.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/6b/d4/608049_8CyB6.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/6b/d4/608049_8CyB6.jpg"},"summary":"因一场以利益交换为目的的联姻，太玄楼刺客江元与九璇宗圣女韶月奉命成婚。两人在洞房夜发起暗杀，却发现彼此皆是不死之身。为了得到对方宗门的秘宝御妖铃、镇魔钟，两人从死敌转为表面夫妻，虚与委蛇。但两人尚不知道，对方也是家园被“虚无”所毁的外星遗民。这对宿命伴侣在戒备与试探中结成同盟，不仅要寻找遗失飞船化做的秘宝，更要对抗虎视眈眈的整个修仙界，在危机四伏中寻找击败“虚无”的希望。","name":"盗妖行","name_cn":"","tags":[{"name":"原创","count":7,"total_cont":0},{"name":"玄幻","count":7,"total_cont":0},{"name":"中国","count":6,"total_cont":0},{"name":"战斗","count":6,"total_cont":0},{"name":"索以文化","count":4,"total_cont":0},{"name":"国产","count":4,"total_cont":0},{"name":"WEB","count":3,"total_cont":0},{"name":"3D","count":3,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"2026年3月","count":1,"total_cont":0},{"name":"搞笑","count":1,"total_cont":0},{"name":"2026年4月","count":1,"total_cont":0},{"name":"点子","count":1,"total_cont":0},{"name":"周二","count":1,"total_cont":0},{"name":"周四","count":1,"total_cont":0},{"name":"9:00","count":1,"total_cont":0}],"infobox":[{"key":"话数","value":"60"},{"key":"放送开始","value":"2026年3月3日"},{"key":"放送星期","value":"星期二、四"},{"key":"导演","value":"李廷赫"},{"key":"製作","value":"bilibili、索以科技(索以文化)；出品人：李旎、马洪堂"},{"key":"动画制作","value":"索以科技(索以文化)"},{"key":"总制片人","value":"张圣晏、赵洁"},{"key":"监制","value":"总监制：郑珊珊、王雪雅"},{"key":"制片人","value":"娄婷、应妮慧"},{"key":"制片","value":"田雪姣"},{"key":"联合导演","value":"项目导演：马伟东"},{"key":"脚本","value":"小赫、吴滢雅"},{"key":"项目制片","value":"李雪"},{"key":"执行制片","value":"施俊烨"}],"rating":{"rank":0,"total":8,"count":{"1":0,"2":0,"3":0,"4":2,"5":1,"6":4,"7":1,"8":0,"9":0,"10":0},"score":5.5},"total_episodes":60,"collection":{"on_hold":5,"dropped":4,"wish":10,"collect":4,"doing":27},"id":608049,"eps":60,"meta_tags":["