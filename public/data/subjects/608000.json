,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-08-25","name":"","name_cn":"","duration":"","desc":"","ep":56,"sort":56,"id":1654602,"subject_id":608049,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-08-27","name":"","name_cn":"","duration":"","desc":"","ep":57,"sort":57,"id":1654603,"subject_id":608049,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-09-01","name":"","name_cn":"","duration":"","desc":"","ep":58,"sort":58,"id":1654604,"subject_id":608049,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-09-03","name":"","name_cn":"","duration":"","desc":"","ep":59,"sort":59,"id":1654605,"subject_id":608049,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-09-08","name":"","name_cn":"","duration":"","desc":"","ep":60,"sort":60,"id":1654606,"subject_id":608049,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T19:29:41.428Z"},"608227":{"detail":{"date":"2026-04-02","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/2e/f4/608227_44kWb.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/2e/f4/608227_44kWb.jpg","large":"https://lain.bgm.tv/pic/cover/l/2e/f4/608227_44kWb.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/2e/f4/608227_44kWb.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/2e/f4/608227_44kWb.jpg"},"summary":"追月朔也的父亲是传说中的名侦探，但他自己只是个半吊子的高中生侦探。\r\n今天他也一如往常接下外遇调查、寻猫等委托，却总是莫名被卷入杀人事件，而且「被害者」竟然就是他自己！？\r\n每次凭着特殊体质复活后，总有一位优秀的助手以膝枕迎接他的醒来。\r\n身为侦探，同时也是被害者，朔也不断赌上性命，挑战一件又一件疑难案件！\r\n\r\n[简介原文]\r\n伝説の名探偵の息子、追月朔也。\r\n探偵としての実力は父親に遠く及ばないが、それを気に病むこともなく、地味な依頼を好む半人前の高校生探偵。\r\n朔也は普通の人間にはない体質を持っていた。殺される度に生き返るのだ。\r\nそして行く先々で殺人事件に巻き込まれては、殺されてしまう。\r\n\r\n奇怪な体質を持つ朔也の復活をいつも膝枕で迎えるのは、優秀な助手のリリテア。\r\n「また殺されてしまったのですね、探偵様」\r\n「……らしいね」\r\n探偵として、被害者として、文字通り命懸けで事件を解決していく掟破りミステリー、開幕。","name":"また殺されてしまったのですね、探偵様","name_cn":"又被杀掉了呢，侦探大人","tags":[{"name":"2026年4月","count":168,"total_cont":0},{"name":"轻小说改","count":102,"total_cont":0},{"name":"推理","count":86,"total_cont":0},{"name":"TV","count":85,"total_cont":0},{"name":"LIDENFILMS","count":71,"total_cont":0},{"name":"小说改","count":57,"total_cont":0},{"name":"2026","count":55,"total_cont":0},{"name":"日本","count":55,"total_cont":0},{"name":"轻改","count":43,"total_cont":0},{"name":"奇幻","count":30,"total_cont":0},{"name":"若山詩音","count":25,"total_cont":0},{"name":"恋爱","count":22,"total_cont":0},{"name":"悬疑","count":14,"total_cont":0},{"name":"直古隆","count":7,"total_cont":0},{"name":"未上映","count":6,"total_cont":0},{"name":"直谷たかし","count":4,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"侦探","count":3,"total_cont":0},{"name":"2026年","count":3,"total_cont":0},{"name":"安田陸矢","count":2,"total_cont":0},{"name":"井上美緒","count":2,"total_cont":0},{"name":"釘宮理恵","count":2,"total_cont":0},{"name":"てにをは","count":2,"total_cont":0},{"name":"直谷隆","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"ライデンフィルム","count":2,"total_cont":0},{"name":"高田憂希","count":1,"total_cont":0},{"name":"校园","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"气笑了","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"又被杀掉了呢，侦探大人"},{"key":"别名","value":[{"v":"你又被杀了呢，侦探大人"},{"v":"Mata Korosarete Shimatta no desu ne, Tantei-sama"},{"v":"Killed Again, Mr. Detective."}]},{"key":"话数","value":"*"},{"key":"放送开始","value":"2026年4月2日"},{"key":"放送星期","value":"星期四"},{"key":"官方网站","value":"https://www.tbs.co.jp/anime/matakoro/"},{"key":"播放电视台","value":"TBS"},{"key":"其他电视台","value":"BS11"},{"key":"导演","value":"直谷たかし"},{"key":"音乐","value":"睦月周平"},{"key":"Copyright","value":"©2026/てにをは/KADOKAWA/またころ製作委員会"},{"key":"原作","value":"てにをは（MF文庫J「また殺されてしまったのですね、探偵様」/KADOKAWA刊）"},{"key":"人物设定","value":"熊田明子"},{"key":"副人物设定","value":"高畑かおり"},{"key":"製作","value":"またころ製作委員会（TBS、アスミック・エース、日本BS放送、SANKYO、arma bianca、クロックワークス）"},{"key":"企画","value":"赤津一彦、有吉篤史、羽川寛、小倉敏男、坂井智成、武智恒雄"},{"key":"执行制片人","value":"畠山渉、大和田智之"},{"key":"制片人","value":"池乗彰吾、星野朗広、多田祐一、井東真一、塩谷尚史、小澤文啓"}