{"112655":{"detail":{"date":"2000-02-05","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/86/68/112655_cCkuU.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/86/68/112655_cCkuU.jpg","large":"https://lain.bgm.tv/pic/cover/l/86/68/112655_cCkuU.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/86/68/112655_cCkuU.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/86/68/112655_cCkuU.jpg"},"summary":"モーションキャプチャーを使用し、フル3DCGでつくられたデジタルアニメ。西暦2010年、月への観光ツアーへ向かったシャトルが墜落。旅行者として搭乗していた少女・亜利寿は、スチュワーデスロボットのマリアと共に脱出する。突然ロボットに襲われた亜利寿たちは、地元の少年・ユアンに助けられ、ここが独裁者ネロの支配する30年後の未来の世界であることを知る。ネロがつくりだしたコンピューターが支配する暗黒の社会を救うため、亜利寿は立ち上がるのだった。","name":"A・LI・CE","name_cn":"超越时空爱丽丝","tags":[{"name":"剧场版","count":5,"total_cont":0},{"name":"独立剧场版","count":3,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"日本动画电影考察","count":2,"total_cont":0},{"name":"2000","count":2,"total_cont":0},{"name":"评分略","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"2000s","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"超越时空爱丽丝"},{"key":"别名","value":[{"v":"アリス"},{"v":"A.LI.CE"},{"v":"alice"}]},{"key":"上映年度","value":"2000年2月5日"},{"key":"片长","value":"85分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":10,"count":{"1":1,"2":1,"3":2,"4":1,"5":3,"6":1,"7":1,"8":0,"9":0,"10":0},"score":4.1},"total_episodes":1,"collection":{"on_hold":2,"dropped":4,"wish":9,"collect":16,"doing":1},"id":112655,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":912701,"subject_id":112655,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T14:38:40.942Z"},"112705":{"detail":{"date":"2000-02-29","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/11/89/112705_D9oJm.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/11/89/112705_D9oJm.jpg","large":"https://lain.bgm.tv/pic/cover/l/11/89/112705_D9oJm.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/11/89/112705_D9oJm.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/11/89/112705_D9oJm.jpg"},"summary":"继1995年迪士尼推出《终极傻瓜》（A Goofy Movie）电影上映受到热烈欢迎之后，于是迪士尼决定再度推出第二集。本片大部分是在迪士尼悉尼片厂所完成的，内容则是衍生在 Goofy 的儿子 Max 上大学后的故事，与电视影集与电影第一集相较，《高飞家族》电视影集 Max 年龄是设定在14岁；电影第一集《终极傻瓜》Max 则是设定为16岁；而在本片中，Max 年纪则是设定为19或20岁。本片故事焦点仍是摆在亲子间的代沟问题，当 Max 升上大学后，等待他的是无拘无束的自由又刺激的生活，而他那个老爸 Goofy ，在此时对 Max 而言，活像是个未进化的古董似的，正当 Max 庆幸从此摆脱高飞家族脱线阴影的同时，不料他老爸 Goofy 也来到他的学校上课，当他老爸居然穿着70年代的衣服出现在校园的时候，Max 觉得丢脸丟大了！然而，最后 Max 还是发现，无论如何他和老爸还是最佳拍档，永远的“高飞家族”！","name":"An Extremely Goofy Movie","name_cn":"极限高飞","tags":[{"name":"欧美","count":5,"total_cont":0},{"name":"迪士尼","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"搞笑","count":2,"total_cont":0},{"name":"2000","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"极限高飞"},{"key":"上映年度","value":"2000-02-29"},{"key":"片长","value":"76 分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":6,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":2,"8":1,"9":0,"10":0},"score":6.5},"total_episodes":1,"collection":{"on_hold":4,"dropped":4,"wish":2,"collect":19,"doing":2},"id":112705,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":912700,"subject_id":112705,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T14:38:30.349Z"}}