l_episodes":12,"collection":{"on_hold":3,"dropped":23,"wish":39,"collect":3,"doing":110},"id":622634,"eps":0,"meta_tags":["TV","TV","日本","日本","原创","原创","子供向","子供向"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2026-04-05","name":"おねがい！アイプリになって","name_cn":"","duration":"","desc":"おねがい町に帰ってきたいのりは、広場の女神像におねがいする。「アイプリになるチャンスをください！」すると、人気アイプリのあおいが声をかけてきた。一緒にアイプリショップに行くと、モコという小さな女の子から、引っ越していく近所のお姉ちゃんのプレゼントを選んで欲しいと、おねがいされるいのり。「ココロのまんなかにある『好き』なものをプレゼントすればいい」とアドバイスすると、あおいの持っていたぬいぐるみが突然しゃべり出した！フォーチュと名乗る不思議なぬいぐるみとあおいは、いのりにアイプリになるためのミラーパクトと、おねがいジュエルをくれて……。","ep":1,"sort":1,"id":1656128,"subject_id":622634,"comment":14,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-04-12","name":"その夢、かなえちゃお♪","name_cn":"","duration":"","desc":"おねがい町での生活をスタートさせたいのり。おねがい中学に入学すると、あおいも同じクラスだった。放課後、あおいがいのりを連れてきたのは、おねがい町にあるめが姉ぇのカフェ。そこで、フォーチュからおねがい町の人たちのおねがいをかなえる『おねがいかなえ隊』に入ってほしいと言われるいのり。早速フォーチュがおねがいをキャッチした相手は、同じ学校の先輩・こはるだった。はたして、こはるのおねがいとは……？","ep":2,"sort":2,"id":1656129,"subject_id":622634,"comment":7,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-04-19","name":"たったひとつのだいすき","name_cn":"","duration":"","desc":"いのりとあおいは、探し物をしている女の子と出会う。彼女は、同じクラスの友坂ぐみ。大切にしていたシールをなくしてしまったと言う。それは、弟と妹が誕生日にプレゼントしてくれた世界にひとつだけのシール。一緒に見つけて欲しい！と、おねがいされたいのりとあおい。ぐみのおねがいをかなえるために探し始めるが、シールは一向に見つからず……。","ep":3,"sort":3,"id":1656130,"subject_id":622634,"comment":6,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-04-26","name":"おともだちがアイプリ!?","name_cn":"","duration":"","desc":"めが姉ぇさんのおつかいで、おねがい通りにやってきたいのりとあおい。目当ての洋菓子店に入ると、そこにはぐみの姿が。パティスリー・トモサカは、ぐみの家だったのだ。いのりとあおいのライブを見て、すごいと言ってくれたぐみに、「アイプリをやってみない？」と誘ういのり。だが、ぐみは無理だと首を横に振る。そこから数日間、放課後先に帰ってしまうぐみ。実はいのりとあおいに内緒で、アイプリの特訓をしていたのだ。それを見たいのりは……。","ep":4,"sort":4,"id":1656131,"subject_id":622634,"comment":7,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-03","name":"はじめてのアイプリフェス！","name_cn":"","duration":"","desc":"いのりのおじいちゃんは、おねがい町の町長さん。『みんなが今よりもっとノリノリになれるように笑顔あふれる町にしたい』と女神像におねがいをしている。それを聞いたいのりは広場にたくさんの人たちを集めて、『おねがい町アイプリフェスティバル』、略して『アイプリフェス』を開こうと提案する。そして、フェス当日。広場には、あまり人が集まっていない。が、アイプリ部のこはるの協力もあり、徐々に人が集まり始めた。気合いを入れるいのり、あおい、ぐみ。いよいよフェスの幕が開く！","ep":5,"sort":5,"id":1656132,"subject_id":622634,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-10","name":"","name_cn":"","duration":"","desc":"","ep":6,"sort":6,"id":1656133,"subject_id":622634,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-17","name":"","name_cn":"","duration":"","desc":"","ep":7,"sort":7,"id":1656134,"subject_id":622634,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-24","name":"","name_cn":"","duration":"","desc":"","ep":8,"sort":8,"id":1656135,"subject_id":622634,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-31","name":"","name_cn":"","duration":"","desc":"","ep":9,"sort":9,"id":1656136,"subject_id":622634,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-07","name":"","name_cn":"","duration":"","desc":"","ep":10,"sort":10,"id":1656137,"subject_id":622634,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-14","name":"","name_cn":"","duration":"","desc":"","ep":11,"sort":11,"id":1656138,"subject_id":622634,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-21","name":"","name_cn":"","duration":"","desc":"","ep":12,"sort":12,"id":1656139,"subject_id":622634,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T14:38:15.351Z"}}