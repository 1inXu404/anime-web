合いながら、\r\n無常の世に生きる新しい舞を形作っていく―\r\n\r\n三原和人によるモーニング刊行の衝撃的『能』漫画がついにアニメ化！\r\nアニメでしか見られない躍動感のある舞・謡い、心が動くシーンの数々―\r\n\r\n『舟を編む』『バクテン!!』の黒柳トシマサ×『ウマ娘 シンデレラグレイ』『光が死んだ夏』のCygames Pictures\r\nさらに豪華キャストでお届けする最高クオリティのアニメーションが今、花開く。\r\n\r\nこれは後に『能』を生み出す世阿弥が鬼夜叉と呼ばれていた頃にあったかもしれない、\r\n600年の時を経て続いていく、ダンシングストーリー。","name":"ワールド イズ ダンシング","name_cn":"","tags":[{"name":"CygamesPictures","count":31,"total_cont":0},{"name":"漫画改","count":28,"total_cont":0},{"name":"TV","count":27,"total_cont":0},{"name":"2026","count":25,"total_cont":0},{"name":"2026年7月","count":24,"total_cont":0},{"name":"黑柳利充","count":15,"total_cont":0},{"name":"历史","count":10,"total_cont":0},{"name":"漫改","count":9,"total_cont":0},{"name":"日本","count":5,"total_cont":0},{"name":"舞蹈","count":4,"total_cont":0},{"name":"Cypic","count":3,"total_cont":0},{"name":"黒柳トシマサ","count":3,"total_cont":0},{"name":"剧集","count":2,"total_cont":0},{"name":"TVA","count":2,"total_cont":0},{"name":"佐佐木启悟","count":2,"total_cont":0},{"name":"2026年","count":2,"total_cont":0},{"name":"和风","count":2,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"音乐","count":1,"total_cont":0},{"name":"7月","count":1,"total_cont":0},{"name":"2026夏","count":1,"total_cont":0},{"name":"未上映","count":1,"total_cont":0},{"name":"夏季","count":1,"total_cont":0},{"name":"26夏","count":1,"total_cont":0},{"name":"渊本宗平","count":1,"total_cont":0},{"name":"川满佐贺子","count":1,"total_cont":0},{"name":"花守ゆみり","count":1,"total_cont":0}],"infobox":[{"key":"别名","value":[{"v":"The World Is Dancing"}]},{"key":"话数","value":"*"},{"key":"放送开始","value":"2026年7月"},{"key":"官方网站","value":"https://sh-anime.shochiku.co.jp/worldisdancing-anime/"},{"key":"导演","value":"黒柳トシマサ"},{"key":"Copyright","value":"©三原和人・講談社／『ワールド イズ ダンシング』製作委員会"},{"key":"原作","value":"三原和人（講談社モーニングKC刊）"},{"key":"人物设定","value":"佐々木啓悟"},{"key":"題字","value":"根本知"},{"key":"型付監修","value":"津村禮次郎"},{"key":"振付","value":"森山開次、川村美紀子"},{"key":"能楽監修","value":"川口晃平"},{"key":"歴史監修","value":"清水克行"}],"rating":{"rank":0,"total":0,"c