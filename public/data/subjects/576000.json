alue":"岩本佳大"},{"key":"录音工作室","value":"STUDIO T&T"},{"key":"音响","value":"ビットグルーヴプロモーション"},{"key":"音响制作担当","value":"中村暢、大黒紗季"},{"key":"音乐助理","value":"音乐制作协力：中路あけ美、関根隆裕"}],"rating":{"rank":2335,"total":892,"count":{"1":4,"2":1,"3":1,"4":7,"5":28,"6":128,"7":479,"8":211,"9":19,"10":14},"score":7.1},"total_episodes":12,"collection":{"on_hold":57,"dropped":116,"wish":772,"collect":96,"doing":3816},"id":576121,"eps":0,"meta_tags":["TV","日本","漫画改","少年向","职场"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2026-04-04","name":"あの日","name_cn":"那一天","duration":"00:24:50","desc":"小学5年生の桜咲朱音は、噺家の父・阿良川志ん太の背中を見て、その魔法のような落語に魅せられていた。志ん太は自分の夢を支えてくれている家族のため、落語界の最高位“真打”への昇進試験に挑む。朱音たちが見守る中、実力を発揮した志ん太だったが、昇進試験は誰もが思いもよらない衝撃的な展開を迎える。\r\n\r\nSTAFF\r\n脚本：土屋理敬\r\n絵コンテ：渡辺歩\r\n演出：播摩優\r\n総作画監督：田中紀衣、新田靖成\r\n作画監督：大沢美奈、北川大輔、原田大基","ep":1,"sort":1,"id":1656164,"subject_id":576121,"comment":173,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-04-11","name":"初高座","name_cn":"初次登台","duration":"00:24:50","desc":"駆け出しの“二ツ目”である阿良川ぐりこは、師匠の阿良川志ぐまが若い女性と密会しているという噂を聞きつけ調査を開始する。するとそこには、カラオケ店で志ぐまに稽古をつけてもらう高校生の朱音の姿があった。そんな折、急きょ「らくご喫茶」で寄席に出られる演者が1人必要になったと連絡を受けた志ぐまは、経験のあるぐりこではなく朱音を指名する。\r\n\r\nSTAFF\r\n脚本：土屋理敬\r\n絵コンテ：播摩 優\r\n演出：山根幹史\r\n総作画監督：田中紀衣、香川 久\r\n作画監督：吉田雄一、斎藤 梢","ep":2,"sort":2,"id":1656165,"subject_id":576121,"comment":125,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-04-18","name":"兄弟子","name_cn":"师兄","duration":"00:24:50","desc":"初高座を終え、阿良川魁生に刺激を受けた朱音は、志ぐま一門に見習いとして弟子入りすることになる。志ぐまから個性豊かな兄弟子たちを紹介され、生真面目な性格の阿良川享二が朱音の指導を担当することに。これで芸を磨けると意気込む朱音だったが、享二から任されるのは雑用ばかり。さらには思いもよらない場所で修業をすることになり…。\r\n\r\nSTAFF\r\n脚本：土屋理敬\r\n絵コンテ：三室健太\r\n演出：三室健太\r\n総作画監督：田中紀衣\r\n作画監督：大沢美奈、佐藤菜穂、三浦春樹、竹上貴雄","ep":3,"sort":3,"id":1656166,"subject_id":576121,"comment":78,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-04-25","name":"喜びの先","name_cn":"喜悦之后","duration":"00:24:50","desc":"居酒屋「海」での修業で “気働き”を学んだ朱音は、享二に同行して次の仕事場に向かう。その日の会場は老人ホームで、施設のレクリエーションとして落語を披露することに。お年寄りばかりのお客さんに楽しんでもらえるよう、朱音は高座の上で修業の成果をいかんなく発揮していく。続く享二は、朱音に兄弟子の威厳を示すべく、高座に上がるのだった。\r\n\r\nSTAFF\r\n脚本：土屋理敬\r\n絵コンテ：長屋誠志郎\r\n演出：中釜勇亮\r\n総作画監督：新田靖成\r\n作画監督：LEE JOOHYUN、田中ちゆき","ep":4,"sort":4,"id":1656167,"subject_id":576121,"comment":58,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-05-02","name":"進む道","name_cn":"前进的道路","duration":"00:24:50","desc":"高校3年生の朱音は、中間試験を終えてホッとしたのもつかの間、担任からの進路指導を受けることに。しかも相手は“氷の女”と称される岩清水。将来は落語家になるつもりの朱音に対し、現実的な大学進学を勧めてくる岩清水は一歩も譲らない。なんとか落語家になることを認めさせたい朱音は、友人たちと相談して岩清水を懐柔しようとするが…。\r\n\r\nSTAFF\r\n脚本：土屋理敬\r\n絵コンテ：佐々木美和\r\n演出：佐々木美和\r\n総作画監督：新田靖成\r\n作画監督：島沢ノリコ、宮島有香、北川大輔、降籏秀吉","ep":5,"sort":5,"id":1656168,"subject_id":576121,"comment":0,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-05-09","name":"","name_cn":"","duration":"00:24:50","desc":"","ep":6,"sort":6,"id":1656169,"subject_id":576121,"comment":0,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-05-16","name":"","name_cn":"","duration":"00:24:50","desc":"","ep":7,"sort":7,"id":1656170,"subject_id":576121,"comment":0,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-05-23","name":"","name_cn":"","duration":"00:24:50","desc":"","ep":8,"sort":8,"id":1656171,"subject_id":576121,"comment":0,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-05-30","name":"","name_cn":"","duration":"00:24:50","desc":"","ep":9,"sort":9,"id":1656172,"subject_id":576121,"comment":0,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-06-06","name":"","name_cn":"","duration":"00:24:50","desc":"","ep":10,"sort":10,"id":1656173,"subject_id":576121,"comment":0,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-06-13","name":"","name_cn":"","duration":"00:24:50","desc":"","ep":11,"sort":11,"id":1656174,"subject_id":576121,"comment":0,"type":0,"disc":0,"duration_seconds":1490},{"airdate":"2026-06-20","name":"","name_cn":"","duration":"00:24:50","desc":"","ep":12,"sort":12,"id":1656175,"subject_id":576121,"comment":0,"type":0,"disc":0,"duration_seconds":1490}],"updatedAt":"2026-05-01T14:37:52.929Z"},"576351":{"detail":{"date":"2026-04-12","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/2f/1b/576351_3yf4O.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/2f/1b/576351_3yf4O.jpg","large":"https://lain.bgm.tv/pic/cover/l/2f/1b/576351_3yf4O.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/2f/1b/576351_3yf4O.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/2f/1b/576351_3yf4O.jpg"},"summary":"「魔女见习生」丝碧卡·瓦戈完全不会使用魔法。为了考上梦寐以求的魔法学校，她急需一位师傅指点，却苦于没有金钱也没有人脉。就在此时，一只会说人类语言、还会使用魔法的神秘黑猫出现在她眼前！\r\n渴望学习魔术的丝碧卡，与一心想解开诅咒的黑猫。两人的目的不谋而合，于是便缔结了秘密的师徒关系！而解开诅咒的关键竟是对着「○○○」亲吻！？\r\n\r\n\r\n\r\n[简介原文]\r\n「魔女見習い」スピカ・ヴァルゴは魔法が使えない。\r\n憧れの魔法学校合格のためには師匠が必要だが、金もコネもない。\r\nそんな時、人語を駆使し魔法を使う謎の黒猫がスピカの前に現れた!!\r\n魔術を学びたいスピカと呪いを解きたい黒猫の思惑は完全一致。\r\n秘密の師弟関係が結ばれた!!!\r\n呪いを解く鍵は「✕✕✕」にキス!?","name":"黒猫と魔女の教室","name_cn":"黑猫与魔女的教室","tags":[{"name":"2026年4月","count":201,"total_cont":0},{"name":"漫画改","count":137,"total_cont":0},{"name":"奇幻","count":132,"total_cont":0},{"name":"校园","count":116,"total_cont":0},{"name":"LIDENFILMS","count":113,"total_cont":0},{"name":"TV","count":111,"total_cont":0},{"name":"2026","count":79,"total_cont":0},{"name":"漫改","count":60,"total_cont":0},{"name":"日本","count":57,"total_cont":0},{"name":"魔法","count":46,"total_cont":0},{"name":"龙轮直征","count":28,"total_cont":0},{"name":"本渡楓","count":20,"total_cont":0},{"name":"龍輪直征","count":10,"total_cont":0},{"name":"2026年","count":9,"total_cont":0},{"name":"TVA","count":6,"total_cont":0},{"name":"恋爱","count":5,"total_cont":0},{"name":"島﨑信長","count":4,"total_cont":0},{"name":"日本动画","count":4,"total_cont":0},{"name":"黑猫与魔女的教室","count":3,"total_cont":0},{"name":"搞笑","count":3,"total_cont":0},{"name":"26春","count":2,"total_cont":0},{"name":"4月","count":2,"total_cont":0},{"name":"涩涩","count":2,"total_cont":0},{"name":"喵喵喵","count":2,"total_cont":0},{"name":"ライデンフィルム","count":2,"total_cont":0},{"name":"奇幻异世","count":2,"total_cont":0},{"name":"福利","count":1,"total_cont":0},