d":584758,"subject_id":154748,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":26,"sort":26,"id":584759,"subject_id":154748,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:08:37.093Z"},"154771":{"detail":{"date":"2018-10-01","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/cb/b2/154771_aR3Rx.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/cb/b2/154771_aR3Rx.jpg","large":"https://lain.bgm.tv/pic/cover/l/cb/b2/154771_aR3Rx.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/cb/b2/154771_aR3Rx.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/cb/b2/154771_aR3Rx.jpg"},"summary":"大宇資訊與東京電視台攜手合作《軒轅劍》動畫版，劇情以《軒轅劍外傳：蒼之濤》為基礎改編，推出富含原創劇情的《軒轅劍 蒼之曜》動畫，並將於在 2017 年在日本與兩岸三地同步播映。\r\n\r\n動畫名稱《蒼之曜》是大宇這邊取的名字，主要是故事會講到七曜使者，那會以《蒼之濤》為基底，同時延伸到過去沒有講到的七曜使者的事情，這部動畫不會是就把原本遊戲故事照舊搬上去，而是一種延伸的作法，像是原本在故事中主線上沒有著墨或是支線等都會講得更加完整。\r\n動畫故事主要是以《蒼之濤》背景來改，大宇主要提供原著劇本建議方向，會希望能夠在動畫中呈現較多大型場面。至於原本《蒼之濤》的主角也計畫會在動畫中登場，但方式會調整。\r\n在此次合作中大綱腳本會是雙方共同製作，其他大宇則屬於監修的角色，動畫本身則是東京電視台來負責製作；目前動畫進度主要是和日本進行腳本大綱討論，日方相當慎重，雙方會花一段時間來討論相關內容，等大綱完成後會討論分鏡，一步一步來，所以人設等都還沒有確定，而未來推出動畫時，應該也會推出相關周邊商品。目前希望以一季十三話方式推出，至於總共多少話等其他細節都還在討論中，此部動畫會在日本與兩岸三地同步推出，聲優未來他們的想法會是日本、台灣分開，至於兩岸聲優人選是否相同，主要會看未來合作發行廠商的想法來評估。","name":"軒轅剣・蒼き曜","name_cn":"轩辕剑·苍之曜","tags":[{"name":"游戏改","count":56,"total_cont":0},{"name":"2018年10月","count":36,"total_cont":0},{"name":"TV","count":32,"total_cont":0},{"name":"轩辕剑","count":28,"total_cont":0},{"name":"2018","count":22,"total_cont":0},{"name":"中日","count":19,"total_cont":0},{"name":"苍之涛","count":15,"total_cont":0},{"name":"中日合作","count":11,"total_cont":0},{"name":"国产","count":10,"total_cont":0},{"name":"スタジオディーン","count":10,"total_cont":0},{"name":"中国","count":9,"total_cont":0},{"name":"日本","count":7,"total_cont":0},{"name":"官方同人","count":6,"total_cont":0},{"name":"studiodeen","count":5,"total_cont":0},{"name":"能登麻美子","count":3,"total_cont":0},{"name":"水树奈奈","count":3,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"松岡禎丞","count":2,"total_cont":0},{"name":"2018年","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"台湾","count":2,"total_cont":0},{"name":"动作","count":2,"total_cont":0},{"name":"苍之曜","count":2,"total_cont":0},{"name":"g.中国","count":1,"total_cont":0},{"name":"高山カツヒコ","count":1,"total_cont":0},{"name":"剧","count":1,"total_cont":0},{"name":"Action","count":1,"total_cont":0},{"name":"玄幻","count":1,"total_cont":0},{"name":"f.日本","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"轩辕剑·苍之曜"},{"key":"别名","value":[{"v":"軒轅劍‧蒼之曜"},{"v":"Ken En Ken: Aoki Kagayaki"},{"v":"Xuan Yuan Sword Luminary"}]},{"key":"话数","value":"13"},{"key":"放送开始","value":"2018年10月1日"},{"key":"放送星期","value":"星期一"},{"key":"官方网站","value":"http://xuanyuansword.net/index.html"},{"key":"播放电视台","value":"テレビ東京"},{"key":"播放结束","value":"2018年12月24日"},{"key":"音乐","value":"堀田星司"},{"key":"Copyright","value":"©ソフトスター・軒轅剣製作委員会"},{"key":"CG 导演","value":"大嶋慎介"},{"key":"企画","value":"涂俊光、Joe Teng、川崎由纪夫（テレビ東京）"},{"key":"执行制片人","value":"张孝全、赤尾周（テレビ東京）"},{"key":"制作人","value":"徐小龙、山内未来（·テレビ東京）"},{"key":"音乐导演","value":"あきのかつひこ"},{"key":"音乐制作","value":"Drive"},{"key":"制片人","value":"市冈大辅"}],"rating":{"rank":8314,"total":141,"count":{"1":1,"2":1,"3":9,"4":17,"5":38,"6":55,"7":14,"8":6,"9":0,"10":0},"score":5.4},"total_episodes":13,"collection":{"on_hold":32,"dropped":64,"wish":93,"collect":182,"doing":31},"id":154771,"eps":13,"meta_tags":["TV","日本","游戏改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2018-10-01","name":"濫觴之故","name_cn":"滥觞之故","duration":"00:24:00","desc":"旅行艺人的殷以及宁，是感情很好的姐妹。\r\n姐姐一边照顾着失去双臂的妹妹，一边表演着剑舞从一个村落旅行到下一个村落。\r\n当两人来到一个废弃的村落时，发现了奇异的竹简。\r\n竹简一发光，就会从中出现一名不可思议的少女以及一柄剑。\r\n另一方面，在统一了神州大地的太白帝国，名为钊的少年做为奴隶做着苦工。\r\n独自修学着机关术的钊，某夜与一名少女邂逅。","ep":1,"sort":1,"id":811261,"subject_id":154771,"comment":28,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-10-08","name":"追憶之業","name_cn":"追忆之业","duration":"00:24:00","desc":"三年前――在游牧民族的部落生活的姐妹，殷与宁。\r\n以及生活在同一个部落的少年，钊。三人是感情很好的青梅竹马。\r\n姐妹俩都将钊当做哥哥一样敬慕着，但那样的心情不知不觉变成了爱恋。\r\n一如往昔在草原戏耍着的三人发现了坏掉的机关兽。钊对那未知的机械装置所深深吸引。\r\n另一方面，在太白帝国，首席机关师墨衡开始了最强兵器，「征天」的设计。","ep":2,"sort":2,"id":811262,"subject_id":154771,"comment":8,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-10-15","name":"悲嘆之刀","name_cn":"悲叹之刀","duration":"00:24:00","desc":"从被称为天书的竹简中出现的，是用木甲术制作成的人偶，云。\r\n云将天书中出现的剑称之为传说之剑——轩辕剑。殷与宁，因为云的关系得到了新的力量。\r\n另一方面，因为皇帝澄的一句话成为机关师的钊开始了机关兽的开发。\r\n此时，投靠了反抗军的墨衡也开始制作新武器——黑火铠甲。","ep":3,"sort":3,"id":811263,"subject_id":154771,"comment":7,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-10-22","name":"天命之戯","name_cn":"天命之戏","duration":"00:24:00","desc":"殷与宁在旅途中邂逅了两名青年，渊以及参狼。\r\n他们是对抗太白帝国的反抗军成员，并邀请姐妹俩加入反抗军，因为那是持有天书以及轩辕剑之人的天命。\r\n另一方面，升职的钊投入在机关兽的设计上，十分苦恼。为了犒劳那样的钊，皇帝澄希望让他去见识外面的世界来转换心情，进而给了钊机关部队的指挥权，让他到帝国四处去旅行。但……","ep":4,"sort":4,"id":811264,"subject_id":154771,"comment":11,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-10-29","name":"雄飛之勇","name_cn":"雄飞之勇","duration":"00:24:00","desc":"殷与宁在旅行途中遭遇太白帝国的运输部队。\r\n追随着部队来到一个农产丰盛的村落。但是太白帝国的官员为了中饱私囊，课下重税使村民生活刻苦。\r\n想为了拯救村民而战的宁，担心着那样的宁的殷；在这样的殷面前，出现一名奇特的女性。\r\n另一方面，指挥着机关部队的钊来到那官员的宅邸。官员一面欢迎钊的到来，一面戒备着不要让他举发自己的贪污","ep":5,"sort":5,"id":811265,"subject_id":154771,"comment":6,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-11-05","name":"二人之絆","name_cn":"二人之绊","duration":"00:24:00","desc":"殷宁两姐妹，与反抗军成员的越之及柔会合。\r\n宁被邀请加入反抗军，积极参与战斗，而殷则是担心宁的安全而反对。宁受不了姐姐的关怀而爆发。\r\n另一方面，钊对皇帝澄吐露自己的烦恼。自从三年前的惨剧以来，钊就再也无法入眠。同时，对于自己的所见也变成过目不忘。夜间，总是因为惨剧的回忆而痛苦。\r\n为了那样的钊，澄带他导览了宫殿中的密道。","ep":6,"sort":6,"id":811266,"subject_id":154771,"comment":5,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-11-12","name":"錯綜之念","name_cn":"错综之念","duration":"00:24:00","desc":"殷与宁一行人，为了与开发着新武器的墨衡会合，朝着反抗军的据点踏上旅途。\r\n另一方面，在太白帝国，机关总帅蒙忌则武断地自行下令量产新型机关兽。钊虽反对量产试验作，蒙机关总帅却表示为了征服世界必须加快进度，而皇帝·澄听了后也下令量产。\r\n把机关宫交给部下的钊，为了找寻上次一战、会使用法术的叛乱分子，带着机关游击队出击。","ep":7,"sort":7,"id":811267,"subject_id":154771,"comment":14,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-11-19","name":"黒火之鎧","name_cn":"黑火之铠","duration":"00:24:00","desc":"钊开始追求更强大、且可以得到一切的力量，因而全心投入古代葵蚕文明遗迹中所发现的无限之力“黑火”的研究。\r\n什么都不知道的皇帝‧澄，则与热心的钊约定会升他为关内侯。\r\n另一方面，担忧着宁安全的殷；为了让殷打起精神，渊等人提出要结拜为义兄弟的想法，希望可以作为一个家族，齐心协力而战，但身为义父的项楚却不以为然。","ep":8,"sort":8,"id":811268,"subject_id":154771,"comment":4,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-11-26","name":"謀略之宮","name_cn":"谋略之宫","duration":"00:24:00","desc":"黑火铠甲的战斗力让反抗军印象深刻，但铠甲因尚未完成仍有缺陷。醒来的殷受到黑火影响，完全失去战斗时的记忆；墨衡为了完善铠甲着手调整。\r\n另一方面，于太白帝国，蒙机关总帅因为突击队全灭而被咎责降级，因而迁怒于皇帝・澄以及钊。\r\n同时，钊正全心投入黑火的研究中。因为钊总是不在家而感到寂寞的宁转而向梨香发泄。此时，出现了谜样的敌人。","ep":9,"sort":9,"id":811269,"subject_id":154771,"comment":5,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-12-03","name":"詰問之雫","name_cn":"诘问之雫","duration":"00:24:00","desc":"为了准备与太白帝国一战，墨衡将黑火铠甲调整完善；殷也穿上完成后的黑火铠甲练习法术。\r\n另一方面，在太白帝国被拿下的宁以及因藏匿反乱军之罪而被逮捕的钊，与皇帝澄对质，但二人的心意却错身而过。宁与钊各自受到了意想不到的惩罚。\r\n此时，想要让钊失足的蒙机关总帅，与企图夺走皇帝宝座的庞夫人接触，并向反叛军的据点派遣了讨伐部队。","ep":10,"sort":10,"id":811270,"subject_id":154771,"comment":8,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-12-10","name":"愛憎之刃","name_cn":"爱憎之刃","duration":"00:24:00","desc":"因黑火铠甲的威力而战意激昂的反抗军，计划着要突击太白帝国。殷，下定决心要救出宁。\r\n另一方面，太白帝国正进行着机关要塞・征天的建造。钊担心宁的生命安全，为了让皇帝澄放过宁加快进度，自己也跟奴隶一起参与着劳力工作；\r\n但，宁已丧失心神，澄内心也受到创伤，把自己关在房间里。蒙机关总帅与庞夫人瞄准了这个好机会⋯⋯","ep":11,"sort":11,"id":811271,"subject_id":154771,"comment":4,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-12-17","name":"忘卻之罪","name_cn":"忘却之罪","duration":"00:24:00","desc":"太白帝国进行征天的主炮・黑火炮的试射，成果让蒙机关总帅非常的满意，皇帝・澄也赞赏钊的功绩给予赏赐。不过，虽说是皇帝的职责，要让心爱的钊与青梅竹马交战还是让澄心里受伤害。一个人烦恼着的澄遇上了庞夫人的女儿．涓。\r\n另一方面，听闻黑火炮的试射，墨衡察觉到征天的存在，反抗军开始检讨对抗征天的策略。殷则为了与钊、宁再会，决意赴上战场","ep":12,"sort":12,"id":811272,"subject_id":154771,"comment":12,"type":0,"disc":0,"duration_seconds":1440},{"airdate":"2018-12-24","name":"天空之要塞","name_cn":"天空之要塞","duration":"00:24:00","desc":"意图破坏建造中征天的反抗军，以及要击退他们的太白帝国，双方迎来了决战。\r\n终于知道事件真相的皇帝．澄，因罪恶感而内心备受苛责。钊将给澄的书简交给梨香后便催促她远离战场。得知庞夫人计划失败的蒙机关总帅，决定在自己的计划暴露前实行作战。\r\n那，是互相势力拿出全力碰撞的战场。丧失心神、憎恨姐姐的宁，意欲拯救妹妹的殷，再度相遇，刀刃相向⋯⋯。","ep":13,"sort":13,"id":811273,"subject_id":154771,"comment":21,"type":0,"disc":0,"duration_seconds":1440}],"updatedAt":"2026-05-01T18:20:25.230Z"},"154971":{"detail":{"date":"2016-10-14","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/7a/04/154971_bFkvj.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/7a/04/154971_bFkvj.jpg","large":"https://lain.bgm.tv/pic/cover/l/7a/04/154971_bFkvj.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/7a/04/154971_bFkvj.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/7a/04/154971_bFkvj.jpg"},"summary":"地下鉄で事故に遭った加藤勝。次の瞬間、加藤はマンションの一室にいた。\r\nそこで玄野というリーダーを亡くし失意の東京チームと出会う。\r\n更にGANTZ部屋から彼らと共に転送された先は、怪現象で火の手があがる大阪の街だった。\r\n曲者揃いの大阪チームとの遭遇。強力な妖怪型の星人軍団=百鬼夜行との戦闘。\r\nシングルマザーでありながら戦いに身を投じていた大阪チーム山咲杏との出会い。\r\n驚くべき事態の連続に翻弄されつつも、\r\n加藤はたった一人の家族である弟のもとへ帰るために、東京・大阪チームと共に、死闘を繰り広げていく。\r\nやがて、加藤らの前に大ボス「ぬらりひょん」が立ちはだかり・・・・・・。","name":"GANTZ:O","name_cn":"杀戮都市：O","tags":[{"name":"剧场版","count":396,"total_cont":0},{"name":"3D","count":207,"total_cont":0},{"name":"战斗","count":168,"total_cont":0},{"name":"漫画改","count":157,"total_cont":0},{"name":"2016","count":156,"total_cont":0},{"name":"科幻","count":154,"total_cont":0},{"name":"CG","count":116,"total_cont":0},{"name":"漫改","count":93,"total_cont":0},{"name":"DigitalFrontier","count":83,"total_cont":0},{"name":"杀戮都市","count":54,"total_cont":0},{"name":"2016年10月","count":47,"total_cont":0},{"name":"川村泰","count":29,"total_cont":0},{"name":"2016年","count":20,"total_cont":0},{"name":"奇幻","count":14,"total_cont":0},{"name":"血腥","count":12,"total_cont":0},{"name":"黑暗向的邪道漫","count":11,"total_cont":0},{"name":"猎奇","count":9,"total_cont":0},{"name":"日本","count":9,"total_cont":0},{"name":"热血","count":8,"total_cont":0},{"name":"电影","count":7,"total_cont":0},{"name":"动画电影","count":7,"total_cont":0},{"name":"奥浩哉","count":7,"total_cont":0},{"name":"GANTZ","count":7,"total_cont":0},{"name":"2016年十月番","count":6,"total_cont":0},{"name":"デジタル・フロンティア","count":4,"total_cont":0},{"name":"动画","count":4,"total_cont":0},{"name":"日漫","count":3,"total_cont":0},{"name":"黒岩勉","count":3,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"アニメ映画","count":3,"total_cont":0}],"infobox":[{"key":"中文名","value":"杀戮都市：O"},{"key":"上映年度","value":"2016年10月14日"},{"key":"片长","value":"95分"},{"key":"官方网站","value":"http://gantzo.jp/"},{"key":"Copyright","value":"© 奥浩哉／集英社・「GANTZ:O」製作委員会"},{"key":"话数","value":"1"},{"key":"导演","value":"川村泰"},{"key":"CG导演","value":"齋藤和丈"},{"key":"配给","value":"東宝映像事業部"},{"key":"製作","value":"「GANTZ:O」製作委員会（フィールズ、京楽産業ホールディングス、東宝、キングレコード、電通、神南スタジオ、ローソンHMVエンタテイメント）"}],"rating":{"rank":2413,"total":1265,"count":{"1":3,"2":3,"3":4,"4":11,"5":55,"6":275,"7":512,"8":315,"9":54,"10":33},"score":7},"total_episodes":1,"collection":{"on_hold":30,"dropped":16,"wish":349,"collect":2053,"doing":42},"id":154971,"eps":1,"meta_tags":["科幻","剧场版","漫画改","战斗"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2016-10-14","name":"GANTZ:O","name_cn":"","duration":"01:35:15","desc":"","ep":1,"sort":1,"id":672353,"subject_id":154971,"comment":9,"type":0,"disc":0,"duration_seconds":5715}],"updatedAt":"2026-05-01T18:04:29.044Z"}}