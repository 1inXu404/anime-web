追在其后来到了“迷雾岛”，危机四伏险象环生的这座岛上，是座会受到海水产生的雾气影响的“封印能力者之岛”？","name":"ONE PIECE 〜アドベンチャー オブ ネブランディア〜","name_cn":"航海王：迷雾岛大冒险","tags":[{"name":"海贼王","count":48,"total_cont":0},{"name":"2015","count":35,"total_cont":0},{"name":"SP","count":28,"total_cont":0},{"name":"特别篇","count":26,"total_cont":0},{"name":"TV","count":21,"total_cont":0},{"name":"搞笑","count":17,"total_cont":0},{"name":"热血","count":17,"total_cont":0},{"name":"战斗","count":15,"total_cont":0},{"name":"雾之岛","count":9,"total_cont":0},{"name":"福克斯","count":7,"total_cont":0},{"name":"2015年12月","count":7,"total_cont":0},{"name":"日本","count":6,"total_cont":0},{"name":"富冈淳广","count":5,"total_cont":0},{"name":"漫画改","count":4,"total_cont":0},{"name":"宇田钢之介","count":4,"total_cont":0},{"name":"OVA","count":4,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"奇幻","count":3,"total_cont":0},{"name":"孔明","count":3,"total_cont":0},{"name":"冒险","count":3,"total_cont":0},{"name":"東映アニメーション","count":3,"total_cont":0},{"name":"东映","count":3,"total_cont":0},{"name":"JUMP","count":2,"total_cont":0},{"name":"2015年","count":2,"total_cont":0},{"name":"谋略","count":2,"total_cont":0},{"name":"番外","count":2,"total_cont":0},{"name":"漫改","count":2,"total_cont":0},{"name":"抢人","count":2,"total_cont":0},{"name":"海军","count":2,"total_cont":0},{"name":"原创","count":2,"total_cont":0}],"infobox":[{"key":"中文名","value":"航海王：迷雾岛大冒险"},{"key":"别名","value":[{"v":"航海王特别篇：迷雾岛大冒险"},{"v":"海贼王 特别篇 雾之岛的冒险"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"2015年12月19日"},{"key":"放送星期","value":"星期六"},{"key":"官方网站","value":"https://one-piece.com/news/detail/20151109_2963"},{"key":"播放电视台","value":"フジテレビ"},{"key":"导演","value":"宇田鋼之介"},{"key":"音乐","value":"神保直史（AUDIO・タナカ）"},{"key":"Copyright","value":"©尾田栄一郎／集英社・フジテレビ・東映アニメーション"},{"key":"动画制作","value":"東映アニメーション"},{"key":"演出","value":"三上雅人、中村亮太、矢吹勉"},{"key":"分镜","value":"宇田鋼之介、竹之内和久、所勝美、古賀豪、貝澤幸男"},{"key":"企画","value":"狩野雄太（フジテレビ）、出樋昌稔（フジテレビ）櫻田博之（東映アニメーション）、小山弘起（東映アニメーション）"},{"key":"原作","value":"尾田栄一郎（『ONE