c":0,"duration_seconds":0},{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":10,"sort":10,"id":1558366,"subject_id":580662,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":11,"sort":11,"id":1558367,"subject_id":580662,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":12,"sort":12,"id":1558368,"subject_id":580662,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":13,"sort":13,"id":1558369,"subject_id":580662,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T18:26:54.068Z"},"580762":{"detail":{"date":"2025-12-04","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/fe/38/580762_Aidod.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/fe/38/580762_Aidod.jpg","large":"https://lain.bgm.tv/pic/cover/l/fe/38/580762_Aidod.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/fe/38/580762_Aidod.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/fe/38/580762_Aidod.jpg"},"summary":"地元・神奈川を愛するスタッフ＆キャストが集結！\r\n鎧田氏が描く、神奈川県ご当地漫画\r\n\r\n『#神奈川に住んでるエルフ』が、ついにTVアニメ化！\r\n\r\nかつて住処の森を焼かれたエルフたちは──「神奈川」に住んでいた。\r\n\r\n東京都の真下に位置する神奈川県。\r\n横浜、横須賀、茅ヶ崎、相模原……様々な場所にエルフたちは別にひっそりするでもなく普通に暮らしている。\r\n\r\n物語の中心となるのは、「横浜のエルフ」と、色々あって彼をほっとけない「川崎の人間」。\r\n\r\nすっかり現代日本に馴染んだ「神奈川県に住んでるエルフ」たちが織りなす、\r\n地元愛溢れる、現代ファンタジーコメディ！","name":"＃神奈川に住んでるエルフ","name_cn":"住在神奈川的精灵","tags":[{"name":"2025","count":3,"total_cont":0},{"name":"泡面番","count":2,"total_cont":0},{"name":"动态漫画","count":2,"total_cont":0},{"name":"漫画改","count":2,"total_cont":0},{"name":"2026冬","count":2,"total_cont":0},{"name":"2026","count":1,"total_cont":0},{"name":"IMAGEWORKS","count":1,"total_cont":0},{"name":"TV","count":1,"total_cont":0},{"name":"搞笑","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"住在神奈川的精灵"},{"key":"话数","value":"12"},{"key":"放送开始","value":"2025年12月4日"},{"key":"放送星期","value":"星期四"},{"key":"官方网站","value":"https://animationid.com/kanael/"},{"key":"播放电视台","value":"tvkテレビ神奈川、チバテレ、テレ玉"},{"key":"播放结束","value":"2026年3月12日"},{"key":"导演","value":"うもとゆーじ"},{"key":"音乐","value":"川本新"},{"key":"Copyright","value":"©鎧田／マイクロマガジン社／ドラマ「#かなエル」製作委員会"},{"key":"原作","value":"鎧田「#神奈川に住んでるエルフ」（マイクロマガジン社「コミックELMO」連載）"},{"key":"音响监督","value":"三浦妙子"},{"key":"制作统括","value":"高橋和也"},{"key":"制作协力","value":"ウサギ王"},{"key":"製作","value":"アニメ「#かなエル」製作委員会"}],"rating":{"rank":0,"total":4,"count":{"1":1,"2":0,"3":2,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0},"score":3},"total_episodes":12,"collection":{"on_hold":0,"dropped":5,"wish":8,"collect":9,"doing":3},"id":580762,"eps":12,"meta_tags":["TV","TV","日本","日本","漫画改","漫画改","动态漫画"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2025-12-04","name":"#エルフと人間と有隣堂と","name_cn":"","duration":"00:04:10","desc":"かつて森を焼かれたエルフたちは、現代日本の神奈川へ移住し、人類とともに普通に暮らしている。そんなある日、「横浜のエルフ」は、いつまでも完成しない横浜駅の改修工事に翻弄され迷子になってしまう。彼の面倒を見るのは、川崎在住で口は悪いが優しい「川崎の人間」。長寿のエルフと短命な人間、二人の日常を中心に、横浜・川崎をはじめとする地元ネタとファンタジー要素が融合した現代コメディが展開する。","ep":1,"sort":1,"id":1608335,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":250},{"airdate":"2025-12-11","name":"#神奈川にエルフいっぱいいんじゃん！","name_cn":"","duration":"00:04:10","desc":"「川崎の人間」は、「横浜のエルフ」から週末に開催されるエルフの集まりに誘われる。しぶしぶ向かう道中、彼は絡まれている少年を助けたが、その少年はなんと「横須賀のエルフ」だった。久々に顔を合わせたエルフたちは、現代社会の急速な変化についていけないと悩み、人間である彼にある切実な相談を持ちかける。","ep":2,"sort":2,"id":1608336,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":250},{"airdate":"2025-12-18","name":"#相模原、県境を越えて…","name_cn":"","duration":"00:04:10","desc":"「相模原のエルフ」は、大切に育てたナラの木を守るため、引っ越し先を探し始める。「川崎の人間」は、彼のあまりに時代遅れな金銭感覚や常識に戸惑いながらも物件探しを手伝うが、難航する。ナラの木のために奮闘する相模原のエルフだったが、ある決定的な事実に気づくことになり——。","ep":3,"sort":3,"id":1608337,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":250},{"airdate":"2026-01-15","name":"#町田のオーク来襲！","name_cn":"","duration":"00:04:10","desc":"森を焼かれたエルフたちと時を同じくして、オークたちも町田へ移住していた。「横浜のエルフ」と犬猿の仲である「町田のオーク」は遭遇するやいなや口論に発展。またもトラブルに巻き込まれた「川崎の人間」は、あまりに常識が通じないエルフたちに対し、オークの「人外」としての常識ぶりになぜか感動してしまう。","ep":4,"sort":4,"id":1624338,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":250},{"airdate":"2026-01-22","name":"#“ごめんなさい”はお手土産と一緒に","name_cn":"","duration":"00:04:09","desc":"先日の「町田のオーク」との一件で苦労を強いられた「川崎の人間」。彼から話を聞いた「横浜のエルフ」は、長年の因縁を謝罪するため、川崎の提案で菓子折りを持って町田へ行くことを決意する。「横浜のエルフ」は、オークとの関係修復に向け、相手が本当に喜ぶ手土産を検討し始める。","ep":5,"sort":5,"id":1627713,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":249},{"airdate":"2026-01-29","name":"#呑んだくれて野毛","name_cn":"","duration":"00:04:09","desc":"エルフ相手に商売をしていたダークエルフは、エルフの移住を聞き、自身も神奈川へと移住していた。ある日、ギャンブルに負けた「野毛のダークエルフ」は、「伊勢佐木町のダークエルフ」とやけ酒を煽る。そこに「横浜のエルフ」と「川崎の人間」が偶然遭遇し、事態はまたも口論へと発展していくのだった。","ep":6,"sort":6,"id":1631074,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":249},{"airdate":"2026-02-05","name":"#激突！湘南事変！","name_cn":"","duration":"00:04:09","desc":"「茅ヶ崎のエルフ」に誘われ、湘南のビーチへやってきた「川崎の人間」。「茅ヶ崎のエルフ」は湘南の広い海のような寛大なハートが大事だと説くが、そこに地元愛に溢れた各地のエルフたちが集結 。\"真の湘南はどこか\"を巡る熾烈な地域バトルが勃発する。エルフたちが自らの地元こそ湘南だと熱く主張し合う最中、とあるエルフが現れる。","ep":7,"sort":7,"id":1634821,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":249},{"airdate":"2026-02-12","name":"#ロードサイドエルフ","name_cn":"","duration":"00:04:09","desc":"「海老名のエルフ」と「相模原のエルフ」は、東名高速道路のEXPASA海老名で名物のメロンパンを食べながら、それぞれの地元の名前の由来や地域あるあるで盛り上がっていた。その最中、偶然とあるものを見つけてしまい自体は大きく動き出してしまう。それはエルフに伝わる恐ろしいものだった…？","ep":8,"sort":8,"id":1638062,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":249},{"airdate":"2026-02-19","name":"#歡迎！橫濱中華街","name_cn":"","duration":"00:04:09","desc":"「川崎の人間」が風邪をひいて以来、妖精が見えるようになってしまう。困った彼は横浜のエルフと共に、中華街で「何でも屋」を営む「横浜中華街のハーフエルフ」を訪ねる。漢方の知見がある「中華街のハーフエルフ」が薬を出そうとするが、エルフに借りは作りたくないと駄々をこねる「川崎の人間」。そこで、強引にでも薬を飲ませようとするが…","ep":9,"sort":9,"id":1647031,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":249},{"airdate":"2026-02-26","name":"#おいしいシウマイ","name_cn":"","duration":"00:04:09","desc":"「横浜のエルフ」は横浜名物である崎陽軒のシウマイ弁当を買いに来ていた。食べるのを楽しみに想像を膨らませている帰路で、ふと初めて食べた時の衝撃を思い出す。それは、彼がエルフの常識である「草食」から解放され、シウマイ弁当の虜になった瞬間だった。","ep":10,"sort":10,"id":1655250,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":249},{"airdate":"2026-03-05","name":"#ヨコハマサワヤカサン","name_cn":"","duration":"00:04:09","desc":"神奈川に住むエルフや人々は、それぞれの地域で朝のゴミ出し問題に直面していた。 「川崎の人間」はゴミを出し忘れ、「横浜のエルフ」は\"ヨコハマさわやかさん\"の音楽で目覚めるも間に合わず絶望する。 一方、他のエルフやオークたちのゴミ出し事情はというと…。","ep":11,"sort":11,"id":1656236,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":249},{"airdate":"2026-03-12","name":"#バイバイ川崎？さよなら神奈川？","name_cn":"","duration":"00:04:09","desc":"「川崎の人間」は「町田のオーク」に通勤の大変さについて話していた。その場面を式神を通じて「鎌倉のエルフ」に見つかってしまい、「川崎の人間」が川崎から出ていくのではと誤解される。それを聞いた各地のエルフたちは自分の地域に引っ越すべきだと「川崎の人間」のもとへ押しかけてきて…！？","ep":12,"sort":12,"id":1662714,"subject_id":580762,"comment":0,"type":0,"disc":0,"duration_seconds":249}],"updatedAt":"2026-05-01T19:27:50.427Z"},"580872":{"detail":{"date":"2025-09-05","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a2/9a/580872_3VXv3.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a2/9a/580872_3VXv3.jpg","large":"https://lain.bgm.tv/pic/cover/l/a2/9a/580872_3VXv3.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a2/9a/580872_3VXv3.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a2/9a/580872_3VXv3.jpg"},"summary":"「チェンソーの悪魔」ポチタと共にデビルハンターとして暮らす少年デンジ。親が遺した借金返済のため、貧乏な生活を送る中、裏切りに遭い殺されてしまう。薄れる意識の中、デンジはポチタと契約し、悪魔の心臓を持つもの「チェンソーマン」として蘇る。","name":"チェンソーマン 総集篇","name_cn":"链锯人 总集篇","tags":[{"name":"总集篇","count":230,"total_cont":0},{"name":"MAPPA","count":217,"total_cont":0},{"name":"战斗","count":198,"total_cont":0},{"name":"2025","count":187,"total_cont":0},{"name":"漫画改","count":181,"total_cont":0},{"name":"剧场版","count":148,"total_cont":0},{"name":"藤本树","count":129,"total_cont":0},{"name":"WEB","count":90,"total_cont":0},{"name":"日本","count":85,"total_cont":0},{"name":"奇幻","count":85,"total_cont":0},{"name":"吉原达矢","cou