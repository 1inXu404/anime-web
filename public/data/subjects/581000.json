te":"2026-05-02","name":"おしゃぶり決闘","name_cn":"","duration":"","desc":"ノレンと付き合っているフリをすることになり、戸惑い気味の十三。そんななか、ミツオカ製薬の研究と新薬を狙って、暗殺業界2番手の中華系組織ユイガンが動き出す。中学生暗殺者・古波鮫シンがノレンの婚約者になるべく転校してきたのだ。ノレンの「彼氏」である十三に決闘を申し込むシン。十三とシンの戦いの火蓋が切られる!","ep":4,"sort":4,"id":1655891,"subject_id":581284,"comment":1,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-09","name":"","name_cn":"","duration":"","desc":"","ep":5,"sort":5,"id":1655892,"subject_id":581284,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-16","name":"","name_cn":"","duration":"","desc":"","ep":6,"sort":6,"id":1655893,"subject_id":581284,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-23","name":"","name_cn":"","duration":"","desc":"","ep":7,"sort":7,"id":1655894,"subject_id":581284,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-05-30","name":"","name_cn":"","duration":"","desc":"","ep":8,"sort":8,"id":1655895,"subject_id":581284,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-06","name":"","name_cn":"","duration":"","desc":"","ep":9,"sort":9,"id":1655896,"subject_id":581284,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-13","name":"","name_cn":"","duration":"","desc":"","ep":10,"sort":10,"id":1655897,"subject_id":581284,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-20","name":"","name_cn":"","duration":"","desc":"","ep":11,"sort":11,"id":1655898,"subject_id":581284,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-06-27","name":"","name_cn":"","duration":"","desc":"","ep":12,"sort":12,"id":1655899,"subject_id":581284,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:00:43.936Z"},"581408":{"detail":{"date":"2012-06-08","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/aa/7a/581408_kfHCK.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/aa/7a/581408_kfHCK.jpg","large":"https://lain.bgm.tv/pic/cover/l/aa/7