026-05-01T18:24:41.712Z"},"300839":{"detail":{"date":"2020-04-01","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/24/04/300839_Tv41q.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/24/04/300839_Tv41q.jpg","large":"https://lain.bgm.tv/pic/cover/l/24/04/300839_Tv41q.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/24/04/300839_Tv41q.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/24/04/300839_Tv41q.jpg"},"summary":"如果登上塔，一切就都可以得到。\r\n塔顶上有着这世界上的一切，可以得到这个世界……成为神。\r\n为了欣赏星空而登塔的少女·蕾哈尔，以及如果有蕾哈尔这样的女朋友就什么也不需要了的少年·二十五夜，他们之间的故事开始了。","name":"神之塔 -Tower of God-","name_cn":"神之塔","tags":[{"name":"战斗","count":598,"total_cont":0},{"name":"漫画改","count":591,"total_cont":0},{"name":"2020年4月","count":584,"total_cont":0},{"name":"奇幻","count":543,"total_cont":0},{"name":"TV","count":409,"total_cont":0},{"name":"TelecomAnimationFilm","count":311,"total_cont":0},{"name":"2020","count":286,"total_cont":0},{"name":"韩国漫画改编","count":234,"total_cont":0},{"name":"漫改","count":220,"total_cont":0},{"name":"神之塔","count":130,"total_cont":0},{"name":"热血","count":118,"total_cont":0},{"name":"佐野隆史","count":53,"total_cont":0},{"name":"韩国","count":51,"total_cont":0},{"name":"日本","count":41,"total_cont":0},{"name":"韩漫","count":41,"total_cont":0},{"name":"日本动画","count":29,"total_cont":0},{"name":"2020年","count":19,"total_cont":0},{"name":"冒险","count":18,"total_cont":0},{"name":"异世界","count":16,"total_cont":0},{"name":"智斗","count":13,"total_cont":0},{"name":"韩漫改","count":12,"total_cont":0},{"name":"漫画改编","count":10,"total_cont":0},{"name":"早見沙織","count":7,"total_cont":0},{"name":"2020春","count":6,"total_cont":0},{"name":"B4","count":5,"total_cont":0},{"name":"动画","count":5,"total_cont":0},{"name":"A6","count":5,"total_cont":0},{"name":"C2","count":4,"total_cont":0},{"name":"日漫","count":4,"total_cont":0},{"name":"大逃杀","count":4,"total_cont":0}],"infobox":[{"key":"中文名","value":"神之塔"},{"key":"别名","value":[{"v":"タワーオブゴッド"}]},{"key":"话数","value":"13"},{"key":"放送开始","value":"202