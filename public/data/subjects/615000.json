"},{"key":"製作","value":"「闇芝居」製作委員会"}],"rating":{"rank":0,"total":31,"count":{"1":1,"2":1,"3":3,"4":6,"5":11,"6":4,"7":1,"8":1,"9":1,"10":2},"score":5.1},"total_episodes":13,"collection":{"on_hold":10,"dropped":7,"wish":17,"collect":43,"doing":24},"id":615739,"eps":13,"meta_tags":["TV","日本","原创"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2026-01-11","name":"最終回","name_cn":"","duration":"","desc":"今から40年前に放送された子供番組の最終回がある特定の地域だけ全く別の内容が放送されたという都市伝説が噂され、自称都市伝説研究家・東村光太郎は長年の調査の末、噂の発信源とされる村を特定するのだが...。","ep":1,"sort":1,"id":1622506,"subject_id":615739,"comment":3,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-01-18","name":"研究結果","name_cn":"","duration":"","desc":"直樹が提出した夏休みの自由研究の結果を不可解に思った担任教師・美桜。直樹の家を訪問し、両親に直樹について尋ねるが不審な様子はないという。しかし、そういう両親の挙動が徐々に奇妙なものになっていき...。","ep":2,"sort":2,"id":1622507,"subject_id":615739,"comment":5,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-01-25","name":"穏やかな村","name_cn":"","duration":"","desc":"身を隠すため田舎の集落に移住してきた男。村人たちはみんな親切で、よそ者である自分にきれいな住居や美味しい食料まで与えてくれて男にとってまさに天国のような場所だった。だが、ある日の夜、村人が亡くなったという話を聞き...。","ep":3,"sort":3,"id":1622508,"subject_id":615739,"comment":1,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-02-01","name":"ついていく","name_cn":"","duration":"","desc":"洋服修理の店を営む悠里の元に、着物をネクタイに仕立て直して欲しいと客の隆太が現れる。さっそく鋏を入れようとする悠里だが、着物の裏に何かが縫い綴じられているのに気付き...。","ep":4,"sort":4,"id":1622509,"subject_id":615739,"comment":2,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-02-08","name":"呪結","name_cn":"","duration":"","desc":"不動産屋に勤める男、柴崎。社長に頼まれた柴崎は管理するワケあり物件に霊能者の青年・大原を案内する。その物件で大原は霊視と除霊を行うはずだったが…。","ep":5,"sort":5,"id":1622510,"subject_id":615739,"comment":2,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-02-15","name":"合言葉","name_cn":"","duration":"","desc":"学校帰りの4人の小学生。いつもの道を楽しく帰っていると見覚えのない古めかしい洋館があることに気づく。興味をそそられて、中を探検してみることにした彼らだったが、亮介だけは得体の知れぬ不気味な何かに怯えていて…。","ep":6,"sort":6,"id":1622511,"subject_id":615739,"comment":1,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-02-22","name":"ぐるぐる","name_cn":"","duration":"","desc":"出産を間近に控え、産休に入った妻・朝子を見守っている勇一郎。穏やかな日々を過ごす中、朝子が「ぐるぐる」という言葉を口にするが、聞いたことがない勇一郎は…。","ep":7,"sort":7,"id":1622512,"subject_id":615739,"comment":3,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-03-01","name":"凍結","name_cn":"","duration":"","desc":"雪山で兄を亡くした秀吾。彼は兄が遺した写真を証拠に死因は遭難事故ではなく他殺だと訴えるが、誰も聞く耳を持たない。そんな失意の秀吾の前に現れた一人の女。彼女は写真に映る女性に瓜二つだったのだが…。","ep":8,"sort":8,"id":1622513,"subject_id":615739,"comment":2,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-03-08","name":"寝台列車","name_cn":"","duration":"","desc":"二人旅に出かけた紗友里と美和。初めての寝台列車ということですっかりテンションが上がる二人だったが、切符を確認しに来た車掌はおかしなことを言い出す。あくまで「お客様の安全のため」だというのだが…。","ep":9,"sort":9,"id":1622514,"subject_id":615739,"comment":2,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-03-15","name":"ムスビメサマ","name_cn":"","duration":"","desc":"付き合って間もないアミと斗真のカップル。真夜中のドライブで「ムスビメサマ」という都市伝説の話になると、アミは友人のユカリが体験したというある話を語り始めて…。","ep":10,"sort":10,"id":1622515,"subject_id":615739,"comment":2,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-03-22","name":"夢結び","name_cn":"","duration":"","desc":"寮に住んでいる高校生の幸也はこのところ奇妙な夢に悩まされていた。同室の康太にそれを話すと、「夢結び」という康太の故郷に伝わるまじないをしようと誘われるが…。","ep":11,"sort":11,"id":1622516,"subject_id":615739,"comment":2,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-03-29","name":"結戻し","name_cn":"","duration":"","desc":"男の元へかかってきた一本の謎の電話。「“あるもの”を預かってほしい」とだけ告げる見知らぬ女性は、男の都合など一切無視して“あるもの”とやらを置き去りにしていった。どうやらそれはいわくつきの品で、いくら手放そうとしてもどこまでも男の前に現れ…。","ep":12,"sort":12,"id":1622517,"subject_id":615739,"comment":1,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-04-05","name":"結末","name_cn":"","duration":"","desc":"今夜は信仁が大好きなアニメの最終回。果たしてどんな結末を迎えるのかと心待ちにしていた信仁だったが、世間は “終末の日”の話題でもちきりになっていた。ある予言者が「世界が滅亡する」と言った日は、まさに今日なのだ…。","ep":13,"sort":13,"id":1622518,"subject_id":615739,"comment":2,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T19:28:16.214Z"},"615843":{"detail":{"date":"2025-12-15","platform":"其他","images":{