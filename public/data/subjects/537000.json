ect_id":537722,"comment":68,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-05-05","name":"レプリカは、夢を見る。","name_cn":"","duration":"00:24:04","desc":"駅で呆然と立ち尽くすアキは、電話で素直に、ナオが亡くなったかもしれないことを伝える。驚き、動揺する素直。線路の下からは、ナオの着ていた制服と靴、水色のシュシュが見つかって――","ep":5,"sort":5,"id":1655988,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-05-12","name":"","name_cn":"","duration":"00:24:04","desc":"","ep":6,"sort":6,"id":1655989,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-05-19","name":"","name_cn":"","duration":"00:24:04","desc":"","ep":7,"sort":7,"id":1655990,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-05-26","name":"","name_cn":"","duration":"00:24:04","desc":"","ep":8,"sort":8,"id":1655991,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-06-02","name":"","name_cn":"","duration":"00:24:04","desc":"","ep":9,"sort":9,"id":1655992,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-06-09","name":"","name_cn":"","duration":"00:24:04","desc":"","ep":10,"sort":10,"id":1655993,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-06-16","name":"","name_cn":"","duration":"00:24:04","desc":"","ep":11,"sort":11,"id":1655994,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-06-23","name":"","name_cn":"","duration":"00:24:04","desc":"","ep":12,"sort":12,"id":1655995,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444},{"airdate":"2026-06-30","name":"","name_cn":"","duration":"00:24:04","desc":"","ep":13,"sort":13,"id":1666250,"subject_id":537722,"comment":0,"type":0,"disc":0,"duration_seconds":1444}],"updatedAt":"2026-05-01T14:36:10.264Z"}}