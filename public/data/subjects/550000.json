s / Psyde Kick Studio"},{"key":"发行","value":"Aniplex"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":28,"count":{"1":1,"2":0,"3":0,"4":2,"5":6,"6":11,"7":4,"8":2,"9":1,"10":1},"score":6},"total_episodes":1,"collection":{"on_hold":13,"dropped":7,"wish":320,"collect":35,"doing":36},"id":550937,"eps":1,"meta_tags":["剧场版","日本","小说改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2026-01-30","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":1598185,"subject_id":550937,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T19:27:55.998Z"},"550966":{"detail":{"date":"2025-01-23","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/93/80/550966_PJ8O8.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/93/80/550966_PJ8O8.jpg","large":"https://lain.bgm.tv/pic/cover/l/93/80/550966_PJ8O8.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/93/80/550966_PJ8O8.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/93/80/550966_PJ8O8.jpg"},"summary":"主人公林峰本是天才机器人工程师，为了提升其所研发的超能机器人的机能，他费尽千辛万苦，从深渊之中挖掘出了神秘的上古至宝——祖龙之眸，而正当其欲将祖龙之眸的能量，转化入超能机器人之中时，龙眸内的神力被意外激发，引发时空漩涡，将林峰带到了崇尚武道的古神大陆，转世重生。重生的林峰被封印了前世的记忆，成为了一个只觉醒了治疗系武魂的平庸人士，备受冷眼，甚至惨遭未婚妻的悔婚。其未婚妻的族人为了斩草除根，狠心袭杀林峰。危机时刻，林峰觉醒了关于祖龙之眸的记忆，并惊喜发现龙眸的神力已成功与其所研发的超能机器人所融合。随后，在超能机器人的帮助之下，他逐渐掌控了祖龙之眸的神力，踏上了强者之路。","name":"万界主宰","name_cn":"","tags":[{"name":"国产","count":3,"total_cont":0},{"name":"中国","count":3,"total_cont":0},{"name":"战斗","count":3,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"WEB","count":2,"total_cont":0},{"name":"玄幻","count":2,"total_cont":0},{"name":"2025","count":2,"total_cont":0},{"name":"3D","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"2025年1月","count":1,"total_cont":0}],"infobox":[{"key":"话数","value":"32"},{"key":"放送开始","value":"2025年1月23日"},{"key":"在线播放平台","value":"哔哩哔哩、优酷、芒果TV、腾讯视频、爱奇艺"},{"key":"导演","value":"不灵不灵"},{"key":"链接","value":[{"k":"哔哩哔哩","v":"https://www.bilibili.com/bangu