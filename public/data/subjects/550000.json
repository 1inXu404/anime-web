世界は、少しずつ色を帯びていく。\r\n\r\n――だが、玲斗はまだ知らなかった。クスノキが持つ＜本当の力＞を。\r\n\r\nやがてその謎は、玲斗の人生をも巻き込みながら、彼を思いもよらぬ真実へと導いていく。","name":"クスノキの番人","name_cn":"祈念守护人","tags":[{"name":"剧场版","count":79,"total_cont":0},{"name":"A-1Pictures","count":63,"total_cont":0},{"name":"2026","count":59,"total_cont":0},{"name":"小说改","count":48,"total_cont":0},{"name":"伊藤智彦","count":34,"total_cont":0},{"name":"东野圭吾","count":26,"total_cont":0},{"name":"日本","count":18,"total_cont":0},{"name":"2026年1月","count":17,"total_cont":0},{"name":"PsydeKickStudio","count":7,"total_cont":0},{"name":"2026年","count":7,"total_cont":0},{"name":"東野圭吾","count":7,"total_cont":0},{"name":"轻小说改","count":5,"total_cont":0},{"name":"アニメ映画","count":3,"total_cont":0},{"name":"动画电影","count":3,"total_cont":0},{"name":"小说改编","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"未上映","count":2,"total_cont":0},{"name":"Studio","count":1,"total_cont":0},{"name":"高橋文哉","count":1,"total_cont":0},{"name":"剧场动画","count":1,"total_cont":0},{"name":"菅野祐悟","count":1,"total_cont":0},{"name":"Psyde","count":1,"total_cont":0},{"name":"轻改","count":1,"total_cont":0},{"name":"未发售","count":1,"total_cont":0},{"name":"Kick","count":1,"total_cont":0},{"name":"祈念守护人","count":1,"total_cont":0},{"name":"anime","count":1,"total_cont":0},{"name":"2020s","count":1,"total_cont":0},{"name":"劇場","count":1,"total_cont":0},{"name":"山口つばさ","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"祈念守护人"},{"key":"别名","value":[{"v":"Kusunoki no Bannin"},{"v":"The Camphorwood Custodian"}]},{"key":"上映年度","value":"2026年1月30日"},{"key":"片长","value":"113分钟"},{"key":"官方网站","value":"https://kusunoki-movie.com/"},{"key":"Copyright","value":"©東野圭吾／アニメ「クスノキの番人」製作委員会"},{"key":"原作","value":"東野圭吾「クスノキの番人」（実業之日本社文庫 刊）"},{"key":"导演","value":"伊藤智彦"},{"key":"副导演","value":"助监督：神林裕"},{"key":"脚本","value":"岸本卓"},{"key":"人物设定","value":"山口つばさ、板垣彰子"},{"key":"印象板","value":"Sheya(丁丁框)、名倉靖博"},{"key":"设定","value":"堀口悠紀子、上ノ山芽衣子、塚田陽子、鈴木一穂、安田京弘、三腰航平"},{"key":"服装设计","value":"高橋毅