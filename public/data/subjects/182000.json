s://lain.bgm.tv/r/200/pic/cover/l/43/d4/182239_LWzC1.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/43/d4/182239_LWzC1.jpg","large":"https://lain.bgm.tv/pic/cover/l/43/d4/182239_LWzC1.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/43/d4/182239_LWzC1.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/43/d4/182239_LWzC1.jpg"},"infobox":[{"key":"wiki","value":"{{Infobox animanga/OVA\r\n|中文名= 噬血狂袭 II\r\n|别名={\r\n[ Strike the Blood Second]\r\n}\r\n|话数= 8\r\n|发售日= 2016年11月23日\r\n|官方网站= http://www.strike-the-blood.com/#/homepage\r\n|开始= 2016年11月23日\r\n|结束= 2017年5月24日\r\n|其他= \r\n|Copyright= ©2015 三雲岳斗／KADOKAWA　アス キー・メディアワークス刊／PROJECT STB OVA\r\n|动画制作= SILVER LINK./CONNECT\r\n}}"}],"volumes":0,"eps":8,"total_episodes":8,"rating":{"rank":4959,"total":2303,"score":6.6,"count":{"1":3,"2":2,"3":10,"4":52,"5":211,"6":805,"7":910,"8":233,"9":33,"10":44}},"collection":{"wish":689,"collect":4330,"doing":173,"on_hold":121,"dropped":65},"tags":[{"name":"后宫","count":594},{"name":"OVA","count":517},{"name":"轻小说改","count":408},{"name":"战斗","count":331},{"name":"噬血狂袭","count":325},{"name":"SILVERLINK.","count":296},{"name":"卖肉","count":239},{"name":"2016","count":197},{"name":"2016年11月","count":197},{"name":"奇幻","count":171},{"name":"轻改","count":137}],"meta_tags":["OVA","后宫","小说改","战斗"]},"episodes":[{"id":655118,"sort":1,"name":"黒の剣巫篇 I","name_cn":"黑之剑巫篇 I","airdate":"2016-11-23","duration":"00:25:32","type":0,"desc":"マリンリゾート施設・ブルーエリジアムでバカンスを楽しむ代わりに、施設の飲食店でバイトすることになった古城と浅葱。バイト中に結瞳という少女と知り合った古城は、彼女がとある研究施設から紗矢華の手によって助け出されたことを聞かされる。結瞳達が逃走する際、紗矢華は剣巫の技を使う謎の少女と交戦状態となり、安否不明になっていた。"},{"id":655119,"sort":3,"name":"黒の剣巫篇 III","name_cn":"黑之剑巫篇 III","airdate":"2016-12-23","duration":"00:27:27","type":0,"desc":"神々が太古に作り出した生体兵器・レヴィアタン。その巨大兵器を結瞳の力で意のままに操ろうとしていたテロリスト・久須木。彼の野望を阻むため、浅葱の協力も得て古城と雪菜はレヴィアタンへと向かう。古城達を妨害しようとする霧葉の相手を紗矢華に任せると、眷獣でレヴィアタンの魔力障壁を突破！　内部への侵入に成功する!!"},{"id":655120,"sort":5,"name":"逃亡の第四真祖篇 II","name_cn":"逃亡的第四真祖篇 II","airdate":"2017-03-29","duration":"00:24:45","type":0,"desc":"凪沙の安否を確認するため本土へと渡ろうとする古城。しかし那月から思わぬ拘束を受けてしまう。ニーナと夏音の助けで辛くも逃げ出すが、那月の追跡は厳しく、古城は那月の監獄結界へと囚われてしまう……。監獄結界で“本来の姿”の那月と対峙した古城は、助けようと共に巻き込まれた夏音から吸血すると、新たな眷獣を目覚めさせるのだった！"},{"id":655121,"sort":6,"name":"咎神の騎士篇 I","name_cn":"咎神的骑士篇 I","airdate":"2017-03-29","duration":"00:24:52","type":0,"desc":"沙を連れて本土へと渡った牙城。実家の神緒多神社を訪れると、何故か母親である緋紗乃に拘束されてしまう。神緒多神社のある神縄湖周辺では、獅子王機関と自衛隊によって、とある作戦が決行されようとしていたのだった……。一方、そんな状況を知らず、温泉で羽根を伸ばしていた凪沙のもとに、獅子王機関の“三聖”が一人、闇白奈が現れ――。"},{"id":655187,"sort":2,"name":"黒の剣巫篇 II","name_cn":"黑之剑巫篇 II","airdate":"2016-11-23","duration":"00:25:12","type":0,"desc":"深夜に目を覚ました古城は、妖艶に変貌した結瞳の姿を目にする。彼女の正体は最強の夢魔・サキュバスで、結瞳の能力に影響された雪菜や浅葱も、上気した表情で古城に迫ってくる……。雪霞狼の力で、なんとかその場は乗り切ったものの、今度は魔導災害専門の国家機関・太子局に所属する妃崎霧葉や、サキュバスの力に操られた紗矢華まで現れて!?"},{"id":655188,"sort":4,"name":"逃亡の第四真祖篇 I","name_cn":"逃亡的第四真祖篇 I","airdate":"2016-12-23","duration":"00:24:08","type":0,"desc":"久々に絃神島を訪れた古城の父親・牙城。古城との再会も早々に、凪沙を連れて本土へと舞い戻ってしまう。残された古城が雪菜や友人達と共に年越しの初詣を楽しんでいると、魔法陣が映し出された謎のメールが凪沙から送られてくる。凪沙と連絡が取れないことを不審に思った古城は、浅葱に頼んで牙城の動向を探ってみるのだが――!?"},{"id":655189,"sort":7,"name":"咎神の騎士篇 II","name_cn":"咎神的骑士篇 II","airdate":"2017-05-24","duration":"00:25:46","type":0,"desc":"本土へ渡り、古城達のもとへと急ぐ浅葱とリディアーヌ。道中で魔獣の群れに襲われるが、褐色の肌をした少年に助けられる。少年の名はイブリスベール。滅びの王朝を統べる第二真祖直系の王子であった。一方、獅子王機関と自衛隊の作戦は、トラブルに見舞われ失敗。どさくさに紛れて拘束を解いた牙城だったが、翼竜に乗った謎の騎士の襲撃を受ける！"},{"id":655190,"sort":8,"name":"咎神の騎士篇 III","name_cn":"咎神的骑士篇 III","airdate":"2017-05-24","duration":"00:26:23","type":0,"desc":"神縄湖の湖底に眠っていた龍族の少女グレンダ。彼女の身柄を引き渡すよう要求してくる自衛隊の様子を不審に思った古城が拒否すると、隊員は自衛隊車両をゴーレム化し、古城を襲撃！一連の騒動の黒幕は、自衛隊の中に紛れていた聖殱派のしわざであった。そして古城は、正体を現した聖殱派の魔具の力で虚無世界“ノド”へと送られてしまい――!?"}],"updatedAt":"2026-05-02T07:20:10.115Z"},"182294":{"detail":{"id":182294,"type":2,"name":"太陽の黙示録","name_cn":"太阳默示录","summary":"柳舷一郎本来出生在一个政治家的家庭中，背负着将来要成为一名政治家的命运。但是，在０２年８月１０富士山发生了大规模的火山爆发，结果造成了以琵琶湖为中心的日本分裂。舷一郎在逃难的过程中与双亲失散并失去了记忆，后来被一对台湾藉夫妇救起并一起逃往台湾。结果，日本由美国、中国进行分割统治，而日本难民则往世界各地避难而去……１５年后，日本仍未复兴，而在台湾无法返回祖国的日本人与台湾人之间的摩擦已经达到了顶点。在这种情况下，舷一郎在命运之丝的操纵下，在富有正义感的台湾人与日本难民之间来回往赴……之后，他将要背负起日本难民的将来，把日本导入再生之路…… ","nsfw":false,"date":"2006-09-17","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/17/7e/182294_BZJPM.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/17/7e/182294_BZJPM.jpg","large":"https://lain.bgm.tv/pic/cover/l/17/7e/182294_BZJPM.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/17/7e/182294_BZJPM.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/17/7e/182294_BZJPM.jpg"},"infobox":[{"key":"wiki","value":"{{Infobox animanga/TVAnime\r\n|中文名= 太阳默示录\r\n|别名={\r\n}\r\n|话数= 2\r\n|放送开始= 2006年9月17日\r\n|放送星期= \r\n|官方网站= \r\n|在线播放平台= \r\n|播放电视台= WOWOW\r\n|其他电视台= \r\n|播放结束= 2006年9月18日\r\n|导演= 小島正幸\r\n|音乐= 本多俊之\r\n|其他= \r\n|Copyright= \r\n|原作= かわぐちかいじ\r\n|脚本= 浦畑達彦\r\n|分镜= 小島正幸、鶴岡耕次郎、中村亮介、松戸太郎、高橋亨\r\n|演出= 小島正幸、大野和寿、増原光幸、神崎ユウジ、中村亮介、荻原露光、大久保唯男\r\n|人物设定= 西城隆詞\r\n|总作画监督= 西城隆詞\r\n|美术监督= 水谷利春\r\n|色彩设计= 木村聡子\r\n|音响监督= 清水洋史\r\n|动画制作= MADHOUSE\r\n|制作= ｢太陽の黙示録｣製作委員会（東北新社、WOWOW、博報堂DYメディアパートナーズ、小学館）\r\n|作画监督= 水村十司、松田芳明、高橋直樹、田中修司、渡辺章、Jang Hee-kyu、Kim Gi-du\r\n}}"}],"volumes":0,"eps":2,"total_episodes":2,"rating":{"rank":0,"total":15,"score":4.7,"count":{"1":1,"2":1,"3":1,"4":2,"5":5,"6":4,"7":1,"8":0,"9":0,"10":0}},"collection":{"wish":30,"collect":20,"doing":1,"on_hold":4,"dropped":5},"tags":[{"name":"TV","count":12},{"name":"MADHouse","count":9},{"name":"漫画改","count":7},{"name":"2006","count":7},{"name":"小岛正幸","count":5},{"name":"2006年9月","count":3},{"name":"架空","count":3},{"name":"政治","count":2},{"name":"独立剧场版","count":2},{"name":"台湾","count":1},{"name":"2006年","count":1}],"meta_tags":["TV","日本","漫画改"]},"episodes":[{"id":635405,"sort":1,"name":"前編『海峡』","name_cn":"海峡","airdate":"","duration":"","type":0,"desc":""},{"id":635406,"sort":2,"name":"後編『国境』","name_cn":"国境","airdate":"","duration":"","type":0,"desc":""}],"updatedAt":"2026-05-02T07:20:10.115Z"},"182341":{"detail":{"id":182341,"type":2,"name":"おなら吾郎","name_cn":"屁吾郎","summary":"個人作家として数々のアニメを制作し、自主制作アニメ『森の安藤』が、YouTubeで400万回以上再生（ファンの方がアップしたもので現在そのアカウントは消滅）され話題となるなど、独特な世界観で映像作品を制作し続けるアニメ作家・谷口崇（九州大学芸術