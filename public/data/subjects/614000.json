動戦士ガンダム　鉄血のオルフェンズ　ウルズハント　小さな挑戦者の軌跡」と同時上映で劇場公開。","name":"機動戦士ガンダム 鉄血のオルフェンズ 幕間の楔","name_cn":"机动战士高达 铁血的奥尔芬斯 幕间之楔","tags":[{"name":"剧场版","count":9,"total_cont":0},{"name":"SUNRISE","count":8,"total_cont":0},{"name":"2025","count":8,"total_cont":0},{"name":"高达","count":7,"total_cont":0},{"name":"机战","count":5,"total_cont":0},{"name":"萝卜","count":4,"total_cont":0},{"name":"长井龙雪","count":4,"total_cont":0},{"name":"原创","count":4,"total_cont":0},{"name":"冈田麿里","count":2,"total_cont":0},{"name":"千叶道德","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"岡田麿里","count":2,"total_cont":0},{"name":"短片","count":2,"total_cont":0},{"name":"GUNDAM","count":1,"total_cont":0},{"name":"海老川兼武","count":1,"total_cont":0},{"name":"鹫尾直广","count":1,"total_cont":0},{"name":"2025年","count":1,"total_cont":0},{"name":"热血","count":1,"total_cont":0},{"name":"2020s","count":1,"total_cont":0},{"name":"科幻","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"机动战士高达 铁血的奥尔芬斯 幕间之楔"},{"key":"别名","value":[{"v":"機動戦士ガンダム 鉄血のオルフェンズ 10周年記念新作短編「幕間の楔」"}]},{"key":"上映年度","value":"2025年10月31日"},{"key":"片长","value":"16分钟"},{"key":"官方网站","value":"https://www.gundam.info/feature/g-orphans/movie/?cate=movie2"},{"key":"话数","value":"1"},{"key":"主动画师","value":"有澤寛(チーフメカアニメーター)"},{"key":"美术","value":"須江信人(美術協力)"}],"rating":{"rank":0,"total":34,"count":{"1":0,"2":0,"3":2,"4":2,"5":3,"6":17,"7":7,"8":1,"9":0,"10":2},"score":6.1},"total_episodes":1,"collection":{"on_hold":2,"dropped":2,"wish":19,"collect":52,"doing":4},"id":614207,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"","name":"","name_cn":"","duration":"","desc":"","ep":1,"sort":1,"id":1609395,"subject_id":614207,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T19:26:04.504Z"},"614308":{"detail":{"date":"2022-12-10","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c9/1e/614308_rR09u.jpg","grid":"https://lain.bgm.tv/r