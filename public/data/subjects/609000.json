onds":1442},{"airdate":"2026-07-24","name":"","name_cn":"","duration":"00:24:02","desc":"","ep":16,"sort":16,"id":1653397,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":1442},{"airdate":"2026-07-31","name":"","name_cn":"","duration":"00:24:02","desc":"","ep":17,"sort":17,"id":1653398,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":1442},{"airdate":"2026-08-07","name":"","name_cn":"","duration":"00:24:02","desc":"","ep":18,"sort":18,"id":1653399,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":1442},{"airdate":"2026-08-14","name":"","name_cn":"","duration":"00:24:02","desc":"","ep":19,"sort":19,"id":1653400,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":1442},{"airdate":"2026-08-21","name":"","name_cn":"","duration":"","desc":"","ep":20,"sort":20,"id":1653401,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-08-28","name":"","name_cn":"","duration":"","desc":"","ep":21,"sort":21,"id":1653402,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-09-04","name":"","name_cn":"","duration":"","desc":"","ep":22,"sort":22,"id":1653403,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-09-11","name":"","name_cn":"","duration":"","desc":"","ep":23,"sort":23,"id":1653404,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":0},{"airdate":"2026-09-18","name":"","name_cn":"","duration":"","desc":"","ep":24,"sort":24,"id":1653405,"subject_id":609175,"comment":0,"type":0,"disc":0,"duration_seconds":0}],"updatedAt":"2026-05-01T17:00:31.785Z"},"609183":{"detail":{"date":"2026-04-05","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/50/ac/609183_hr8ZH.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/50/ac/609183_hr8ZH.jpg","large":"https://lain.bgm.tv/pic/cover/l/50/ac/609183_hr8ZH.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/50/ac/609183_hr8ZH.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/50/ac/609183_hr8ZH.jpg"},"summary":"「要是能像玩恋爱游戏一样能看见别人的好感度就好了。」\r\n北见彼方一直暗恋身为青梅竹马的千岁茉莉花，但因为自身原因迟迟不敢跟她告白。某日，他对着流星许愿，没想到隔天竟然真的能看到女生对他的好感度计量条了！\r\n不过当他看到正在单恋中的茉莉花的好感度时……她的好感度却黏稠稠地融化，还整个坏掉了！？况且，明明呈现出来的结果代表着茉莉花讨厌彼方，但直到现在都还对他这么温柔。另一方面，班上其他女生对彼方所抱持的意外好感，也逐渐变得明朗……\r\n触及「有暗面却很可爱」的女孩子们的秘密，温馨又硬核的恋爱喜剧，就此开幕！\r\n\r\n\r\n\r\n[简介原文]\r\n女の子の好感度メーターが 見えるようになりました。\r\nだけど、幼馴染で片思い中の茉莉花ちゃんの好感度を見たら、ドロドロに溶けてぶっ壊れていて⋯!?\r\n茉莉花ちゃん、僕のこと嫌いなのにどうして今まで優しかったの…？\r\nそして、クラスの女の子達が僕に向ける意外な好意も明らかになっていき…\r\n――裏アリ可愛い女の子の秘密に触れる、ハートフルでハードコアなラブコメディ開幕！","name":"茉莉花ちゃんの好感度はぶっ壊れている","name_cn":"茉莉花酱的好感度正在崩坏","tags":[{"name":"2026年4月","count":272,"total_cont":0},{"name":"恋爱","count":213,"total_cont":0},{"name":"漫画改","count":180,"total_cont":0},{"name":"校园","count":137,"total_cont":0},{"name":"TV","count":137,"total_cont":0},{"name":"泡面番","count":118,"total_cont":0},{"name":"2026","count":116,"total_cont":0},{"name":"StudioLeo","count":93,"total_cont":0},{"name":"后宫","count":92,"total_cont":0},{"name":"日本","count":88,"total_cont":0},{"name":"日常","count":83,"total_cont":0},{"name":"漫改","count":74,"total_cont":0},{"name":"搞笑","count":72,"total_cont":0},{"name":"卖肉","count":52,"total_cont":0},{"name":"正太","count":24,"total_cont":0},{"name":"佐佐木纯人","count":14,"total_cont":0},{"name":"彗星社","count":10,"total_cont":0},{"name":"内田真礼","count":9,"total_cont":0},{"name":"伊藤彩沙","count":7,"total_cont":0},{"name":"福利","count":6,"total_cont":0},{"name":"泡面","count":6,"total_cont":0},{"name":"伊驹百合绘","count":5,"total_cont":0},{"name":"天崎滉平","count":5,"total_cont":0},{"name":"肉番","count":5,"total_cont":0},{"name":"短片","count":5,"total_cont":0},{"name":"钉宫理惠","count":4,"total_cont":0},{"name":"新番","count":4,"total_cont":0},{"name":"2026年","count":3,"total_cont":0},{"name":"2026春","count":3,"total_cont":0},{"name":"未上映","count":2,"total_cont":0}],"infobox":[{"key":"中文名","value":"茉莉花酱的好感度正在崩坏"},{"key":"别名","value":[{"v":"茉莉花同學的好感度壞得很徹底"}]},{"key":"话数","value":"8"},{"key":"放送开始","value":"2026年4月5日"},{"key":"放送星期","value":"星期日"},{"key":"官方网站","value":"https://marikowa.af-original.com/"},{"key":"播放电视台","value":"TOKYO MX"},{"key":"其他电视台","value":"BS11"},{"key":"导演","value":"佐々木純人"},{"key":"Copyright","value":"©小麦りん／Suiseisha Inc."},{"key":"原作","value":"小麦りん"},{"key":"人物设定","value":"那須玲奈"},{"key":"系列构成","value":"大武政満 / シナリオ工学研究所"},{"key":"美术设定","value":"チャン・ド・キム・ファン"},{"key":"美术监督","value":"チャン・ド・キム・ファン"},{"key":"摄影监督","value":"有馬総一郎"}],"rating":{"rank":9302,"total":374,"count":{"1":7,"2":5,"3":16,"4":61,"5":138,"6":118,"7":16,"8":5,"9":1,"10":7},"score":5.2},"total_episodes":8,"collection":{"on_hold":54,"dropped":148,"wish":555,"collect":62,"doing":2081},"id":609183,"eps":8,"meta_tags":["校园","TV","恋爱","日本","漫画改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2026-04-05","name":"好感度が見えるようになりました","name_cn":"我开始看得见好感度了","duration":"00:05:58","desc":"幼馴染の茉莉花ちゃんに告白する勇気の無い僕は流れ星に強く願った。\r\nすると、クラスの女子達の好感度メーターが見えるようになって…\r\n非現実な光景に戸惑いながらも茉莉花ちゃんを見ると、\r\nドロドロに下限突破した最悪のメーター…!？\r\n茉莉花ちゃん、それなのにどうして僕にあんなに優しくしてくれたの…？\r\n好感度メーターが示す本当の意味とは⋯","ep":1,"sort":1,"id":1656104,"subject_id":609183,"comment":60,"type":0,"disc":0,"duration_seconds":358},{"airdate":"2026-04-12","name":"好感度が上がったり下がったり","name_cn":"好感度突上突下","duration":"00:05:58","desc":"片思い相手の茉莉花ちゃんのぶっ壊れた好感度メーターをなんとかしたい。\r\nまずは好感度の低い豊富さんと仲良くせねばと思うけれど、\r\n思い切り邪険に扱われて早速意気消沈。\r\nところが放課後、いつもの公園で泣いている女の子を助けて送り届けた先は、\r\n豊富さんの家だった！？　女の子は豊富さんの妹さんだったんだ！\r\nお礼にと晩ごはんに誘われるやいなや、好感度は上がっていき…\r\n\r\n脚本：大武政満/シナリオ工学研究所\r\n絵コンテ：佐々木純人\r\n演出：佐々木純人\r\n作画監督：荒井久磨","ep":2,"sort":2,"id":1656105,"subject_id":609183,"comment":51,"type":0,"disc":0,"duration_seconds":358},{"airdate":"2026-04-19","name":"好感度は覚醒する","name_cn":"好感度要觉醒了","duration":"00:05:58","desc":"茉莉花ちゃんの好感度メーターをなんとかしようと悩む僕は、\r\nいつもの公園にて僕は愛犬を連れたクラスメイトの三笠さんと遭遇する。\r\n愛犬同士のトークで盛り上がった彼女の好感度は高い。\r\n本命の茉莉花ちゃんのためにも格好悪いところを見せて、\r\n好感度を下げようとするのだけど、三笠さんの好感度メーターが…！？\r\n通りかかった茉莉花ちゃんに目撃されてしまっていたことを僕は知らなくて…\r\n\r\n脚本：大武政満/シナリオ工学研究所\r\n絵コンテ：横浜サトシ\r\n演出：佐々木純人\r\n作画監督：荒井久磨","ep":3,"sort":3,"id":1656106,"subject_id":609183,"comment":52,"type":0,"disc":0,"duration_seconds":358},{"airdate":"2026-05-03","name":"好感度はナマモノですか？","name_cn":"","duration":"00:05:58","desc":"好感度メーターに般若が宿ったこの日の茉莉花ちゃんはまったくの無表情。\r\n嫌われたくない僕はがんばってアプローチを続けることに…。\r\n何をしても笑顔を見せてくれない茉莉花ちゃんだったけど、僕は諦めない。\r\nそして、思い切ってお昼の時間にデートのお誘いに成功する！\r\nだけど、そこに豊富さんが現れて、好感度メーターに突然の変化が！？\r\nそれに呼応して、茉莉花ちゃんの好感度メーターも…\r\n\r\n脚本：大武政満/シナリオ工学研究所\r\n絵コンテ：森田侑希\r\n演出：佐々木純人\r\n作画監督：荒井久磨","ep":4,"sort":4,"id":1656107,"subject_id":609183,"comment":5,"type":0,"disc":0,"duration_seconds":358},{"airdate":"2026-05-10","name":"","name_cn":"","duration":"00:05:58","desc":"","ep":5,"sort":5,"id":1656108,"subject_id":609183,"comment":0,"type":0,"disc":0,"duration_seconds":358},{"airdate":"2026-05-17","name":"","name_cn":"","duration":"00:05:58","desc":"","ep":6,"sort":6,"id":1656109,"subject_id":609183,"comment":0,"type":0,"disc":0,"duration_seconds":358},{"airdate":"2026-05-24","name":"","name_cn":"","duration":"00:05:58","desc":"","ep":7,"sort":7,"id":1656110,"subject_id":609183,"comment":0,"type":0,"disc":0,"duration_seconds":358},{"airdate":"2026-05-31","name":"","name_cn":"","duration":"00:05:58","desc":"","ep":8,"sort":8,"id":1656111,"subject_id":609183,"comment":0,"type":0,"disc":0,"duration_seconds":358}],"updatedAt":"2026-05-01T17:00:51.853Z"},"609191":{"detail":{"date":"2018-04-09","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/6e/ac/609191_zowUV.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/6e/ac/609191_zowUV.jpg","large":"https://lain.bgm.tv/pic/cover/l/6e/ac/609191_zowUV.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/6e/ac/609191_zowUV.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/6e/ac/609191_zowUV.jpg"},"summary":"It’s the story of a praying mantis who goes off the city to become a policeman and is going to suffer a lot. It’s a bit like Zootopia but without being tolerant.\r\n故事的主角是一只螳螂，它离开城市去成为一名警察，并在这个过程中遭遇了许多困难和挑战。剧情充满了幽默和惊