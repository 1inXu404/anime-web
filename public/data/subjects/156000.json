":156591,"eps":24,"meta_tags":["漫画改","战斗","玄幻","中国","WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"episodes":[{"airdate":"2016-04-28","name":"镇魂街","name_cn":"","duration":"00:20:48","desc":"镇魂街连接着灵域和人类世界，此乃吸纳亡灵镇压恶灵之地。夏铃是一名普通的大学毕业生，一次偶然的事件导致她进入了镇魂街的其中之一，罗刹街。在这个充满恶灵的街道，罗刹街的镇魂将曹焱兵帅气出场，上演英雄救美。","ep":1,"sort":1,"id":622142,"subject_id":156591,"comment":10,"type":0,"disc":0,"duration_seconds":1248},{"airdate":"2016-05-05","name":"兄弟","name_cn":"","duration":"00:13:01","desc":"曹氏兄弟童年回忆开启，父母不告而别，哥哥独自一人照顾年幼的弟弟，父母还未归家却等来了神秘人的驱逐，曹氏兄弟将何去何从……","ep":2,"sort":2,"id":633286,"subject_id":156591,"comment":3,"type":0,"disc":0,"duration_seconds":781},{"airdate":"2016-05-12","name":"寄灵人","name_cn":"","duration":"00:13:06","desc":"老司机曹焱兵带美少女夏铃“罗刹街深♂度游”，教你如何正确地打开镇魂街……","ep":3,"sort":3,"id":633287,"subject_id":156591,"comment":1,"type":0,"disc":0,"duration_seconds":786},{"airdate":"2016-05-19","name":"誓言","name_cn":"","duration":"00:13:05","desc":"被驱逐出罗刹街的兄弟生活艰难，偶遇“救星”却遭遇拐卖，弟弟竟然被直接扔进垃圾堆……","ep":4,"sort":4,"id":633288,"subject_id":156591,"comment":3,"type":0,"disc":0,"duration_seconds":785},{"airdate":"2016-05-26","name":"王国组织","name_cn":"","duration":"00:12:39","desc":"历经过罗刹街发生的一切，夏铃开始迷惘。在即将尘安落定时却遭遇神秘人追杀，故事仿佛才刚刚开始……","ep":5,"sort":5,"id":633289,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":759},{"airdate":"2016-06-02","name":"无家可归","name_cn":"","duration":"00:13:14","desc":"兄弟二人重返罗刹街，再遇卢少爷。历经磨难后，已经长大的兄弟能否打败恶少？","ep":6,"sort":6,"id":633290,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":794},{"airdate":"2016-06-09","name":"欢迎来到罗刹街","name_cn":"","duration":"00:13:11","desc":"为了逃避王国组织的追杀夏铃躲进罗刹街，没想到她却做起了女仆……","ep":7,"sort":7,"id":633291,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":791},{"airdate":"2016-06-16","name":"刘羽禅","name_cn":"","duration":"00:14:03","desc":"哥哥被送到死魂岛后备受欺凌，一心想要回去救弟弟的他能借助他人之力成功脱逃吗？","ep":8,"sort":8,"id":633292,"subject_id":156591,"comment":1,"type":0,"disc":0,"duration_seconds":843},{"airdate":"2016-06-23","name":"山不在高","name_cn":"","duration":"00:12:46","desc":"曹焱兵开始认真帮助夏铃训练成为强大的寄灵人，铁头劈木板、水底憋气湿身play齐上阵……","ep":9,"sort":9,"id":633293,"subject_id":156591,"comment":1,"type":0,"disc":0,"duration_seconds":766},{"airdate":"2016-06-30","name":"温柔是罪","name_cn":"","duration":"00:13:25","desc":"逃离死魂岛后，哥哥一路艰辛返回罗刹街寻找弟弟，弟弟究竟能不能躲过恶灵的搜寻直到哥哥回来救他呢？","ep":10,"sort":10,"id":633294,"subject_id":156591,"comment":3,"type":0,"disc":0,"duration_seconds":805},{"airdate":"2016-07-07","name":"暴雨梨花","name_cn":"","duration":"00:13:03","desc":"曹焱兵得知杀害父母的嫌疑犯后，开始四面八方搜索他的踪迹，不料却正中敌人的陷阱……","ep":11,"sort":11,"id":633349,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":783},{"airdate":"2016-07-14","name":"新的誓言","name_cn":"","duration":"00:14:18","desc":"历尽千辛万苦的哥哥终于救下了危机之中的弟弟，二人还没离开罗刹街却节外生枝，一直照顾弟弟的哑女姐姐竟然变成了恶灵，兄弟之间面临着抉择危机……","ep":12,"sort":12,"id":633350,"subject_id":156591,"comment":1,"type":0,"disc":0,"duration_seconds":858},{"airdate":"2016-08-04","name":"锁心链","name_cn":"","duration":"00:13:39","desc":"夏铃一直无法召唤出自己的守护灵，同样心急的曹焱兵尝试剑走偏锋，又一次把夏铃置入险境之中……","ep":13,"sort":13,"id":633353,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":819},{"airdate":"2016-08-11","name":"灵槐枝","name_cn":"","duration":"00:13:35","desc":"时隔四年修炼归来的曹家兄弟，面对凶狠的卢少爷，他们能夺回自己的家吗？","ep":14,"sort":14,"id":633354,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":815},{"airdate":"2016-08-18","name":"夏铃的抉择","name_cn":"","duration":"00:13:16","desc":"夏铃无意间听到灵槐枝可以提升灵力不禁心动，而曹焱兵却责怪她只想走捷径，面对他的反对，夏铃会作何选择？","ep":15,"sort":15,"id":633355,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":796},{"airdate":"2016-08-25","name":"为了过去的战斗","name_cn":"","duration":"00:12:48","desc":"吃了灵槐枝的卢少爷灵力大增，依靠自己力量战斗的兄弟二人还能打败他吗？","ep":16,"sort":16,"id":633356,"subject_id":156591,"comment":1,"type":0,"disc":0,"duration_seconds":768},{"airdate":"2016-09-01","name":"四面楚歌","name_cn":"","duration":"00:12:45","desc":"王国组织终于突破结界进入了罗刹街，为了保护夏铃，曹焱兵独自一人冲锋陷阵……","ep":17,"sort":17,"id":633357,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":765},{"airdate":"2016-09-08","name":"人鬼殊途","name_cn":"","duration":"00:12:38","desc":"哥哥为了保护弟弟，独自面对吃了灵槐枝的恶灵，在罗刹街孤军奋战，而没有灵力的弟弟却千方百计想要回到罗刹街……","ep":18,"sort":18,"id":633358,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":758},{"airdate":"2016-09-15","name":"第九骑士","name_cn":"","duration":"00:12:50","desc":"为了不让亡灵们受到牵连，曹焱兵决定另辟蹊径，却不想正中王国组织的下怀……","ep":19,"sort":19,"id":633359,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":770},{"airdate":"2016-09-22","name":"背水一战","name_cn":"","duration":"00:14:30","desc":"弟弟终于回到罗刹街和卢少爷正面交锋，面对心存恶念的卢少爷，兄弟二人之间又会出现怎样的变故……","ep":20,"sort":20,"id":633360,"subject_id":156591,"comment":2,"type":0,"disc":0,"duration_seconds":870},{"airdate":"2016-09-29","name":"破竹之势","name_cn":"","duration":"00:13:29","desc":"在曹焱兵被引出罗刹街之后，落单的小亮和夏铃无力抵抗步步紧逼的王国组织，危难之时夏铃又会作何举动……","ep":21,"sort":21,"id":633361,"subject_id":156591,"comment":0,"type":0,"disc":0,"duration_seconds":809},{"airdate":"2016-10-06","name":"武神躯","name_cn":"","duration":"00:15:19","desc":"记忆紊乱的弟弟按照卢少爷的意念行动，转而和哥哥对抗，在哥哥无法抵抗之时，弟弟会如何选择……\r\n而另一边始终忠心护主的于禁为了抵抗卢少爷，又会做出何种举动……","ep":22,"sort":22,"id":633362,"subject_id":156591,"comment":3,"type":0,"disc":0,"duration_seconds":919},{"airdate":"2016-10-13","name":"成王之路","name_cn":"","duration":"00:15:42","desc":"陷入恶战的曹焱兵只想速战速决，无意间却发现了鬼符三通的秘密。而另一边的罗刹街也陷入大乱，夏铃的守护灵能否被控制住？小亮能否化险为夷？","ep":23,"sort":23,"id":633363,"subject_id":156591,"comment":1,"type":0,"disc":0,"duration_seconds":942},{"airdate":"2016-10-20","name":"冒险的黎明","name_cn":"","duration":"00:26:46","desc":"","ep":24,"sort":24,"id":633364,"subject_id":156591,"comment":2,"type":0,"disc":0,"duration_seconds":1606}],"updatedAt":"2026-05-01T18:00:09.966Z"},"156731":{"detail":{"date":"2016-05-21","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/8a/5c/156731_K7qxD.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/8a/5c/156731_K7qxD.jpg","large":"https://lain.bgm.tv/pic/cover/l/8a/5c/156731_K7qxD.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/8a/5c/156731_K7qxD.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/8a/5c/156731_K7qxD.jpg"},"summary":"　人気特撮テレビドラマ「牙狼 GARO」シリーズのアニメ版として2014年から放送された「牙狼 GARO 炎の刻印」の劇場版。テレビアニメ版の続編で、4年後を舞台に新たな物語が展開される。黄金騎士「牙狼」の称号を受け継いだレオンは、バリアンテ王国の王子アルフォンソと共に次代の騎士の育成に心血を注いでいた。そんな彼らに、隣国バゼリアに巣食うホラーの討伐命令が下される。しかし同じ頃、次代の騎士候補が何者かに拉致されてしまう。必死で行方を追うレオンは、敵の妨害で窮地に陥ったところをバゼリアの魔戒騎士ダリオに助けられ、彼に導かれてたどり着いた街で、ある意外な人物に遭遇する。テレビアニメ版も手がけた林祐一郎が監督を続投。","name":"牙狼〈GARO〉-DIVINE FLAME-","name_cn":"牙狼 神之火焰","tags":[{"name":"剧场版","count":80,"total_cont":0},{"name":"MAPPA","count":61,"total_cont":0},{"name":"2016","count":36,"total_cont":0},{"name":"原创","count":32,"total_cont":0},{"name":"牙狼","count":24,"total_cont":0},{"name":"小林靖子","count":22,"total_cont":0},{"name":"战斗","count":21,"total_cont":0},{"name":"林祐一郎","count":15,"total_cont":0},{"name":"奇幻","count":13,"total_cont":0},{"name":"2016年","count":9,"total_cont":0},{"name":"东北新社","count":8,"total_cont":0},{"name":"2016年5月","count":7,"total_cont":0},{"name":"日本","count":5,"total_cont":0},{"name":"MoNACA","count":5,"total_cont":0},{"name":"特摄","count":4,"total_cont":0},{"name":"東北新社","count":4,"total_cont":0},{"name":"朴性厚","count":4,"total_cont":0},{"name":"林佑一郎","count":3,"total_cont":0},{"name":"特摄改","count":3,"total_cont":0},{"name":"热血","count":2,"total_cont":0},{"name":"菅野利之","count":2,"total_cont":0},{"name":"2016年四月番","count":2,"total_cont":0},{"name":"2010s","count":1,"total_cont":0},{"name":"异态","count":1,"total_cont":0},{"name":"7-用心享受","count":1,"total_cont":0},{"name":"动作","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"伪","count":1,"total_cont":0},{"name":"16春","count":1,"total_cont":0},{"name":"SF","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"牙狼 神之火焰"},{"key":"上映年度","value":"2016年5月21日"},{"key":"片长","value":"78分"},{"key":"官方网站","value":"http://garo-divineflame.jp/"},{"key":"人设协力","value":"武井宏之"},{"key":"美术监督","value