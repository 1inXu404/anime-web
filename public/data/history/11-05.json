[{"id":132361,"type":2,"name":"The Old Mill","name_cn":"老磨坊","summary":"      在空寂无人的郊外，清澄明澈的河边伫立着一个废弃良久的老磨坊。人类的足迹早已从此消失，如今这里变成了动物们栖息繁衍的欢乐所在。鸟儿在此筑巢，小老鼠们欢快地跑来跑去，更有无数蝙蝠倒挂在磨坊的顶层，期待夜晚的来临。夜幕降临，荷花敛去洁净的花容，青蛙、蟋蟀、猫头鹰、萤火虫这些活跃于夜晚的小生命又在老磨坊前演奏起夜之安魂曲。正在此时，习习凉风转变为强劲的狂风，乌云遮蔽了月亮的光辉，愤怒的闪电在空中聒噪，灾难一般的暴风雨随即而至。它猛烈抽打着这座摇摇欲坠的老磨坊，栖息于此的小动物们也共同经历着暴风雨的洗礼…… \r\n　　本片为1938年奥斯卡电影节最佳动画短片。","date":"1937-11-05","images":null,"rating":{"rank":3368,"total":70,"score":6.7,"count":{"1":0,"2":1,"3":0,"4":3,"5":6,"6":20,"7":19,"8":20,"9":1,"10":0}},"tags":[{"name":"短片","count":44},{"name":"欧美","count":23},{"name":"迪士尼","count":17},{"name":"1937","count":17},{"name":"Disney","count":13},{"name":"奥斯卡","count":13},{"name":"美国","count":8},{"name":"原创","count":5},{"name":"音乐","count":4},{"name":"剧场版","count":4},{"name":"破屋遭遇雷雨","count":4}],"eps":1,"collection":{"wish":24,"collect":110,"doing":2,"on_hold":2,"dropped":8}},{"id":280546,"type":2,"name":"Out Foxed","name_cn":"逮狐狸","summary":"","date":"1949-11-05","images":null,"rating":{"rank":0,"total":13,"score":7.2,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":6,"8":3,"9":0,"10":1}},"tags":[{"name":"短片","count":8},{"name":"1949","count":4},{"name":"美国","count":4},{"name":"欧美","count":2},{"name":"1940s","count":2},{"name":"动画","count":1},{"name":"1940-1949","count":1},{"name":"6(+1)","count":1},{"name":"Short","count":1},{"name":"米高梅","count":1}],"eps":1,"collection":{"wish":1,"collect":24,"doing":1,"on_hold":2,"dropped":3}},{"id":142227,"type":2,"name":"ある街角の物語","name_cn":"某个街角的故事","summary":"一个女孩子和她亲密的玩具熊；喜欢恶作剧的康库君；四处散播种子的大树；上了年纪的街灯；坏心眼的蛾子；墙壁上的张贴画们。——故事就在某个秋天的日子里开始了。","date":"1962-11-05","images":null,"rating":{"rank":3159,"total":103,"score":6.8,"count":{"1":0,"2":1,"3":0,"4":3,"5":9,"6":24,"7":41,"8":19,"9":4,"10":2}},"tags":[{"name":"短片","count":47},{"name":"手塚治虫","count":40},{"name":"1962","count":38},{"name":"山本暎一","count":25},{"name":"原创","count":24},{"name":"虫Production","count":23},{"name":"剧场版","count":18},{"name":"坂本雄作","count":15},{"name":"OVA","cou