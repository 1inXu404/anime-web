r/200/pic/cover/l/38/dd/221017_6l8hw.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/38/dd/221017_6l8hw.jpg","large":"https://lain.bgm.tv/pic/cover/l/38/dd/221017_6l8hw.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/38/dd/221017_6l8hw.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/38/dd/221017_6l8hw.jpg"},"rating":{"rank":4248,"total":65,"score":6.4,"count":{"1":0,"2":0,"3":0,"4":5,"5":7,"6":21,"7":25,"8":6,"9":0,"10":1}},"tags":[{"name":"Khara","count":39},{"name":"短片","count":31},{"name":"2016","count":22},{"name":"庵野秀明","count":10},{"name":"小林浩康","count":8},{"name":"WEB","count":6},{"name":"原创","count":6},{"name":"剧场版","count":6},{"name":"新世纪OVA及剧场","count":4},{"name":"日本","count":3},{"name":"表外","count":2}],"eps":1,"collection":{"wish":19,"collect":115,"doing":2,"on_hold":4,"dropped":7}},{"id":207439,"type":2,"name":"Inner Workings","name_cn":"内部运作","summary":"《内部运作》由日本和巴西混血儿导演Leo Matsuda执导，他曾是迪士尼的故事艺术师，参与过《六大英雄》（Big Hero 6）、《无敌破坏王》（Wreck-It Ralph）等影片制作。 \r\n　　《内部运作》的故事有些类似《头脑特工队》，讲述了一个人的务实、谨慎的头脑和他自由、奔放的心脏之间的斗争。 \r\n　　短片主角是一个名叫“保罗”的十分普通的办公室小职员，在他上班的路上充满了各种诱惑，时刻都在召唤他那颗爱玩的心，但他的头脑理智则总是把这种念头压制了下去。在完整体会过了枯燥无聊的工作生活和过度放纵的玩乐之后，保罗的头脑和他的心达成了妥协，商定以后会平衡好他的工作与娱乐。 \r\n　　本片的灵感来自Leo Matsuda的个人体验，他有着日本人的严谨和纪律性，同时也有着巴西人的狂热奔放，如何平衡好这两者是他一直在努力做的事。","date":"2016-11-23","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0e/18/207439_q7HsC.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0e/18/207439_q7HsC.jpg","large":"https://lain.bgm.tv/pic/cover/l/0e/18/207439_q7HsC.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0e/18/207439_q7HsC.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0e/18/207439_q7HsC.jpg"},"rating":{"rank":0,"total":10,"score":6.4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":4,"7":5,"8":0,"9":0,"10":0}},"tags":[{"name":"短片","count":7},{"name":"欧美","count":5},{"name":"2016","count":4},{"name":"迪士尼","count":3},{"name":"Disney","count":2},{"name":"剧场版","count":2},{"name":"欢乐","count":1},{"name":"美国","count":1}],"eps":1,"collection":{"wish":