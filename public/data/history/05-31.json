r/800/pic/cover/l/aa/d9/100665_1xJi6.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/aa/d9/100665_1xJi6.jpg"},"rating":{"rank":0,"total":44,"score":6.4,"count":{"1":0,"2":0,"3":0,"4":3,"5":4,"6":18,"7":15,"8":2,"9":0,"10":2}},"tags":[{"name":"剧场版","count":25},{"name":"2014","count":14},{"name":"2014年5月","count":9},{"name":"萝卜","count":6},{"name":"永井豪","count":5},{"name":"总集篇","count":5},{"name":"ロボットガールズZ","count":5},{"name":"东映","count":4},{"name":"東映アニメーション","count":4},{"name":"百合","count":4},{"name":"博史池畠","count":4}],"eps":1,"collection":{"wish":82,"collect":89,"doing":4,"on_hold":8,"dropped":10}},{"id":130892,"type":2,"name":"太空熊猫总动员","name_cn":"","summary":"　　熊猫星球在百年庆典之时被邪恶的鼠司令一伙趁机占领，他控制所有的熊猫，把他们都变成了小丑，而太空熊猫和他的小伙伴则因为意外逃过一劫，来到了熊猫星球内部神秘的地下世界。在神秘的地下世界中太空熊猫为拯救熊猫一族勇敢的踏上了寻找熊猫一族最大的秘密神器，可鼠司令却另有打算，他要夺去熊猫一族的希望，更利用神器满足自己更大的野心，统治全宇宙。双方人马在神奇的地下世界中展开一系列的斗智斗勇，可太空熊猫却不知道危险早已逼近自己，面对亲情友情他将如何面对，太空熊猫能不能拯救熊猫星球…… ","date":"2014-05-31","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/bf/f1/130892_Oum1T.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/bf/f1/130892_Oum1T.jpg","large":"https://lain.bgm.tv/pic/cover/l/bf/f1/130892_Oum1T.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/bf/f1/130892_Oum1T.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/bf/f1/130892_Oum1T.jpg"},"rating":{"rank":0,"total":3,"score":1.7,"count":{"1":1,"2":2,"3":0,"4":0,"5":0,"6":0,"7":0,"8":0,"9":0,"10":0}},"tags":[{"name":"剧场版","count":2},{"name":"国产","count":1},{"name":"无","count":1}],"eps":1,"collection":{"wish":3,"collect":4,"doing":0,"on_hold":1,"dropped":10}},{"id":208065,"type":2,"name":"猪猪侠之勇闯巨人岛","name_cn":"","summary":"　　在童话世界经营“猪猪万事屋”的猪猪侠意外收获一颗魔豆。随后，魔豆的主人杰克找到猪猪侠，道出魔豆与其丢失的会下金蛋的巨鹅有关系，同时委托猪猪侠帮忙到巨人岛寻找巨鹅。 \r\n　　为了擦亮“猪猪万事屋”的招牌，猪猪侠和他的同伴们欣然接受了杰克的委托，并开始了他们惊险的巨人岛大冒险。 \r\n　　然而，猪猪侠和他的同伴们并不知道，此时他们正掉进一个巨大阴谋的漩涡之中…… \r\n　　光怪陆离的巨人岛充满了种种未知的危险。猪猪侠一行人历经艰难困苦，潜入了巨人城堡，带走了会下金蛋的巨鹅，但却遭到巨人的追击，他们乘坐的鹅从空中坠落森林，再一次陷入险境…… \r\n　　几经周折，猪猪侠和同伴们终于找到了可以逃离巨人岛的机会。然而就在此时，杰克却撕开了伪装的面纱，原来他正是童话世界中最险恶的汪洋大盗，所发生的一切都只是他为了偷取