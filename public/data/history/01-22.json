エと共に大陸へ帰る為に家を飛び出していくのだった。","date":"1997-01-22","images":null,"rating":{"rank":0,"total":21,"score":5.2,"count":{"1":0,"2":0,"3":1,"4":5,"5":7,"6":7,"7":0,"8":0,"9":0,"10":1}},"tags":[{"name":"OVA","count":17},{"name":"漫改","count":5},{"name":"高河弓","count":4},{"name":"1997","count":4},{"name":"独立ova","count":3},{"name":"漫画改","count":3},{"name":"95-99","count":2},{"name":"其他","count":2},{"name":"旧物","count":2},{"name":"山崎理","count":1},{"name":"奥野浩行","count":1}],"eps":2,"collection":{"wish":44,"collect":29,"doing":1,"on_hold":1,"dropped":5}},{"id":23155,"type":2,"name":"メモリーズオフ2nd OVA","name_cn":"秋之回忆 2nd OVA","summary":"OVA メモリーズオフ2nd Vol.1 真夏の中で\r\nOVA メモリーズオフ2nd vol.2それぞれの想いに\r\nOVA メモリーズオフ2nd vol.3陽の当たる場所\r\n\r\n另有2004年3月24日发售的以白河萤为中心的加有新画面的再编辑版，限量3000张的 OVA メモリーズオフ2nd 特別編 ~Nocturne~ ","date":"2003-01-22","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/27/e7/23155_4aN76.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/27/e7/23155_4aN76.jpg","large":"https://lain.bgm.tv/pic/cover/l/27/e7/23155_4aN76.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/27/e7/23155_4aN76.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/27/e7/23155_4aN76.jpg"},"rating":{"rank":8673,"total":130,"score":5.2,"count":{"1":1,"2":3,"3":11,"4":23,"5":41,"6":31,"7":11,"8":5,"9":1,"10":3}},"tags":[{"name":"OVA","count":57},{"name":"秋之回忆","count":31},{"name":"2003","count":25},{"name":"GAL改","count":24},{"name":"恋爱","count":20},{"name":"游戏改","count":9},{"name":"水树奈奈","count":7},{"name":"崩","count":7},{"name":"动画","count":6},{"name":"日本","count":4},{"name":"メモオフ","count":3}],"eps":3,"collection":{"wish":108,"collect":216,"doing":10,"on_hold":9,"dropped":17}},{"id":56391,"type":2,"name":"SEXFRIEND ～セックスフレンド～","name_cn":"","summary":"早瀬美奈是个大胆又开放的女孩，她在学校里有不少炮友。本来一直是抱着玩玩的心理和男生交往，然而随着男主人公的出现，恋爱却在她心中悄悄萌芽了。","date":"2004-01-22","images":null,"rating":{"rank":5994,"total":223,"score":6.2,"count":{"1":1,"2":0,"3":6,"4":17,"5":36,"6":68,"7":59,"8":27,"9":3,"10":6}},"tags":[{"name":"里番","count