over/l/0c/ca/285688_hqBVN.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0c/ca/285688_hqBVN.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0c/ca/285688_hqBVN.jpg"},"rating":{"rank":0,"total":5,"score":6.2,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":2,"7":1,"8":1,"9":0,"10":0}},"tags":[{"name":"欧美","count":8},{"name":"剧场版","count":7},{"name":"战争","count":6},{"name":"历史","count":5},{"name":"小说改","count":3},{"name":"波兰","count":2},{"name":"2018","count":2},{"name":"电影院","count":1},{"name":"电影","count":1},{"name":"2010s","count":1}],"eps":1,"collection":{"wish":6,"collect":7,"doing":0,"on_hold":2,"dropped":2}},{"id":270294,"type":2,"name":"みるタイツ","name_cn":"裤袜视界","summary":"４月。雨の朝。散り始めた桜が雨に打たれ、水たまりに浮かんでいる。生徒たちが色とりどりの傘が高校の校門をくぐり抜けていく。\r\n\r\n「おはよ、レン」。下駄箱の前で、濡れたタイツのレンにユアが話しかける。憂鬱そうに振り向くレンに、そこにいっそうびしょ濡れのホミが、跳ねるようにやってきて話に花を咲かせる。他愛無い３人女子生徒の会話が、新学期の訪れを教室に告げる。\r\n\r\n少女たちのかけがえのない時間が駆け抜けて、季節が移り変わっていく…","date":"2019-05-11","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f1/7d/270294_5ybVy.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f1/7d/270294_5ybVy.jpg","large":"https://lain.bgm.tv/pic/cover/l/f1/7d/270294_5ybVy.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f1/7d/270294_5ybVy.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f1/7d/270294_5ybVy.jpg"},"rating":{"rank":5192,"total":2964,"score":6.5,"count":{"1":9,"2":16,"3":35,"4":82,"5":334,"6":945,"7":1060,"8":336,"9":75,"10":72}},"tags":[{"name":"泡面番","count":934},{"name":"原创","count":611},{"name":"裤袜","count":552},{"name":"卖肉","count":524},{"name":"2019年4月","count":475},{"name":"WEB","count":385},{"name":"2019","count":329},{"name":"丸戸史明","count":314},{"name":"百合","count":224},{"name":"TV","count":217},{"name":"裤袜视界","count":171}],"eps":12,"collection":{"wish":1483,"collect":4913,"doing":425,"on_hold":245,"dropped":189}},{"id":282692,"type":2,"name":"アーサー 騎士王の覚醒","name_cn":"亚瑟王 骑士王的觉醒","summary":"「アーサー 騎士王の覚醒」は、アーサーが\"王とは何か\"を問う物語ーー。\r\n\r\nエクスカリバーを強敵に奪われ、内面の弱さを知ったアーサーは、自分に足りないもの、大切なものは何かを