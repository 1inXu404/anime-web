ain.bgm.tv/r/400/pic/cover/l/a6/80/84701_MGjZ7.jpg"},"rating":{"rank":1930,"total":304,"score":7.2,"count":{"1":2,"2":0,"3":3,"4":1,"5":11,"6":45,"7":127,"8":91,"9":15,"10":9}},"tags":[{"name":"剧场版","count":130},{"name":"XEBEC","count":89},{"name":"2014","count":63},{"name":"科幻","count":46},{"name":"宇宙战舰大和号","count":43},{"name":"原创","count":41},{"name":"出渕裕","count":29},{"name":"宇宙战舰大和号2199","count":14},{"name":"出渊裕","count":14},{"name":"结城信辉","count":10},{"name":"2014年","count":7}],"eps":1,"collection":{"wish":222,"collect":467,"doing":15,"on_hold":24,"dropped":22}},{"id":109053,"type":2,"name":"THE LAST -NARUTO THE MOVIE-","name_cn":"火影忍者 剧场版 终章","summary":"鸣人和佐助的因缘之战结束2年之后，木叶忍者村临近冬日的祭典。鸣人在拉面店“一乐”与一同成长起来的同伴们正度过着快乐的时间。在那之中，带着自己偷偷编织的围巾的雏田仍然没能传达自己的心意。雏田对于只能一直在旁边守望的自己感到厌恶。这时，一个神秘的男人突然现身了。千钧一发之际，鸣人前来搭救了雏田，但那个男人却留下“你们将迎来灭亡的命运。就在这时，伴随着强烈的光芒，陨石贯穿了夜空……\r\n五影会谈紧急开幕。在那里就座的是各国的首长雷影、水影、土影、我爱罗。月球不断靠近地球，其残骸将会落向地面，可以说人类灭亡的倒计时已经开始了。忍者们为此陷入混乱。鸣人与小樱、鹿丸、佐井以及雏田开始展开调查，并到达了一个刻着巨大咒印的异质地底空间。在那里等着他们的是，“某个计划”以及大筒木舍人。这个男人的真实身份是曾经与鸣人、佐助展开殊死决斗的查克拉之祖大筒木辉夜的子孙。在那瞬间，率领着傀儡队的舍人现身，以压倒性的力量将鸣人等人击倒。雏田也终于落入了舍人的手中。与此同时，地面上的人们与不断降落的陨石所进行的壮烈防卫战也即将迎来极限。舍人终于道出的“真正的最终计划”究竟是！？大筒木一族，以及雏田她们的日向一族之间的悲哀宿命究竟是！？即将到来的地球最后之日，众人各自心怀不屈的意志，超越时空展开激烈的冲突！","date":"2014-12-06","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/95/62/109053_YdD8U.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/95/62/109053_YdD8U.jpg","large":"https://lain.bgm.tv/pic/cover/l/95/62/109053_YdD8U.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/95/62/109053_YdD8U.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/95/62/109053_YdD8U.jpg"},"rating":{"rank":3906,"total":1752,"score":6.7,"count":{"1":7,"2":5,"3":14,"4":39,"5":141,"6":497,"7":662,"8":290,"9":50,"10":47}},"tags":[{"name":"剧场版","count":609},{"name":"火影忍者","count":329},{"name":"2014","count":223},{"name":"完结篇","count":178},{"name":"热血","count":168},{"name":"恋爱","count":153},{"name":"StudioPierrot","count":142},{"name":"战斗","count":109},{"name":"漫画改","count":91},{"name":"岸本斉史