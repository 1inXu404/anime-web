[{"id":133739,"type":2,"name":"Jungle Rhythm","name_cn":"丛林乐章","summary":"　　美丽的原始大草原上，欢快的米奇（沃尔特·迪斯尼 Walt Disney 配音）正站在一头不断跳跃的大象身上演奏手风琴，欢快的音乐连冷峻的秃鹫都受到感染，于是随之起舞。米奇发现了秃鹫，命令大象停下，他也滑了下来，随即从裤子里掏出一把猎枪，悄悄靠近闭目养神的秃鹫。谁知他的猎枪爆了枪膛，还被秃鹫嘲笑了一番。米奇十分气愤，举枪挥了过去，谁知却惹恼了旁边的狗熊和狮子。危难当前，惶恐的米奇噘起嘴吹响了口哨。音乐再次响起，所有的小动物们都跳起舞蹈，世界名曲以别致的方式演绎，引起了动物们的热烈欢迎。 \r\n　　快乐的音乐会并未结束，开始朝着下一轮高潮行进…… ","date":"1929-11-15","images":null,"rating":{"rank":0,"total":9,"score":7,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":1,"7":2,"8":3,"9":1,"10":0}},"tags":[{"name":"短片","count":5},{"name":"剧场版","count":3},{"name":"1929","count":3},{"name":"欧美","count":2},{"name":"迪士尼","count":2},{"name":"考古","count":2},{"name":"UB_IWERKS","count":1},{"name":"慢节奏","count":1},{"name":"美国","count":1},{"name":"Disney","count":1},{"name":"鬃毛hula","count":1}],"eps":1,"collection":{"wish":1,"collect":19,"doing":0,"on_hold":0,"dropped":3}},{"id":112693,"type":2,"name":"The Lord of the Rings","name_cn":"指环王","summary":"The Fellowship of the Ring embark on a journey to destroy the One Ring and end Sauron's reign over Middle Earth.","date":"1978-11-15","images":null,"rating":{"rank":0,"total":19,"score":6.1,"count":{"1":0,"2":0,"3":1,"4":2,"5":2,"6":7,"7":5,"8":1,"9":0,"10":1}},"tags":[{"name":"剧场版","count":8},{"name":"转描","count":6},{"name":"魔戒","count":5},{"name":"美国","count":3},{"name":"欧美","count":3},{"name":"1978","count":2},{"name":"非日本动画","count":2},{"name":"剧场版-02","count":1},{"name":"1970-1979","count":1}],"eps":1,"collection":{"wish":20,"collect":30,"doing":2,"on_hold":2,"dropped":5}},{"id":112887,"type":2,"name":"Mickey's House of Villains","name_cn":"米奇家族的万圣历险","summary":"","date":"2001-11-15","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/09/ba/112887_ZM7y5.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/09/ba/112887_ZM7y5.jpg","large":"https://lain.bgm.tv/pic/cover/l/09/ba/112887_ZM7y5.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/09/ba/112887_ZM7y5.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/09/ba/112887_Z