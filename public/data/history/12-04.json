ect":1,"doing":0,"on_hold":0,"dropped":4}},{"id":74930,"type":2,"name":"ヴァイス・サヴァイヴR","name_cn":"Weiss Survive R","summary":"","date":"2009-12-04","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0a/92/74930_IpiWj.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0a/92/74930_IpiWj.jpg","large":"https://lain.bgm.tv/pic/cover/l/0a/92/74930_IpiWj.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0a/92/74930_IpiWj.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0a/92/74930_IpiWj.jpg"},"rating":{"rank":0,"total":23,"score":5.2,"count":{"1":1,"2":1,"3":1,"4":3,"5":7,"6":5,"7":3,"8":2,"9":0,"10":0}},"tags":[{"name":"泡面番","count":14},{"name":"TV","count":8},{"name":"2009","count":6},{"name":"南條愛乃","count":4},{"name":"榎本温子","count":3},{"name":"橘田いずみ","count":3},{"name":"动画","count":1},{"name":"日本","count":1},{"name":"游戏改","count":1},{"name":"2010年1月","count":1}],"eps":12,"collection":{"wish":31,"collect":40,"doing":2,"on_hold":7,"dropped":4}},{"id":18480,"type":2,"name":"劇場版BLEACH 地獄篇","name_cn":"死神剧场版 地狱篇","summary":"生前犯下重罪的人将会被送往地狱，这是一个连死神都不得过问的地方。通向这一禁忌之地的“地狱之门”竟然出现在了空座町上空。露琪亚和恋次从尸魂界赶来调查这一异常情况。\r\n与此同时，一群披黑斗篷的人向黑崎一护所在的学校发起攻击。一护、雨龙和茶渡在猛烈的攻势中努力保护大家，却因对方超级强大灵压而处于下风。紧急赶到的露琪亚和恋次也被黑衣人轻易击败。\r\n原来，这些人是地狱的罪人——“咎人”，他们拥有强大的灵力和特殊能力，为了达成某一野望而出现于现世。袭击空座町的咎人们将魔爪伸向了一护的妹妹游子和夏梨。一护拼命战斗，却被操纵火焰的咎人朱莲挡住去路，无计可施。\r\n危急时刻，一个男人突然出现攻向朱莲，一护抓住空隙夺回了夏梨，而游子却被掳去了地狱。救了夏梨的人叫黑刀，他也是咎人，曾经为了心爱的妹妹犯下重罪，由此堕入地狱。护妹心切的一护十分理解黑刀，并不因他的身份而防范他。\r\n一护决定前往地狱营救游子。在充满瘴气的地狱，游子撑不了很久。一护、雨龙、恋次、露琪亚，以及咎人黑刀的地狱之行拉开了帷幕。","date":"2010-12-04","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d2/57/18480_vP5Gp.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d2/57/18480_vP5Gp.jpg","large":"https://lain.bgm.tv/pic/cover/l/d2/57/18480_vP5Gp.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d2/57/18480_vP5Gp.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d2/57/18480_vP5Gp.jpg"},"rating":{"rank":5680,"total":755,"score":6.4,"count":{"1":2,"2":3,"3":6,"4":16,"5":90,"6":316,"7":225,"8":69,"9":15,"10":13}},"tag