"large":"https://lain.bgm.tv/pic/cover/l/5d/47/104288_C2cEc.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/5d/47/104288_C2cEc.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/5d/47/104288_C2cEc.jpg"},"rating":{"rank":0,"total":26,"score":5.9,"count":{"1":0,"2":2,"3":2,"4":1,"5":1,"6":11,"7":4,"8":5,"9":0,"10":0}},"tags":[{"name":"国产","count":16},{"name":"短片","count":10},{"name":"2014","count":7},{"name":"DCZLD","count":5},{"name":"WEB","count":4},{"name":"中国","count":3},{"name":"动画","count":2},{"name":"国产动画","count":1},{"name":"ovaoad","count":1},{"name":"现实","count":1},{"name":"黑暗系","count":1}],"eps":1,"collection":{"wish":15,"collect":44,"doing":0,"on_hold":4,"dropped":7}},{"id":138600,"type":2,"name":"民间鬼术","name_cn":"民间鬼术","summary":"张新是一名籍籍无名的普通插画师，某日一个神秘的ID“民间鬼术”找到了他，开始给他提供大量精彩绝伦的志怪故事。张新以这些故事为蓝本开始创作漫画故事，并且渐渐成为了国内著名的漫画家。他却始终不知道这个神秘ID的背后到底是谁，又为什么会找上他。但这些神秘的故事却渐渐流传开来……","date":"2015-05-14","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/52/b4/138600_DlBNN.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/52/b4/138600_DlBNN.jpg","large":"https://lain.bgm.tv/pic/cover/l/52/b4/138600_DlBNN.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/52/b4/138600_DlBNN.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/52/b4/138600_DlBNN.jpg"},"rating":{"rank":0,"total":6,"score":5.3,"count":{"1":0,"2":1,"3":0,"4":0,"5":1,"6":3,"7":1,"8":0,"9":0,"10":0}},"tags":[{"name":"2015","count":4},{"name":"中国","count":3},{"name":"国产","count":1},{"name":"WEB","count":1}],"eps":20,"collection":{"wish":4,"collect":16,"doing":3,"on_hold":2,"dropped":9}},{"id":537687,"type":2,"name":"梦飞纸客国","name_cn":"梦飞纸客国","summary":"十二生肖在吉娃娃的带领下解决了气模城的危机后，来到了纸客国。这是一个全新的世界，这里的王子梦飞是一个梦想家，他希望帮助其他人梦想成真。但是，他只依靠睡眠术的办法并不能真正实现人们的梦想，梦飞遭遇了信任危机。这时，敌对势力趁势而起，欲取而代之，纸客国陷入危机。","date":"2015-05-14","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ef/89/537687_jixyY.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ef/89/537687_jixyY.jpg","large":"https://lain.bgm.tv/pic/cover/l/ef/89/537687