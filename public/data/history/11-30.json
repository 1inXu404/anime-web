/r/100/pic/cover/l/ed/9a/294820_Sssss.jpg","large":"https://lain.bgm.tv/pic/cover/l/ed/9a/294820_Sssss.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ed/9a/294820_Sssss.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ed/9a/294820_Sssss.jpg"},"rating":{"rank":0,"total":19,"score":5.8,"count":{"1":0,"2":0,"3":1,"4":1,"5":5,"6":7,"7":4,"8":1,"9":0,"10":0}},"tags":[{"name":"WEB","count":13},{"name":"泡面番","count":9},{"name":"2019","count":9},{"name":"3D","count":7},{"name":"怪物弹珠","count":6},{"name":"山口雄大","count":2},{"name":"游戏改","count":2},{"name":"日本动画","count":2},{"name":"手游改","count":1},{"name":"斉藤壮馬","count":1}],"eps":6,"collection":{"wish":21,"collect":34,"doing":0,"on_hold":2,"dropped":6}},{"id":298407,"type":2,"name":"砂ノ灯","name_cn":"砂之灯","summary":"「仄暗い砂漠で、少年は輝く“それ”を拾う。“それ”は、彼に光の力を与えた。光に導かれ、出会った美少女と、新たな世界との繋がりへと少年は引き込まれてゆく。」\r\n\r\n山賀博之監督による全く新しい世界観に、貞本義行氏の魅力的なキャラクターが登場する本作品は、「アニマトリックス」などで知られる竹内宏彰氏がプロデュース。\r\n手描きフル4K画像に、5.1chのサウンドで繰り広げるファンタジーショートアニメーション。","date":"2019-11-30","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/34/25/298407_zanrI.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/34/25/298407_zanrI.jpg","large":"https://lain.bgm.tv/pic/cover/l/34/25/298407_zanrI.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/34/25/298407_zanrI.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/34/25/298407_zanrI.jpg"},"rating":{"rank":0,"total":47,"score":5.5,"count":{"1":0,"2":0,"3":0,"4":2,"5":27,"6":12,"7":5,"8":0,"9":0,"10":1}},"tags":[{"name":"短片","count":27},{"name":"GAINAX","count":19},{"name":"山贺博之","count":13},{"name":"原创","count":11},{"name":"剧场版","count":8},{"name":"2019","count":7},{"name":"2020","count":6},{"name":"Take-Y","count":6},{"name":"貞本義行","count":4},{"name":"贞本义行","count":3},{"name":"山賀博之","count":3}],"eps":1,"collection":{"wish":36,"collect":68,"doing":1,"on_hold":1,"dropped":7}},{"id":345828,"type":2,"name":"神医九小姐","name_cn":"神医九小姐","summary":"改编自豆喵喵小说《邪帝缠宠:神医九小姐》，动画讲述了现代美艳神医圣手君九在一次丹药拍卖中意外坠亡，穿越到了一个古代废材九小姐的身上。这个九小姐本是皇城两大世家之一的君家嫡女，因为父母双亡而被本家下放到风罗城的君家分家，且生前在风罗君家受尽屈辱，被逼而亡。君九继承了九小姐全部的记忆，发誓要一血前耻。无奈这位九小姐是个无法灵气入体的废柴，在这个崇尚武力的修仙世界里，穿越后的她先是通过自己惊世骇俗的医术为自己洗筋伐髓、提升修炼天赋，后又广结善缘、小心铺路。且看君九如何手刃仇人、血洗风罗分家，开始她一代天之娇女的传奇故事。\r\n在复仇的过程中，君九阴差阳错认识了墨无越，而这个男人是君九心中独特的存在，他冷酷邪魅、强势霸道，天赋卓绝。君九的废柴身体世人皆知，只有墨无越慧眼识珠，在君九身后暗自保护，做她最强大的盾牌。并且君九还结识了云乔、谷松、君小蕾等好友，有了友情的加持，君九步步为营，渐渐掌管君家大权，斩乱臣贼子、奸佞小人。为了避免承受被太子退婚的奇耻大辱，她在皇城君家家主的寿宴上退婚太子，轰动一时。后来又去参加天纵国的最高修炼学院天纵院的弟子选拔，在选拔试炼中一战成名。\r\n本片属于玄幻冒险类的大女主戏，一个个充满激情和热血的冒险故事，使得本片独具魅力。女主角君九凭借自己精湛的医术救死扶伤，在若肉强食的世界中努力修炼。她勇敢、聪慧、坚毅、狡猾，无论面对多么凶残的敌人都不会皱一下眉头。正所谓“穷且益坚，不坠青云之志”，她用自己的勇敢和努力创造了一个又一个修炼道路上的奇迹。她待人宽厚却不圣母，对待恶人绝不心慈手软，对待朋友也能只身赴险、两肋插刀。这不仅仅是一个关于重生的冒险的故事，与其他混乱而又充满杀戮的奇幻故事不同的是，它完全为了我们展现了一个有血有肉、充满善意的奇幻世界。","date":"2021-11-30","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e2/72/345828_azCwu.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e2/72/345828_azCwu.jpg","large":"https://lain.bgm.tv/pic/cover/l/e2/72/345828_azCwu.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e2/72/345828_azCwu.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e2/72/345828_azCwu.jpg"},"rating":{"rank":0,"total":6,"score":3.8,"count":{"1":2,"2":1,"3":0,"4":0,"5":1,"6":1,"7":0,"8":1,"9":0,"10":0}},"tags":[{"name":"中国","count":7},{"name":"国产","count":5},{"name":"WEB","count":4},{"name":"2022年1月","count":3},{"name":"3D","count":3},{"name":"索以","count":2},{"name":"卖肉","count":2},{"name":"11","count":2},{"name":"后宫","count":2},{"name":"小说改","count":1},{"name":"2021","count":1}],"eps":80,"collection":{"wish":5,"collect":12,"doing":5,"on_hold":3,"dropped":9}},{"id":360398,"type":2,"name":"まっさら","name_cn":"纯","summary":"\"原创动画短片《纯》是以生物股长的歌唱家吉冈清惠的第一首原创歌曲《纯》启发制作的动画短片。\r\n启用通常的动画短片的风格为主，同时融合了音乐视频格式的混合电影形式。\"\r\n\r\n导演/故事板/导演：长原圭太\r\n角色设计/动画导演：中村真由美\r\n动画制作：ENISHIYA\r\n企划：FIREBUG / ENISHIYA\r\n制作：FIREBUG\r\n主题曲：吉冈聖惠“纯（まっさら）”（索尼唱片公司）\r\n声优：吉冈聖惠、花泽佳奈","date":"2021-11-30","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/3d/90/360398_Zs11C.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/3d/90/360398_Zs11C.jpg","large