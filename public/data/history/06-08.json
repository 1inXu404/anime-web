作。\r\n","date":"2013-06-08","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/59/eb/56849_SYlE2.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/59/eb/56849_SYlE2.jpg","large":"https://lain.bgm.tv/pic/cover/l/59/eb/56849_SYlE2.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/59/eb/56849_SYlE2.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/59/eb/56849_SYlE2.jpg"},"rating":{"rank":4054,"total":615,"score":6.7,"count":{"1":0,"2":2,"3":5,"4":8,"5":51,"6":185,"7":254,"8":86,"9":17,"10":7}},"tags":[{"name":"剧场版","count":298},{"name":"WITSTUDIO","count":146},{"name":"2013","count":139},{"name":"治愈","count":125},{"name":"科幻","count":118},{"name":"ProductionI.G","count":69},{"name":"細谷佳正","count":55},{"name":"日笠陽子","count":51},{"name":"原创","count":51},{"name":"机器人","count":46},{"name":"牧原亮太郎","count":34}],"eps":1,"collection":{"wish":340,"collect":892,"doing":27,"on_hold":25,"dropped":18}},{"id":62281,"type":2,"name":"キングダム 第2シリーズ","name_cn":"王者天下 第二季","summary":"","date":"2013-06-08","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/6d/ac/62281_timPZ.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/6d/ac/62281_timPZ.jpg","large":"https://lain.bgm.tv/pic/cover/l/6d/ac/62281_timPZ.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/6d/ac/62281_timPZ.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/6d/ac/62281_timPZ.jpg"},"rating":{"rank":1882,"total":495,"score":7.2,"count":{"1":2,"2":2,"3":1,"4":1,"5":22,"6":71,"7":207,"8":156,"9":19,"10":14}},"tags":[{"name":"热血","count":94},{"name":"漫画改","count":82},{"name":"战国","count":82},{"name":"TV","count":79},{"name":"2013","count":57},{"name":"2013年7月","count":48},{"name":"战争","count":37},{"name":"王者天下","count":37},{"name":"历史","count":33},{"name":"漫改","count":25},{"name":"福山潤","count":24}],"eps":39,"collection":{"wish":248,"collect":795,"doing":65,"on_hold":42,"dropped":37}},{"id":113486,"type":2,"name":"十九国","name_cn":"十九国","summary":"《十九国》是爱奇艺自制出品的一部网络动画。讲述的是世界将在100天内灭亡，螺旋大陆上的十九个国家在面临末日燃烧时展现出了不同的信