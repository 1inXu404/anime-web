[{"date":"1997-08-31","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/1a/55/59845_3z1Yb.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/1a/55/59845_3z1Yb.jpg","large":"https://lain.bgm.tv/pic/cover/l/1a/55/59845_3z1Yb.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/1a/55/59845_3z1Yb.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/1a/55/59845_3z1Yb.jpg"},"summary":"《下课后》以第三街小学一群普通的小学生为主角，通过这几个好朋友的视角，讲述了发生在教室、操场和家庭中的种种有趣的故事，巧妙地回答了成长过程中他们所面临的种种问题，并借此向电视机前的青少年朋友揭示成长的真谛与友情的可贵，并培养大家勤于思考、见义勇为和不畏挑战的优良品质。\r\n2000年，《下课后》获得了美国艾美奖最佳动画片，一年之后，迪斯尼又将它改编成一部动画电影《暑期历险》，集中讲述了第三街小学的几个小朋友在暑期生活中所遭遇的的诸多趣闻。","name":"Recess","name_cn":"下课后","tags":[{"name":"童年","count":25,"total_cont":0},{"name":"欧美","count":21,"total_cont":0},{"name":"小神龙俱乐部","count":13,"total_cont":0},{"name":"1997","count":11,"total_cont":0},{"name":"美漫","count":8,"total_cont":0},{"name":"校园","count":6,"total_cont":0},{"name":"美国","count":6,"total_cont":0},{"name":"经典","count":4,"total_cont":0},{"name":"在电视上断断续续看过","count":4,"total_cont":0},{"name":"动画","count":3,"total_cont":0},{"name":"TV","count":3,"total_cont":0},{"name":"Disney_Television_Animation","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"子供向","count":1,"total_cont":0},{"name":"剧集","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"下课后"},{"key":"话数","value":"65"},{"key":"放送开始","value":"1997年8月31日"},{"key":"IMDb","value":"tt0126170"}],"rating":{"rank":3433,"total":61,"count":{"1":0,"2":1,"3":1,"4":2,"5":9,"6":11,"7":22,"8":11,"9":3,"10":1},"score":6.6},"total_episodes":0,"collection":{"on_hold":5,"dropped":12,"wish":22,"collect":121,"doing":3},"id":59845,"eps":65,"meta_tags":["校园","TV","原创","子供向","欧美"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1997-08-25","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e9/3e/37467_4iZAj.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e9/3e/37467_4iZAj.jpg