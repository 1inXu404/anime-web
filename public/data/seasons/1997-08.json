重要意义和灾难中人性的光辉。","name":"地球が動いた日","name_cn":"地动之日","tags":[{"name":"剧场版","count":16,"total_cont":0},{"name":"1997","count":11,"total_cont":0},{"name":"原创","count":7,"total_cont":0},{"name":"治愈","count":4,"total_cont":0},{"name":"後藤俊夫","count":3,"total_cont":0},{"name":"岸川悦子","count":2,"total_cont":0},{"name":"独立剧场版","count":2,"total_cont":0},{"name":"西条隆詞","count":2,"total_cont":0},{"name":"1997年","count":1,"total_cont":0},{"name":"小六禮次郎","count":1,"total_cont":0},{"name":"动画电影","count":1,"total_cont":0},{"name":"映画","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"正太","count":1,"total_cont":0},{"name":"小说改","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"地动之日"},{"key":"别名","value":[{"v":"地球变动之日"},{"v":"The Day the Earth Moved"}]},{"key":"上映年度","value":"1997年8月10日"},{"key":"片长","value":"78min"},{"key":"原作","value":"岸川悦子(新日本出版社刊)"},{"key":"监督","value":"後藤俊夫"},{"key":"脚本","value":"翁妙子、後藤俊夫"},{"key":"作画监督&角色设定","value":"西条隆詞"},{"key":"音乐","value":"小六禮次郎"},{"key":"製作","value":"映画「地球が動いた日」製作委員会"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":28,"count":{"1":0,"2":0,"3":0,"4":1,"5":13,"6":7,"7":5,"8":2,"9":0,"10":0},"score":5.8},"total_episodes":0,"collection":{"on_hold":4,"dropped":8,"wish":26,"collect":38,"doing":2},"id":37527,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1997-08-06","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f5/1c/27207_F9NK7.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f5/1c/27207_F9NK7.jpg","large":"https://lain.bgm.tv/pic/cover/l/f5/1c/27207_F9NK7.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f5/1c/27207_F9NK7.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f5/1c/27207_F9NK7.jpg"},"summary":"","name":"それゆけ! 宇宙戦艦ヤマモト・ヨーコII","name_cn":"宇宙战舰山本洋子II","tags":[{"name":"OVA","count":52,"total_cont":0},{"name":"新房昭之","count":35,"total_cont":0},{"name":"J.C.STAFF","count":32,"total_cont":0},{"name":"1997","count":