[{"date":"1937-12-24","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0d/b7/241593_n72Nw.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0d/b7/241593_n72Nw.jpg","large":"https://lain.bgm.tv/pic/cover/l/0d/b7/241593_n72Nw.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0d/b7/241593_n72Nw.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0d/b7/241593_n72Nw.jpg"},"summary":"　　天寒地冻，暴雪纷飞。在偏远的荒郊野外，伫立着一幢历史悠久、破破烂烂的幽森古堡。这里空无一人，却住着4个倍感无聊的幽灵。在过去的日子里，他们已经把所有胆敢进入旧房子的人类都吓跑了。为了打发无聊的时间，幽灵们给报上登载广告的精灵终结公司打去电话。这间公司由米老鼠（沃特·迪斯尼 Walt Disney 配音）、唐老鸭（克拉伦斯·纳什 Clarence Nash 配音）和高飞狗共同经营，同样感到无聊的他们得到工作后欣喜过望，连忙收拾好工具启程前来抓鬼。","name":"Lonesome Ghosts","name_cn":"寂寞的精灵","tags":[{"name":"短片","count":5,"total_cont":0},{"name":"1937","count":4,"total_cont":0},{"name":"迪士尼","count":4,"total_cont":0},{"name":"Disney","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"1930-1939","count":1,"total_cont":0},{"name":"米老鼠","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"童年","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"寂寞的精灵"},{"key":"话数","value":"1"},{"key":"上映年度","value":"1937-12-24"},{"key":"片长","value":"9分钟"},{"key":"制片国家","value":"美国"},{"key":"语言","value":"英语"},{"key":"导演","value":"Burt Gillett"},{"key":"脚本","value":"Dick Friel"},{"key":"IMDb_id","value":"tt0029161"}],"rating":{"rank":0,"total":10,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":3,"8":4,"9":0,"10":0},"score":7},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":3,"collect":25,"doing":0},"id":241593,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1937-12-21","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e6/52/36226_25f5u.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e6/52/36226_25f5u.jpg","large":"https://lain.bgm.tv/pic/cover/l/e6/52/36226_25f5u.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e6/52/36226_25f5u.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e6/52/36226_25f5u.jpg"},"summary":"　　白雪公主原本是世界上最幸福的人，可惜当她母后逝去，父王娶了她继母后，这一切都改变了。恶毒的继母处处为难白雪公主，当她父王也死后，白雪公主过得更艰难了。这天，皇后从魔镜中得知世上最美的人不是自己而是白雪公主后，气急败坏的她下令武士将她带到森林处决了，好心的武士放走了白雪公主。夜晚，森林里的七个小矮人收留了无家可归的白雪公主。当皇后得知白雪公主还没死时，气急败坏的她决定亲自出马将白雪公主害死。第二天，她化妆成了一个老婆婆，带着毒苹果往森林深处走去。  ","name":"Snow White and the Seven Dwarfs","name_cn":"白雪公主和七个小矮人","tags":[{"name":"欧美","count":176,"total_cont":0},{"name":"迪士尼","count":137,"total_cont":0},{"name":"剧场版","count":137,"total_cont":0},{"name":"Disney","count":133,"total_cont":0},{"name":"童年","count":104,"total_cont":0},{"name":"1937","count":92,"total_cont":0},{"name":"动画电影","count":65,"total_cont":0},{"name":"美国","count":54,"total_cont":0},{"name":"小说改","count":37,"total_cont":0},{"name":"电影","count":31,"total_cont":0},{"name":"奇幻","count":25,"total_cont":0},{"name":"童年回忆","count":12,"total_cont":0},{"name":"童话","count":11,"total_cont":0},{"name":"美国动画","count":9,"total_cont":0},{"name":"动画","count":8,"total_cont":0},{"name":"Film","count":5,"total_cont":0},{"name":"30年代","count":5,"total_cont":0},{"name":"1930s","count":4,"total_cont":0},{"name":"60年代前","count":3,"total_cont":0},{"name":"公主系列","count":3,"total_cont":0},{"name":"原创","count":2,"total_cont":0},{"name":"欧美动画","count":2,"total_cont":0},{"name":"00前","count":2,"total_cont":0},{"name":"1937年","count":2,"total_cont":0},{"name":"WilliamCottrell","count":2,"total_cont":0},{"name":"WilfredJackson","count":2,"total_cont":0},{"name":"奥斯卡","count":2,"total_cont":0},{"name":"童话改","count":2,"total_cont":0},{"name":"DavidHand","count":2,"total_cont":0},{"name":"1930-1939","count":2,"total_cont":0}],"infobox":[{"key":"中文名","value":"白雪公主和七个小矮人"},{"key":"别名","value":[{"v":"白雪公主"},{"v":"雪姑七友"}]},{"key":"上映年度","value":"1937-12-21"},{"key":"片长","value":"83分钟"},{"key":"官方网站","value":"https://www.disneyanimation.com/films/snow-white-and-the-seven-dwarfs/"},{"key":"Copyright","value":"Walt Disney Productions"},{"key":"话数","value":"1"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","va