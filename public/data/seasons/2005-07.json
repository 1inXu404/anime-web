ps://lain.bgm.tv/pic/cover/l/da/42/10508_64I4T.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/da/42/10508_64I4T.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/da/42/10508_64I4T.jpg"},"rating":{"rank":4771,"total":513,"score":6.6,"count":{"1":2,"2":1,"3":4,"4":15,"5":43,"6":169,"7":199,"8":64,"9":9,"10":7}},"tags":[{"name":"青春","count":116},{"name":"校园","count":103},{"name":"凉风","count":96},{"name":"TV","count":92},{"name":"恋爱","count":83},{"name":"2005","count":60},{"name":"体育","count":47},{"name":"2005年7月","count":44},{"name":"漫画改","count":43},{"name":"StudioComet","count":33},{"name":"漫改","count":15}],"eps":26,"collection":{"wish":530,"collect":812,"doing":65,"on_hold":105,"dropped":62}},{"id":16215,"type":2,"name":"破滅のマルス","name_cn":"破灭的Mars","summary":"这是同名的PlayStation2游戏的OVA作品。\r\n故事讲述了2016年，美国火星探测计划实现，载人探测机在火星表面发现了火星人的痕迹。但是在收集信息之后返回地球途中由于故障在经过日本上空时爆炸。向日本落下的碎片所携带的神秘病毒使人类突然变异，这些变异的人被称为“遗迹人”，而与之对抗的秘密机关AAST则开发了对遗迹人的特殊防护服。 \r\n\r\n破滅のマルス　アニメーション\r\n『破滅のマルス』は同名のプレイステーション２ゲームソフトの発売後にリリースされるオリジナル作品です。\r\nＡＡＳＴ（アースト）と呼ばれる特殊部隊の隊員は若き女性たち。特殊防護服「マルス」を着る能力を持つ為に戦うことになる主人公・日向タケル。\r\n傷つきながら戦う少年少女たちに待ちうける命は『破滅』だけなのか…？\r\n\r\n2016年、アメリカが行ってきた火星探査計画により火星の表面を調査していた有人探査機は、「火星人の痕跡」を回収することに成功し地球への帰路についていた。ところが、トラブルにより日本上空で爆発。その破片は日本に落下した。\r\nその日から、突然変異により人間が化け物となって、人を襲う事件が起こる。火星からの謎のウイルスに侵された事が原因とされ、治療の方法はない。人々は化け物を「遺跡人」（太古の遺跡に出てくる化け物に似ているから）と呼び、ＡＡＳＴと呼ばれる秘密機関が退治の為に組織される。ＡＡＳＴは、日向浩造博士の協力を得て、対遺跡人兵器の切り札として特殊防護服「マルス」を作る。超能力を得る「マルス」だが、それを着るにはＤＮＡレベルでの「適合者」が必要であり、博士の息子のタケルがその最初の適合者であった。タケルは望まなくとも「マルス」を着て戦わねばならない。事件解決の糸口となる「火星人の痕跡」がある破片は、分析のためアメリカにばれる。だが、輸送する車を「遺跡人」達が襲ってきた…！ ","date":"2005-07-06","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/03/08/16215_ug2yZ.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/03/08/16215_ug2yZ.jpg","large":"https://lain.bgm.tv/pic/cover/l/03/08/16215_ug2yZ.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/03/08/16215_ug2yZ.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/03/08/16215_ug2yZ.jpg"},"rating":{"rank":9974,"total":84,"score":2.2,"count":{"1":34,"2":27,"3":9,"4":9,"5":2,"6":1,"7":1,"8":1,"9":0,"10":0}},"tags":[{"name":"OVA","count":50},{"name":"2005","count":34},{"name":"游戏改","count":25},{"name":"独立ova","count":13},{"name":"补番","count":5},{"name":"茅原实里","count":3},{"name":"WAOWorld","count":3},{"name":"ワオワールド","count":3},{"name":"藤澤経清","count":2},{"name":"毒","count":2}],"eps":1,"collection":{"wish":46,"collect":104,"doing":6,"on_hold":6,"dropped":22}},{"id":2937,"type":2,"name":"SHUFFLE!","name_cn":"","summary":"　　神族、魔族、人类，三个不同的种族和世界，有一天通过一扇“门”联结了起来，从此三个种族生活在了一起，当然，在学校也不例外。\r\n　　土见凛，一个普通的男生，自幼双亲在一场事故中丧生，于是只能寄住在青梅竹马的芙蓉枫的家中。枫对凛一直有很深的感情，两人保持着平常的生活，直到有一天，神族的神王和魔族的魔王双双来到人间，并带来了他们两个可爱的女儿——西亚和奈莉奈。而凛居然要从她们两个中选择一个作为未婚妻！\r\n　　于是，一段复杂的恋爱故事就此开始……\r\n　　（二）故事发生在一所名为国立巴贝那学园的高校，普通高中生土见禀与自幼青梅竹马的女孩枫一起过着快乐安详的生活。因为10年前的一场巨变，神·人·魔三界的通道被打开，神界和魔界的居民开始在人界自由同行，三界的种族开始共同生活在一个社会里，随着时间的推移，人们也慢慢习以为常了。 \r\n　　某日，来自神界和魔界的两位美少女转校到巴贝那学园，她们为了寻找儿时的邂逅决定留在人界。从此禀的生活开始发生某种仿佛注定了的变化……\r\n","date":"2005-07-07","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/8f/c6/2937_R1a3g.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/8f/c6/2937_R1a3g.jpg","large":"https://lain.bgm.tv/pic/cover/l/8f/c6/2937_R1a3g.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/8f/c6/2937_R1a3g.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/8f/c6/2937_R1a3g.jpg"},"rating":{"rank":6223,"total":1244,"score":6.3,"count":{"1":9,"2":7,"3":14,"4":45,"5":177,"6":440,"7":379,"8":133,"9":23,"10":17}},"tags":[{"name":"后宫","count":326},{"name":"SHUFFLE","count":259},{"name":"GAL改","count":231},{"name":"TV","count":161},{"name":"校园","count":126},{"name":"四大渣","count":114},{"name":"2005","count":104},{"name":"杉田智和","count":88},{"name":"四大人渣","count":74},{"name":"2005年7月","count":70},{"name":"galgame","count":69}],"eps":24,"collection":{"wish":929,"collect":1990,"doing":171,"on_hold":221,"dropped":101}},{"id":14086,"type":2,"name":"ぺとぺとさん","name_cn":"我是小粘粘","summary":"作品は人間と妖怪が共存する田舎町を舞台に、この住民の日常生活を描く。妹が多いとされ、「女未（にょみ）の里」と呼ばれる鮎川町（あゆかわまち）の中学校「大曲垣峠（お