仙人はメコイスの壷さえあれば、世界一の大魔王になれるというのだった。その頃、ばいきんまんが向かったピラミッドには、昔滅んだヤーダ国を復活させようと、ヤーダ姫がメコイスの壷を求めて探索していた。だが、壷はばいきんまんの手に渡ってしまうのだった。アンパンマンは壷を取り返そうとするが、バイキン仙人からもらった変身玉を使って巨大グモに変身したばいきんまんによって苦戦するのだった。さらにばいきんまんは壷を使って、巨大なばいきん大魔王に変身し、暴れまわるが、ヤーダ姫がペンダントから魔王を封じ込めるヒントをつかみ、ばいきんまんは壷の中に吸い込まれていくのだった。そして、ヤーダ姫はメコイスの壷の力によって、ヤーダ国を復活させるのだった。","name":"それいけ!アンパンマン ばいきんまんの逆襲","name_cn":"面包超人：细菌人大反攻","tags":[{"name":"剧场版","count":3,"total_cont":0},{"name":"TMSEntertainment","count":2,"total_cont":0},{"name":"1990","count":2,"total_cont":0},{"name":"子供向","count":2,"total_cont":0},{"name":"东京电影新社","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"面包超人：细菌人大反攻"},{"key":"别名","value":[{"v":"面包超人：细菌人反击战"},{"v":"Sore Ike! Anpanman: Baikinman no Gyakushuu"}]},{"key":"上映年度","value":"1990年7月14日"},{"key":"片长","value":"70分"},{"key":"官方网站","value":[{"v":"https://www.anpanman.jp/anime/movie.html"},{"v":"https://www.tms-e.co.jp/alltitles/anpanman/060302.html"},{"v":"https://www.shochiku.co.jp/cinema/database/04304/"}]},{"key":"Copyright","value":"©やなせたかし/フレーベル館・TMS・NTV©やなせたかし/アンパンマン製作委員会1990"},{"key":"话数","value":"1"},{"key":"发行","value":"松竹富士"},{"key":"原作","value":"やなせたかし"},{"key":"导演","value":"永丘昭典"},{"key":"副导演","value":"矢野博之"},{"key":"人物设定","value":"山田みちしろ"},{"key":"脚本","value":"武上純希"},{"key":"音乐","value":"いずみたく"},{"key":"执行制片人","value":"藤岡豊"},{"key":"企画","value":"武井英彦"},{"key":"制片人","value":"柳内一彦"},{"key":"製作","value":"日本テレビ、松竹富士、東京ムービー新社、フレーベル館、バップ"}],"rating":{"rank":0,"total":2,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":3,"collect":4,"doing":0},"id":418854,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1990-07-07","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d5/25/44941_wXGL4.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d5/25/44941_wXGL4.jpg","large":"https://lain.bgm.tv/pic/cover/l/d5/25/44941_wXGL4.jpg","