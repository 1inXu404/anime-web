[{"date":"1942-05-30","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0e/16/262576_qU7WN.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0e/16/262576_qU7WN.jpg","large":"https://lain.bgm.tv/pic/cover/l/0e/16/262576_qU7WN.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0e/16/262576_qU7WN.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0e/16/262576_qU7WN.jpg"},"summary":"　　平静的一天，调皮顽劣的汤姆将可怜的小老鼠杰瑞困在鱼缸内，看这个小家伙拼尽全力向外跑，时不时推对方一把，从中取乐。就在此时，门铃声响起，女主人应声准备开门。汤姆连忙将杰瑞拿出来，塞进抽屉里的档案夹中，随后躲在房间角落里。这时女主人开门，她似乎接受了什么人的嘱托，帮助照顾一只小动物。汤姆从远处头头望去，竟发现那是一只干净优雅的小母猫。这可美坏了汤姆，他迅速跑到梳妆台打扮起来，而后故作优雅踱到小母猫的面前大献殷勤，他拿来金鱼和金丝雀讨好对方，可是对方似乎并不喜欢。于是乎，汤姆将小杰瑞作为礼物送给眼前的美女……","name":"Puss n' Toots","name_cn":"猫儿心上人","tags":[{"name":"短片","count":19,"total_cont":0},{"name":"猫和老鼠","count":9,"total_cont":0},{"name":"欧美","count":8,"total_cont":0},{"name":"1942","count":5,"total_cont":0},{"name":"美国","count":5,"total_cont":0},{"name":"60年代前","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"米高梅","count":2,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"电影","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"先驱","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"猫儿心上人"},{"key":"上映年度","value":"1942年5月30日"},{"key":"片长","value":"7分29秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":38,"count":{"1":1,"2":0,"3":0,"4":0,"5":5,"6":14,"7":12,"8":5,"9":1,"10":0},"score":6.4},"total_episodes":0,"collection":{"on_hold":0,"dropped":6,"wish":2,"collect":82,"doing":1},"id":262576,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1942-05-01","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/00/45/262367_LKTLB.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/00/45/262367_LK