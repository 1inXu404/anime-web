n　本作の実制作は東京ムービー新社などの作品でも協力しているスタジオジュニオが担当。校長と教頭の役で音楽芸人のバブルガム・ブラザーズ（ブラザー・トムとブラザー・コーン）が出演している。","name":"マドンナ","name_cn":"我们的麦当娜","tags":[{"name":"OVA","count":11,"total_cont":0},{"name":"草尾毅","count":5,"total_cont":0},{"name":"独立ova","count":4,"total_cont":0},{"name":"补旧番","count":2,"total_cont":0},{"name":"85~89年","count":2,"total_cont":0},{"name":"运动","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"漫画改","count":1,"total_cont":0},{"name":"1988","count":1,"total_cont":0},{"name":"岡村香織","count":1,"total_cont":0},{"name":"其他","count":1,"total_cont":0},{"name":"1988年","count":1,"total_cont":0},{"name":"永丘昭典","count":1,"total_cont":0},{"name":"1980s","count":1,"total_cont":0},{"name":"富永美伊奈","count":1,"total_cont":0},{"name":"東映ビデオ","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"我们的麦当娜"},{"key":"别名","value":"Madonna"},{"key":"话数","value":"2"},{"key":"发售日","value":"1988年3月25日"},{"key":"开始","value":"1988年3月25日"},{"key":"结束","value":"1989年6月23日"},{"key":"製作","value":"東映ビデオ、青二企画、スタジオジュニオ(1)"},{"key":"原作","value":"くじらいいく子（小学館「週刊ビッグコミックスピリッツ」連載）"},{"key":"企画","value":"吉田達(1)、高橋尚子(2)"},{"key":"企画协力","value":"「週刊ビッグコミックスピリッツ」編集部"},{"key":"制片人","value":"高橋尚子(1)、佐々木章(2)、栗山富郎"},{"key":"脚本","value":"岡村香織"},{"key":"人物设定","value":"前田実"},{"key":"作画监督","value":"前田実"},{"key":"美术监督","value":"河野次郎"},{"key":"摄影监督","value":"石川欣一"},{"key":"导演","value":"永丘昭典"},{"key":"制作管理","value":"製作担当：岩崎哲也"},{"key":"主题歌作词","value":"小林和子、松本一起、石川あゆ子"},{"key":"主题歌作曲","value":"西木栄二、後藤次利、JOHNNY GOODSON、JUDI GOODSON"},{"key":"主题歌编曲","value":"大村憲司、伊藤銀次、奈良部匠平"},{"key":"主题歌演出","value":"本田美奈子、バブルガム・ブラザーズ、早見優"},{"key":"插入歌作词","value":"吉元由美"},{"key":"插入歌作曲","value":"羽田一郎"},{"key":"插入歌编曲","value":"和泉一弥"},{"key":"插入歌演出","value":"早見優"},{"key":"音乐","value":"篠田元一(1)、山崎稔[山崎一稔](2)"},{"key":"音乐制作人","value":"矢作樹久麿(1)、細井虎雄(2)"},{"key":"主动画师","value":"江口摩吏介(1)"},{"key":"特效","value":"橋爪朋二(1)、中島正之(2)"},{"key":"剪辑","value":"花井正明(1)、鶴渕和子(2)"},{"key":"音响监督","value":"三間雅文"},{"key":"录音","value":"市川修