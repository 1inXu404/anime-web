oing":13},"id":16557,"eps":1,"meta_tags":["科幻","日本","OVA","原创","冒险"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1988-03-14","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c8/af/5927_Lj7u9.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c8/af/5927_Lj7u9.jpg","large":"https://lain.bgm.tv/pic/cover/l/c8/af/5927_Lj7u9.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c8/af/5927_Lj7u9.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c8/af/5927_Lj7u9.jpg"},"summary":"国宝 憲一（ケンイチ）は幼い頃、父の不注意から川に流され、山で行方不明になってしまう。しかし、山に住む空手家に拾われたケンイチは野生児としてたくましく（?）成長する。そして本当の家族と街への憧れからケンイチは下山し、程なく本当の家族と再会する。だがしかしケンイチには都会の知識や常識がまるで無く、本人の人間離れした身体能力もあいまって、普通ではないトラブルに満ちた日常が繰り広げられるのであった。","name":"燃える! お兄さん","name_cn":"森林好小子","tags":[{"name":"童年","count":45,"total_cont":0},{"name":"爆笑","count":33,"total_cont":0},{"name":"TV","count":33,"total_cont":0},{"name":"森林好小子","count":32,"total_cont":0},{"name":"搞笑","count":29,"total_cont":0},{"name":"1988","count":17,"total_cont":0},{"name":"卡内奇","count":17,"total_cont":0},{"name":"牛肉火锅","count":16,"total_cont":0},{"name":"恶搞","count":13,"total_cont":0},{"name":"欢乐","count":11,"total_cont":0},{"name":"StudioPierrot","count":9,"total_cont":0},{"name":"日本","count":8,"total_cont":0},{"name":"漫画改","count":7,"total_cont":0},{"name":"1988年","count":6,"total_cont":0},{"name":"儿时回忆","count":4,"total_cont":0},{"name":"尼桑好燃","count":4,"total_cont":0},{"name":"崩坏","count":3,"total_cont":0},{"name":"80年代","count":3,"total_cont":0},{"name":"ぴえろ","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"漫改","count":2,"total_cont":0},{"name":"童年系","count":2,"total_cont":0},{"name":"池田秀一","count":2,"total_cont":0},{"name":"小林治","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"补旧番","count":2,"total_cont":0},{"name":"本多知恵子","count":1,"total_cont":0},{"name":"会川升","count":1,"total_cont":0},{"name":"秃头","count":1,"total_cont":0},{"name":"矢尾一樹","count":1,"total_cont":0}