[{"date":"1964-12-18","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/07/14/132399_dLZ7N.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/07/14/132399_dLZ7N.jpg","large":"https://lain.bgm.tv/pic/cover/l/07/14/132399_dLZ7N.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/07/14/132399_dLZ7N.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/07/14/132399_dLZ7N.jpg"},"summary":"　　这一天，粉红豹迈着优雅的步伐从走廊经过，这时他看到一个油漆工正往墙上刷着蓝漆。它偷偷尝了一口蓝油漆，发现味道相当糟糕，于是轻轻换了一桶粉油漆放在旁边。蒙在鼓里的油漆工闷头工作，突然发现墙上的颜色变成了粉红色。他十分生气，端着桶准备换一下，结果粉红豹开门却将他拍在了墙上。在此之后，油漆工和粉红豹各自执拗地要将他们眼前的门、墙、楼梯刷成喜欢的颜色。忽蓝忽粉、忽粉忽蓝，一连串有趣的颜色攻防战就这样开始了…… \r\n　　本片荣获第37届奥斯卡金像奖最佳动画短片奖。","name":"The Pink Phink","name_cn":"粉红豹","tags":[{"name":"短片","count":29,"total_cont":0},{"name":"奥斯卡","count":15,"total_cont":0},{"name":"1964","count":11,"total_cont":0},{"name":"欧美","count":9,"total_cont":0},{"name":"粉豹","count":5,"total_cont":0},{"name":"美国","count":4,"total_cont":0},{"name":"自带BGM","count":4,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"哥仑比亚影视","count":3,"total_cont":0},{"name":"搞笑","count":3,"total_cont":0},{"name":"和清洁工有仇","count":2,"total_cont":0},{"name":"1960s","count":2,"total_cont":0},{"name":"Freleng","count":1,"total_cont":0},{"name":"无排名","count":1,"total_cont":0},{"name":"60s","count":1,"total_cont":0},{"name":"PP","count":1,"total_cont":0},{"name":"动画短片","count":1,"total_cont":0},{"name":"Friz.Freleng","count":1,"total_cont":0},{"name":"Tag","count":1,"total_cont":0},{"name":"Phink","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"Hawley.Pratt","count":1,"total_cont":0},{"name":"米高梅","count":1,"total_cont":0},{"name":"MGM","count":1,"total_cont":0},{"name":"人·兽·鬼","count":1,"total_cont":0},{"name":"欢乐","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"神奇的椅子","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"粉红豹"},{"key":"别名","value":[{"v":"粉红色的芬克"}]},{"key":"上映年度","value":"1964年12