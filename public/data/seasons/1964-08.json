[{"id":53748,"type":2,"name":"ビッグX","name_cn":"大X超人","summary":"这部作品是东京MOVIE创立后的第一部动画，也是首部原作为手塚治虫，而制作非虫制作公司担当的动画。原作漫画中以与纳粹分子的斗争，严厉控诉了法西斯主义的恐怖，而动画版中则将故事情节简化为了正义的伙伴打倒坏人。另外原作漫画中的通过注射药物使力气变大，身体变大等设定，因担心牵扯到兴奋剂注射问题，在动画版中改为了使用电磁项链吊坠。","date":"1964-08-03","images":null,"rating":{"rank":0,"total":5,"score":6.4,"count":{"1":0,"2":0,"3":1,"4":0,"5":1,"6":1,"7":0,"8":0,"9":2,"10":0}},"tags":[{"name":"1964","count":4},{"name":"日本动画","count":2},{"name":"TV","count":2},{"name":"大X巨人","count":2},{"name":"永井一郎","count":1},{"name":"TVA","count":1},{"name":"补","count":1},{"name":"东京movie","count":1},{"name":"SF","count":1},{"name":"東京ムービー","count":1},{"name":"旧物","count":1}],"eps":59,"collection":{"wish":9,"collect":11,"doing":4,"on_hold":4,"dropped":8}}]