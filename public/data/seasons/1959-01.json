[{"date":"1959-01-29","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ac/47/60392_UYGGQ.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ac/47/60392_UYGGQ.jpg","large":"https://lain.bgm.tv/pic/cover/l/ac/47/60392_UYGGQ.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ac/47/60392_UYGGQ.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ac/47/60392_UYGGQ.jpg"},"summary":"奥罗拉公主的出生让国王和皇后乐坏了。宴会上他们邀请来十二位仙女，为公主献上祝词。一个没有机会前来宴会的坏心肠仙女，一气之下落下诅咒：她今天受的屈辱都会报应在公主身上，公主会在18岁那年死于纺锤之下。\r\n　　在这个魔咒的笼罩下，国王和仙女都小心翼翼的保护着奥罗拉公主。国王甚至把全国的纺织器具统统没收，以防止公主遇上不测。然而，悲剧还是发生了。奥罗拉在一个古堡里看到了正在纺布的老奶奶，一伸手就被纺锤的魔法击中，美丽的公主顿时沉睡，整个王国都随之陷入沉睡，国王，侍从，甚至猫狗，都落入了巫婆的咀咒。\r\n　　邻国的王子闻说睡美人的故事，决定披荆斩棘前来古堡搭救公主，他的武器除了勇气和毅力之外，还有对奥罗拉公主的真爱。 ","name":"Sleeping Beauty","name_cn":"睡美人","tags":[{"name":"迪士尼","count":57,"total_cont":0},{"name":"欧美","count":57,"total_cont":0},{"name":"1959","count":41,"total_cont":0},{"name":"剧场版","count":39,"total_cont":0},{"name":"Disney","count":37,"total_cont":0},{"name":"童年","count":22,"total_cont":0},{"name":"动画电影","count":21,"total_cont":0},{"name":"公主系列","count":15,"total_cont":0},{"name":"美国","count":11,"total_cont":0},{"name":"电影","count":10,"total_cont":0},{"name":"音乐剧","count":6,"total_cont":0},{"name":"童话改","count":4,"total_cont":0},{"name":"Film","count":4,"total_cont":0},{"name":"Musical","count":3,"total_cont":0},{"name":"1950-1959","count":2,"total_cont":0},{"name":"童话","count":2,"total_cont":0},{"name":"50年代","count":2,"total_cont":0},{"name":"Romance","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"系列","count":1,"total_cont":0},{"name":"幻想","count":1,"total_cont":0},{"name":"ClydeGeronimi","count":1,"total_cont":0},{"name":"奇幻","count":1,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"表番","count":1,"total_cont":0},{"name":"同人","count":1,"total_cont":0},{"name":"恋爱","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":