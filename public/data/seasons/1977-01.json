[{"date":"1977-01-02","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/08/7b/23609_071Ld.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/08/7b/23609_071Ld.jpg","large":"https://lain.bgm.tv/pic/cover/l/08/7b/23609_071Ld.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/08/7b/23609_071Ld.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/08/7b/23609_071Ld.jpg"},"summary":"　　日本卡通「小浣熊」原名「あらいぐまラスカル」，是富士電視台製作的「世界名作劇場」系列動畫之一，1977年1月2日至12月25日在日本富士電視台首播，共52集。台灣於1978年1月11日至3月28日在華視首次播映，之後於1991年1月10日至6月27日的每週四下午四點卅分～五點在中視頻道重播；兩次播出的主題曲並不同，華視版本的主題曲為汪石泉老師所創作，而中視的版本則是依照其日本原曲重新填上中文詞。\r\n　　「小浣熊」卡通影集改編自美國知名作家史特靈諾斯（Sterling North）在1963年發表的童年自傳《Rascal: A Memoir of a Better Era》，曾獲得昭和52年度（1977年）的「文化廳兒童電視優秀映畫賞」與「厚生省兒童福祉文化獎勵賞」。\r\n　　「小浣熊」敘述11歲的少年史特靈諾斯（華視版本的名字為南南）收養了在森林裡發現的小浣熊洛斯可（Rascal），自此展開了少年與動物間的親密成長旅程，也發生了許許多多逗趣天真的冒險故事。\r\n","name":"あらいぐまラスカル","name_cn":"小浣熊","tags":[{"name":"TV","count":11,"total_cont":0},{"name":"1977","count":9,"total_cont":0},{"name":"世界名作剧场","count":8,"total_cont":0},{"name":"小说改","count":5,"total_cont":0},{"name":"补旧番","count":3,"total_cont":0},{"name":"宫崎骏","count":3,"total_cont":0},{"name":"日本动画公司","count":2,"total_cont":0},{"name":"童年系","count":2,"total_cont":0},{"name":"童年","count":1,"total_cont":0},{"name":"加藤盟","count":1,"total_cont":0},{"name":"斋藤博","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"日常","count":1,"total_cont":0},{"name":"1970s","count":1,"total_cont":0},{"name":"1978","count":1,"total_cont":0},{"name":"剧情","count":1,"total_cont":0},{"name":"4クール","count":1,"total_cont":0},{"name":"小田部羊一","count":1,"total_cont":0},{"name":"世界名作劇場","count":1,"total_cont":0},{"name":"1970.80","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"小浣熊"},{"key":"别名","value":[{"v":"可爱的浣熊"},{"v":"浣熊拉斯卡爾"}]},{"key":"话数","value":"52"},{"key":"放送开始","value":"1977年1月2日"},{"key":"放送星期","value":"星期日"},{"key":"官方网站","value":[{"v":"https://www.nippon-animation.co.jp/work/1