in.bgm.tv/r/800/pic/cover/l/88/54/132382_jVLQJ.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/88/54/132382_jVLQJ.jpg"},"summary":"　　维也纳著名音乐家约翰•施特劳斯的家中住着一只名为约翰的小老鼠，每当音乐家弹奏美妙的华尔兹时，小约翰就情不自禁走出洞口，随着音乐翩翩起舞。而家中的老猫汤姆却无心欣赏音乐，它把心思全放在捕捉约翰这件事上，然而每次出击都功败垂成。 \r\n　　一天施特劳斯外出演出，小约翰始终躲在洞里。汤姆为了捉住它也弹起华尔兹，引出了完全被音乐迷住的小约翰。它们之间的追逐再次展开，不过最终两个小家伙握手言欢，甚至走进皇宫为皇帝倾情演出…… \r\n　　本片荣获1953年奥斯卡最佳动画短片奖。","name":"Johann Mouse","name_cn":"老鼠约翰","tags":[{"name":"短片","count":41,"total_cont":0},{"name":"欧美","count":27,"total_cont":0},{"name":"猫和老鼠","count":22,"total_cont":0},{"name":"奥斯卡","count":11,"total_cont":0},{"name":"米高梅","count":10,"total_cont":0},{"name":"1950s","count":9,"total_cont":0},{"name":"1953","count":9,"total_cont":0},{"name":"钢琴天赋爆表的汤姆猫","count":7,"total_cont":0},{"name":"美国","count":6,"total_cont":0},{"name":"搞笑","count":4,"total_cont":0},{"name":"MGM","count":3,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"喜爱音乐的约翰鼠","count":2,"total_cont":0},{"name":"1950-1959","count":2,"total_cont":0},{"name":"奥斯卡获奖动画短片","count":1,"total_cont":0},{"name":"Barbera","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"OVA","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"Joseph.Barbera","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"猫","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"作曲","count":1,"total_cont":0},{"name":"短片&OVA","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"Hanna","count":1,"total_cont":0},{"name":"50s","count":1,"total_cont":0},{"name":"Tom&Jerry","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"老鼠约翰"},{"key":"上映年度","value":"1953年2月17日"},{"key":"片长","value":"8分钟"},{"key":"IMDb链接","value":"tt0045937"},{"key":"语言","value":"英语"},{"key":"制片国家/地区","value":"美国"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 家庭"},{"key":"导演","value":"约瑟夫·巴伯拉 / 威廉·汉纳"},{"key":"话数","value":"1"}],"rating