[{"date":"1958-05-02","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d5/47/634845_6y8ey.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d5/47/634845_6y8ey.jpg","large":"https://lain.bgm.tv/pic/cover/l/d5/47/634845_6y8ey.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d5/47/634845_6y8ey.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d5/47/634845_6y8ey.jpg"},"summary":"　　夜幕降临，戴着眼镜的乔治登门拜访，为她美丽可爱的女友琼带来一只会唱生日歌的小黄鸭作为礼物。一曲结束后，乔治约请女友外出看电影，共度美好夜晚。琼欣喜非常，唯一担心的是将鸭子留在家里，会不会被贪嘴的汤姆残害。她的顾虑不是没有道理，乔治和琼前脚刚刚离开，躲在垃圾桶内的汤姆便悄悄溜进房内。他打开盒子，将全然没有任何防备、开心唱歌的鸭子一口吞进肚子里。小黄鸭夺路狂逃，藏进杰瑞的窝中。汤姆绝不会善罢甘休，他对两个小家伙展开无情追杀。\r\n　　在此期间，小黄鸭无意中利用雪花膏（Vanishing Cream）变成了透明的。他计上心头，决定和杰瑞利用雪花膏好好戏耍汤姆……","name":"The Vanishing Duck","name_cn":"消失的鸭子","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"消失的鸭子"},{"key":"上映年度","value":"1958年5月2日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0052347"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":0,"8":0,"9":0,"10":1},"score":7},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":5,"doing":0},"id":634845,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]