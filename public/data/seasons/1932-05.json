[{"id":133760,"type":2,"name":"Mickey's Revue","name_cn":"米奇的歌剧团","summary":"　　在一个简陋破败的乡下剧院，米奇（沃尔特·迪斯尼 Walt Disney 配音）正率领他的乐队进行庄严的交响乐演出。伴随着美妙的音乐，乐队身后的大幕缓缓拉开，牛小姐扮成的花朵伴随美妙的音乐扭动曼妙的身姿，米妮（玛西丽特·加纳 Marcellite Garner 配音）则扮作仙女，在空中自由飞翔。台下的观众认真观看演出，分外投入，在高潮部分还伴随着热烈的掌声。观众席中还坐着一个颇为讨厌的老头Dippy Dawg（品托·考维格 Pinto Colvig 配音），他时而旁若无人大嚼花生米，时而放肆地朗声大笑，引起周围观众的不满。演出继续进行，一幕幕精彩的表演让观众们乐而忘返…… \r\n　　本片新引入了一个角色Dippy Dawg，他就是后来的古菲（Goofy）。","date":"1932-05-02","images":null,"rating":{"rank":0,"total":7,"score":6.9,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":1,"8":3,"9":0,"10":0}},"tags":[{"name":"迪士尼","count":4},{"name":"1932","count":3},{"name":"美国","count":2},{"name":"剧场版","count":2},{"name":"短片","count":2},{"name":"剧团","count":1},{"name":"欧美","count":1},{"name":"1930s","count":1},{"name":"经典","count":1},{"name":"搞笑","count":1},{"name":"动画","count":1}],"eps":1,"collection":{"wish":3,"collect":19,"doing":0,"on_hold":0,"dropped":3}},{"id":241666,"type":2,"name":"It's Got Me Again","name_cn":"又捉到了我","summary":"","date":"1932-05-14","images":null,"rating":{"rank":0,"total":1,"score":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0}},"tags":[{"name":"短片","count":2},{"name":"美国","count":1},{"name":"欧美","count":1},{"name":"华纳","count":1},{"name":"1932","count":1}],"eps":1,"collection":{"wish":2,"collect":7,"doing":1,"on_hold":0,"dropped":3}}]