olumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1998-05-16","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/2f/41/98869_y6dAc.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/2f/41/98869_y6dAc.jpg","large":"https://lain.bgm.tv/pic/cover/l/2f/41/98869_y6dAc.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/2f/41/98869_y6dAc.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/2f/41/98869_y6dAc.jpg"},"summary":"日本最大の暴力団組織・崇和会連合。この組織の総裁・村田京介の息子である京太郎はヤクザのいる環境から遠ざけたいという母の願いから田舎暮らしをさせられていた。そんなことも知らず多くの舎弟を引きつれ密漁や売春の斡旋などを行う京太郎も将来は漁師になろうとしていた。だが、房州を取り仕切る力団・鬼竜会に舎弟を殺されたことをきっかけに一念発起。舎弟と銃器を集めて鬼竜会を襲撃し壊滅させる。そのことがきっかけで刑務所に入所し、さらに父からの刺客・崇和会連合の大友の妨害を受けるが、根性のある京太郎は無事に出所。シャバで待っていたのは、かつての仲間と村田組の旗揚げだった。さらに京太郎に魅せられた大友も加わり、村田組は極道の世界を脅かす存在へと進化していく。本作は本宮ひろ志原作のコミックをアニメ化した作品。","name":"新・男樹","name_cn":"新·男树","tags":[{"name":"OVA","count":4,"total_cont":0},{"name":"独立ova","count":2,"total_cont":0},{"name":"1998年","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"新·男树"},{"key":"别名","value":[{"v":"Shin Otokogi"}]},{"key":"话数","value":"2"},{"key":"发售日","value":"1998年5月16日"},{"key":"开始","value":"1998年5月16日"},{"key":"结束","value":"1998年9月4日"},{"key":"原作","value":"本宮ひろ志"},{"key":"导演","value":"うえだしげる"},{"key":"脚本","value":"大橋志吉"},{"key":"人物设定","value":"古瀬登"},{"key":"动画制作","value":"スタジオぴえろ"}],"rating":{"rank":0,"total":4,"count":{"1":1,"2":0,"3":0,"4":0,"5":2,"6":0,"7":0,"8":0,"9":0,"10":1},"score":5.3},"total_episodes":0,"collection":{"on_hold":2,"dropped":5,"wish":6,"collect":6,"doing":1},"id":98869,"eps":2,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1998-05-15","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/6b/2a/468838_uD0U1.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/6b/2a/468838_uD0U1.jpg","large":"https://lain.bgm.tv/pic/cover/l/6b/2a/468838_uD0U1.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/6b/2a/468838_uD0U1.jpg","common":"https://lain.bgm.t