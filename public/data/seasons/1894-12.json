[{"id":113653,"type":2,"name":"Autour d'une cabine","name_cn":"更衣室之旁","summary":"　　一个登徒子在海滨浴场游玩。他向一位少妇调情，受到了她丈夫的打骂，最后被推入海中，成为落汤鸡。法国电影史学家乔治·萨杜尔认为，这部动画片已经具备了现代动画片的一些基本特点。例如“一定的反映时间、巧妙的剧情、典型的人物、噱头、特技摄影、紧凑生动的故事情节、同步的音乐、美丽的 布景、以及动人的色彩等等。”其中出现的场景和画面，也几乎像“镜头组合”。 \r\n　　本片是一部无声彩色动画短片。\r\n","date":"1894-12-01","images":null,"rating":{"rank":0,"total":14,"score":5.6,"count":{"1":0,"2":0,"3":0,"4":3,"5":4,"6":4,"7":1,"8":2,"9":0,"10":0}},"tags":[{"name":"短片","count":18},{"name":"法国","count":7},{"name":"1894","count":6},{"name":"剧场版","count":2},{"name":"原创","count":2},{"name":"1984","count":2},{"name":"19世纪动画","count":2},{"name":"Reynaud","count":2},{"name":"欧美","count":2},{"name":"埃米尔·雷纳德","count":1}],"eps":1,"collection":{"wish":6,"collect":39,"doing":1,"on_hold":0,"dropped":2}}]