al_cont":0},{"name":"皮克斯","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"红色的梦"},{"key":"别名","value":[{"v":"小红车的梦"},{"v":"独轮车的梦想"}]},{"key":"上映年度","value":"1987年7月10日"},{"key":"片长","value":"4分钟"},{"key":"官方网站","value":"https://www.imdb.com/title/tt0093832/"},{"key":"链接","value":[{"k":"IMDb","v":"tt0093832"}]},{"key":"话数","value":"1"},{"key":"制片国家/地区","value":"美国"},{"key":"语言","value":"英语"},{"key":"导演","value":"John Lasseter"},{"key":"脚本","value":"John Lasseter"}],"rating":{"rank":0,"total":46,"count":{"1":0,"2":0,"3":0,"4":5,"5":14,"6":16,"7":6,"8":5,"9":0,"10":0},"score":5.8},"total_episodes":0,"collection":{"on_hold":3,"dropped":4,"wish":6,"collect":74,"doing":0},"id":108089,"eps":1,"meta_tags":["剧场版","美国","欧美"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1987-07-10","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ef/bd/112334_NvxJ2.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ef/bd/112334_NvxJ2.jpg","large":"https://lain.bgm.tv/pic/cover/l/ef/bd/112334_NvxJ2.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ef/bd/112334_NvxJ2.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ef/bd/112334_NvxJ2.jpg"},"summary":"　一群因为主人搬家被遗弃的电器：勇敢的小面包炉Toaster， 总是滔滔不绝的收音机Radio，不太聪明的小台灯Lampy，强壮硕大的吸尘器Kirby ，害羞的电热毛毯Blanky。这些小伙伴险些被垃圾处理厂的机器卷碎。逃出后，因为太想念小主人，于是大家决定，一起踏上寻找小主人的旅程... \r\n　　The Brave Little Toaster is an animated film from 1987, directed by Jerry Rees, written by Thomas M. Disch. \r\n　　The film was based on the novel of the same name, written by Disch, which first appeared in The Magazine of Fantasy and Science Fiction in 1980. \r\n　　In 1988, it was the first animated film to be exhibited at the Sundance Film Festival, and the only one for 10 years until 1998's I Married a Strange Person. \r\n　　Two of the voice actors, Jon Lovitz (Radio) and Phil Hartman (Air Conditioner/Hanging Lamp), were then-current cast members of Saturday Night Live and guest stars for The Simpsons later on. Another, Thurl Ravenscroft (Kirby), was best remembered as the voice of Tony the Tiger, and some voice works on classic Disney films. \r\n　　Many members of Pixar Animation Studios were involved with this film, including John Lasseter, whose trademark A113 appears on Master's door, and Joe Ranft.","name":"The Brave Little Toaster","name_cn":"电器小英雄","tags":[{"name":"剧场版","count":2,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"电器小英雄"},{"key":"别名","value":[{"v":"烤面包机"},{"v":"勇敢的小托斯特"}]},{"key":"上映年度","value":"1987-07-10"},{"key":"片长","value":"90 分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":1,"dropped":6,"wish":3,"collect":5,"doing":1},"id":112334,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1987-07-10","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/aa/01/597825_Ai3Q3.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/aa/01/597825_Ai3Q3.jpg","large":"https://lain.bgm.tv/pic/cover/l/aa/01/597825_Ai3Q3.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/aa/01/597825_Ai3Q3.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/aa/01/597825_Ai3Q3.jpg"},"summary":"　「パイロットフィルム」は本編制作に先駆けて関係者向けに制作された映像で、「リテイク版」はロゴや美術の差し替え、庵野秀明氏によるロケット三段目切り離しカットのリテイク版などが収められています。","name":"王立宇宙軍 オネアミスの翼 パイロットフィルム","name_cn":"王立宇宙军 样片","tags":[{"name":"森山雄治","count":1,"total_cont":0},{"name":"井上俊之","count":1,"total_cont":0},{"name":"远藤正明","count":1,"total_cont":0},{"name":"饭田史雄","count":1,"total_cont":0},{"name":"庵野秀明","count":1,"total_cont":0},{"name":"山贺博之","count":1,"total_cont":0},{"name":"摩砂雪","count":1,"total_cont":0},{"name":"贞本义行","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"OVA","count":1,"total_cont":0},{"name":"前田真宏","count":1,"total_cont":0},{"name":"高坂希太郎","count":1,"total_cont":0},{"name":"短片","count":1,"total_co