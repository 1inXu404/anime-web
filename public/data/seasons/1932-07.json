":"Pete","count":1},{"name":"解救米妮","count":1},{"name":"美国","count":1},{"name":"眼镜蛇","count":1},{"name":"迪士尼","count":1}],"eps":1,"collection":{"wish":1,"collect":13,"doing":1,"on_hold":0,"dropped":3}},{"id":113649,"type":2,"name":"Flowers and Trees","name_cn":"花与树","summary":"　　本片1932年获得奥斯卡最佳动画短片奖。 \r\n　　清晨，森林中的花儿、树儿、鸟儿从睡梦中醒来，舒展腰肢梳洗打扮，准备充实愉快地度过崭新的一天。自然，枯干的老树桩也醒了过来，不过他可不觉得生活有什么美好，睁开眼即不耐烦地驱赶他身旁的花儿、鸟儿。见男树正向女树浪漫地求爱，他不由分说强行将女树揽入怀中，男树见状，起身与他决定，老树桩败下阵来。不甘心的老树桩心生毒计，没料想遭殃的是他自己。","date":"1932-07-30","images":null,"rating":{"rank":4530,"total":139,"score":6.5,"count":{"1":0,"2":2,"3":2,"4":3,"5":16,"6":44,"7":52,"8":14,"9":2,"10":4}},"tags":[{"name":"短片","count":69},{"name":"欧美","count":45},{"name":"迪士尼","count":34},{"name":"1932","count":34},{"name":"Disney","count":28},{"name":"美国","count":16},{"name":"奥斯卡","count":11},{"name":"欢乐","count":9},{"name":"原创","count":8},{"name":"动值物","count":7}],"eps":1,"collection":{"wish":17,"collect":223,"doing":4,"on_hold":7,"dropped":7}},{"id":149120,"type":2,"name":"Just Dogs","name_cn":"狗的故事","summary":"","date":"1932-07-30","images":null,"rating":{"rank":0,"total":3,"score":5.3,"count":{"1":0,"2":1,"3":0,"4":0,"5":0,"6":0,"7":2,"8":0,"9":0,"10":0}},"tags":[{"name":"短片","count":3},{"name":"1932","count":3},{"name":"美国","count":2},{"name":"空","count":1},{"name":"迪士尼","count":1},{"name":"Disney","count":1},{"name":"30s","count":1}],"eps":1,"collection":{"wish":1,"collect":13,"doing":0,"on_hold":0,"dropped":3}}]