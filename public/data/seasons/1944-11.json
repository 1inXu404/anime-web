[{"date":"1944-11-23","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/2d/ec/132370_4a1qD.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/2d/ec/132370_4a1qD.jpg","large":"https://lain.bgm.tv/pic/cover/l/2d/ec/132370_4a1qD.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/2d/ec/132370_4a1qD.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/2d/ec/132370_4a1qD.jpg"},"summary":"　　汤姆邮购了一本书，名为《如何捉老鼠》。它按照书中的章节逐个尝试，要么不灵验，要么就被杰瑞一一破解。两个小家伙的战争并未就此结束，它们在家中大打出手，从最初的老鼠夹子到各类工具再到烟花炮竹，无所不用其极，都成了它们的制胜武器。然而无论汤姆多么努力，最终倒霉的似乎只有它自己…… \r\n　　本片荣获1945年奥斯卡最佳动画短片奖。","name":"Mouse Trouble","name_cn":"老鼠的麻烦","tags":[{"name":"短片","count":55,"total_cont":0},{"name":"欧美","count":34,"total_cont":0},{"name":"猫和老鼠","count":33,"total_cont":0},{"name":"奥斯卡","count":20,"total_cont":0},{"name":"1944","count":16,"total_cont":0},{"name":"米高梅","count":13,"total_cont":0},{"name":"美国","count":13,"total_cont":0},{"name":"搞笑","count":11,"total_cont":0},{"name":"童年","count":8,"total_cont":0},{"name":"原创","count":6,"total_cont":0},{"name":"MGM","count":5,"total_cont":0},{"name":"1940s","count":4,"total_cont":0},{"name":"动画短片","count":2,"total_cont":0},{"name":"1940-1949","count":2,"total_cont":0},{"name":"子供向","count":2,"total_cont":0},{"name":"欢乐","count":2,"total_cont":0},{"name":"智商碾压","count":2,"total_cont":0},{"name":"Oscars","count":1,"total_cont":0},{"name":"童年回忆","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"40s","count":1,"total_cont":0},{"name":"60年代前","count":1,"total_cont":0},{"name":"先驱","count":1,"total_cont":0},{"name":"William.Hanna","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"OVA","count":1,"total_cont":0},{"name":"Joseph.Barbera","count":1,"total_cont":0},{"name":"幽默","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"老鼠的麻烦"},{"key":"别名","value":[{"v":"老鼠遇险"}]},{"key":"上映年度","value":"1944年11月23日"},{"key":