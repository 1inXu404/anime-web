[{"date":"1958-01-03","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/90/c6/634840_4LMTf.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/90/c6/634840_4LMTf.jpg","large":"https://lain.bgm.tv/pic/cover/l/90/c6/634840_4LMTf.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/90/c6/634840_4LMTf.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/90/c6/634840_4LMTf.jpg"},"summary":"　　复活节的早上，一阵敲门声过后，汤姆和杰瑞兴高采烈的冲向门口。门外放着一只篮子，里面装着一枚漂亮的彩蛋。他们向院门望去，一只白色兔子正一蹦一蹦地离开。这枚彩蛋是兔子送给他们俩的礼物，但是汤姆想将其独吞，于是两个好朋友在房间内大打出手，你争我夺。结果彩蛋被扔上天空，落在汤姆头上摔裂了。谁知从彩蛋里出来一只可爱的小黄鸭。小家伙跳进浴缸，自由自在游弋，惹出不少乱子。为了控制住这个随时随地不分场合游泳的鸭子，汤姆和杰瑞只能将他关起来，可是根本没法控制这个疯狂的小家伙。\r\n　　难忘的节日，难忘的新朋友……","name":"Happy Go Ducky","name_cn":"快乐小鸭","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"快乐小鸭"},{"key":"上映年度","value":"1958年1月3日"},{"key":"片长","value":"6分钟"},{"key":"IMDb","value":"tt0051698"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":1,"7":1,"8":0,"9":0,"10":0},"score":5.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634840,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]