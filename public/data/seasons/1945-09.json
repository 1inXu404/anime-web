[{"date":"1945-09-22","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/33/3d/262828_Q84rc.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/33/3d/262828_Q84rc.jpg","large":"https://lain.bgm.tv/pic/cover/l/33/3d/262828_Q84rc.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/33/3d/262828_Q84rc.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/33/3d/262828_Q84rc.jpg"},"summary":"　　阳光明媚的一天，汤姆在院子里精心布下陷阱，终于引得小老鼠杰瑞上钩。他将杰瑞家在三明治的面包里，正准备大快朵颐的时候，半路杀出个程咬金，一只凶恶的老鹰低空掠过，并且以极快的速度从汤姆手中抢走了三明治——当然，也包括里面的杰瑞。老鹰叼着战利品来到一棵树枝上，同样准备享受这顿无上的早餐。汤姆自然不会放弃到嘴的美食，他和老鹰展开对决，然而对方过于强大，汤姆根本不是老鹰的对手。强攻不成，只能施以美人计。汤姆化妆成为一只性感妖娆的雌鹰，若即若离吸引着对面那个凶恶强壮的大家伙，不过他的目标自然还是老鹰手里的小老鼠……","name":"Flirty Birdy","name_cn":"秃鹰变奏曲","tags":[{"name":"短片","count":18,"total_cont":0},{"name":"猫和老鼠","count":8,"total_cont":0},{"name":"欧美","count":7,"total_cont":0},{"name":"1945","count":6,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"秃鹰变奏曲"},{"key":"上映年度","value":"1945年9月22日"},{"key":"片长","value":"7分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":37,"count":{"1":0,"2":0,"3":0,"4":2,"5":1,"6":8,"7":17,"8":9,"9":0,"10":0},"score":6.8},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":4,"collect":81,"doing":1},"id":262828,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]