":0},"id":9539,"eps":22,"meta_tags":["TV","日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1991-05-02","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/91/0d/75184_57PiN.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/91/0d/75184_57PiN.jpg","large":"https://lain.bgm.tv/pic/cover/l/91/0d/75184_57PiN.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/91/0d/75184_57PiN.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/91/0d/75184_57PiN.jpg"},"summary":"1968年から1969年にかけて『週刊少年サンデー』に連載され、その後『朝日小学生新聞』での連載やアニメ化など各種メディアに展開された。\r\n藤子・F・不二雄は「これまで日常の舞台にオバケやスーパーマンなどの「非日常」が入り込むことで生まれるギャップの面白さを描いてきたが、ひとつその逆をやってみようと思い、この21エモンを描きました。つまり未来という「非日常」を舞台に、今に通じる日常を描くことで新たな面白さが生まれると思ったからです」と、本作のコンセプトを後日述懐している。\r\n藤子・F・不二雄が珍しく「楽しんで描いた」と語る作品だったが、連載当時は評価は芳しくなく、この当時の藤子作品は早々にテレビアニメ化されていたが本作は実現しなかった。\r\nしかし、後年になるに従ってしだいに再評価されるようになり、1981年に映画化、さらに1991年にようやくテレビアニメ化された。\r\n2010年、小学館発行の藤子・F・不二雄大全集のラインナップとして、全2巻で刊行された。2011年、アニメ版の全話がDVD化された。","name":"21エモン","name_cn":"21卫门","tags":[{"name":"漫画改","count":4,"total_cont":0},{"name":"TV","count":3,"total_cont":0},{"name":"1991","count":3,"total_cont":0},{"name":"藤子・F・不二雄","count":3,"total_cont":0},{"name":"SF","count":2,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"正太","count":1,"total_cont":0},{"name":"童年","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"SHIN-EI","count":1,"total_cont":0},{"name":"1991年","count":1,"total_cont":0},{"name":"佐々木望","count":1,"total_cont":0},{"name":"原恵一","count":1,"total_cont":0},{"name":"大谷育江","count":1,"total_cont":0},{"name":"桶谷顕","count":1,"total_cont":0},{"name":"シンエイ動画","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"21卫门"},{"key":"别名","value":[{"v":"21世纪小福星"},{"v":"にじゅういちエモン"}]},{"key":"话数","value":"39"},{"key":"放送开始","value":"1991年5月2日"},{"key":"播放结束","value":"1992年3月26日"}],"rating":{"rank":0,"total":7,"count":{"1":0,"2":1,