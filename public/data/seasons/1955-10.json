[{"date":"1955-10-28","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e0/41/431518_dznrr.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e0/41/431518_dznrr.jpg","large":"https://lain.bgm.tv/pic/cover/l/e0/41/431518_dznrr.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e0/41/431518_dznrr.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e0/41/431518_dznrr.jpg"},"summary":"蛮荒的美国西部某座小镇，一辆马车刚刚运来一袋金币。粗鲁蛮横的警长将金子装进保险箱，并且告诫副警长德鲁比要小心防范，不要让任何宵小之徒有机可乘。他们这一番话早被躲在外面的一胖一瘦两个歹徒听到，两个家伙趁警长在前面休息的时候，偷偷潜入警察局伺机行窃。他们生怕弄出一点声响，每当被弄疼忍不住大叫的时候，都会跑到远离小镇的野外大叫。这两个坏家伙的举动引起德鲁比的注意，他用各种看起来不起眼的小计谋对付笨贼们，以让他们忍不住大叫出声，好引来警长。 \r\n　　这是一场斗智斗勇的游戏，德鲁比交出满分答卷……","name":"Deputy Droopy","name_cn":"副警长德鲁比","tags":[{"name":"美国","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"短片","count":2,"total_cont":0},{"name":"1955","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"米高梅","count":1,"total_cont":0},{"name":"1950-1959","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"副警长德鲁比"},{"key":"上映年度","value":"1955年10月28日"},{"key":"片长","value":"7分32秒"},{"key":"导演","value":"Tex Avery、Michael Lah"},{"key":"脚本","value":"Heck Allen"},{"key":"制片国家/地区","value":"美国"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":7,"count":{"1":0,"2":0,"3":1,"4":0,"5":0,"6":4,"7":2,"8":0,"9":0,"10":0},"score":5.9},"total_episodes":0,"collection":{"on_hold":1,"dropped":3,"wish":2,"collect":14,"doing":0},"id":431518,"eps":1,"meta_tags":["剧场版","美国"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1955-10-14","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0f/27/634783_Y5ezd.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0f/27/634783_Y5ezd.jpg","large":"https://lain.bgm.tv/pic/cover/l/0f/27/634783_Y5ezd.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0f/27/634783_Y5ezd.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0f/27/634783_Y5ezd.jpg"},"summary":"　　在一个周末的夜晚，汤姆家空无一人，他兴奋非常，在窗口打出“家中无人”的牌子。狐朋狗友布奇、托普西、闪电闻讯前往。这是属于猫儿们的狂欢之夜，当然他们必须提防趴在院子里鼾声如雷的大狗史派克。今天布奇带来新玩艺儿，一台小型家庭放映机，他准备放上一段关于傻狗的录像娱乐大众。不过并非所有屋子里的成员都能观赏，小老鼠杰瑞便在放映前被粗暴地扔了出去。录像第一个故事来自《浪漫小夜曲（Solid Serenade）》，汤姆一面求爱一面戏耍史派克。接下来还有两个故事，分别来自《猫钓鱼（Cat Fishin'）》和《拴好爱犬（Fit to Be Tied）》，汤姆的狡猾机警以及史派克粗蠢愚笨的表现令几只猫儿乐不可支。\r\n　　而在此期间，想看录像的杰瑞则三番五次被扔出窗外，这让他分外光火……","name":"Smarty Cat","name_cn":"自作聪明的笨猫","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"自作聪明的笨猫"},{"key":"上映年度","value":"1955年10月14日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0048633"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":1,"4":0,"5":1,"6":1,"7":1,"8":0,"9":0,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634783,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]