两个因犯罪而被投放到监狱的损友，某日，绿山集团的大小姐丽.绿山以加入她所建立的私立警务组织“马戏团”为条件保释了他们，无宇和麻矢驾驶组织的新型机器人“Circus1号加尔比昂”完成各种各样的任务，渐渐地，他们开始接触到神秘的地下组织“暗影”并为打倒“暗影”而行动。","name":"超攻速ガルビオン","name_cn":"超攻速加尔比安","tags":[{"name":"TV","count":7,"total_cont":0},{"name":"原创","count":5,"total_cont":0},{"name":"1984","count":4,"total_cont":0},{"name":"国际映画社","count":4,"total_cont":0},{"name":"robo","count":3,"total_cont":0},{"name":"ロボットアニメ","count":2,"total_cont":0},{"name":"机战","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"1984年2月","count":2,"total_cont":0},{"name":"鴫野彰","count":2,"total_cont":0},{"name":"补旧番","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"半年番","count":1,"total_cont":0},{"name":"橋本晃一","count":1,"total_cont":0},{"name":"80s","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"鈴置洋孝","count":1,"total_cont":0},{"name":"科幻","count":1,"total_cont":0},{"name":"80","count":1,"total_cont":0},{"name":"萝卜","count":1,"total_cont":0},{"name":"伊東恒久","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"作画崩坏","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"超攻速加尔比安"},{"key":"别名","value":[{"v":"超攻速加尔比昂"}]},{"key":"话数","value":"22"},{"key":"放送开始","value":"1984年2月3日"},{"key":"放送星期","value":"星期五"},{"key":"播放结束","value":"1984年6月29日"},{"key":"分镜","value":"長尾粛、栗山美秀、鴫野彰、山谷善彦、根岸弘、香川豊、網野哲郎（アミノテツロー）、しぎの義信、しぎのあきら、石川康夫、加藤雄治、ときたひろこ"},{"key":"演出","value":"長尾粛、山谷善彦、根岸弘、栗山美秀、鴫野彰、内田祐司、石川康夫、永田辰也、山谷善彦、篠幸裕、しぎのあきら、しぎの義信、網野哲郎（アミノテツロー）、ときたひろこ、加藤雄治、石川康夫"},{"key":"作画监督","value":"谷口守泰、八幡正、服部憲知、西山英雄、下田正美、高橋朝雄、菊池城二、二宮常雄"},{"key":"製作","value":"テレビ朝日、国際映画社"},{"key":"音响监督","value":"山田悦司"},{"key":"制片人","value":"宇都宮恭三（テレビ朝日）、佐久間敏郎（国際映画社）"},{"key":"总作画监督","value":"二宮常雄"},{"key":"美术监督","value":"杉浦正一郎"},{"key":"プランニング・ディレクター","value":"藤家和正"}],"rating":{"rank":0,"total":5,"count":{"1":1,"2":0,"3":0,"4":2,"5":1,"6":1,"7":0,"8":0,"9":0,"10":0},"score":4},"total_episodes":0,"collection":{"on_hold":3