8":574,"9":254,"10":84},"score":7.9},"total_episodes":0,"collection":{"on_hold":54,"dropped":41,"wish":693,"collect":1915,"doing":49},"id":516,"eps":1,"meta_tags":["科幻","剧场版","日本","原创"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1998-08-07","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ff/b7/104561_Q20Mj.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ff/b7/104561_Q20Mj.jpg","large":"https://lain.bgm.tv/pic/cover/l/ff/b7/104561_Q20Mj.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ff/b7/104561_Q20Mj.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ff/b7/104561_Q20Mj.jpg"},"summary":"　名優・渥美清と監督・山田洋次による松竹映画の看板作品「男はつらいよ」をベースとしたおよそ1時間のTVスペシャルアニメ。厳密な意味で本作の原作は、1973年の映画第11作をもとに林律雄と高井研一郎が手がけた漫画「コミック寅さん」の第6巻の一作であり、絵柄も同コミックに近いものとなっている。\r\n　生まれも育ちも柴又のフーテンの寅次郎。自分がヒーローになって怪獣と戦うことを夢の中で見たりと、今日ものんびり気ままな一人旅。そんな中、夜汽車で知り合った流しの美人歌手リリーとの出会いを経て、寅は北海道の網走へとたどり着く。そこの牧場での生活をはじめる寅だったが、仕事の大変さゆえついに倒れてしまう。柴又へ帰った寅をたずねてきたのはあのリリーだった……？\r\n　本作は「男はつらいよ」初のアニメ作品で、TBSのバラエティ番組「金曜テレビの星」の枠で放送された。総監督は四分一節子、演出は棚橋一徳が担当。寅次郎の声は山寺宏一が演じた。","name":"男はつらいよ 寅次郎忘れな草","name_cn":"寅次郎的故事 寅次郎勿忘我","tags":[{"name":"TV","count":2,"total_cont":0},{"name":"TVspecial","count":2,"total_cont":0},{"name":"TVSP","count":1,"total_cont":0},{"name":"四分一節子","count":1,"total_cont":0},{"name":"1998","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"寅次郎的故事 寅次郎勿忘我"},{"key":"别名","value":[{"v":"男人真命苦 寅次郎勿忘我"},{"v":"アニメ 男はつらいよ〜寅次郎忘れな草〜"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"1998年8月7日"},{"key":"播放电视台","value":"TBS"},{"key":"总导演","value":"四分一節子"},{"key":"演出","value":"棚橋一徳"},{"key":"原作","value":"山田洋次"},{"key":"人物设定","value":"小林ゆかり"}],"rating":{"rank":0,"total":7,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":2,"7":1,"8":1,"9":0,"10":1},"score":6.7},"total_episodes":0,"collection":{"on_hold":2,"dropped":4,"wish":9,"collect":10,"doing":1},"id":104561,"eps":1,"meta_tags":["TV","日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1998-08-04","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/47/44/112354_677KX.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/47/44/112354_677KX.jpg","large":"https://lain.bgm.tv/pic/cover/l/47/44/112354_677KX.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/47/44/112354_677KX.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/47/44/112354_677KX.jpg"},"summary":"本片是迪士尼1995年出品的《风中奇缘》续集，剧情接第一部的故事。 \r\n　　公元1612年，Pocahontas（Irene Bedard 配音）听到 John Smith（Donal Gibson 配音）死讯的传言，不禁又开始迟疑自己当初所作的决定到底是对是错。后来她为了谋求她的族人与英国移民之间的和平关系，就随着一位年轻有为的英国外交官 John Rolfe 远渡重洋来到英国伦敦，展开一次前所未有的新世界之旅！那三只小动物 Meeko 、Percy 和 Flit 也跟着偷渡过洋！当 Pocahontas 踏上英国伦敦打算到白金汉宫面见英国国王时，不料又遇到大坏蛋 Ratcliffe 正准备重回新大陆捞金，要发动战舰去消灭印地安人。于是 Pocahontas 又开始为族人的自由而努力以赴，片中她还穿着欧式的礼服到白金汉宫面见英国的国王与皇后，在英国异乡也终于见到许久都没音讯的 John Smith，但是 Pocahontas 最后还是选择了跟 John Smith 分别，与英国外交官 John Rolfe 返回美洲大陆，结束了这趟难忘的新世界之旅。","name":"Pocahontas II: Journey to a New World","name_cn":"风中奇缘2","tags":[{"name":"欧美","count":6,"total_cont":0},{"name":"Disney","count":6,"total_cont":0},{"name":"剧场版","count":5,"total_cont":0},{"name":"动画电影","count":4,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"Jim_Cummings","count":1,"total_cont":0},{"name":"90年代","count":1,"total_cont":0},{"name":"迪士尼","count":1,"total_cont":0},{"name":"英语","count":1,"total_cont":0},{"name":"表番","count":1,"total_cont":0},{"name":"DisneyToon_Studios","count":1,"total_cont":0},{"name":"Cindy_Marcus","count":1,"total_cont":0},{"name":"Tom_Ellery","count":1,"total_cont":0},{"name":"历史","count":1,"total_cont":0},{"name":"Bradley_Raymond","count":1,"total_cont":0},{"name":"Flip_Kobler","count":1,"total_cont":0},{"name":"Allen_Estrin","count":1,"total_cont":0},{"name":"Animation","count":1,"total_cont":0},{"name":"Donal_Gibson","count":1,"total_cont":0},{"name":"Irene_Bedard","count":1,"total_cont":0},{"name":"1998","count":1,"total_