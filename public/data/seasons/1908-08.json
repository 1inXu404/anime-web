[{"id":80198,"type":2,"name":"Fantasmagorie","name_cn":"幻影集","summary":"　　本片是电影史上世界上第一部抽象动画，无声黑白，2006年法国安锡（Annecy）国际动画电影节上，被评为“动画的世纪•100部作品”第二名。 \r\n　　本片无情节无主题，不到两分钟的影像里，导演émile Cohl用再简单不过的线条为观众做了多次变形：人变为酒瓶、酒瓶变为花朵、大象变为房子等等，今天看来，想象力也美得让人叫奇。","date":"1908-08-17","images":null,"rating":{"rank":4595,"total":111,"score":6.4,"count":{"1":1,"2":0,"3":1,"4":2,"5":26,"6":28,"7":31,"8":14,"9":6,"10":2}},"tags":[{"name":"短片","count":81},{"name":"法国","count":41},{"name":"1908","count":39},{"name":"欧美","count":23},{"name":"考古","count":23},{"name":"ÉmileCohl","count":13},{"name":"原创","count":11},{"name":"先驱","count":11},{"name":"无声","count":7},{"name":"无对白","count":7},{"name":"创意","count":6}],"eps":1,"collection":{"wish":31,"collect":194,"doing":4,"on_hold":5,"dropped":8}}]