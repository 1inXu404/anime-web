1/37238_7q4cf.jpg"},"summary":"　　人口・環境・汚染問題のはけ口を地球の外に求める「地球クリーン化政策」のもとに置かれた未来の地球。火星と月が産業廃棄物や犯罪流刑者の送り先となっていた中、月で軍を組織したゴッドハイド博士は量産型戦闘ロボット「ブラックベアー」を開発、地球に対しての反乱を開始した。その戦闘の余波がブルーハイム博士・シルベスター将軍が指揮する地球連邦軍の物質電送システム実験場に及び、実験装置にミサイルが激突。パソコン好きの少年・香取敬の作った対戦ネットゲーム用の戦闘ロボットデータが、このときのショックで地球連邦軍のコンピューターと混線してしまい、敬がプログラミングした「レザリオン」が物質電送装置の力で実体化した。成り行きから彼は地球を守る戦いへと巻き込まれていくことになる。","name":"ビデオ戦士レザリオン","name_cn":"电脑战士雷萨里昂","tags":[{"name":"TV","count":8,"total_cont":0},{"name":"1984","count":5,"total_cont":0},{"name":"robo","count":5,"total_cont":0},{"name":"東映アニメーション","count":4,"total_cont":0},{"name":"机战","count":4,"total_cont":0},{"name":"赛璐珞","count":3,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"TVA","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"萝卜","count":2,"total_cont":0},{"name":"80","count":2,"total_cont":0},{"name":"东映","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"古谷徹","count":1,"total_cont":0},{"name":"野田圭一","count":1,"total_cont":0},{"name":"1984年3月","count":1,"total_cont":0},{"name":"森下孝三","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"潘恵子","count":1,"total_cont":0},{"name":"作画wiki推荐","count":1,"total_cont":0},{"name":"80s","count":1,"total_cont":0},{"name":"八手三郎","count":1,"total_cont":0},{"name":"ロボットアニメ","count":1,"total_cont":0},{"name":"机甲","count":1,"total_cont":0},{"name":"年番","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"电脑战士雷萨里昂"},{"key":"别名","value":[{"v":"Video Warrior Laserion"}]},{"key":"话数","value":"45"},{"key":"放送开始","value":"1984年3月4日"},{"key":"官方网站","value":"https://lineup.toei-anim.co.jp/ja/tv/lazerion/"},{"key":"播放结束","value":"1985年2月3日"},{"key":"系列监督","value":"森下孝三"}],"rating":{"rank":0,"total":12,"count":{"1":0,"2":0,"3":1,"4":3,"5":2,"6":4,"7":1,"8":1,"9":0,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":6,"dropped":9,"wish":23,"collect":20,"doing":3},"id":37238,"eps":45,"meta_tags":["机战","TV","日本","原创"],"volumes":0,"se