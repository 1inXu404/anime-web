[{"date":"1981-08-23","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/1f/67/111922_v13r5.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/1f/67/111922_v13r5.jpg","large":"https://lain.bgm.tv/pic/cover/l/1f/67/111922_v13r5.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/1f/67/111922_v13r5.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/1f/67/111922_v13r5.jpg"},"summary":"该作品是专为24小时电视节目制作的第4部特别动画。在首次播出后，整个作品的三分之一内容被重新制作，最终完整版以录像带的形式进行了发售。为了保护地球，必须坚决消除战争，不惜付出任何代价——为实现这一目标，四只动物踏上了拯救世界的征途。故事的设定虽以《不来梅四重奏乐队》为基础，但对于手塚治虫的粉丝来说，也能发现与《三神奇（W3）》相似之处。在外星和平使者的帮助下，小猫、小狗、小驴和小鸡化身为人类，为地球的和平而战。这不禁让人想起《三神奇（W3）》中为拯救地球而变身为动物的那三位角色。","name":"ブレーメン4 地獄の中の天使たち","name_cn":"布莱梅4 地狱中的天使","tags":[{"name":"剧场版","count":6,"total_cont":0},{"name":"1981","count":4,"total_cont":0},{"name":"手塚治虫","count":4,"total_cont":0},{"name":"战争","count":3,"total_cont":0},{"name":"小说改","count":2,"total_cont":0},{"name":"机器人","count":2,"total_cont":0},{"name":"童话","count":2,"total_cont":0},{"name":"独立剧场版","count":2,"total_cont":0},{"name":"SF","count":2,"total_cont":0},{"name":"手冢治虫","count":1,"total_cont":0},{"name":"岡本茉利","count":1,"total_cont":0},{"name":"1981年","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"手塚プロダクション","count":1,"total_cont":0},{"name":"TVSP","count":1,"total_cont":0},{"name":"机战","count":1,"total_cont":0},{"name":"TV","count":1,"total_cont":0},{"name":"笹川ひろし","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"布莱梅4 地狱中的天使"},{"key":"别名","value":[{"v":"不来梅四重奏"},{"v":"四神奇"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"1981年8月23日"},{"key":"播放电视台","value":"日本テレビ"},{"key":"片长","value":"90分"},{"key":"原案、脚本、キャラクターデザイン、総監督","value":"手塚治虫"},{"key":"演出","value":"笹川ひろし、手塚治虫、秋山勝仁"},{"key":"作画監督","value":"宇田川一彦"},{"key":"美術監督","value":"中村光毅"},{"key":"音楽","value":"樋口康雄"},{"key":"メカデザイン","value":"坂口尚"},{"key":"原画","value":"西村緋禄司、吉村昌輝、小林準治、谷沢豊、瀬谷新二、加納薫、野間吐史