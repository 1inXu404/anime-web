ることが度々あった。「変化テクター」の代わりに「Gメタル」が登場。変化テクターと違い動物（鳥・虎・竜・ライオン）がモチーフになっているほか、顔面も覆うので、SDガンダムのような外見になる。本作品には夜叉姫という鬼族が登場するが、ゲームに登場する夜叉姫とは外見が異なり、別人である。前作と違い、全話がビデオ化されている。なお、主題歌のオープニングでは桃太郎を演じる佐々木望を、エンディングではティンクルを演じる折笠愛が担当した。本作にもってナックはTVアニメ制作から撤退した。","name":"PEACH COMMAND 新桃太郎伝説","name_cn":"新桃太郎传说","tags":[{"name":"TV","count":8,"total_cont":0},{"name":"草尾毅","count":5,"total_cont":0},{"name":"1990","count":5,"total_cont":0},{"name":"童年","count":4,"total_cont":0},{"name":"机甲","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"经典","count":2,"total_cont":0},{"name":"TVA","count":2,"total_cont":0},{"name":"动","count":1,"total_cont":0},{"name":"robo","count":1,"total_cont":0},{"name":"ICHI","count":1,"total_cont":0},{"name":"桃太郎传说","count":1,"total_cont":0},{"name":"桃太郎","count":1,"total_cont":0},{"name":"折笠愛","count":1,"total_cont":0},{"name":"1989-1993","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"中村大树","count":1,"total_cont":0},{"name":"山崎敬之","count":1,"total_cont":0},{"name":"游戏改","count":1,"total_cont":0},{"name":"福本洁","count":1,"total_cont":0},{"name":"铠甲系","count":1,"total_cont":0},{"name":"ナック映画","count":1,"total_cont":0},{"name":"福本潔","count":1,"total_cont":0},{"name":"1990年","count":1,"total_cont":0},{"name":"広井王子","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"佐々木望","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"新桃太郎传说"},{"key":"别名","value":[{"v":"PC新・桃太郎伝説"}]},{"key":"话数","value":"24"},{"key":"放送开始","value":"1990年10月8日"},{"key":"播放电视台","value":"テレビ東京系列"},{"key":"播放结束","value":"1991年4月1日"},{"key":"机械设定","value":"多賀谷学（Gメタルデザイン）"},{"key":"製作","value":"テレビ東京・I＆S・Knack"}],"rating":{"rank":0,"total":19,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":10,"7":6,"8":2,"9":0,"10":0},"score":6.5},"total_episodes":0,"collection":{"on_hold":4,"dropped":5,"wish":14,"collect":43,"doing":1},"id":53640,"eps":24,"meta_tags":["TV","日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"