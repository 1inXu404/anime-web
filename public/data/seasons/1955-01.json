[{"date":"1955-01-14","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/57/3d/243291_2YBY8.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/57/3d/243291_2YBY8.jpg","large":"https://lain.bgm.tv/pic/cover/l/57/3d/243291_2YBY8.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/57/3d/243291_2YBY8.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/57/3d/243291_2YBY8.jpg"},"summary":"　　这一天，唐老鸭（克拉伦斯·纳什 Clarence Nash 配音）正惬意地享受他丰盛的早餐，墙上挂着一幅他老祖先（Bill Thompson 配音）的照片。照片中，祖先雄赳赳气昂昂，手持猎枪，脚踩着一头大野牛的身上。这个经验丰富的老猎手，眼神中透着敏锐和坚毅。当然，这一切对唐老鸭来说是如此遥远，而且也似乎全然不相关。他悠闲地翻开报纸，看到一则新闻，原来狩猎的季节明天就要来到了。得知这个消息，祖先的灵魂再也无法安然待在画上，他挣脱画布的束缚，钻进唐老鸭的体内，带着孙子并肩前往狩猎场。 \r\n　　时间一分一秒地艰难流逝。清晨，唐老鸭吹响狩猎的号角，一时间枪声大作，炮弹横飞，碧绿青山瞬时间化作焦土……","name":"No Hunting","name_cn":"禁止狩猎","tags":[{"name":"迪士尼","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"短片","count":1,"total_cont":0},{"name":"1955","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"禁止狩猎"},{"key":"上映年度","value":"1955年1月14日"},{"key":"片长","value":"6分钟"},{"key":"制片国家/地区","value":"美国"},{"key":"语言","value":"英语"},{"key":"IMDb_id","value":"tt0048425"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":2,"collect":5,"doing":0},"id":243291,"eps":0,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]