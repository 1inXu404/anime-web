","count":1,"total_cont":0},{"name":"英国","count":1,"total_cont":0},{"name":"2009","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"去野餐的好天气"},{"key":"别名","value":[{"v":"野餐的好日子"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"2009-05-26"},{"key":"导演","value":"Monica Gallab"},{"key":"类型","value":"动画 / 短片"},{"key":"制片国家/地区","value":"英国"},{"key":"片长","value":"4分17秒"}],"rating":{"rank":0,"total":2,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":3,"dropped":4,"wish":9,"collect":8,"doing":1},"id":157975,"eps":1,"meta_tags":["WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"2009-05-24","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/39/66/37874_qB06C.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/39/66/37874_qB06C.jpg","large":"https://lain.bgm.tv/pic/cover/l/39/66/37874_qB06C.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/39/66/37874_qB06C.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/39/66/37874_qB06C.jpg"},"summary":"在光坂高中空无一人的教室内，藤林椋终于鼓起勇气向被人当作不良少年的冈崎朋也表白。幸运的是，她的爱意没有落于虚空，得到了冈崎热情而肯定的回应。两人自此开始交往，望着沉浸在幸福中的妹妹，藤林杏心中自是无法道出的复杂感受。某个明媚的假日，冈崎和杏在公园不期而遇。杏半开玩笑地教冈崎把自己当作椋练习接吻，谁知这一幕却被同学看见，第二天便在学校内传得风言风语。为了消除谣言，杏甚至假装和春原阳平交往。甜蜜又青涩的学生时代，说不清道不明的爱恋情怀……","name":"CLANNAD 〜AFTER STORY〜もうひとつの世界 杏編","name_cn":"CLANNAD ～AFTER STORY～另一个世界 杏篇","tags":[{"name":"京阿尼","count":2012,"total_cont":0},{"name":"Clannad","count":1725,"total_cont":0},{"name":"OVA","count":1717,"total_cont":0},{"name":"key","count":1426,"total_cont":0},{"name":"GAL改","count":957,"total_cont":0},{"name":"2009","count":738,"total_cont":0},{"name":"杏篇","count":727,"total_cont":0},{"name":"校园","count":715,"total_cont":0},{"name":"麻枝准","count":712,"total_cont":0},{"name":"催泪","count":649,"total_cont":0},{"name":"治愈","count":491,"total_cont":0},{"name":"游戏改","count":439,"total_cont":0},{"name":"恋爱","count":387,"total_cont":0},{"name"