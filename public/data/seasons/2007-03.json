ain.bgm.tv/r/100/pic/cover/l/ed/05/66253_Dx27X.jpg","large":"https://lain.bgm.tv/pic/cover/l/ed/05/66253_Dx27X.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ed/05/66253_Dx27X.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ed/05/66253_Dx27X.jpg"},"rating":{"rank":0,"total":35,"score":6.7,"count":{"1":0,"2":1,"3":0,"4":0,"5":4,"6":10,"7":13,"8":3,"9":2,"10":2}},"tags":[{"name":"欧美","count":12},{"name":"迪士尼","count":8},{"name":"剧场版","count":8},{"name":"Disney","count":8},{"name":"科幻","count":7},{"name":"2007","count":5},{"name":"电影","count":4},{"name":"动画电影","count":4},{"name":"未来小子","count":3},{"name":"治愈","count":3},{"name":"電影","count":2}],"eps":1,"collection":{"wish":5,"collect":67,"doing":2,"on_hold":2,"dropped":4}},{"id":37264,"type":2,"name":"鉄人28号 白昼の残月","name_cn":"铁人28号 白昼之残月","summary":"　　战后复兴的东京，、少年侦探金田正太郎和他的“铁人28号”一起解决了一个接着一个的困难事件。但是在战争中行踪不明的正太郎的哥哥出现在了正太郎面前。（正太郎的哥哥也叫正太郎，故下面用 SHOUTAROU代替）。为了战争而接受铁人操控训练后返回日本的SHOUTAROU却得知了博士的遗言为“将铁人留给弟弟正太郎”。而现在的日本也已恢复了和平，他的存在似乎变得毫无价值。但SHOUTAROU还是接受了这个现实，并向弟弟正太郎传授铁人的操纵技术。与此同时，东京埋藏着“废墟弹”的事实也被暴露了出来，那是铁人28号的开发者金田博士研制出来的最终兵器。如果这个武器爆炸的话，东京将化为一片灰烬。SHOUTAROU传达了金田博士的另一个遗言：废墟弹的所在地只有铁人才知道……。\r\n　　于是正太郎一行人开始积极准备废墟弹的回收处理工作。但却突然出现了一个名叫“白昼的残月”的复员兵人。他指责正太郎没有持有铁人的资格，并不断的企图杀死正太郎，干扰回收工作。\r\n　　现在，被铁人和废墟弹掩盖起来的可怕事实正在慢慢变得清晰……　　 ","date":"2007-03-31","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/8a/39/37264_nctZj.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/8a/39/37264_nctZj.jpg","large":"https://lain.bgm.tv/pic/cover/l/8a/39/37264_nctZj.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/8a/39/37264_nctZj.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/8a/39/37264_nctZj.jpg"},"rating":{"rank":0,"total":32,"score":6.5,"count":{"1":0,"2":0,"3":0,"4":0,"5":4,"6":10,"7":15,"8":3,"9":0,"10":0}},"tags":[{"name":"剧场版","count":20},{"name":"2007","count":14},{"name":"今川泰宏","count":13},{"name":"横山光輝","count":8},{"name":"萝卜","count":7},{"name":"机战","count":6},{"name":"漫画改","count":5},{"name":"铁人28号","count":4},{"name":"PALM"