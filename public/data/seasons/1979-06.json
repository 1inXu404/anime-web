[{"date":"1979-06-30","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/94/b4/309050_dg68a.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/94/b4/309050_dg68a.jpg","large":"https://lain.bgm.tv/pic/cover/l/94/b4/309050_dg68a.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/94/b4/309050_dg68a.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/94/b4/309050_dg68a.jpg"},"summary":"イギリスの小さな村の陶芸工マイヤーじいさんが作ったねずみの人形に生命が芽生えた。ウサギのように長い耳を持ち、青い体に短い尻尾のそれは、自分のことをトンデモネズミと名乗り、やがて冒険の旅に出る。冒険の途中、トンデモネズミはおばけのドロロン、鷹のキャプテンホーク、そして内向的な少女ウェンディたちと仲良しになる。旅を続け、苦難に立ち向かうことで勇気を学ぶトンデモネズミだったが、トンデモネズミを食べてしまおうとする謎の敵・トンデモネコの脅威が知らないうちに迫っているのだった。「日生ファミリー劇場」スペシャル番組として放送された、ファンタジーアニメーション。","name":"トンデモネズミ大活躍","name_cn":"","tags":[{"name":"TV","count":3,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"1979","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"70s","count":1,"total_cont":0}],"infobox":[{"key":"别名","value":[{"v":"Manxmouse"},{"v":"Tondemo Nezumi Daikatsuyaku"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"1979年6月30日"},{"key":"放送星期","value":"星期六"},{"key":"官方网站","value":"https://www.nippon-animation.co.jp/work/1324/"},{"key":"播放电视台","value":"フジテレビ系"},{"key":"导演","value":"森やすじ、百瀬義行"},{"key":"Copyright","value":"NIPPON ANIMATION CO., LTD."},{"key":"脚本","value":"雪室俊一、斎藤博"},{"key":"演出","value":"斎藤博"},{"key":"编集","value":"岡安肇、掛須秀一、小野寺桂子"},{"key":"制片人","value":"松土隆二"},{"key":"作画监督","value":"百瀬義行"},{"key":"美术监督","value":"山口俊和"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":3,"dropped":4,"wish":6,"collect":2,"doing":2},"id":309050,"eps":1,"meta_tags":["TV","日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]