[{"id":496280,"type":2,"name":"ドラえもん のび太と未来ノート","name_cn":"哆啦A梦：大雄与未来笔记本","summary":"《大雄与未来笔记本》（ドラえもん　のび太と未来ノート）为《哆啦A梦》的一个OVA动画，1994年由日本“新能源产业技术综合开发机构”（New Energy and Industrial Technology Development Organization，NEDO）企划，主要宣导能源相关事项。过去被称为梦幻动画，后来被收入《我、哆啦A梦》杂志第13号“哆啦A梦生日特辑”所附的DVD中，现今于网络亦可找到这支动画。","date":"2004-09-03","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ba/02/496280_aU4t7.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ba/02/496280_aU4t7.jpg","large":"https://lain.bgm.tv/pic/cover/l/ba/02/496280_aU4t7.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ba/02/496280_aU4t7.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ba/02/496280_aU4t7.jpg"},"rating":{"rank":0,"total":13,"score":7.1,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":7,"8":2,"9":0,"10":1}},"tags":[{"name":"OVA","count":6},{"name":"哆啦A梦","count":4},{"name":"2004","count":2},{"name":"2004年","count":2},{"name":"漫画改","count":1},{"name":"搞笑","count":1},{"name":"续作","count":1}],"eps":1,"collection":{"wish":12,"collect":37,"doing":1,"on_hold":6,"dropped":3}},{"id":40597,"type":2,"name":"수호요정 미셸","name_cn":"守护精灵","summary":"黑锤团伙是一个拥有强大武器和战斗机器人的高科技盗窃团伙，发誓要偷走所有“世界上最美丽的东西”，他们盗走了科学家白博士的发明四处为非作歹，甚至把贪婪带到了维系着地球自然和谐的精灵天堂——菩提岛。黑锤团伙绑架了精灵并冒险使用危险的激光把精灵一个个变为残忍的怪物……菩提岛精灵的守护者蒙奇与白博士的女儿楠为了一个共同的目标——拯救大自然、解救精灵们，决心联手追击这伙盗贼，从而展开了一场动人心魄的历险，表现了智慧、勇气与团结的永恒主题，也突出了人类应该与自然和谐共存的真谛。 ","date":"2004-09-06","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/66/f0/40597_69I76.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/66/f0/40597_69I76.jpg","large":"https://lain.bgm.tv/pic/cover/l/66/f0/40597_69I76.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/66/f0/40597_69I76.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/66/f0/40597_69I76.jpg"},"rating":{"rank":5138,"total":55,"score":6.1,"count":{"1":1,"2":1,"3":2,"4":6,"5":5,"6":17,"7":16,"8":4,"9":1,"10":2}},"tags":[{"name":"童年","count":21},{"name":"国产","count":16},{"name":"中韩合作","count":15},{"name":"TV","count":13},{"name":"守护精灵","count":8},{"name":