[{"date":"1950-07-01","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/7a/7a/634566_9qQdd.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/7a/7a/634566_9qQdd.jpg","large":"https://lain.bgm.tv/pic/cover/l/7a/7a/634566_9qQdd.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/7a/7a/634566_9qQdd.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/7a/7a/634566_9qQdd.jpg"},"summary":"　　旭日初升，暖暖的阳光照满院子的每一个角落，连缩聚到角落里的老鼠洞也感受到了阳光的召唤。杰瑞从香甜的梦中醒来，而旁边的小家伙还呼呼大睡。偶然瞥见墙上的日历，杰瑞惊喜地发现今天竟然是7月4日美国国庆日，他满心欢喜地叫醒了小老鼠，而那个还裹着尿布的小家伙比杰瑞还激动，端出了整整一箱烟花爆竹要跑到外边燃放。作为第一监护人，杰瑞自然不会允许小家伙做这种危险的事情，他夺下小家伙手中的烟花，只给他儿童的玩具玩耍。小家伙毫不就范，接连拿出私藏的爆竹，致使杰瑞一次次被炸得满面漆黑。\r\n　　与此同时，汤姆暗中向杰瑞伸出毒手。眼见得最敬爱的杰瑞叔叔落难，小家伙与汤姆进行了一场烟火大战……","name":"Safety Second","name_cn":"爆竹风波","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"爆竹风波"},{"key":"上映年度","value":"1950年7月1日"},{"key":"片长","value":"6分钟"},{"key":"导演","value":"Joseph Barbera,William Hanna"},{"key":"IMDb","value":"tt0042916"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":0,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634566,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]