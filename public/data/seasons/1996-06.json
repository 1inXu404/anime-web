[{"date":"1996-06-29","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/21/6d/34459_4R2p9.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/21/6d/34459_4R2p9.jpg","large":"https://lain.bgm.tv/pic/cover/l/21/6d/34459_4R2p9.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/21/6d/34459_4R2p9.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/21/6d/34459_4R2p9.jpg"},"summary":"学校の怪談などの都市伝説に登場する幽霊少女「トイレの花子さん」をメインキャラクターにした、ジュブナイルホラー風味のアニメ映画。\r\n小学生・大介はある日、北校舎３階のトイレで幽霊少女の「花子さん」に出会った。花子さんは、もうじきみんなの周囲で「取りかえっこ」が始まると警告。その内、大介の担任・よしこ先生が学校を休み、替わりに強面の教師・岩山岩男が現れる。やがて大介と友人のかおり、なおやたちは、オバケの魔王が人間とオバケ、その双方の子供を取り替えようとしているのだと知った……。\r\n監督は『こどものおもちゃ』『おじゃる丸』の大地丙太郎が担当。本作の花子さんは、悪いオバケたちに立ち向かい、子供たちを守ってくれる優しいお友達的な存在として描かれた。男子主人公・大介のCVは、21世紀に新生『ドラえもん』を演じる水田わさび。","name":"トイレの花子さん","name_cn":"厕所里的花子","tags":[{"name":"剧场版","count":14,"total_cont":0},{"name":"1996","count":8,"total_cont":0},{"name":"原创","count":6,"total_cont":0},{"name":"大地丙太郎","count":5,"total_cont":0},{"name":"妖怪","count":3,"total_cont":0},{"name":"搞笑","count":2,"total_cont":0},{"name":"平見瞠","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"少萌里的那个NETA？！","count":1,"total_cont":0},{"name":"渕崎ゆり子","count":1,"total_cont":0},{"name":"1990s","count":1,"total_cont":0},{"name":"独立剧场版","count":1,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0},{"name":"1996年","count":1,"total_cont":0},{"name":"MULTIBOX","count":1,"total_cont":0},{"name":"95-99","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"剧场","count":1,"total_cont":0},{"name":"矢島晶子","count":1,"total_cont":0},{"name":"齋藤彩夏","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"厕所里的花子"},{"key":"上映年度","value":"1996年6月29日"},{"key":"片长","value":"30min"},{"key":"监督","value":"大地丙太郎"},{"key":"作画监督","value":"楠本祐子"},{"key":"脚本","value":"平見瞠"},{"key":"音乐","value":"馬飼野康二"},{"key":"音响监督","value":"田中一也"},{"key":"角色设定","value":"宮崎なぎさ"},{"key":"演出","value":"高柳哲司"},{"key":"製作","value":"映画「忍たま乱太郎」製作委員会"},{"ke