6/87332_uul8o.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ef/06/87332_uul8o.jpg","large":"https://lain.bgm.tv/pic/cover/l/ef/06/87332_uul8o.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ef/06/87332_uul8o.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ef/06/87332_uul8o.jpg"},"summary":"『攻殻機動隊』の士郎正宗の原案によるSFアドベンチャーファンタジーOVA。各巻およそ50分弱の上下2巻がリリースされた。最終戦争を経て文明と大自然が交錯する混沌の時代。ある村で暮らす少年ルーダは、風を操る「風使い」の村長ムーグから息子同然に育てられ、現在に至っていた。紅い瞳の右目を持つルーダと同様、ムーグの実娘である巫女アンサもまた左目に蒼い眼を宿している。そんな村に軍事国家のゾロアース軍が侵攻を開始した。ある目的からゾロアース軍司令官ザナークは「風の力」を有するというルーダを狙い、娘として育てた攻撃司令官アガハリを差し向ける。だがアガハリも蒼い左目を持つ一人であり、実は彼女こそ幼い頃に生き別れたアンサの姉だった。かつての大戦で大地（ランド）に封印（ロック）されたという最終兵器をめぐる物語がここにはじまる……。本作の実制作は『超特急ヒカリアン』などの東京キッズが担当。本OVA刊行に先駆けて文化放送でラジオドラマも展開された。","name":"ランドロック","name_cn":"封闭的神秘大地","tags":[{"name":"OVA","count":10,"total_cont":0},{"name":"奇幻","count":4,"total_cont":0},{"name":"独立ova","count":3,"total_cont":0},{"name":"旧","count":2,"total_cont":0},{"name":"士郎正宗","count":2,"total_cont":0},{"name":"1996年","count":1,"total_cont":0},{"name":"风","count":1,"total_cont":0},{"name":"松村やすひろ","count":1,"total_cont":0},{"name":"复仇","count":1,"total_cont":0},{"name":"中庸","count":1,"total_cont":0},{"name":"天野由梨","count":1,"total_cont":0},{"name":"绪方惠美","count":1,"total_cont":0},{"name":"柏仓敦","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"漫画改","count":1,"total_cont":0},{"name":"人设美","count":1,"total_cont":0},{"name":"1996","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"封闭的神秘大地"},{"key":"别名","value":[{"k":"英文名","v":"LANDLOCK"}]},{"key":"话数","value":"2"},{"key":"发售日","value":"1996年6月21日"},{"key":"开始","value":"1996年6月21日"},{"key":"结束","value":"1996年9月27日"}],"rating":{"rank":0,"total":9,"count":{"1":0,"2":0,"3":0,"4":1,"5":4,"6":3,"7":1,"8":0,"9":0,"10":0},"score":5.4},"total_episodes":0,"collection":{"on_hold":1,"dropped":5,"wish":17,"collect":16,"doing":0},"id":87332,"eps":2,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1996-0