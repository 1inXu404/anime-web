[{"date":"1979-05-19","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d4/e8/13012_v9QuO.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d4/e8/13012_v9QuO.jpg","large":"https://lain.bgm.tv/pic/cover/l/d4/e8/13012_v9QuO.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d4/e8/13012_v9QuO.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d4/e8/13012_v9QuO.jpg"},"summary":"　　商末时期，陈塘关总兵李靖的夫人怀胎3年6个月，最终生下一个肉球，肉球中跳出一个伶俐可爱的男孩。李靖原当他是妖孽欲杀之而后快，幸太乙真人前来收之为徒，赐名哪吒，并赐以乾坤圈和混天绫两件宝贝。某年，天下大旱，甘露未降。哪吒和家将到东海洗澡玩耍。他用混天绫搅动海水，撼动龙宫，惹出巡海夜叉李艮和龙王三太子敖丙。几番言语不和，哪吒杀此二人，由此闯下通天大祸。四海龙王齐聚陈塘关索命，为救一方百姓，哪吒决定交出生命……\r\n　　本片根据《封神演义》故事改编，并荣获1980年电影百花奖最佳美术片奖；文化部1979年优秀影片奖、青年优秀创作奖；1983年菲律宾马尼拉国际电影节特别奖；1988年法国布尔波拉斯文化俱乐部青年国际动画电影节评委奖和宽银幕长动画片奖。  ","name":"哪吒闹海","name_cn":"哪吒闹海","tags":[{"name":"国产","count":564,"total_cont":0},{"name":"上海美术电影制片厂","count":475,"total_cont":0},{"name":"童年","count":390,"total_cont":0},{"name":"剧场版","count":242,"total_cont":0},{"name":"1979","count":190,"total_cont":0},{"name":"剥龙皮抽龙筋","count":95,"total_cont":0},{"name":"动画电影","count":87,"total_cont":0},{"name":"国产动画","count":73,"total_cont":0},{"name":"经典","count":57,"total_cont":0},{"name":"童年的经典","count":45,"total_cont":0},{"name":"人兽SM","count":40,"total_cont":0},{"name":"小说改","count":40,"total_cont":0},{"name":"中国","count":37,"total_cont":0},{"name":"童年系","count":22,"total_cont":0},{"name":"小时候","count":15,"total_cont":0},{"name":"神话","count":13,"total_cont":0},{"name":"电影","count":11,"total_cont":0},{"name":"奇幻","count":11,"total_cont":0},{"name":"玄幻","count":9,"total_cont":0},{"name":"战斗","count":7,"total_cont":0},{"name":"1970s","count":7,"total_cont":0},{"name":"严定宪","count":7,"total_cont":0},{"name":"王树忱","count":6,"total_cont":0},{"name":"上美","count":6,"total_cont":0},{"name":"徐景达","count":6,"total_cont":0},{"name":"1979年","count":5,"total_cont":0},{"name":"中国动画","count":5,"total_cont":0},{"name":"映画","count":5,"total_cont":0},{"name":"原创","count":5,"total_cont":0},{"name":"国漫","count":5,"total_co