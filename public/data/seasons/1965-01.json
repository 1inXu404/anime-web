.tv/r/200/pic/cover/l/88/4c/53750_504R1.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/88/4c/53750_504R1.jpg","large":"https://lain.bgm.tv/pic/cover/l/88/4c/53750_504R1.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/88/4c/53750_504R1.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/88/4c/53750_504R1.jpg"},"summary":"　本邦TVアニメの黎明期にあって初となる、原作を持たないオリジナルSFヒーローアニメ。30世紀のタイムパトロール隊員ジェッターは、悪人ジャガーを追跡中の事故により共に1000年前の時代へと放り出されてしまう。ジェッターはそこで知り合った国際科学捜査局の西郷長官と協力し、女流カメラマンの水島かおるとコンビを組んで、20世紀の平和を守るべく戦うことになった。周囲の時間を30秒だけ停止させるタイムストッパー、電撃を放つ銃パラライザー、空を飛べる反重力ベルト、そしてマッハ15で突っ走る乗機・流星号……といった数々の未来科学を駆使するジェッターはまさに無敵だ！　人気作家・筒井康隆が企画段階より制作に参加しており、彼を始めとしたスタッフにより考案された各種SF設定は、当時の子供たちを虜にした。本作は白黒アニメ番組だが、後に相応のエピソードがカラーでリメイクされている。","name":"未来から来た少年 スーパージェッター","name_cn":"来自未来的少年超级杰特","tags":[{"name":"TV","count":3,"total_cont":0},{"name":"1965","count":3,"total_cont":0},{"name":"TCJ動画センター","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"河島治之","count":1,"total_cont":0},{"name":"TCJ","count":1,"total_cont":0},{"name":"松島みのり","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"黑白","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"SF","count":1,"total_cont":0},{"name":"60s","count":1,"total_cont":0},{"name":"市川治","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"来自未来的少年超级杰特"},{"key":"话数","value":"52"},{"key":"放送开始","value":"1965年1月7日"},{"key":"播放结束","value":"1966年1月20日"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":0,"8":0,"9":1,"10":0},"score":6.7},"total_episodes":0,"collection":{"on_hold":3,"dropped":7,"wish":13,"collect":6,"doing":2},"id":53750,"eps":52,"meta_tags":["TV","日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1965-01-03","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ff/46/208760_sA1Kk.jpg","grid":"https://lain.bgm.tv/r/100/pic/cov