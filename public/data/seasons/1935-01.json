[{"date":"1935-01-19","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e8/7b/133798_iyCIp.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e8/7b/133798_iyCIp.jpg","large":"https://lain.bgm.tv/pic/cover/l/e8/7b/133798_iyCIp.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e8/7b/133798_iyCIp.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e8/7b/133798_iyCIp.jpg"},"summary":"　　蔚蓝的大海之上，米奇（华特·迪士尼 Walt Disney 配音）驾驶着他的小船一路前行。可是浪头突然变得分外汹涌，他的船完全失去控制，被推到了一座小岛之上，在礁石上撞得粉碎。晕头转向的米奇站起身来，听到附近传来阵阵鼓声。他从树丛里张望过去，只见一群土著载歌载舞进行某种仪式，而在一口沸腾的油锅上面，一个黑人土著正被迫迈向死亡。米奇急中生智，做出了一个怪物吓跑土著，救下那个可怜的牺牲品，并为他起名星期五（比利·布莱彻 Billy Bletcher 配音）。 \r\n　　开心的米奇和星期五约定建一个坚固的堡垒，防止凶恶的土著们入侵。果不其然，当堡垒建好的那一刻，愤怒的土著们卷土重来……","name":"Mickey's Man Friday","name_cn":"米奇的鲁滨逊漂流记","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"1935","count":1,"total_cont":0},{"name":"1930s","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"迪士尼","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"米奇的鲁滨逊漂流记"},{"key":"上映年度","value":"1935-01-19"},{"key":"片长","value":"8分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0026709"},{"key":"主演","value":"利·布莱彻 / 华特·迪斯尼"},{"key":"类型","value":"短片 / 家庭"},{"key":"制片国家/地区","value":"美国"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":1,"9":0,"10":0},"score":6.6},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":5,"collect":15,"doing":1},"id":133798,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1935-01-05","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/63/38/132358_LIZyD.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/63/38/132358_LIZyD.jpg","large":"https://lain.bgm.tv/pic/cover/l/63/38/132358_LIZyD.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/63/38/132358_LIZyD.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/63/38/132358_LIZyD.jpg"},"summary":"      热闹的森林里正在举行跑步比赛，参赛双方实力悬殊。一边是有蓝色飞毛腿之称的巨兔，另一边老态龙钟、步履蹒跚的老乌龟。巨兔傲慢无礼，丝毫不把这个无精打采的老家伙放在眼里，甚至对其肆无忌惮地嘲弄。老乌龟性格善良，对巨兔的恶意玩笑似乎全无知觉。随着一声枪响，巨兔如旋风一般冲出起跑线，而他的对手则被巨大的声响吓得缩入壳中。对手的软弱更令巨兔的傲慢肆意膨胀，他或者躺在路边睡觉，或者和赛道边上的小母兔们调情，或者炫耀其敏捷的身手。老乌龟则一如既往，坚定地向终点跑去…… \r\n　　本片荣获1935年奥斯卡金像奖最佳动画短片奖。","name":"The Tortoise and the Hare","name_cn":"乌龟与兔子","tags":[{"name":"短片","count":39,"total_cont":0},{"name":"欧美","count":20,"total_cont":0},{"name":"1935","count":15,"total_cont":0},{"name":"Disney","count":13,"total_cont":0},{"name":"迪士尼","count":12,"total_cont":0},{"name":"奥斯卡","count":12,"total_cont":0},{"name":"美国","count":10,"total_cont":0},{"name":"龟兔赛跑","count":6,"total_cont":0},{"name":"欢乐","count":5,"total_cont":0},{"name":"寓言","count":5,"total_cont":0},{"name":"1930s","count":4,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"音乐节拍剧","count":2,"total_cont":0},{"name":"1935年","count":1,"total_cont":0},{"name":"WilfredJackson","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"JeandelaFontaine","count":1,"total_cont":0},{"name":"undefined","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"子供向","count":1,"total_cont":0},{"name":"短片&OVA","count":1,"total_cont":0},{"name":"弱6","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"Silly-Symphony","count":1,"total_cont":0},{"name":"Wilfred·Jackson","count":1,"total_cont":0},{"name":"Oscars","count":1,"total_cont":0},{"name":"动物","count":1,"total_cont":0},{"name":"30s","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"乌龟与兔子"},{"key":"别名","value":[{"v":"龟兔赛跑"}]},{"key":"上映年度","value":"1935-01-05"},{"key":"片长","value":"9 分钟"},{"key":"语言","value":"英语"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 家庭"},{"key":"导演","value":"Wilfred Jackson"},{"key