-01-07","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/fd/2a/53794_n0RNk.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/fd/2a/53794_n0RNk.jpg","large":"https://lain.bgm.tv/pic/cover/l/fd/2a/53794_n0RNk.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/fd/2a/53794_n0RNk.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/fd/2a/53794_n0RNk.jpg"},"summary":"　　脱生于顽石中的孙悟空曾经雄霸一方，靠剪径为生。后来被邪恶的国王关在监狱中，偶遇小龙女，在此之后拜入龙海仙人门下，不仅学得七十二般变化，还得到宝贝如意金箍棒。本领大增的孙悟空啸聚山林，劫富济贫，甚至惊动天庭，惹出大闹天宫的连场好戏。最后终因自不量力，被如来佛祖压在五指山下。借助胆小如鼠的唐僧的帮助，孙悟空重获自由，之后他们遇到穿西装戴领结的猪八戒还有爱财如命四处挖宝藏的沙悟净，师徒一行由此展开了险象环生、乐趣无穷的西天大冒险……","name":"悟空の大冒険","name_cn":"悟空的大冒险","tags":[{"name":"TV","count":12,"total_cont":0},{"name":"童年","count":10,"total_cont":0},{"name":"1967","count":9,"total_cont":0},{"name":"漫画改","count":7,"total_cont":0},{"name":"西游记","count":6,"total_cont":0},{"name":"子供向","count":6,"total_cont":0},{"name":"手塚治虫","count":6,"total_cont":0},{"name":"虫Production","count":3,"total_cont":0},{"name":"童年系列","count":3,"total_cont":0},{"name":"童年系","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"出﨑統","count":2,"total_cont":0},{"name":"漫改","count":1,"total_cont":0},{"name":"60年代","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"小龙女","count":1,"total_cont":0},{"name":"60s","count":1,"total_cont":0},{"name":"补","count":1,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"YL","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"1970.00","count":1,"total_cont":0},{"name":"高橋良輔","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"悟空的大冒险"},{"key":"别名","value":[{"v":"Gokuu no Daibouken"}]},{"key":"话数","value":"39"},{"key":"放送开始","value":"1967年1月7日"},{"key":"放送星期","value":"星期六"},{"key":"播放结束","value":"1967年9月30日"}],"rating":{"rank":0,"total":26,"count":{"1":0,"2":0,"3":1,"4":1,"5":1,"6":7,"7":8,"8":3,"9":3,"10":2},"score":7},"