杜子春は仙人に頼み込み、自分も貴方のようになりたいと願う。だが相手の仙人が出した課題、それは試練の間、絶対に口を利かないというものだった。壮絶な苦難の中、無言を貫く杜子春だが……。番組製作は『まんが世界昔ばなし』などのダックス・インターナショナルで、アニメ実制作はスタジオ古留美が担当。古留美の『さすらいの少女ネル』や東京ムービー（現トムスエンターテインメント）の『ガンバの冒険』などの名アニメーター樺島義夫がキャラクターデザインと作画監督を担当。樺島と縁が深い演出家・西牧秀夫がチーフディレクターを務めた。実写映画『天平の甍』の美術スタッフ・木村威夫も、美術考証を手がける。","name":"杜子春","name_cn":"杜子春","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"80s","count":1,"total_cont":0},{"name":"小说改","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"TV","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"杜子春"},{"key":"话数","value":"1"},{"key":"放送开始","value":"1981年4月12日"},{"key":"导演","value":"斉藤武市"},{"key":"片长","value":"70分钟"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":1,"7":0,"8":0,"9":0,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":2,"dropped":3,"wish":3,"collect":7,"doing":1},"id":312031,"eps":1,"meta_tags":["TV","小说改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1981-04-11","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/49/82/326201_Z8aF5.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/49/82/326201_Z8aF5.jpg","large":"https://lain.bgm.tv/pic/cover/l/49/82/326201_Z8aF5.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/49/82/326201_Z8aF5.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/49/82/326201_Z8aF5.jpg"},"summary":"1981年4月，作为株式会社KnacK的第一部剧场版动画上映。动画改编自植田正志的《碰丁先生传》。","name":"フリテンくん","name_cn":"碰丁先生传","tags":[{"name":"旧物","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"碰丁先生传"},{"key":"别名","value":[{"v":"顽皮大师"},{"v":"凸槌阿新"}]},{"key":"上映年度","value":"1981年4月11日"},{"key":"片长","value":"75分钟"},{"key":"动画制作","value":"ナック映画"},{"key":"原作","value":"植田まさし"},{"key":"导演","value":"杉山卓"},{"key":"脚本","value":"城山昇、伊東恒久、山崎晴哉、杉山卓"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":1,"4":0,"5":1,"6":1,"7":0,"8":1,"9":0,"10":0},