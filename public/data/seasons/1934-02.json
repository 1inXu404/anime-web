[{"date":"1934-02-10","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0b/ce/137112_Tp53a.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0b/ce/137112_Tp53a.jpg","large":"https://lain.bgm.tv/pic/cover/l/0b/ce/137112_Tp53a.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0b/ce/137112_Tp53a.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0b/ce/137112_Tp53a.jpg"},"summary":"　　春去秋来，正是丰收的黄金季节。青草绿叶还未退去绿色的衣装，宜人的天气让所有的生灵都沉湎其中。远处传来了愉快的歌声和小提琴声，那是四处流浪的蚱蜢演奏的乐而无忧的乐曲，他歌唱美好的生活，歌唱当下的逍遥自在，一切仿佛如青草绿叶一般唾手可得，不值得珍惜。这时，蚱蜢看见附近的大树下，蚂蚁们正辛勤地搬运食物。这群勤劳的小生命知晓寒冷的冬天将近，于是抓紧时间储备过冬的粮食。可在蚱蜢看来，蚂蚁们的举止不仅不解风情，简直浪费了当下的大好时光。他鼓励疲于奔命的小蚂蚁和他畅快歌舞，这可惹恼了威严的蚂蚁女王。 \r\n　　在女王看来，没有劳动就没有食物……","name":"The Grasshopper and the Ants","name_cn":"蚱蜢与蚂蚁","tags":[{"name":"短片","count":8,"total_cont":0},{"name":"1934","count":5,"total_cont":0},{"name":"Disney","count":4,"total_cont":0},{"name":"欧美","count":4,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"Wilfred·Jackson","count":1,"total_cont":0},{"name":"Wilfred.Jackson","count":1,"total_cont":0},{"name":"Silly-Symphony","count":1,"total_cont":0},{"name":"30s","count":1,"total_cont":0},{"name":"1930s","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"蚱蜢与蚂蚁"},{"key":"上映年度","value":"1934-02-10"},{"key":"片长","value":"8:24"},{"key":"制片国家/地区","value":"美国"},{"key":"语言","value":"英语"},{"key":"导演","value":"Wilfred Jackson"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":12,"count":{"1":1,"2":0,"3":1,"4":0,"5":4,"6":3,"7":3,"8":0,"9":0,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":3,"collect":27,"doing":0},"id":137112,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]