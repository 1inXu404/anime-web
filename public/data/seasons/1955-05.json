[{"date":"1955-05-21","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c1/7a/634780_V8b5p.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c1/7a/634780_V8b5p.jpg","large":"https://lain.bgm.tv/pic/cover/l/c1/7a/634780_V8b5p.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c1/7a/634780_V8b5p.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c1/7a/634780_V8b5p.jpg"},"summary":"　　无聊慵懒的一天，汤姆躺在沙发上，一边翘着二郎腿一边阅读报纸。当女主人经过时，他假装乖巧趴在地上睡觉，使主人放松警惕。突然，一则新闻映入眼帘，某宠物店刊登启事，高价收购白老鼠一只。汤姆见钱眼开，计上心头，用假的奶酪骗出杰瑞，并将其刷成白色卖给宠物店。他贪婪地拿钱回家，将钱藏到沙发的地毯下，做起了挥金如土的美梦。谁知女主人发现了这笔钱，于是决定外出逛街消费。\r\n　　汤姆无比郁闷，当然更郁闷的还在后面，因为女主人买回来的竟然就是那只假冒白老鼠——汤姆的老冤家杰瑞……","name":"Mouse for Sale","name_cn":"老鼠出售","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"老鼠出售"},{"key":"上映年度","value":"1955年5月21日"},{"key":"片长","value":"06:54"},{"key":"IMDb","value":"tt0048390"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":1,"8":0,"9":0,"10":0},"score":6},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634780,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1955-05-17","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/44/bc/646090_sizV1.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/44/bc/646090_sizV1.jpg","large":"https://lain.bgm.tv/pic/cover/l/44/bc/646090_sizV1.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/44/bc/646090_sizV1.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/44/bc/646090_sizV1.jpg"},"summary":"A man wakes up in his grave and realizes that he’s been buried alive. He gets up and arrives home only to find out that his wife and relatives threw a party instead of mourning, looking forward to his big inheritance.","name":"Jubilej gospodina Ikla","name_cn":"","tags":[],"infobox"