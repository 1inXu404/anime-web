at Pup","name_cn":"小鬼难缠","tags":[{"name":"短片","count":21,"total_cont":0},{"name":"猫和老鼠","count":9,"total_cont":0},{"name":"欧美","count":8,"total_cont":0},{"name":"1949","count":7,"total_cont":0},{"name":"美国","count":6,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"原创","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"剧场版-02","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"小鬼难缠"},{"key":"上映年度","value":"1949-10-01"},{"key":"片长","value":"7分55秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":33,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":8,"7":16,"8":6,"9":1,"10":0},"score":6.9},"total_episodes":0,"collection":{"on_hold":1,"dropped":4,"wish":2,"collect":85,"doing":1},"id":275356,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":null,"platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/8c/26/377943_8CVz4.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/8c/26/377943_8CVz4.jpg","large":"https://lain.bgm.tv/pic/cover/l/8c/26/377943_8CVz4.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/8c/26/377943_8CVz4.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/8c/26/377943_8CVz4.jpg"},"summary":"異才アニメーター・瀬尾光世が日本漫画映画社で企画製作した、当時（1949年）としては大作の中編アニメ。\r\n　狐の王国に王子が誕生。だが王子には、あるべきハズのシッポが無かった。これを気にかけた重臣たちは、国民の狐全員に、今後シッポを王子の前で見せてはならないとお告げを出した。そうとは知らぬままシッポが無いのを当たり前に育つ王子だが、やがて彼はこのカラクリに気がついてしまい……。\r\n「裸の王様」ほか『アンデルセン童話』の諸編を下敷きにした内容。当時としては多数のアニメーターと作画枚数を導入し、その一方、資金難で何度も中座しかけたもののどうにか完成。さらに47分の本編を33分にカットして公開を待っていたが、内容が左翼的（当時の言葉で「アカ」）だと配給の東宝に認定され、オクラ入りの憂き目にあった。瀬尾はこれを理由にアニメ界を去り、そんな多くの逸話を残す作品である。","name":"王様のしっぽ","name_cn":"国王的尾巴","tags":[{"name":"空","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value"