[{"date":"1947-07-12","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/32/1e/263189_2rhi0.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/32/1e/263189_2rhi0.jpg","large":"https://lain.bgm.tv/pic/cover/l/32/1e/263189_2rhi0.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/32/1e/263189_2rhi0.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/32/1e/263189_2rhi0.jpg"},"summary":"　　阳光夏日海滩，身着红色泳衣的汤姆热情高涨，快乐地冲向充满垃圾的大海。虽然在垃圾和沙滩上干蹭了半天，不过他还是快乐非常。游了一圈垃圾泳后，汤姆蹦蹦跳跳走上岸来，这时美丽的母猫图丝引起了他的注意，以至于不小心都跌入了臭烘烘的垃圾桶中。不过汤姆不以为意，他继续向图丝搭讪，然而旁边便当篮里传来的声响打扰了他的约会。发出声响的是穿着红色游泳裤的杰瑞，他在篮子内大快朵颐，忘乎所以，甚至咬破了汤姆的手。 \r\n　　愤怒的汤姆一路追杀小杰瑞，没想到惹上了藏在石头缝中的绿色大螃蟹，本就闹哄哄的猫鼠大战，加上螃蟹的参与，变得更加激烈起来……","name":"Salt Water Tabby","name_cn":"海水玩具鸭","tags":[{"name":"短片","count":20,"total_cont":0},{"name":"欧美","count":9,"total_cont":0},{"name":"猫和老鼠","count":9,"total_cont":0},{"name":"1947","count":7,"total_cont":0},{"name":"米高梅","count":5,"total_cont":0},{"name":"美国","count":5,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"1940-1949","count":2,"total_cont":0},{"name":"搞笑","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"1940s","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"海水玩具鸭"},{"key":"上映年度","value":"1947-07-12"},{"key":"片长","value":"7分17秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":40,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":7,"7":19,"8":10,"9":2,"10":1},"score":7.2},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":3,"collect":83,"doing":1},"id":263189,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1947-07-11","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/cb/c9/243246_xrnHV.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/cb/c9/243246_xrnHV.jpg","large":"https://lain.bgm.tv/pic/cover/l/cb/c9/243246_xrnHV.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/cb/c9/243246_xrnHV.jpg","common