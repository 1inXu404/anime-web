[{"date":"1958-04-05","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/3b/2c/408085_p25ob.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/3b/2c/408085_p25ob.jpg","large":"https://lain.bgm.tv/pic/cover/l/3b/2c/408085_p25ob.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/3b/2c/408085_p25ob.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/3b/2c/408085_p25ob.jpg"},"summary":"　東映動画（現・東映アニメーション）が、ごく初期に制作したファンタジーアニメ。\r\n　夢の世界を支配する不思議な人物・夢見童子。彼が木下で昼寝をしながら夢を見ていると、子供たちがやってきてそれぞれ好き勝手な夢を見たい、と願う。だが童子は、欲深い子供たちの望む夢をそのまま見させてやる気はなかった。そんな中、一人の少女が童子に、お腹が空きませんか、と貴重な卵を持ってきた。少女の無欲な優しさに感心した童子は、この女の子の願う夢を見させてやろうと思う。\r\n　大勝末期から昭和初期にかけて、挿し絵画家として活躍した蕗谷虹児。そんな彼を構成、演出、作画スタッフに迎えて制作した作品。題材となる伝承は本来は江戸時代のものだが、アニメでは天平時代の出来事に脚色された。","name":"夢見童子","name_cn":"梦见童子","tags":[{"name":"1958","count":7,"total_cont":0},{"name":"东映","count":5,"total_cont":0},{"name":"剧场版","count":5,"total_cont":0},{"name":"短片","count":4,"total_cont":0},{"name":"蕗谷虹儿","count":3,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"蕗谷虹児","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"短篇","count":1,"total_cont":0},{"name":"东映动画","count":1,"total_cont":0},{"name":"东映アニメーション","count":1,"total_cont":0},{"name":"1958年","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"梦见童子"},{"key":"上映年度","value":"1958年4月5日"},{"key":"片长","value":"16min"},{"key":"导演","value":"蕗谷虹児"},{"key":"构成","value":"蕗谷虹児"},{"key":"演出","value":"蕗谷虹児"},{"key":"企划","value":"赤川孝一、山本早苗"},{"key":"背景美术","value":"糸井俊二"},{"key":"音乐","value":"伊藤宣二"},{"key":"录音","value":"森武"},{"key":"摄影","value":"石川光明"},{"key":"进行","value":"茂呂清一"},{"key":"作画","value":"長沼寿美子、加藤洋子、寺千賀雄、太宰真知子、喜多真佐武、進藤みつ子、藤井武、山田みよ、松隈玉江、伊藤澄子、中島清、前場孝一"},{"key":"动画制作","value":"東映動画スタジオ（現・東映アニメーション）"},{"key":"製作","value":"東映教育映画部"}],"rating":{"rank":0,"total":6,"count":{"1":1,"2":0,"3":0,"4":1,"5":0,"6":2,"7":1,"8":1,"9":0,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":2,"droppe