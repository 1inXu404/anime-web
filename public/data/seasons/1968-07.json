无数导演来说是一个灯塔，处处给予艺术家以灵感，并且毫无疑问是在共产主义的捷克斯洛伐克的专制环境下浮现出的重要艺术品。尽管这些作品都是超现实主义的，但Svankmajer以电影为手段探索了社会习俗、社会阶层及其相互作用等问题。","name":"Rakvickarna","name_cn":"棺材与天竺鼠","tags":[{"name":"短片","count":19,"total_cont":0},{"name":"1966","count":12,"total_cont":0},{"name":"杨·史云梅耶","count":9,"total_cont":0},{"name":"欧美","count":8,"total_cont":0},{"name":"JanŠvankmajer","count":4,"total_cont":0},{"name":"Švankmajer","count":3,"total_cont":0},{"name":"捷克斯洛伐克","count":3,"total_cont":0},{"name":"定格动画","count":2,"total_cont":0},{"name":"欧洲","count":2,"total_cont":0},{"name":"捷克动画","count":2,"total_cont":0},{"name":"60年代","count":2,"total_cont":0},{"name":"undefined","count":1,"total_cont":0},{"name":"1968","count":1,"total_cont":0},{"name":"上世纪","count":1,"total_cont":0},{"name":"60a","count":1,"total_cont":0},{"name":"Jan.Švankmajer","count":1,"total_cont":0},{"name":"cult","count":1,"total_cont":0},{"name":"欧美动画","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"Jan","count":1,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"无","count":1,"total_cont":0},{"name":"Athanor","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"棺材与天竺鼠"},{"key":"别名","value":[{"v":"Punch and Judy"}]},{"key":"上映年度","value":"1968-07-18"},{"key":"片长","value":"10 分钟"},{"key":"导演","value":"Jan Švankmajer"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":36,"count":{"1":0,"2":0,"3":1,"4":3,"5":4,"6":5,"7":10,"8":10,"9":1,"10":2},"score":6.8},"total_episodes":0,"collection":{"on_hold":1,"dropped":3,"wish":5,"collect":59,"doing":1},"id":188813,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1968-07-17","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c0/b4/112397_Az5ym.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c0/b4/112397_Az5ym.jpg","large":"https://lain.bgm.tv/pic/cover/l/c0/b4/112397_Az5ym.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c0/b4/112397_Az5ym.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c0/b4/112397_Az5ym.jpg"},"summary":"本片是一部将伟大的摇滚乐队披头士的音乐和波普视觉艺术完美结合而成的二维插画风格的动画片，整部片子中共穿插了披头士的15首经典歌曲。影片讲述了披头士成员保罗·麦卡特尼在半梦半醒之间来到花椒国，这是一个讨厌音乐的地方，正遭遇蓝色恶魔的侵略，老船长弗莱德召集披头士成员一同乘坐黄色潜水艇共同保卫花椒国。 \r\n　　披头士音乐贯穿整个影片中：影片开头用George Martin（乔治·马丁，披头士音乐制作人）的弦乐描述祥和的花椒国，接着由Ringo Starr (林格·斯塔尔，披头士鼓手)演唱的“黄色潜水艇”(Yellow Submarine)则象征着花椒人民的朝气蓬勃。然而好景不长，坏蛋蓝心恶魔开始破坏花椒国的快乐与宁静，老船长征召披头士成员“一起来吧”(Come Together)，联手抗击蓝心恶魔，披头士成员装扮成花椒军士在“帕伯军士孤独之心俱乐部乐队”(Sgt Peppers Lonely Heart Club Band)的音乐中击溃了敌人，维护了他们的信念——“你需要的就是爱”（All You Need Is Love），拯救了花椒国。","name":"Yellow Submarine","name_cn":"黄色潜水艇","tags":[{"name":"剧场版","count":80,"total_cont":0},{"name":"1968","count":61,"total_cont":0},{"name":"欧美","count":58,"total_cont":0},{"name":"Beatles","count":41,"total_cont":0},{"name":"音乐","count":38,"total_cont":0},{"name":"英国","count":29,"total_cont":0},{"name":"英国动画","count":19,"total_cont":0},{"name":"原创","count":19,"total_cont":0},{"name":"GeorgeDunning","count":14,"total_cont":0},{"name":"动画电影","count":10,"total_cont":0},{"name":"电影","count":9,"total_cont":0},{"name":"1960s","count":5,"total_cont":0},{"name":"映画","count":5,"total_cont":0},{"name":"60年代","count":5,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"George.Dunning","count":2,"total_cont":0},{"name":"实验动画","count":2,"total_cont":0},{"name":"奇幻","count":2,"total_cont":0},{"name":"1960-1969","count":2,"total_cont":0},{"name":"fantasy","count":1,"total_cont":0},{"name":"AlBrodax","count":1,"total_cont":0},{"name":"Film","count":1,"total_cont":0},{"name":"movie","count":1,"total_cont":0},{"name":"Paul.Driessen","count":1,"total_cont":0},{"name":"剧场动画","count":1,"total_cont":0},{"name":"剧场","count":1,"total_cont":0},{"name":"乐队？","count":1,"total_cont":0},{"name":"冒险","count":1,"total_cont":0},{"name":"LeeMinoff","count":1,"total_cont":0},{"name":"评分略","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"黄色潜水艇"},{"key":"别名","value":[{"v":"黄色潜艇"},{"v":"黄色的潜水艇"},{"v":"The Beatles' Yellow Submarine"}]},{"key":