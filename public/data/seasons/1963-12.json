[{"date":"1963-12-25","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a9/93/64096_8cZc3.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a9/93/64096_8cZc3.jpg","large":"https://lain.bgm.tv/pic/cover/l/a9/93/64096_8cZc3.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a9/93/64096_8cZc3.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a9/93/64096_8cZc3.jpg"},"summary":"      当小华特（Wart）从屋顶掉进了梅林法师的家中时，就已注定他传奇的命运了。神奇的梅林法师是如何教导华特的呢？不小心撞进女巫家的华特会不会有危险呢？伦敦的比武大赛就要开始了，会有什么奇异的事发生呢？\r\n      在本片中，迪士尼把传说中那位魔法高强、十分有名的梅林魔法师被塑造成一个漫不经心、偶尔脱线的老糊涂，还养了一只博学多闻的猫头鹰，他与女巫斗法那一段十分有趣，他们变成各种东西，彼此一物克一物，是本片中颇有创意的一段。","name":"The Sword in the Stone","name_cn":"石中剑","tags":[{"name":"迪士尼","count":22,"total_cont":0},{"name":"欧美","count":22,"total_cont":0},{"name":"剧场版","count":18,"total_cont":0},{"name":"1963","count":16,"total_cont":0},{"name":"Disney","count":10,"total_cont":0},{"name":"童年","count":9,"total_cont":0},{"name":"动画电影","count":9,"total_cont":0},{"name":"迪斯尼","count":3,"total_cont":0},{"name":"搞笑","count":2,"total_cont":0},{"name":"美国","count":2,"total_cont":0},{"name":"Walt_Disney_Animation_Studios","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"T.H.White","count":1,"total_cont":0},{"name":"-1970","count":1,"total_cont":0},{"name":"SebastianCabot","count":1,"total_cont":0},{"name":"20世纪","count":1,"total_cont":0},{"name":"60年代","count":1,"total_cont":0},{"name":"1963年","count":1,"total_cont":0},{"name":"奇幻","count":1,"total_cont":0},{"name":"石中剑","count":1,"total_cont":0},{"name":"迪士尼童年","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"考古","count":1,"total_cont":0},{"name":"幻想","count":1,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0},{"name":"WolfgangReitherman","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"石中剑"},{"key":"别名","value":[{"v":"La espada en la piedra"}]},{"key":"上映年度","value":"1963年12月25日"},{"key":"片长","value":"79分钟"},{"ke