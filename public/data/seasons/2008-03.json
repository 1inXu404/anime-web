cover/l/b7/1a/46121_7vQ5e.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b7/1a/46121_7vQ5e.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b7/1a/46121_7vQ5e.jpg"},"rating":{"rank":0,"total":40,"score":6.9,"count":{"1":0,"2":0,"3":0,"4":1,"5":4,"6":10,"7":15,"8":7,"9":1,"10":2}},"tags":[{"name":"剧场版","count":10},{"name":"动画电影","count":9},{"name":"2008","count":8},{"name":"欧美","count":7},{"name":"喜剧","count":6},{"name":"电影","count":4},{"name":"蓝天工作室","count":4},{"name":"搞笑","count":2},{"name":"2000s","count":2},{"name":"冒险","count":2}],"eps":1,"collection":{"wish":13,"collect":63,"doing":2,"on_hold":4,"dropped":3}},{"id":3760,"type":2,"name":"BUS GAMER","name_cn":"玩命游戏","summary":"3个完全不搭、个性不同的少年美柴鸨、齐藤一雄、中条伸人，为了3亿元巨额奖金而参加了一场3×3对战的“商业游戏”。他们组成的团队“AAA”屡战屡胜。可是，在一场与别人的对绝中，战败者突然的死亡，使这场本来看着“简单”的游戏，变得诡异了起来。","date":"2008-03-14","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/27/e8/3760_dmH2i.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/27/e8/3760_dmH2i.jpg","large":"https://lain.bgm.tv/pic/cover/l/27/e8/3760_dmH2i.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/27/e8/3760_dmH2i.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/27/e8/3760_dmH2i.jpg"},"rating":{"rank":6269,"total":95,"score":6,"count":{"1":1,"2":0,"3":3,"4":12,"5":17,"6":28,"7":23,"8":7,"9":2,"10":2}},"tags":[{"name":"峰仓和也","count":27},{"name":"OVA","count":25},{"name":"2008","count":18},{"name":"漫画改","count":14},{"name":"2008年3月","count":14},{"name":"基片可能","count":11},{"name":"TV","count":8},{"name":"坑","count":7},{"name":"BL","count":6},{"name":"未完结","count":3}],"eps":3,"collection":{"wish":84,"collect":161,"doing":3,"on_hold":13,"dropped":17}},{"id":2459,"type":2,"name":"ギャグマンガ日和3","name_cn":"搞笑漫画日和3","summary":"《搞笑漫画日和》是一部没有条理的超搞笑漫画，2002年以JUMPFesta动画的形式被制作推出之后，引发了很大的反响，2005年被正式动画化，并附有“增田幸助剧场”这个副标题。基本上是每一话完成一个故事，不过因为每话的长度各式各样，也有二、三话作为一回分别登载，以及一话定为前篇后编的形式。这是在幽默漫画类中非常著名的一部作品，以特有的对名人和名作的滑稽戏仿，得到了读者们的高度评价。","date":"2008-03-17","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/8b/db/2459_T0439.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/8b/db/2459_T0439.jpg","large":"https://lain.bgm.tv/pic/cover/l/8b/db/2459_T0439.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/8b/db/2459_T0439.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/8b/db/2459_T0439.jpg"},"rating":{"rank":541,"total":3191,"score":7.7,"count":{"1":11,"2":9,"3":6,"4":17,"5":76,"6":291,"7":885,"8":1174,"9":438,"10":284}},"tags":[{"name":"吐槽","count":615},{"name":"日和","count":614},{"name":"搞笑","count":385},{"name":"光速吐槽","count":319},{"name":"2008","count":275},{"name":"恶搞","count":273},{"name":"泡面番","count":268},{"name":"TV","count":260},{"name":"大地丙太郎","count":195},{"name":"神作","count":173},{"name":"studiodeen","count":133}],"eps":12,"collection":{"wish":537,"collect":5390,"doing":76,"on_hold":94,"dropped":59}},{"id":121844,"type":2,"name":"Orgesticulanismus","name_cn":"","summary":"《Orgesticulanismus》是Mathieu Labaye献给自己因疾病致残去世的父亲Benoît Labaye的二维动画短片,可以说本片将二维动画的自由度发挥到了极致。\r\n　　片子的开头有点沉闷,叙述一些他不能做到的动作,但片子中间开始作者的情绪完全迸发,特别精彩,非常好看,无限的变化让人心潮澎湃.接着被一根根线牵住的人，天天重复的动作，都是现实生活每个人都可以做到的，然而这还不能满足我们，我们需要的是挣脱那根线，然后有了从凳子起来后跌倒那一幕再演化到风款的大肆舞蹈。接着死亡，死亡后分化为各种元素，依然在这世界上活动。这是残疾的作者所渴望的，从动画可以看出，作者强烈想要挣脱那个椅子，挣脱那根绳子，然后大肆舞蹈，尽管死后也要自由的演变。\r\n　　个人的意识流化的理解：\r\n　　普通而又郁闷的生活-->束缚-->挣扎-->挣扎到极限-->挣脱-->自由-->自由的成为任何人，做任何事情-->自由到解除形体的限制-->自由到解脱肉体束缚,变成骨头-->自由到解除“人”的限制，由骨头成为任何物质-->回归终极的原始和自然的状态-->平静-->平静的思考和感觉-->……","date":"2008-03-18","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/08/7d/121844_k9p5O.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/08/7d/121844_k9p5O.jpg","large":"https://lain.bgm.tv/pic/cover/l/08/7d/121844_k9p5O.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/08/7d/121844_k9p5O.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/08/7d/121844_k9p5O.jpg"},"rating":{"rank":0,"total":24,"score":6.6,"count":{"1":0,"2":0,"3":1,"4":0,"5":2,"6":7,"7":10,"8":3,"9":1,"10":0}},"tags":[{"name":"短片","count":21},{"name":"欧美","count":10},{"name":"2008","count":8},{"name":"法国","count"