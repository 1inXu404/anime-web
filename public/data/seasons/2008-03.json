lain.bgm.tv/r/100/pic/cover/l/86/df/1486_5X7AK.jpg","large":"https://lain.bgm.tv/pic/cover/l/86/df/1486_5X7AK.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/86/df/1486_5X7AK.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/86/df/1486_5X7AK.jpg"},"rating":{"rank":3585,"total":629,"score":6.8,"count":{"1":2,"2":3,"3":2,"4":19,"5":44,"6":163,"7":256,"8":99,"9":25,"10":16}},"tags":[{"name":"聖闘士星矢","count":108},{"name":"OVA","count":88},{"name":"2008","count":58},{"name":"圣斗士","count":57},{"name":"小强","count":50},{"name":"TV完结","count":46},{"name":"热血","count":37},{"name":"燃烧吧，我的小宇宙！","count":33},{"name":"战斗","count":30},{"name":"东映","count":23},{"name":"漫画改","count":20}],"eps":6,"collection":{"wish":115,"collect":996,"doing":16,"on_hold":28,"dropped":23}},{"id":37939,"type":2,"name":"花粉少女注意報!~THE ANIMATION~","name_cn":"花粉少女注意报","summary":"春天到了，又是花粉少女症的季节了，请大家注意防护，避免传染。","date":"2008-03-28","images":null,"rating":{"rank":5429,"total":473,"score":6.4,"count":{"1":3,"2":5,"3":2,"4":20,"5":66,"6":147,"7":143,"8":65,"9":12,"10":10}},"tags":[{"name":"里番","count":366},{"name":"百合","count":84},{"name":"18禁","count":67},{"name":"ピンクパイナップル","count":65},{"name":"2008","count":58},{"name":"OVA","count":54},{"name":"群p","count":46},{"name":"漫画改","count":33},{"name":"18X","count":29},{"name":"不科学","count":28},{"name":"实用","count":25}],"eps":4,"collection":{"wish":337,"collect":887,"doing":50,"on_hold":69,"dropped":43}},{"id":53212,"type":2,"name":"めぐみ","name_cn":"小惠","summary":"『めぐみ』は、北朝鮮による日本人拉致問題を啓発するためのドキュメンタリー漫画作品であり、原作・監修を横田滋・横田早紀江夫妻、作画を本そういちが担当した。双葉社発行の青年漫画雑誌「漫画アクション」にて2004年12月から2005年7月まで連載された。\r\n\r\n2008年に日本国政府拉致問題対策本部企画・制作によりアニメ（Webアニメ）が制作された。同年3月28日から拉致問題対策本部のウェブサイトにて無料ブロードバンド配信されている。この問題をより広く知ってもらうため、コピー・転載が完全に自由である。配信言語は日本語、英語、中国語、韓国語の4種。\r\n\r\n横田惠（1964年10月15日－1994年3月13日（？）），日本新潟縣人，是被朝鲜民主主义人民共和国（以下简称「朝鲜」）绑架的数名日本人之一。她在1977年11月15日被绑架之时，年仅13岁。之前北朝鲜政府一直否认对她的绑架指控，2002年的日朝首脑会谈上，朝鲜劳动党中央总书记金正日正式向时任日本内阁总理大臣小泉纯一郎承认了绑架事件。根据朝鲜政府提供的物证，横田惠已经死亡。但是日本政府就这些物证提出多点怀疑，使得其生死情况至今仍然存在争议。这一事件并导致了日朝两国的长达数年，至今仍未解决的北朝鲜绑架日本人问题。\r\n\r\n漫畫：《小惠》（めぐみ），本壯一（本そういち）繪製，橫田惠的父母監修，於2005年由雙葉社發行，並翻譯成英文、韓文、簡體中文等版本。此漫畫透過日本的外交體系發送給其他國家外交、政府及新聞媒體等人士，並沒有在市面上販售。\r\n\r\n動畫：於2007年3月公開，由同名漫畫改編而成，並由高山南、三木真一郎等知名聲優及演員配音。動畫分別製作成多國語言版本，除透過日本的外交體系發送外，亦分送到日本各地中小學、圖書館等，且可在外務省的網站免費下載觀看。","date":"2008-03-28","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d4/63/53212_zqZGg.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d4/63/53212_zqZGg.jpg","large":"https://lain.bgm.tv/pic/cover/l/d4/63/53212_zqZGg.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d4/63/53212_zqZGg.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d4/63/53212_zqZGg.jpg"},"rating":{"rank":0,"total":18,"score":6.1,"count":{"1":0,"2":0,"3":0,"4":0,"5":7,"6":4,"7":5,"8":2,"9":0,"10":0}},"tags":[{"name":"OVA","count":9},{"name":"WEB","count":8},{"name":"拉致事件","count":5},{"name":"大森英敏","count":3},{"name":"2008年","count":3},{"name":"2008","count":2},{"name":"shisei","count":1},{"name":"三井秀树","count":1},{"name":"横田惠","count":1},{"name":"中篇","count":1}],"eps":1,"collection":{"wish":28,"collect":27,"doing":2,"on_hold":5,"dropped":4}},{"id":62429,"type":2,"name":"思春期少女","name_cn":"","summary":"制服美少女を処女レイプ、さらに大量ぶっかけ…そんな定番を踏まえつつ、マニアックなシチュエーションもてんこ盛りの「思春期少女」。\r\n白濁液に染まる制服美少女たちの痴態を見逃すな！","date":"2008-03-28","images":null,"rating":{"rank":7864,"total":188,"score":5.7,"count":{"1":1,"2":3,"3":7,"4":9,"5":60,"6":72,"7":24,"8":9,"9":1,"10":2}},"tags":[{"name":"里番","count":142},{"name":"鈴木みら乃","count":69},{"name":"OVA","count":37},{"name":"2008","count":30},{"name":"NTR","count":30},{"name":"搞笑","count":22},{"name":"18禁","count":19},{"name":"男主屌炸天","count":17},{"name":"18X","count":14},{"name":"漫画改","count":13},{"name":"早期优秀作品","count":11}],"eps":2,"collection":{"wish":120,"collect":361,"doing":11,"on_hold":25,"dropped":36}},{"id":70293,"type":2,"name":"シオン","name_cn":"残酷天使紫苑","summary":"学園の闇に蔓延る時空侵略者ガイストの影。\r\n太古より続く異次元者たちの暗闘が平凡な学園生活を送る主人公・弘樹の運命を大きく狂わせてゆく！\r\n弘樹の前に姿を現した銀色に輝くスーツの美少女は敵か味方か!?　人と魔法少女が……!?","date":"2008