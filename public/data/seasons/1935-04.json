[{"date":"1935-04-13","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e4/e7/133788_X4R7J.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e4/e7/133788_X4R7J.jpg","large":"https://lain.bgm.tv/pic/cover/l/e4/e7/133788_X4R7J.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e4/e7/133788_X4R7J.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e4/e7/133788_X4R7J.jpg"},"summary":"　　阳光明媚的一天，米奇（华特·迪士尼 Walt Disney 配音）刚刚为他最忠实的狗狗普鲁托搭建了一间狗窝，并在门口写上狗狗的名字。普鲁托兴奋非常，它抱住主人一个劲儿地舔，令米奇哈哈大笑。这时，一位老邮差背着沉重的箱子来到院子前，他把箱子扔在门口转身离去。米奇看看地址栏，发现是来自澳洲的礼物。当他准备撬开箱子时，箱子竟然跳了起来，更把普鲁托吓得够呛。没几下，箱子破成碎片，里面竟然是一只蹦蹦跳跳戴着拳击手套的大袋鼠。 \r\n　　米奇非常高兴，急忙进屋寻找拳击手套要和这个家伙对决一番。而这时候，袋鼠霸占了普鲁托的新狗窝，令普鲁托非常生气……","name":"Mickey's Kangaroo","name_cn":"米奇的拳击手袋鼠","tags":[{"name":"短片","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"1930s","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"1935","count":1,"total_cont":0},{"name":"全","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"迪士尼","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"19","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"米奇的拳击手袋鼠"},{"key":"上映年度","value":"1935-04-13"},{"key":"片长","value":"9分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0026708"},{"key":"类型","value":"喜剧/ 短片 / 家庭 / 运动"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"David Hand"},{"key":"主演","value":"沃尔特·迪士尼 Walt Disney"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":1,"9":0,"10":0},"score":6.6},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":1,"collect":14,"doing":0},"id":133788,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1935-04-13","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/9d/c1/149194_bFkU1.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/9d/c1/149194_bFkU1.jpg","large":"https://lain.bgm.tv/pic/cover/l/9d/c1/149194_bFkU1.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/9d/c1/149194_bFkU1.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/9d/c1/149194_bFkU1.jpg"},"summary":"　　从前有一只淘气顽皮的小黑猫，他整天就知道玩耍，浑身上下脏兮兮的，却超级讨厌洗澡。为此，小黑猫和妈妈发生争吵，甚至离家出走，给自己改名强盗小猫布奇。布奇行走在丛林中，又自由又快活。突然，他遇到一个凶巴巴的家伙，那竟然是遭到全国通缉的大强盗脏手比利。比利得知眼前的小家伙是同行，非常高兴，两个同样不爱洗澡的家伙坐在断木上聊起了天。 \r\n　　布奇大吹牛皮，声称自己早晨刚刚打劫了国王的马车，得到很多的金银财宝，这可让脏手比利打起了歪主意…… ","name":"The Robber Kitten","name_cn":"强盗小猫","tags":[{"name":"短片","count":3,"total_cont":0},{"name":"1935","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"迪士尼","count":1,"total_cont":0},{"name":"搞笑","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"强盗小猫"},{"key":"上映年度","value":"1935-04-13"},{"key":"片长","value":"8min"},{"key":"语言","value":"英语"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"David Hand"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":2,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":1,"8":0,"9":0,"10":0},"score":6},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":1,"collect":12,"doing":0},"id":149194,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]