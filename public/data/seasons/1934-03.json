[{"date":"1934-03-24","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/71/f0/149184_x03DU.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/71/f0/149184_x03DU.jpg","large":"https://lain.bgm.tv/pic/cover/l/71/f0/149184_x03DU.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/71/f0/149184_x03DU.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/71/f0/149184_x03DU.jpg"},"summary":"　　传说中，在一个青翠碧绿的山谷，复活节的兔子们便居住于此。他们一整年都在忙碌，齐心协力准备复活节的彩蛋。兔子们分工明确，一丝不苟，有的专门负责熬制巧克力，有的负责扣模，有的则为巧克力装点上色。他们中还有一些是出色雕塑家，经其之手，巧克力被雕成了活灵活现的兔子形状。另一边，母鸡军团也分外忙碌，她们生出的鸡蛋经特殊管道分发给上色的兔子们，这群小家伙心灵手巧，用彩虹滴下的色彩调浆，各呈其能，绘制出一枚枚好看的彩蛋。兔子王国的小家伙们通过辛苦的努力，为世界各地的小朋友送上最好的复活节礼物。 \r\n　　本片荣获1934年威尼斯电影节最佳动画片奖。","name":"Funny Little Bunnies","name_cn":"有趣的小兔子","tags":[{"name":"短片","count":6,"total_cont":0},{"name":"1934","count":4,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"Disney","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"1930-1939","count":1,"total_cont":0},{"name":"Silly-Symphony","count":1,"total_cont":0},{"name":"30s","count":1,"total_cont":0},{"name":"Wilfred·Jackson","count":1,"total_cont":0},{"name":"威尼斯电影节","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"有趣的小兔子"},{"key":"上映年度","value":"1934-03-24"},{"key":"片长","value":"7min"},{"key":"语言","value":"英语"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"Wilfred Jackson"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":10,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":3,"7":2,"8":3,"9":0,"10":0},"score":6.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":4,"collect":27,"doing":0},"id":149184,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1934-03-24","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a5/66/198593_ch5x8.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a5/