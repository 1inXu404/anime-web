[{"date":"1965-12-31","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a8/66/132400_Aqs9A.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a8/66/132400_Aqs9A.jpg","large":"https://lain.bgm.tv/pic/cover/l/a8/66/132400_Aqs9A.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a8/66/132400_Aqs9A.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a8/66/132400_Aqs9A.jpg"},"summary":"　　一条直线爱上了一个圆，他爱她的完美、精致，然而圆却不爱他，因为直线太过古板、保守，不懂得变通。圆渴望激情、刺激，而这一切恰恰在草书那里得到，纵使草书远远比不上直线的高雅气质。 \r\n　　失恋的直线伤心不已，同伴们亦不能缓解他的痛苦。于是他尝试着改变自己，直线发生了变化，在不懈努力下他可自由变化万千图形。神秘、性感、深邃、睿智，各种风格信手拈来。他终于可以鼓起勇气，去赢回属于自己的爱情。 \r\n　　本片荣获1966年奥斯卡最佳动画短片奖。","name":"The Dot and the Line","name_cn":"线恋点","tags":[{"name":"短片","count":14,"total_cont":0},{"name":"奥斯卡","count":7,"total_cont":0},{"name":"欧美","count":5,"total_cont":0},{"name":"点线面啥的","count":4,"total_cont":0},{"name":"1965","count":4,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"几何抽象艺术","count":3,"total_cont":0},{"name":"秀技术","count":2,"total_cont":0},{"name":"动画短片","count":1,"total_cont":0},{"name":"Chuck.Jones","count":1,"total_cont":0},{"name":"60s","count":1,"total_cont":0},{"name":"Chuck·Jones","count":1,"total_cont":0},{"name":"60年代","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"中庸","count":1,"total_cont":0},{"name":"乱糟糟","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"无排名","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"线恋点"},{"key":"别名","value":[{"v":"点与线"}]},{"key":"上映年度","value":"1965-12-31"},{"key":"片长","value":"10 分钟"},{"key":"语言","value":"英语"},{"key":"制片国家/地区","value":"美国"},{"key":"类型","value":"喜剧 / 爱情 / 动画 / 短片 / 家庭"},{"key":"导演","value":"查克·琼斯 / Maurice Noble"},{"key":"编剧","value":"Norton Juster"},{"key":"主演","value":"罗伯特·莫利"},{"key":"IMDb链接","value":"tt0059122"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":21,"count":{"1":2,"2":1,"3":0,"4":1,"5":