[{"date":"1966-08-04","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/4e/d3/280941_MHmz7.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/4e/d3/280941_MHmz7.jpg","large":"https://lain.bgm.tv/pic/cover/l/4e/d3/280941_MHmz7.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/4e/d3/280941_MHmz7.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/4e/d3/280941_MHmz7.jpg"},"summary":"《猫和老鼠》（Tom and Jerry）剧场短片系列第150集，也是查克·琼斯制作的第23集。\r\n\r\n汤姆和杰瑞在雪山上展开雪橇追逐战，杰瑞躲进了救援站，汤姆害怕站里的救护犬——一条圣伯纳犬，只得装作遇难将救护犬骗出。汤姆自以为得计，却在接下来的追逐战中连续遇险，救护犬不得不多次救助汤姆……\r\n\r\n标题是所谓神秘生物“喜马拉雅雪人”（The Abominable Snowman）的谐音双关语。","name":"The A-Tom-Inable Snowman","name_cn":"汤姆小雪人","tags":[{"name":"短片","count":13,"total_cont":0},{"name":"猫和老鼠","count":7,"total_cont":0},{"name":"美国","count":6,"total_cont":0},{"name":"欧美","count":5,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"1966","count":3,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"Short_film","count":2,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"查克琼斯","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"1960-1969","count":1,"total_cont":0},{"name":"无码","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"汤姆小雪人"},{"key":"上映年度","value":"1966年8月4日"},{"key":"片长","value":"6分39秒"},{"key":"制片人","value":"Chuck Jones"},{"key":"监制","value":"Les Goldman"},{"key":"制作管理","value":"Earl Jonas"},{"key":"总导演","value":"Chuck Jones"},{"key":"导演","value":"Abe Levitow"},{"key":"编剧","value":"Bob Ogle"},{"key":"构图","value":"Robert Givens"},{"key":"动画","value":"Ken Harris, Don Towsley, Tom Ray, Dick Thompson, Ben Washam, Phil Roman"},{"key":"背景美术","value":"Robert Inman"},{"key":"音乐","value":"Dean Elliott"},{"key":"动画制作","value":"MGM Animation/Visual Arts"},{"key":"发行","value":"Metro-Goldwyn-Mayer"},{"key":"IMDb","value":"tt0060055"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":18,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":3,"7":10,"8":2,"9":1,"10":1},"score"