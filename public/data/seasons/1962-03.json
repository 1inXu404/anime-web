[{"date":"1962-03-23","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/aa/07/634853_9F4SH.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/aa/07/634853_9F4SH.jpg","large":"https://lain.bgm.tv/pic/cover/l/aa/07/634853_9F4SH.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/aa/07/634853_9F4SH.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/aa/07/634853_9F4SH.jpg"},"summary":"　　阳光普照的庭院内，胖胖的男主人正向烤架内添加燃料。如此美好的一天，不在院子里来一次露天美味烧烤实在可惜。宠物汤姆自然欣喜非常，他拿着叉子站在主人身旁，伴随主人随口哼出的旋律左摇右摆。当然，烧烤的消息怎能瞒过杰瑞。杰瑞也连忙跑出老鼠洞，谁知途中遭到老对手汤姆的阻拦。美食当前，两个小家伙展开激烈的对决。只不过面对那个身形矮小却异常灵活的对手，汤姆免不了要被对方戏耍，还经常惹到主人遭到一顿胖揍。\r\n　　快乐的庭院烧烤，各种意外情况相继发生。看来可怜的汤姆注定无缘吃上美味的烤肉了……","name":"High Steaks","name_cn":"庭院烧烤","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"庭院烧烤"},{"key":"上映年度","value":"1962年3月23日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0056068"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":1,"4":0,"5":1,"6":0,"7":1,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":4,"doing":0},"id":634853,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]