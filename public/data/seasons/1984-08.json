[{"date":"1984-08-19","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/3e/93/296860_oO1Xk.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/3e/93/296860_oO1Xk.jpg","large":"https://lain.bgm.tv/pic/cover/l/3e/93/296860_oO1Xk.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/3e/93/296860_oO1Xk.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/3e/93/296860_oO1Xk.jpg"},"summary":"这部作品是为《24小时电视节目》制作的第7部特别动画。故事背景并非设定在宇宙或未来，而是现代社会。与《日正当中》和《千钧一发》等作品类似，这部作品采用了使故事情节与现实时间同步进行的手法，从而进一步增强了故事的真实感。与以往手塚治虫人气角色的客串出演不同，在这部作品中手塚治虫专注于描绘“眼前的危机”。他身兼九职，负责原案、构成、演出、角色设计、作画导演、原画、动画以及色指定等多个方面的工作，全情投入到作品的制作中。而所谓的“眼前的危机”是指“基因改造实验”，这部动画作品正是在1984年政府正式批准基因改造实验时制作的。","name":"大自然の魔獣 バギ","name_cn":"大自然的魔兽巴奇","tags":[{"name":"TVSP","count":3,"total_cont":0},{"name":"TV","count":3,"total_cont":0},{"name":"80s","count":2,"total_cont":0},{"name":"赛璐珞","count":2,"total_cont":0},{"name":"手塚プロダクション","count":2,"total_cont":0},{"name":"1984","count":2,"total_cont":0},{"name":"SF","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"井上和彦","count":1,"total_cont":0},{"name":"島津冴子","count":1,"total_cont":0},{"name":"手塚治虫","count":1,"total_cont":0},{"name":"手塚PRODUCTION","count":1,"total_cont":0},{"name":"手冢Production","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"大自然的魔兽巴奇"},{"key":"话数","value":"1"},{"key":"放送开始","value":"1984年8月19日"},{"key":"播放电视台","value":"日本テレビ系列"},{"key":"原作","value":"手塚治虫（原案）"},{"key":"キャラクターデザイン","value":"手塚治虫"},{"key":"音楽","value":"羽田健太郎"},{"key":"製作","value":"日本テレビ、手塚プロダクション"},{"key":"原画","value":"西村緋禄司、小林準治、吉村昌輝、加納薫、瀬谷新二、正延宏三、緒方泰彦、宇田川一彦、加藤誠一、神宮慧、三輪孝輝、谷沢豊、高橋信也、金山明博、広田麻由美、野間吐史、千明百合、大原和男、金澤勝真、鈴木伸一、金海由美子、しまだひであき、手塚治虫"},{"key":"演出","value":"手塚治虫、小熊公晴"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":1,"5":2,"6":1,"7":1,"8":0,"9":0,"10":0},"score":5.4},"total_episodes":0,"collection":{"on_hold":0,"dr