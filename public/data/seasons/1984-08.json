今なお原爆の後遺症に苦しむ人は無数にいた。梅毒を米兵にうつしてアメリカへの復讐を図る百合、ケロイドを見せてヒロシマの生き証人になろうとする友子、被爆者二世ゆえに出産に戸惑う英子。彼女たち一人一人がそれぞれ切実に戦後を生きていた。\r\n　私財をなげうってでもこのアニメで被爆体験を伝えたかった、という自らも被爆者である原作者・中沢の意志が全編にみなぎる劇場作品。主要登場人物の一人・滝村のCVを、西城秀樹が演じたことも話題になった。監督は、東映動画（現・東映アニメーション）作品などで活躍のアニメーター兼演出家・白土武。","name":"黒い雨に打たれて","name_cn":"遭逢黑雨的拍打","tags":[{"name":"剧场版","count":8,"total_cont":0},{"name":"喜多郎","count":3,"total_cont":0},{"name":"弘兼宪史","count":3,"total_cont":0},{"name":"1984","count":3,"total_cont":0},{"name":"大林丈史","count":2,"total_cont":0},{"name":"题材风格不合","count":2,"total_cont":0},{"name":"西城秀樹","count":2,"total_cont":0},{"name":"独立剧场版","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"核爆","count":2,"total_cont":0},{"name":"白土武","count":1,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0},{"name":"1980s","count":1,"total_cont":0},{"name":"致郁","count":1,"total_cont":0},{"name":"漫画改","count":1,"total_cont":0},{"name":"土田プロダクション","count":1,"total_cont":0},{"name":"潘恵子","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"遭逢黑雨的拍打"},{"key":"别名","value":[{"v":"Kuroi ni Ame Utarete"}]},{"key":"上映年度","value":"1984年8月12日"},{"key":"片长","value":"90分"},{"key":"导演","value":"白土武"},{"key":"制作","value":"中沢啓治"},{"key":"企画","value":"中沢啓治"},{"key":"原作","value":"中沢啓治"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":9,"count":{"1":1,"2":0,"3":1,"4":2,"5":2,"6":2,"7":0,"8":1,"9":0,"10":0},"score":4.7},"total_episodes":0,"collection":{"on_hold":1,"dropped":7,"wish":15,"collect":18,"doing":2},"id":101546,"eps":1,"meta_tags":["剧场版","漫画改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1984-08-04","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/97/05/82821_HBP2e.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/97/05/82821_HBP2e.jpg","large":"https://lain.bgm.tv/pic/cover/l/97/05/82821_HBP2e.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/97/05/82821_HBP2e.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/97/05/82821_H