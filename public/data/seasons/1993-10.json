r/100/pic/cover/l/93/e4/14645_fEeE5.jpg","large":"https://lain.bgm.tv/pic/cover/l/93/e4/14645_fEeE5.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/93/e4/14645_fEeE5.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/93/e4/14645_fEeE5.jpg"},"summary":"       一只会喝酒、会跳舞,令人又爱又恨的狗。\r\n　　胆子很小，却又贪吃,外表丑陋（左眼带着一圈黑轮活像被揍了一拳）\r\n　　但风度翩翩，酷爱整人但心底纯洁，出身贫寒但品种高贵（身价较高的英国小骑士——牛头梗）。\r\n　　只要有得吃有得玩,绝对服从。它可以让你笑翻肚皮，也可以让你七窍生烟。\r\n　　别看它一脸呆呆蠢蠢的样子，剧中犬神老大总是被它欺负,\r\n　　它吃老大、用老大、住老大，然后又整老大，而这位神气得不得了的老大，自从贱狗进了犬神家之后，在家中的排名也一落千丈，老被贱狗欺负，甚至女儿莎也加，也都帮贱狗说话，跟她老爸呕气，使得老大还得跟贱狗争风吃醋，博取女儿的欢心。老大在外面耀武扬威，回家却处处吃瘪，贱狗在外，时常遭殃，惹一身麻烦回家后却能骑在老大头上。","name":"平成イヌ物語バウ","name_cn":"家有贱狗","tags":[{"name":"童年","count":45,"total_cont":0},{"name":"TV","count":32,"total_cont":0},{"name":"贱狗","count":21,"total_cont":0},{"name":"搞笑","count":21,"total_cont":0},{"name":"1993","count":19,"total_cont":0},{"name":"爆笑","count":8,"total_cont":0},{"name":"漫画改","count":8,"total_cont":0},{"name":"童年系","count":8,"total_cont":0},{"name":"漫改","count":7,"total_cont":0},{"name":"没看完","count":6,"total_cont":0},{"name":"童年回憶","count":5,"total_cont":0},{"name":"90年代","count":4,"total_cont":0},{"name":"日本","count":4,"total_cont":0},{"name":"家有賤狗","count":3,"total_cont":0},{"name":"萌","count":3,"total_cont":0},{"name":"没看完系列","count":2,"total_cont":0},{"name":"啊呜","count":2,"total_cont":0},{"name":"日本动漫","count":1,"total_cont":0},{"name":"在电视上断断续续看过","count":1,"total_cont":0},{"name":"1993年10月","count":1,"total_cont":0},{"name":"动物","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"Animation","count":1,"total_cont":0},{"name":"1993年","count":1,"total_cont":0},{"name":"8JA","count":1,"total_cont":0},{"name":"没看全","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"待下载","count":1,"total_cont":0},{"name":"NIPPON","count":1,"total_cont":0},{"name":"远古","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"家有贱狗"},{"key":"别名","value":[{"v":"家有傻犬"},{"v":"Bow Wow"},{"v":"Heisei Inu Monogatari Bow"},{"v":"平成イヌ物语バウ"}]},{"key":"话数","value":"40"},{"key":"放送开始","value":"1993年10月4日"},{"key":"放送星期","value":"星期一"},{"key":"官方网站","value":"https://www.nippon-animation.co.jp/work/1674/"},{"key":"播放电视台","value":"テレビ朝日"},{"key":"播放结束","value":"1994年9月22日"},{"key":"导演","value":"加賀剛"},{"key":"Copyright","value":"©テリー山本/小学館･日本アニメーション"},{"key":"原作","value":"テリー山本"},{"key":"制作·发行","value":"Nippon Animation"}],"rating":{"rank":2355,"total":168,"count":{"1":0,"2":0,"3":0,"4":2,"5":11,"6":32,"7":65,"8":50,"9":5,"10":3},"score":7.1},"total_episodes":0,"collection":{"on_hold":22,"dropped":32,"wish":70,"collect":276,"doing":8},"id":14645,"eps":40,"meta_tags":["TV","日本","漫画改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1993-10-01","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/73/ea/38723_t3cqZ.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/73/ea/38723_t3cqZ.jpg","large":"https://lain.bgm.tv/pic/cover/l/73/ea/38723_t3cqZ.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/73/ea/38723_t3cqZ.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/73/ea/38723_t3cqZ.jpg"},"summary":"魔神英雄传第二部OVA，在TV版第二部之后制作发行，共三话。本可作为为系列画上句号的作品。\r\n　　第一话：救世主再临\r\n　　以阎罗王为首的魔界势力突袭创界山，使创界山受到严重损坏，山体的一部分被炸毁。而同时在现生界，已经升上五年级的战部渡也隐约感觉到了异常，但当他赶往龙神池时，却没有像往常一样看见有龙神前来接他。只遇到了一位神秘的钓鱼老人，钓鱼老人和渡说了关于“另一个世界的操龙之族”的传说。当天晚上，骑着一匹白色飞马的虎王在月光中突然出现，告诉了渡情况并将渡带往创界山，可是当渡醒来时虎王已经不知所踪。此时他才看到创界山的惨状。并遭受魔界怪兽的袭击，但魔界的邪气使所有的魔神都失去了作用，渡和朋友们在没有魔神的情况下一番苦战终于暂时安全。\r\n　　创界山女王圣龙妃告诉渡，要击退魔界，必须前往天部界取到“拳龙之勾玉”封住魔界之门，于是渡和星界山皇子海火子通过圣龙妃竭尽全力架设的光之桥前往天部界。\r\n　　第二话：天部界的风暴\r\n　　天部界，是现生界、神部界的人都不能进入的禁地。渡和海火子在此遇上了天部界神子四天龙王，经过一番波折，四天龙王告诉渡必须前往操龙一族的聚居地才能拿到“拳龙之勾玉”。但是当两人在四天龙王的帮助下来到操龙一族的领地时，却被告知“拳龙之勾玉是由拳龙的眼泪所化，是属于操龙一族中每千年才诞生一个的拳龙士的，不能交给别人。”正好他们赶上了千年一度的拳龙降临，而此时，阎罗王突然尾随渡而来。意欲毁坏拳龙之勾玉并伤害拳龙生下的幼仔。渡拼死保护拳龙。而新的“拳龙之勾玉”也被阎罗王毁坏。关键时刻，四天龙王出现，阎罗王暂时退却。\r\n　　操龙一族的长老和四天龙王告诉渡，其实渡就是上一位拳龙士，“拳龙之勾玉”就在渡自己体内！这时，被渡保护的拳龙幼仔变成了白色的飞马——天龙马——这是拳龙为报答拳龙士的相救而变。不知为什么虎王也骑在天龙马马背上。渡、虎王、海火子随即骑着天龙马和四天龙王借予的天马麟王返回神部界。\r\n　　第三话：永远的传说\r\n　　在魔界的大举入侵面前，神部界生灵涂炭，除了人以外，花草树木，一切都在魔界邪气的侵袭之下石化。空手而回的渡等人看到了创界山的难民对自己企盼的目光后下定决心前往魔渊。在魔渊，他们遇上了阎罗王。最后的决战爆发，海火子在战斗中受了伤，渡的剑也被阎罗王斩断。危急时刻，渡体内的拳龙之勾玉突然出现帮渡挡住了阎罗王的剑，同时在虎王的帮助下，渡对阎罗王发出了逆转的一击，将阎罗王打败。但是，他也对自己一直以来战斗的意义产生了怀疑。\r\n　　阎罗王已被打败，剩下的只有用拳龙之勾玉封印位于魔渊的魔界湖下的魔界之扉。但是魔界湖常人无法承受其有毒的湖水。且封印后湖水马上就会结冰。人只能永远被玄冰封在里面。就在渡决心牺牲自己时，虎王用计将渡绑在了天龙马上并让天龙马带渡离开。自己则拿上勾玉潜入湖中封印魔界之扉。创界山得救了，魔界之湖的玄冰支撑住了残缺的创界山，渡也全身而退，但虎王却被封在了那永远不会融化，也不可能被毁掉的玄冰之中，渡也因失去拳龙之勾玉，卸下了救世主的职责。\r\n　　渡带着哀伤回到了现生界。时间慢慢过去，转眼已是第二年的春天，渡已是小学六年级了。在一个春日的晚上，他又一次看到了月光照耀下的天龙马的身影，当他赶往龙神池时，在老樱花树的落瓣之下，骑在天龙马上的，不是别人，正是好朋友虎王！　","name":"魔神英雄伝ワタル 終わりなき時の物語","name_cn":"魔神英雄传 永恒传说","tags":[{"name":"OVA","count":41,"total_cont":0},{"name":"魔神英雄传","count":27,"total_cont":0},{"name":"SUNRISE","count":23,"total_cont":0},{"name":"1993","count":20,"total_cont":0},{"name":"童年","count":11,"total_cont":0},{"name":"神龙斗士","count":10,"total_cont":0},{"name":"虎王","count":6,"total_cont":0},{"name":"萝卜","count":5,"total_cont":0},{"name":"魔神英雄伝ワタル","count":5,"total_cont":0},{"name":"日本","count":3,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"サンライズ","count":2,"total_cont":0},{"name":"robo","count":2,"total_cont":0},{"name":"机战","count":2,"total_cont":0},{"name":"井内秀治","count":2,"total_cont":0},{"name":"怀旧","count":2,"total_cont":0},{"name":"原创","count":2,"total_cont":0},{"name":"90年代","count":2,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"机甲","count":1,"total_cont":0},{"name":"林原女王","count":1,"total_cont":0},{"name":"1990-1999","count":1,"total_cont":0},{"name":"优秀子供向","count":1,"total_cont":0},{"name":"番外","count":1,"total_cont":0},{"name":"經典","count":1,"total_cont":0},{"name":"大长篇","count":1,"total_cont":0},{"name":"8+","count":1,"total_cont":0},{"name":"爷青回","count":1,"total_cont":0},{"name":"儿时萌","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"魔神英雄传 永恒传说"},{"key":"别名","value":[{"v":"魔神英雄传 没有终结时的传说"}]},{"key":"话数","value":"3"},{"key":"发售日","value":"1993年10月1日"},{"key":"官方网站","value":"http://www.mashin-eiyuud