[{"date":"1993-10-29","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/38/b4/11603_P4zRs.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/38/b4/11603_P4zRs.jpg","large":"https://lain.bgm.tv/pic/cover/l/38/b4/11603_P4zRs.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/38/b4/11603_P4zRs.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/38/b4/11603_P4zRs.jpg"},"summary":"       万圣镇的各位鬼怪，已经习惯于在每年万圣节那天出没搞作一下，他们是彻头彻尾的少根筋的生物，只晓得如何吓人。而南瓜王子杰克，是非常与众不同的一个。他已经厌倦了带给人们惊恐的玩意，一心想做出某些改变。偶然一次打开了圣诞镇的大门，让他眼前豁然一亮，杰克心中燃起了要带领兄弟制造圣诞欢乐的决心。\r\n　　但是，这帮万圣镇的鬼怪们似乎并不明白其中深意。杰克绑架了胖乎乎的圣诞老人，吩咐伙计们开始埋头制作圣诞礼物。满脑只有恐怖点子的万圣镇兄弟，又怎能逃过思维惯性，做出令人欢乐的礼物呢。于是，恐怖的、吓人的礼物将在圣诞那夜抛给孩子们，当杰克坐着人造鹿车派出礼物时，一枚高射炮正对准了这个好心办坏事的可怜虫。","name":"The Nightmare Before Christmas","name_cn":"圣诞夜惊魂","tags":[{"name":"欧美","count":98,"total_cont":0},{"name":"剧场版","count":87,"total_cont":0},{"name":"奇幻","count":75,"total_cont":0},{"name":"TimBurton","count":65,"total_cont":0},{"name":"定格动画","count":65,"total_cont":0},{"name":"1993","count":56,"total_cont":0},{"name":"美国","count":47,"total_cont":0},{"name":"动画电影","count":27,"total_cont":0},{"name":"灵异","count":24,"total_cont":0},{"name":"黑童话","count":20,"total_cont":0},{"name":"Disney","count":19,"total_cont":0},{"name":"Xmas","count":18,"total_cont":0},{"name":"迪士尼","count":14,"total_cont":0},{"name":"动画","count":13,"total_cont":0},{"name":"南瓜王","count":10,"total_cont":0},{"name":"定格","count":9,"total_cont":0},{"name":"电影","count":4,"total_cont":0},{"name":"原创","count":4,"total_cont":0},{"name":"补旧番","count":3,"total_cont":0},{"name":"Film","count":3,"total_cont":0},{"name":"映画","count":3,"total_cont":0},{"name":"90年代","count":3,"total_cont":0},{"name":"1990s","count":2,"total_cont":0},{"name":"美国动画","count":2,"total_cont":0},{"name":"亨利·塞利克","count":2,"total_cont":0},{"name":"非日本动画","count":1,"total_cont":0},{"name":"格伦·沙迪克斯","count":1,"total_cont":0},{"name":"19","count":1,"total_cont":0},{"name":"喜剧","count":1,"total_cont":0},{"name":"回忆系","count":1,"total_