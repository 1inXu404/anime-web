[{"date":"1991-12-30","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d6/6f/37400_kIiQ2.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d6/6f/37400_kIiQ2.jpg","large":"https://lain.bgm.tv/pic/cover/l/d6/6f/37400_kIiQ2.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d6/6f/37400_kIiQ2.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d6/6f/37400_kIiQ2.jpg"},"summary":"第1話は15分ほどのアニメーションビデオ作品。\r\n第2話は正式な続編ではあるが、紙芝居にナレーションのみが入った5分ほどのビデオ作品であり、登場人物は一切喋らない。\r\n\r\n为TOMY的玩具系列做宣传而拍摄的全一话的OVA。\r\n由于地球污染日益严重，地球上的特权阶级抛弃了普通民众而移民火星，建立了キルナ国，被留下的民众们则建立了ブルースター連邦。谁知到了公元2999年，受到彗星及太阳风的影响，地球环境得到了净化，相反火星的环境却濒临崩溃，于是心理严重不平衡的キルナ总统ギスカール下令攻打地球。ブルースター連邦軍ベル ランス中尉被任命为封印兵器装甲巨神”Zナイト”的驾驶员，投入到了最前线的战斗中。\r\n这个系列其实是ZOID系列的旁支，装甲巨神其实是在内部藏有ZOID生命体的人型兵器，由于威力过于强大而被地球人封印。 ","name":"装甲巨神Zナイト","name_cn":"装甲巨神Z骑士","tags":[{"name":"OVA","count":8,"total_cont":0},{"name":"SUNRISE","count":6,"total_cont":0},{"name":"1991","count":5,"total_cont":0},{"name":"高山文彦","count":5,"total_cont":0},{"name":"梅津泰臣","count":3,"total_cont":0},{"name":"内田健二","count":2,"total_cont":0},{"name":"大張正己","count":2,"total_cont":0},{"name":"其他","count":2,"total_cont":0},{"name":"サンライズ","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"緑川光","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"天野由梨","count":1,"total_cont":0},{"name":"robo","count":1,"total_cont":0},{"name":"独立ova","count":1,"total_cont":0},{"name":"90-94","count":1,"total_cont":0},{"name":"庵野秀明","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"装甲巨神Z骑士"},{"key":"话数","value":"2"},{"key":"发售日","value":"1991年12月30日"},{"key":"企画","value":"トミー"},{"key":"导演","value":"高山文彦"},{"key":"系列构成","value":"高山文彦"},{"key":"人物设定","value":"梅津泰臣"},{"key":"作画监督","value":"梅津泰臣（人物作画监督）"},{"key":"机械设定","value":"今掛勇、トミーキャラクター開発室（装甲巨神设定）"},{"key":"基本设定","value":"二階堂輝夫（トミー）"},{"key":"设定协力","value":"トミーキャラクター開発室"},{"key":"原画","value":"梅津泰臣、今掛勇、岡野秀彦、森川定美、菊地康二（菊地康仁）、黒田和也、庵野