[{"date":"1948-09-18","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/63/95/275348_p5IFG.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/63/95/275348_p5IFG.jpg","large":"https://lain.bgm.tv/pic/cover/l/63/95/275348_p5IFG.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/63/95/275348_p5IFG.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/63/95/275348_p5IFG.jpg"},"summary":"　　已经是夜幕降临，大房子内却传来阵阵爱好。胖胖的女主人站在凳子上大声呼救，摇摇欲坠，原来小老鼠杰瑞正拼命摇动凳子，乐在其中。女主人的呼声吵醒了正在熟睡的汤姆，他闻声冲了过去，却敌不过敏捷机灵的杰瑞，几次三番遭到戏耍，更不慎和女主人跌落地下室。女主人极其失望，她认为汤姆实在太老了，于是找来真正的捕鼠能手——红猫“闪电”。闪电无愧其名，以极快的速度抓住了杰瑞，并将其扔出门外。他动作迅速，举止优雅，赢得了女主人的欢心。但是，闪电却是个表里不一的家伙。女主人刚刚离开，他便打开冰箱大快朵颐，还诬陷汤姆。 \r\n　　汤姆和杰瑞这对冤家只得联手对付闪电……","name":"Old Rockin' Chair Tom","name_cn":"老摇椅上的汤姆","tags":[{"name":"短片","count":19,"total_cont":0},{"name":"猫和老鼠","count":9,"total_cont":0},{"name":"1948","count":7,"total_cont":0},{"name":"欧美","count":7,"total_cont":0},{"name":"美国","count":5,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"老摇椅上的汤姆"},{"key":"上映年度","value":"1948年9月18日"},{"key":"片长","value":"8分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":36,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":5,"7":17,"8":12,"9":1,"10":0},"score":7.2},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":4,"collect":83,"doing":2},"id":275348,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]