ttps://lain.bgm.tv/r/800/pic/cover/l/2a/f6/94893_n7bAV.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/2a/f6/94893_n7bAV.jpg"},"summary":"侥幸逃脱的滨户良的宠物鼠斯普林特意外的与另外四只乌龟在纽约下水道沾染上了由阿特姆所制作的变异液体，变成了接近人形的变异生物，也就诞生了新一代的忍者神龟，斯普林特开始训练这些乌龟们滨户良留下的忍者功夫和知识，希望有朝一日能为自己的主人复仇。2003年的某一天，已经长大并初露锋芒的忍者神龟们终于遇到了他们的宿敌，施莱德试图拉拢神龟之一的李奥纳多为自己服务，但是惨遭失败，露出邪恶本性的阿特姆施莱德与神龟们开始了第一战，最后在斯普林特出手帮助下众人合力将其击退。过了一段日子，施莱德展开了复仇，并将李奥打成重伤，在朋友帮助下逃过，休养生息后神龟们返回纽约与施莱德展开第二次较量，最终施莱德被李奥用腾古之剑砍下脑袋，但是我们知道这只是他的机器外壳，而神龟们的代价则是失去了他们的父亲:斯普林特的踪迹……为了寻找失踪的父亲，神龟们结识了阿特姆流亡者一族并且了解了他们的历史，但是就在这时，施莱德再度出现了，一番大战后，施莱德露出了他的真面目，眼见阿特姆一族利用传送门逃离地球，千年的复仇计划毁于一旦，施莱德气急败坏的要与神龟们同归于尽，而最终神龟们利用传送门逃生，施莱德则在一片爆炸声中消失了踪迹……","name":"Teenage Mutant Ninja Turtles","name_cn":"忍者神龟","tags":[{"name":"欧美","count":53,"total_cont":0},{"name":"童年","count":45,"total_cont":0},{"name":"TV","count":33,"total_cont":0},{"name":"2003","count":23,"total_cont":0},{"name":"美国","count":18,"total_cont":0},{"name":"战斗","count":16,"total_cont":0},{"name":"忍者神龟","count":15,"total_cont":0},{"name":"热血","count":13,"total_cont":0},{"name":"科幻","count":13,"total_cont":0},{"name":"动画","count":7,"total_cont":0},{"name":"美国动画","count":4,"total_cont":0},{"name":"忍者神龟03版","count":4,"total_cont":0},{"name":"TV（集数≥100）","count":3,"total_cont":0},{"name":"童年的经典","count":2,"total_cont":0},{"name":"2003年","count":2,"total_cont":0},{"name":"TVB","count":2,"total_cont":0},{"name":"OP","count":1,"total_cont":0},{"name":"其他","count":1,"total_cont":0},{"name":"欧美动画","count":1,"total_cont":0},{"name":"¬","count":1,"total_cont":0},{"name":"7","count":1,"total_cont":0},{"name":"2003年2月","count":1,"total_cont":0},{"name":"未看完","count":1,"total_cont":0},{"name":"我的童年","count":1,"total_cont":0},{"name":"没看完","count":1,"total_cont":0},{"name":"2000-2009","count":1,"total_cont":0},{"name":"幼儿园","count":1,"total_cont":0},{"name":"TV没看完","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"忍者神龟"},{"key":"别名","value":[{"v":"新忍者神龟"}]},{"key":"话数","value":"156"},{"key":"放送开始","value":"2003年2月8日"},{"key":"官方网站","value":"http://www.ninjaturtles.com/"},{"key":"导演","value":"Kevin Eastman"}],"rating":{"rank":3239,"total":175,"count":{"1":0,"2":0,"3":0,"4":2,"5":7,"6":52,"7":87,"8":19,"9":7,"10":1},"score":6.8},"total_episodes":0,"collection":{"on_hold":28,"dropped":20,"wish":31,"collect":375,"doing":10},"id":94893,"eps":156,"meta_tags":["TV","美国","欧美"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"2003-02-05","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c3/48/4882_wloUi.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c3/48/4882_wloUi.jpg","large":"https://lain.bgm.tv/pic/cover/l/c3/48/4882_wloUi.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c3/48/4882_wloUi.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c3/48/4882_wloUi.jpg"},"summary":"故事背景可以看作和我们的世界平行的一个世界。1945年，太平洋战争结束的时，不知来自何处的谜之生物对人类展开了攻击，他们数量多，性情凶猛，大型的还会产生瘴气，不知从何时起，这些生物被称为幻兽。人类一切抵抗在它们面前失效，人类最后动用了核武器，但除了将自己的国土弄得到处是放射性污染外，没有其他作用。 接着到了1999年，世界已有大半荒废，而人类也开始适应了幻兽的攻击，战斗进入持久战。在战斗机器人HWT和终极炸弹PBE(看效果类似小型黑洞)等兵器投入后，人类终于有了能抵抗幻兽的手段。而日本也在20年前通过了“学生征兵法”，宣布从中学生中挑选合适人员加入少年军。 少年军不同于普通军队，他们是平时学习，一旦有了幻兽警报就出动作战的部队。少年军以班为作战单位，有指导老师负责日常学习和生活，班长负责战斗指挥。在没有战斗的时候，他们看上去和一般学生没什么两样。 第5121部队HWT驾驶员速水厚志所属的就是一个标准的少年军编制的班，除了学习他们还要通过战斗保卫自己的家园。一天，一个新来的转校生——芝川舞从其他部队转入第5121部队。尽管她驾驶HWT技术很好，但脾气却很暴躁，待人态度又很强硬，很难相处。而速水厚志却是个温吞吞的老好人，被女生起了绰号叫“软绵绵”。担任战斗指导的坂本老师很狡猾的把这两个人配置在了一辆双座HWT上，结果第一次模拟训练速水就被芝川舞剥夺了控制权。但在后来的战斗中，两人的配合逐渐默契起来，并开始产生了感情……\r\n\r\n故事改编自著名的PS游戏《GUNPARADE MARCH》，虽然是以战争为背景，但主要还是以第5121部队的学生们真实的生活为主线来描写的，生活气息浓郁，激烈的战斗并没有影响到那群冒着性命危险的青年的日常生活，在里面并没有感觉到丝毫的抱怨，但也可能是他们已经习以为常。战斗中体会不到紧张感，面对同伴的死却不轻易流露自己的感情。通过这个故事，也可以知道当时的征兵制度掠夺了不少青年的生命和他们的青春，并让他们承受很大的精神压力，每天都有同龄人牺牲，这绝对不是一个愉快的话题。整个故事气氛调节的很好，既有战友牺牲时的悲伤和沉重，又有学生们的轻松搞笑，又不象很多同类片子充满高层的阴谋，总之是部主题比较积极的片子，大力推荐一下。","name":"ガンパレード・マーチ 〜新たなる行軍歌〜","name_cn":"高机动幻想 ～新结行军歌～","tags":[{"name":"J.C.STAFF","count":68,"total_cont":0},{"name":"TV","count":55,"total_cont":0},{"name":"萝卜","count":43,"total_cont":0},{"name":"2003","cou