[{"date":"2003-02-27","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/24/65/23444_4R04h.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/24/65/23444_4R04h.jpg","large":"https://lain.bgm.tv/pic/cover/l/24/65/23444_4R04h.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/24/65/23444_4R04h.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/24/65/23444_4R04h.jpg"},"summary":"很久以前，生活在地球上的人类全都是拥有超能力的奇魔力者，他们代代都过着和平又快乐的生活，但是自从人类为了私欲而产生了争斗后，促使奇魔王国四分五裂，到最后甚至导致国家灭亡。而奇魔王国灭亡之时，有一位谜样的少女娜英，被母亲冷冻在寒冷的南极上，后来被安亦宏发现而交由他的女儿抚养。娜英虽然从小就展现出过人的超能力，但在养父养母细心抚养下，她并不知道自己的身世秘密，在郊外的村庄上过着平凡快乐的生活。直到某一天，她转学到爷爷所担任校长的魔法学园，在那里认识了与自己一样拥有奇魔力的朋友浩正、莉亚、小东、公主。另一方面，奇魔联盟指挥官亚斯天所派出的偶像团体艾司帕二人组的俊与蒂拉，为了秘密侦查娜英的奇魔力而转学到魔法学园；亚斯天为了统治世界，夺取古代奇魔王国所留下来的三个奇魔石，企图唤起当时导致史前奇魔文明灭亡的邪恶奇魔力，从此背负拯救世界责任的娜英与魔法学园的朋友们，与野心勃勃的奇魔联盟，展开了一段正义和邪恶对决的冒险故事。 ","name":"스피어즈","name_cn":"魔法学园","tags":[{"name":"韩国","count":14,"total_cont":0},{"name":"童年","count":8,"total_cont":0},{"name":"TV","count":6,"total_cont":0},{"name":"电视上看的","count":4,"total_cont":0},{"name":"2003","count":4,"total_cont":0},{"name":"其他","count":1,"total_cont":0},{"name":"棒子","count":1,"total_cont":0},{"name":"韩国动画","count":1,"total_cont":0},{"name":"TVB","count":1,"total_cont":0},{"name":"电视","count":1,"total_cont":0},{"name":"杂","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"魔法学园"},{"key":"别名","value":[{"v":"我的奇魔力"},{"v":"魔球小仙女"},{"v":"SPHERES"},{"v":"スフィアーズ"},{"v":"魔法学园 Spheres"}]},{"key":"话数","value":"26"},{"key":"放送开始","value":"2003年2月27日"},{"key":"放送星期","value":"星期四"},{"key":"官方网站","value":"http://www.spheres.co.kr/"},{"key":"播放电视台","value":"韩国MBC"},{"key":"其他电视台","value":"中国大陆-华娱卫视"},{"key":"播放结束","value":"2003年8月21日"}],"rating":{"rank":0,"total":20,"count":{"1":1,"2":0,"3":0,"4":0,"5":8,"6":6,"7":4,"8":0,"9":0,"10":1},"score":5.8},"total_episodes":0,"collection":{"on_hold":6,"dropped":10,"wish":22,"collect":35,"doing":1},"id":23444,"eps":26,"meta_tags":["TV","韩国"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},