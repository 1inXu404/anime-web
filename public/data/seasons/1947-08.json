[{"date":"1947-08-30","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/5d/75/263190_5IvIo.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/5d/75/263190_5IvIo.jpg","large":"https://lain.bgm.tv/pic/cover/l/5d/75/263190_5IvIo.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/5d/75/263190_5IvIo.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/5d/75/263190_5IvIo.jpg"},"summary":"　　傍晚，女主人开心地走入厨房，打算找出冰激凌来吃，结果厨房中的景象令她大为光火。台面上果汁撒得到处都是，冰箱门大开水流满地，桌子上的蛋糕也被咬成灯笼。显然，小老鼠杰瑞曾在这里开过狂欢派对。那么本应该对付杰瑞的汤姆和幸运小子呢？他们正躺在客厅，眼前是吃剩的鱼还有牛奶，以及女主人的冰激凌。女主人勃然大怒，告诉他们只有一只猫能够留在家中，而留下来的唯一条件就是抓住兴风作浪的杰瑞。为了讨得女主人的欢心，汤姆和幸运小子开始翻天覆地的大搜索，其间两个小家伙还互相拆台，结果全部中了杰瑞的诡计……","name":"A Mouse in the House","name_cn":"房子里的老鼠","tags":[{"name":"短片","count":20,"total_cont":0},{"name":"猫和老鼠","count":10,"total_cont":0},{"name":"欧美","count":9,"total_cont":0},{"name":"美国","count":6,"total_cont":0},{"name":"1947","count":6,"total_cont":0},{"name":"原创","count":5,"total_cont":0},{"name":"米高梅","count":4,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"1940s","count":3,"total_cont":0},{"name":"1940-1949","count":2,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"房子里的老鼠"},{"key":"上映年度","value":"1947-08-30"},{"key":"片长","value":"7分32秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":35,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":6,"7":18,"8":7,"9":2,"10":0},"score":7},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":3,"collect":89,"doing":1},"id":263190,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]