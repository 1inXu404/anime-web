者かわからない誘拐犯を追跡することを決意。Ｄｒ．ソーノイダにバックランド号の修理を頼むのだった。\r\n　リュウタたち３人＆３匹の、Ｄｒ．ソーノイダたちアクト団を巻き込んだ、時空を超えた新たな旅が始まる！","name":"古代王者 恐竜キング Dキッズ・アドベンチャー 翼龍伝説","name_cn":"古代王者 恐龙王 翼龙传说","tags":[{"name":"TV","count":3,"total_cont":0},{"name":"2008","count":2,"total_cont":0},{"name":"SUNRISE","count":2,"total_cont":0},{"name":"平野靖士","count":1,"total_cont":0},{"name":"谷田部勝義","count":1,"total_cont":0},{"name":"空","count":1,"total_cont":0},{"name":"菱田正和","count":1,"total_cont":0},{"name":"今西隆志","count":1,"total_cont":0},{"name":"热血","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"TVB","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"古代王者 恐龙王 翼龙传说"},{"key":"话数","value":"30"},{"key":"放送开始","value":"2008年2月3日"},{"key":"官方网站","value":"https://www.sunrise-inc.co.jp/work/detail.php?cid=259"},{"key":"播放结束","value":"2008年8月31日"},{"key":"Copyright","value":"(c)SEGA/サンライズ・メ～テレ"},{"key":"原案","value":"菅野顕二（セガ）"},{"key":"企画","value":"竹崎忠（セガ）、宮河恭夫（サンライズ）"},{"key":"美术监督","value":"小川由紀子、小山俊久"},{"key":"总制片人","value":"宝田寿也（メ～テレ）、尾崎雅之（サンライズ）、生田英隆（ＡＤＫ）"},{"key":"制片人","value":"川本謙一（メ～テレ）、渡辺洋一（サンライズ）、麻生一宏（ＡＤＫ）"},{"key":"製作","value":"メ～テレ（名古屋テレビ）、セガ（SEGA）、サンライズ、ＡＤＫ（アサツー ディ・ケイ）"},{"key":"脚本","value":"平野靖士、神戸一彦、三浦浩児、丸尾みほ、前川淳"},{"key":"分镜","value":"谷田部勝義、菱田正和、藤原良二、伴山人、河村智之、高橋順、渡辺正樹、池野昭二、上坪亮樹"},{"key":"演出","value":"池野昭二、工藤寛顕、杉山慶一、菱田正和、河村智之、高橋順、渡辺正樹"},{"key":"作画监督","value":"平岡正幸、高橋晃、和田喜彰、江上夏樹、石川てつや、金栄範、田中ちゆき、梶浦紳一郎、竹内啓、大野勉、小田武士、鈴木幸江"}],"rating":{"rank":0,"total":6,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":0,"7":3,"8":0,"9":1,"10":0},"score":6.7},"total_episodes":0,"collection":{"on_hold":3,"dropped":3,"wish":5,"collect":10,"doing":0},"id":211559,"eps":30,"meta_tags":["TV","日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":null,"platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/3c/6c/415036_1hGgG.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/3c/6c/415036_1hGgG.jpg","large":"https://lain.b