[{"date":"1940-05-18","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/3a/5b/318264_7CcSA.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/3a/5b/318264_7CcSA.jpg","large":"https://lain.bgm.tv/pic/cover/l/3a/5b/318264_7CcSA.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/3a/5b/318264_7CcSA.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/3a/5b/318264_7CcSA.jpg"},"summary":"　　好莱坞工厂，著名动画人莱昂·施莱辛格（Leon Schlesinger）的工作室内，画家正在绘图板上画下可爱的猪小弟（梅尔·兰克 Mel Blanc 配音）。就在此时到了午餐时间，画家和同事们风一般地冲了出去。就在此时，挂在墙上的达菲鸭（梅尔·兰克 Mel Blanc 配音）开始和猪小弟打招呼，他讨厌猪小弟抢了自己的位置，于是花言巧语想骗猪小弟和施莱辛格老板解除合同。完全没有主见的猪小弟受到蛊惑，敲开了老板的门。老板很干脆地撕毁了合同，回归自由之身的猪小弟开着车要去大制片厂实现他的明星梦。\r\n　　梦想总是很美好，但现实永远很残酷……","name":"You Ought to Be in Pictures","name_cn":"你应该去演电影","tags":[{"name":"短片","count":8,"total_cont":0},{"name":"1940","count":5,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"华纳","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"1940s","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"你应该去演电影"},{"key":"上映年度","value":"1940-05-18"},{"key":"片长","value":"9 min"},{"key":"导演","value":"Friz Freleng"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":8,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":4,"8":2,"9":0,"10":0},"score":6.9},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":4,"collect":21,"doing":0},"id":318264,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]