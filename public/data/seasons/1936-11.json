[{"date":"1936-11-27","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c4/a7/241671_17j78.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c4/a7/241671_17j78.jpg","large":"https://lain.bgm.tv/pic/cover/l/c4/a7/241671_17j78.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c4/a7/241671_17j78.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c4/a7/241671_17j78.jpg"},"summary":"　　在蔚蓝的大海中央，伫立着一个杀机四伏的小岛。这里盘踞着老虎、狮子、毒蛇等各种猛兽，更有双头巨人等力大无穷暴虐残忍的怪物，然而比他们更厉害的便是走遍世界未逢敌手的传奇水手辛巴达（加斯·维基 Gus Wickie 配音）。他盘踞在岛中央的城堡内，吼声如雷的狮子担当看门犬。他 每天高唱为自己歌功颂德的赞歌，兀自陶醉其中。这一天，地平线尽头是来一艘轮船，上面坐着勇敢的大力水手卜派（杰克·梅瑟 Jack Mercer 配音），美丽姑娘奥莉弗（梅伊·奎斯托尔 Mae Questel 配音），以及贪吃的维姆皮先生（洛·弗雷舍 Lou Fleischer 配音）辛巴达垂涎奥莉弗的美貌，于是指示怪鸟弄坏轮船，抢夺美人。以此为契机，两个勇猛水手的战争拉开序幕…… \r\n　　本片为大力水手三部彩色特别版中的第一部，另外两部为阿里巴巴和阿拉丁。","name":"Popeye the Sailor Meets Sindbad the Sailor","name_cn":"当大力水手遇到水手辛巴达","tags":[{"name":"短片","count":10,"total_cont":0},{"name":"1936","count":6,"total_cont":0},{"name":"美国","count":5,"total_cont":0},{"name":"欧美","count":3,"total_cont":0},{"name":"FleischerStudios","count":2,"total_cont":0},{"name":"1930s","count":2,"total_cont":0},{"name":"Short","count":2,"total_cont":0},{"name":"派拉蒙","count":1,"total_cont":0},{"name":"北美","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"当大力水手遇到水手辛巴达"},{"key":"上映年度","value":"1936-11-27"},{"key":"片长","value":"16分钟"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 歌舞 / 家庭 / 奇幻"},{"key":"导演","value":"Dave Fleischer"},{"key":"主演","value":"Lou Fleischer / Jack Mercer / Mae Questel / Gus Wickie"},{"key":"IMDb","value":"tt0028119"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":16,"count":{"1":0,"2":0,"3":1,"4":0,"5":0,"6":4,"7":7,"8":3,"9":1,"10":0},"score":6.8},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":4,"collect":35,"doing":1},"id":241671,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]