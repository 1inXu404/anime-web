[{"date":"1950-01-14","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d8/cd/634544_jj1Jr.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d8/cd/634544_jj1Jr.jpg","large":"https://lain.bgm.tv/pic/cover/l/d8/cd/634544_jj1Jr.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d8/cd/634544_jj1Jr.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d8/cd/634544_jj1Jr.jpg"},"summary":"　　某个周末的夜晚，胖胖的女主人心情愉悦，她换上最华丽的晚装，佩戴光彩夺目的首饰，哼着轻松的小曲准备参加桥牌俱乐部的聚会。汤姆心情激动地盯着女主人的一举一动，主人刚刚离开，他就箭一般地从窝中窜起，跑到窗口前，将正在垃圾堆里厮混的黑猫布奇、红猫闪电和小猫托普西（Topsy）召到家中，举行狂热的周末音乐派对。闪电作为DJ播放着摇摆激烈的爵士乐，布奇坐在钢琴前流利地演奏着跳跃的音符，托普西将酒杯一字排开，奉上了精彩的打击乐表演。汤姆作为东道主准备了丰盛的晚餐，其间还不忘配合伙伴们进行演奏。\r\n　　他们如此狂欢，可愁坏了准备睡觉的杰瑞。杰瑞出门理论，反而被4只猫好一阵戏耍……","name":"Saturday Evening Puss","name_cn":"周末夜之猫","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"周末夜之猫"},{"key":"别名","value":[{"v":"周末猫之夜"}]},{"key":"上映年度","value":"1950年1月14日"},{"key":"片长","value":"6分钟"},{"key":"导演","value":"Joseph Barbera,William Hanna"},{"key":"IMDb","value":"tt0042926"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":1,"8":1,"9":0,"10":0},"score":6.4},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":7,"doing":0},"id":634544,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1950-01-07","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/78/00/584308_CK1cz.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/78/00/584308_CK1cz.jpg","large":"https://lain.bgm.tv/pic/cover/l/78/00/584308_CK1cz.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/78/00/584308_CK1cz.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/78/00/584308_CK1cz.jpg"},"summary":"　　农场的清晨格外安静，池塘边的草丛里，鸭妈妈彻夜负担，劳累而满足。她站起身子，活动了筋骨，然后暂时告别她的宝贝，走进池塘漱口游泳。就在此时，狡猾贪婪的汤姆出现，他偷走了鸭蛋打算回家做煎蛋，结果却发现蛋壳里是已经孵化成形的小鸭子奎克（Quacker）。汤姆马上转变策略，不断喂奎克吃白面包，准备做一顿香喷喷的烤鸭。正当他挥起寒气逼人的菜刀时，奎克警觉地发现随后仓皇逃跑，躲进了杰瑞的洞中。汤姆当然不会允许到嘴的鸭子飞掉，他在门口守株待兔，杀气腾腾。而正义的杰瑞义不容辞出手帮助奎克……\r\n　　本片是猫和老鼠系列在20世纪50年代的开篇之作，也是小鸭子奎克首次登场。","name":"Little Quacker","name_cn":"小鸭子","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"小鸭子"},{"key":"上映年度","value":"1950年1月7日"},{"key":"片长","value":"7分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":6,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":4,"8":0,"9":0,"10":0},"score":6.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":1,"wish":1,"collect":14,"doing":0},"id":584308,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]