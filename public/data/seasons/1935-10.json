[{"date":"1935-10-26","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/50/1c/132359_wii4y.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/50/1c/132359_wii4y.jpg","large":"https://lain.bgm.tv/pic/cover/l/50/1c/132359_wii4y.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/50/1c/132359_wii4y.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/50/1c/132359_wii4y.jpg"},"summary":"      在一个大雪纷飞、寒风刺骨的夜晚。一辆轿车猛然急刹，停在某户人家围墙外边。车上的人将一袋东西扔进院子，随后绝尘离去。布袋蠕动，从里面钻出来三只怯懦孱弱的小猫。它们战战兢兢打量着这个漆黑陌生的世界，随后顺着门缝的灯光小心翼翼向房子里走去。顺着门缝，小家伙们看到胖乎乎的女佣人踩着愉快的节拍、哼着悠扬随意的旋律，正准备一桌丰盛的晚宴。少顷，女佣人走远，三只饥饿的小家伙爬上餐桌。面对美食，它们垂涎欲滴，又充满好奇，有趣的小意外相继发生。随后，它们又在这所大房子内周游，展开了妙趣横生的小冒险…… \r\n　　本片荣获1936年奥斯卡金像奖最佳动画短片奖。","name":"Three Orphan Kittens","name_cn":"三只孤儿猫","tags":[{"name":"短片","count":42,"total_cont":0},{"name":"欧美","count":23,"total_cont":0},{"name":"1935","count":15,"total_cont":0},{"name":"迪士尼","count":13,"total_cont":0},{"name":"Disney","count":11,"total_cont":0},{"name":"美国","count":8,"total_cont":0},{"name":"奥斯卡","count":8,"total_cont":0},{"name":"1930s","count":5,"total_cont":0},{"name":"音乐节拍对应剧","count":4,"total_cont":0},{"name":"原创","count":4,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"Short","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"欢乐","count":2,"total_cont":0},{"name":"可爱","count":2,"total_cont":0},{"name":"1930-1939","count":2,"total_cont":0},{"name":"WaltDisneyPictures","count":2,"total_cont":0},{"name":"David·Hand","count":1,"total_cont":0},{"name":"子供向","count":1,"total_cont":0},{"name":"先驱","count":1,"total_cont":0},{"name":"30s","count":1,"total_cont":0},{"name":"60年代前","count":1,"total_cont":0},{"name":"Oscars","count":1,"total_cont":0},{"name":"7(+2)","count":1,"total_cont":0},{"name":"1935年10月","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"排名低了","count":1,"total_cont":0},{"name":"Silly-Symphony","count":1,"total_cont":0},{"name":"动物","count":1,"tot