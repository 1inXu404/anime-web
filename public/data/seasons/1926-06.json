[{"date":"1926-06-10","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a3/d8/258987_wpJEC.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a3/d8/258987_wpJEC.jpg","large":"https://lain.bgm.tv/pic/cover/l/a3/d8/258987_wpJEC.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a3/d8/258987_wpJEC.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a3/d8/258987_wpJEC.jpg"},"summary":"吾妻の国の都、馬具田の城下に、怠け者で他人の財布などを盗っている団子兵衛という若者がいる。ある日、団子兵衛は城主の美しい姫君が落とした御守を拾う。怪龍城の宝物を手にした男が、姫の婿になれると知って、団子兵衛は御守を手に怪龍城に向かう。まず、雪の国に入った団子兵衛は、雪の精をいじめる怪馬人を傘の先で倒す。雪の精はそのお礼に、「傘に積もった雪を粗末にしないように」と言う。魔ヶ淵に辿り着いた花婿志願の男は、現われた龍に喰われてしまう。団子兵衛が雪の積った傘を龍に投げつけると、それを食べた龍は消えてしまう。そこへ雪の精が現われ、団子兵衛を水底の怪龍城へ案内する。願いのかなう宝珠を手に入れた団子兵衛は、天馬に乗って馬具田城に帰る。城下に戻り、敵軍が攻めて来たことを知ると、団子兵衛は姫を助けるため、宝珠を使って味方の兵隊を出す。味方の大軍の大将となった団子兵衛は、見事お城の危難を救い、お婿様になる。城下では、昼はお神輿、夜は花火と祝宴が続く。","name":"馬具田城の盗賊","name_cn":"","tags":[{"name":"短片","count":5,"total_cont":0},{"name":"大藤信郎","count":5,"total_cont":0},{"name":"1926","count":5,"total_cont":0},{"name":"千代纸映画社","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"千代紙映画社","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"上映年度","value":"1926年6月10日"},{"key":"片长","value":"14min"},{"key":"制作","value":"自由映画研究所（千代紙映画社）"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":0,"7":0,"8":2,"9":0,"10":0},"score":6.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":2,"wish":4,"collect":15,"doing":0},"id":258987,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]