度はアンパンマンが乗組員のロボット、マルデ・ヘンダーを助けた。マルデはドロンコ魔王に盗まれたキラキラの涙という宝石を取り返しにナンダ・ナンダー姫と地球にやって来たのだった。キラキラの涙は悪い心の者が持てば悪の力を発揮し、正しい心の者が持てば平和が訪れるという。その秘密を知ったばいきんまんは姫を森の中に閉じ込めたが、姫は同じ目的のドキンちゃんによって解き放たれ、アンパンマンに無事救出されたのだった。そしてアンパンマンはカレーパンマンやしょくぱんまんたちとナンダ・ナンダー姫のためにキラキラの涙を探す旅に出発。いろいろな宝石を集めている恐ろしい氷の女王から苦戦の末、そのキラキラの涙を取り戻したのだった。","name":"それいけ!アンパンマン キラキラ星の涙","name_cn":"面包超人：亮晶晶星的眼泪","tags":[{"name":"剧场版","count":3,"total_cont":0},{"name":"TMSEntertainment","count":2,"total_cont":0},{"name":"1989","count":2,"total_cont":0},{"name":"东京电影新社","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"面包超人：亮晶晶星的眼泪"},{"key":"别名","value":[{"v":"面包超人：闪烁的眼泪"},{"v":"Sore Ike! Anpanman: Kirakira Boshi no Namida"},{"v":"Go! Anpanman: The Shining Star's Tear"}]},{"key":"上映年度","value":"1989年3月11日"},{"key":"片长","value":"75分"},{"key":"官方网站","value":[{"v":"https://www.anpanman.jp/anime/movie.html"},{"v":"https://www.tms-e.co.jp/alltitles/anpanman/060301.html"},{"v":"https://www.shochiku.co.jp/cinema/database/04266/"}]},{"key":"Copyright","value":"©やなせたかし/フレーベル館・TMS・NTV©やなせたかし/アンパンマン製作委員会1989"},{"key":"话数","value":"1"},{"key":"发行","value":"松竹富士"},{"key":"原作","value":"やなせたかし"},{"key":"导演","value":"永丘昭典"},{"key":"副导演","value":"大賀俊二"},{"key":"人物设定","value":"山田みちしろ"},{"key":"脚本","value":"翁妙子"},{"key":"音乐","value":"いずみたく"},{"key":"制作","value":"トムス・エンタテインメント"},{"key":"执行制片人","value":"藤岡豊"},{"key":"企画","value":"武井英彦"},{"key":"制片人","value":"柳内一彦"},{"key":"助理制片人","value":"伊藤響"},{"key":"製作","value":"日本テレビ、松竹富士、東京ムービー新社、フレーベル館"}],"rating":{"rank":0,"total":2,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":2,"collect":4,"doing":2},"id":418852,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1989-03-11","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/9b/55/458112_wOCO3.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/9b/55/458112_wOCO3.jpg","large