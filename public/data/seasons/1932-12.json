[{"date":"1932-12-17","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d4/cc/133794_JcJ9i.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d4/cc/133794_JcJ9i.jpg","large":"https://lain.bgm.tv/pic/cover/l/d4/cc/133794_JcJ9i.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d4/cc/133794_JcJ9i.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d4/cc/133794_JcJ9i.jpg"},"summary":"　　在圣诞节前夜，米奇（华特·迪士尼 Walt Disney 配音）和他忠实的爱犬普鲁托站在街角乞讨，他用大提琴演奏出哀婉但悠扬的曲子，每有人扔给他们硬币，他便礼貌点向他人致意。天上飘起雪花，街上早已白茫茫一片。普鲁托悲凉地朝天哀鸣，兼带驱赶身上的虱子。米奇感觉钱差不多了，于是带着普鲁托去肉食店，却发现罐子里都是螺丝、螺母一类的东西。失望的主仆转身离开，并在一户富人家停下来继续演奏，谁知对方只想买普鲁托，他们只好再度逃跑，结果连大提琴都被路过的马车压坏。 \r\n　　这时，米奇看见一户比他的遭遇还惨的人家。为了帮助他们，米奇忍痛卖掉了普鲁托……","name":"Mickey's Good Deed","name_cn":"米奇的好事录","tags":[{"name":"剧场版","count":2,"total_cont":0},{"name":"短片","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"迪士尼","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"1930s","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"1932","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"米奇的好事录"},{"key":"上映年度","value":"1932-12-17"},{"key":"片长","value":"8分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0023215"},{"key":"类型","value":"喜剧 / 短片 / 家庭"},{"key":"制片国家/地区","value":"美国"},{"key":"主演","value":"Pinto Colvig / 华特·迪斯尼"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":6,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":2,"8":1,"9":0,"10":0},"score":6.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":2,"collect":13,"doing":2},"id":133794,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]