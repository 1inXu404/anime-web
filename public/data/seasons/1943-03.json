[{"date":"1943-03-25","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c4/76/40835_0v0Nn.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c4/76/40835_0v0Nn.jpg","large":"https://lain.bgm.tv/pic/cover/l/c4/76/40835_0v0Nn.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c4/76/40835_0v0Nn.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c4/76/40835_0v0Nn.jpg"},"summary":"　　本片以第二次世界大战期间，日本海军偷袭珍珠港为原型，以桃太郎为队长的部队向鬼岛进行了驱鬼也就是空袭，取得了巨大的战果。\r\n　　日本海军省参与了本片制作，导演濑尾光世等人也被允许参观了海军航空兵，因此，本作品虽说是动画电影，但更像纪录片。\r\n　　在电影制作中，使用了当时在日本国内刚出现不久的多平面照相机和多平面摄影台。使电影中军用飞机在云中飞行的场景等立体构图成为可能。\r\n　　本片虽然是以宣扬战争为目的制作的电影，但片中到处都有暗示和平的内容，同时，本片票房收入是64万日元，本片的姊妹篇《桃太郎 海的神兵》在1945年4月12日公映。\r\n　　本片制作前，导演濑尾光世有机会从海军军官那里欣赏迪士尼动画电影作为制片的参考，导演濑尾光世认为，迪士尼动画电影制作技术之高，是当时的日本无法比拟的。","name":"桃太郎の海鷲","name_cn":"桃太郎之海鹫","tags":[{"name":"1943","count":23,"total_cont":0},{"name":"剧场版","count":22,"total_cont":0},{"name":"瀬尾光世","count":15,"total_cont":0},{"name":"原创","count":10,"total_cont":0},{"name":"短片","count":9,"total_cont":0},{"name":"日本动画","count":6,"total_cont":0},{"name":"太平洋战争","count":5,"total_cont":0},{"name":"日本","count":5,"total_cont":0},{"name":"动作","count":3,"total_cont":0},{"name":"独立剧场版","count":3,"total_cont":0},{"name":"濑尾光世","count":2,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0},{"name":"40年代","count":1,"total_cont":0},{"name":"1940s","count":1,"total_cont":0},{"name":"动物","count":1,"total_cont":0},{"name":"真实事件改编","count":1,"total_cont":0},{"name":"军事","count":1,"total_cont":0},{"name":"战争","count":1,"total_cont":0},{"name":"垃圾","count":1,"total_cont":0},{"name":"3(-2)","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"历史","count":1,"total_cont":0},{"name":"纳粹","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"二战","count":1,"total_cont":0},{"name":"动画电影","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"桃太郎之海鹫"},{"key":"别名","value":[{"v":"桃太郎的海鹫"},{"v":"Momotaro no umiwashi"}]},{"key":"上映年度","value":"1943年3