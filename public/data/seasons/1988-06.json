isodes":0,"collection":{"on_hold":3,"dropped":13,"wish":28,"collect":26,"doing":0},"id":81624,"eps":1,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1988-06-05","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d7/e5/102445_33yyH.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d7/e5/102445_33yyH.jpg","large":"https://lain.bgm.tv/pic/cover/l/d7/e5/102445_33yyH.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d7/e5/102445_33yyH.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d7/e5/102445_33yyH.jpg"},"summary":"　片山愁の漫画『学園便利屋』シリーズが原作のOVA。本作の副題である「アンティークハート」は脚本家の渡辺麻美によってつけられたもので、登場する妖精・沙姫も本作のためのオリジナルキャラクターである。アニメの実制作はJ.C.スタッフ。\r\n　頭脳面を担うリーダー格の鈴木斉、単純明快な本田高弘そしてクールさが特徴の川崎亨。彼ら3人は揉め事から代返まで何でもこなす学園の便利屋だ。そんな一同は体育館の新築に伴う旧校舎の取り壊しが決定する中、そこの整理をはじめるが、やがて内部に住みついている妖精の長・沙姫が出現。古くから存在する器物に宿った古き物の心「アンティークハート」の精霊たちを守るため、心優しい沙姫は豹変して人間と戦おうとするが。\r\n　本作は2007年に逝去した演出家わたなべぢゅんいちの初監督作品（それまでの同氏はOVAのモンスターデザインなどが主な仕事だった）。本OVAの特色は原作で一番の人気だったクールな性格の亨をあえてメインにせず、頭よりも身体で考えるタイプの高弘を中心にすることでスタッフはバランスを保ったという。","name":"学園便利屋シリーズ アンティークハート","name_cn":"学园便利屋","tags":[{"name":"OVA","count":12,"total_cont":0},{"name":"1988","count":7,"total_cont":0},{"name":"渡邊淳一","count":7,"total_cont":0},{"name":"渡辺麻実","count":6,"total_cont":0},{"name":"独立ova","count":5,"total_cont":0},{"name":"J.C.STAFF","count":5,"total_cont":0},{"name":"関俊彦","count":4,"total_cont":0},{"name":"平松広和","count":3,"total_cont":0},{"name":"漫画改","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"古川登志夫","count":1,"total_cont":0},{"name":"1988年","count":1,"total_cont":0},{"name":"80年代","count":1,"total_cont":0},{"name":"塩沢兼人","count":1,"total_cont":0},{"name":"アニメイトフィルム","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"学园便利屋"},{"key":"别名","value":[{"v":"Finished Airing"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1988-06-05"},{"key":"原作","value":"片山愁"},{"key":"脚本","value":"渡辺麻実"},{"key":"人物