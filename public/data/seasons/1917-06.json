[{"id":206510,"type":2,"name":"なまくら刀","name_cn":"钝刀","summary":"从古物商买到一把日本刀的武士想要拿人来试一试刀的锋利程度，但是武艺不济，从背后袭击一名老者时反而被用脚踢飞。第二次从正面袭击时仍然被打倒。他以为是自己的刀钝，所以将刀折断，扔到一边走掉了。\r\n《塙凹内名刀之巻》（はなわへこないめいとうのまき）是1917年（大正6年）6月30日上映的一部日本短篇动画。2007年（平成19年）3月其原版由映像文化史研究家松本夏树于大阪的一家古董店里找到，被确定为日本现存最古老的动画作品。","date":"1917-06-30","images":null,"rating":{"rank":7290,"total":67,"score":5.4,"count":{"1":1,"2":0,"3":5,"4":3,"5":24,"6":23,"7":10,"8":1,"9":0,"10":0}},"tags":[{"name":"短片","count":44},{"name":"1917","count":31},{"name":"幸内純一","count":17},{"name":"日本","count":13},{"name":"小林商会","count":9},{"name":"考古","count":8},{"name":"日本动画","count":8},{"name":"独立动画","count":7},{"name":"1917年","count":6},{"name":"剧场版","count":4},{"name":"原创","count":2}],"eps":1,"collection":{"wish":12,"collect":125,"doing":0,"on_hold":2,"dropped":5}}]