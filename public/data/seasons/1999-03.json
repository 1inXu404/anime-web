[{"date":"1999-03-29","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/30/3d/45905_2SQ8M.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/30/3d/45905_2SQ8M.jpg","large":"https://lain.bgm.tv/pic/cover/l/30/3d/45905_2SQ8M.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/30/3d/45905_2SQ8M.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/30/3d/45905_2SQ8M.jpg"},"summary":"《逮捕令 Special》（日语：逮捕しちゃうぞ Special）。1999年3月至4月在‘Wonderful’时段以短篇动画的方式首播。全21话。之后在该作在同年5月15日至5月29日于TBS的旗下关系企业每日放送‘Anime Shower’时段再放送。\r\n\r\n此作是《逮捕令》系列的最后一部用赛路片制作的动画，因为该作是相互使用赛路片和电脑绘制的动画，所以也是采电脑上色之前过度时期的作品。\r\n\r\n在播出集数方面，从FILE.1.1到FILE.5.4是以每集约7分钟的短篇动画凑成通常30分钟的电视动画形式播出。\r\n\r\n还有，在电视动画版登场的幼稚园园童因为在该作没有出场、相反的则是强化了成人动画的要素，所以并未能电视上正常在播放。但是，只有FILE.6后来有在“TBS春假动画节期”时段才以片长30分钟的内容第一次正常在电视上播出。","name":"逮捕しちゃうぞ Special","name_cn":"逮捕令 Special","tags":[{"name":"TV","count":64,"total_cont":0},{"name":"1999","count":42,"total_cont":0},{"name":"studiodeen","count":32,"total_cont":0},{"name":"逮捕令","count":31,"total_cont":0},{"name":"搞笑","count":31,"total_cont":0},{"name":"漫画改","count":29,"total_cont":0},{"name":"补旧番","count":20,"total_cont":0},{"name":"90年代","count":16,"total_cont":0},{"name":"西村純二","count":12,"total_cont":0},{"name":"OVA","count":10,"total_cont":0},{"name":"漫改","count":8,"total_cont":0},{"name":"藤岛康介","count":7,"total_cont":0},{"name":"生活","count":6,"total_cont":0},{"name":"日本","count":6,"total_cont":0},{"name":"1999年3月","count":4,"total_cont":0},{"name":"百合","count":3,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"90s","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"スタジオディーン","count":2,"total_cont":0},{"name":"西村纯二","count":2,"total_cont":0},{"name":"STUDIO_DEEN","count":2,"total_cont":0},{"name":"TVA","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"日常","count":2,"total_cont":0},{"name":"大谷幸","count":2,"total_cont":0},{"name":"TBS","count":1,"total_cont":0},{"name":"玉川砂記子","count":1,"total_cont":0},{