特典映像として月岡貞夫版、近藤・友永版、出崎・杉野版の3種のパイロットフィルムを収録。","name":"Little NEMO リトルニモ パイロットフィルム","name_cn":"小尼莫梦乡历险记 样片","tags":[{"name":"短片","count":45,"total_cont":0},{"name":"出崎统","count":36,"total_cont":0},{"name":"近藤喜文","count":32,"total_cont":0},{"name":"1984","count":26,"total_cont":0},{"name":"月岡貞夫","count":18,"total_cont":0},{"name":"友永和秀","count":17,"total_cont":0},{"name":"OVA","count":12,"total_cont":0},{"name":"宫崎骏","count":11,"total_cont":0},{"name":"高畑勋","count":9,"total_cont":0},{"name":"Telecom","count":9,"total_cont":0},{"name":"日本","count":5,"total_cont":0},{"name":"杉野昭夫","count":5,"total_cont":0},{"name":"出﨑統","count":5,"total_cont":0},{"name":"短片集","count":3,"total_cont":0},{"name":"月冈贞夫","count":3,"total_cont":0},{"name":"奇幻","count":3,"total_cont":0},{"name":"80年代","count":3,"total_cont":0},{"name":"1980s","count":2,"total_cont":0},{"name":"1987","count":2,"total_cont":0},{"name":"漫画改","count":2,"total_cont":0},{"name":"1980-1989","count":2,"total_cont":0},{"name":"1980","count":1,"total_cont":0},{"name":"undefined","count":1,"total_cont":0},{"name":"可惜","count":1,"total_cont":0},{"name":"可惜了","count":1,"total_cont":0},{"name":"推荐","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"SUNRISE","count":1,"total_cont":0},{"name":"其他","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"小尼莫梦乡历险记 样片"},{"key":"别名","value":[{"v":"小尼莫梦乡历险记 pilot film"},{"v":"Little NEMO リトルニモ パイロット"},{"v":"Little Nemo Pilot"}]},{"key":"话数","value":"3"},{"key":"发售日","value":"1990年12月21日"},{"key":"开始","value":"1990年12月21日"},{"key":"结束","value":"2019年7月31日"}],"rating":{"rank":1417,"total":89,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":11,"7":28,"8":39,"9":7,"10":1},"score":7.4},"total_episodes":0,"collection":{"on_hold":8,"dropped":12,"wish":60,"collect":126,"doing":3},"id":289458,"eps":3,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1990-12-21","platform":"OVA","im