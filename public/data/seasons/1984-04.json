l_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":0,"doing":0},"id":645276,"eps":1,"meta_tags":["TV","美国"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1984-04-13","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e5/61/9305_z1rnG.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e5/61/9305_z1rnG.jpg","large":"https://lain.bgm.tv/pic/cover/l/e5/61/9305_z1rnG.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e5/61/9305_z1rnG.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e5/61/9305_z1rnG.jpg"},"summary":"叶月优是位充满热血的少女，虽然她拥有令人羡慕的运动天赋，但是她却不愿意参加任何运动竞赛。直到有一天，她遇到了影响她一生的好友【早濑奈美】。她们两个经过一些因缘际会后，参加国中部的排球队，结果两人的光芒在那里大放异彩。而排球队教练【大门教练】，是位非常严厉且对球员不假辞色的教练，于是充满热血的小优就常常跟大门教练起冲突。有一天，大门教练看到小优发球的姿势不正确，而很严厉的斥责她，还把小优的右手给打断(但也导致小优日后练就黄金左手厉害的攻势)。小优和奈美升上高中后，彼此分道扬镳选择不同的教练：小优选择的是待人亲切的三田村教练，而奈美还是跟随在大门教练身边。小优和奈美彼此约定好：【我们，一定要打进全国联赛...】而以此目标互相奋斗着！ 第一时期：小优国中的时候，跟奈美同个学校。当时奈美就已经在大门教练的排球队当正式选手，而小优那时还没有和奈美成为好朋友。","name":"アタッカーYOU!","name_cn":"胜利女排","tags":[{"name":"TV","count":18,"total_cont":0},{"name":"1984","count":14,"total_cont":0},{"name":"排球","count":10,"total_cont":0},{"name":"童年","count":9,"total_cont":0},{"name":"女排","count":6,"total_cont":0},{"name":"体育","count":5,"total_cont":0},{"name":"教练","count":4,"total_cont":0},{"name":"胜利女排","count":4,"total_cont":0},{"name":"没看全","count":4,"total_cont":0},{"name":"童年回忆","count":4,"total_cont":0},{"name":"少女","count":2,"total_cont":0},{"name":"ナック映画","count":2,"total_cont":0},{"name":"运动","count":2,"total_cont":0},{"name":"内裤","count":2,"total_cont":0},{"name":"東洋魔女","count":2,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"初中","count":1,"total_cont":0},{"name":"1984年","count":1,"total_cont":0},{"name":"补","count":1,"total_cont":0},{"name":"松井菜桜子","count":1,"total_cont":0},{"name":"必杀技","count":1,"total_cont":0},{"name":"经典","count":1,"total_cont":0},{"name":"勝利女排","count":1,"total_cont":0},{"name":"岡迫和之","count":