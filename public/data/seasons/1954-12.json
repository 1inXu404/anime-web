all":"https://lain.bgm.tv/r/200/pic/cover/l/34/1e/243288_lKEKU.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/34/1e/243288_lKEKU.jpg","large":"https://lain.bgm.tv/pic/cover/l/34/1e/243288_lKEKU.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/34/1e/243288_lKEKU.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/34/1e/243288_lKEKU.jpg"},"summary":"　　夜深人静，围着尿布的小老鼠尼波斯（Nibbles）挥舞着一把破剑来到中世纪的巴黎。他是弗朗西斯鼠的儿子，受父亲的嘱托前来寻找优秀的剑客杰瑞学习剑术。不只是年龄太小还是资质不够，尼波斯一通胡乱挥舞，将杰瑞的房间弄得一团糟。可是既然是老朋友拜托的事情，杰瑞有一万个不情愿还是得收下这个徒弟，而且还要带着小家伙出门转转，在此期间自然也闹出不少的笑话，更险些成为剑客老猫的食物。 \r\n　　忍无可忍的杰瑞给老友修书，随即赶走了尼波斯。失落的尼波斯独自离开，然而却看见汤姆和杰瑞正展开一场实力极不对等的大战。初生牛犊不怕虎，小家伙决然冲了过去……","name":"Touché, Pussy Cat","name_cn":"惊讶的猫咪","tags":[{"name":"短片","count":6,"total_cont":0},{"name":"1954","count":2,"total_cont":0},{"name":"米高梅","count":2,"total_cont":0},{"name":"美国","count":2,"total_cont":0},{"name":"猫和老鼠","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"惊讶的猫咪"},{"key":"上映年度","value":"1954年12月18日"},{"key":"片长","value":"7分钟"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 家庭"},{"key":"制片国家/地区","value":"美国"},{"key":"语言","value":"英语 / 法语"},{"key":"导演","value":"Joseph Barbera、William Hanna"},{"key":"主演","value":"Francoise Brun-Cottan"},{"key":"IMDb链接","value":"tt0047600"}],"rating":{"rank":0,"total":10,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":3,"7":3,"8":2,"9":1,"10":0},"score":6.9},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":3,"collect":29,"doing":1},"id":243288,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]