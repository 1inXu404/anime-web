alse,"type":2},{"date":"1991-04-05","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d0/c5/427808_E6qD9.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d0/c5/427808_E6qD9.jpg","large":"https://lain.bgm.tv/pic/cover/l/d0/c5/427808_E6qD9.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d0/c5/427808_E6qD9.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d0/c5/427808_E6qD9.jpg"},"summary":"眨眼的瞬间，高中生岛村拓哉（Shimamura Taku）发现自己被带到了一个由智慧生物统治奉行奴隶主义的异世界（the bizarre world of Slaffleaze），而由邪恶的佐巴（Zolba）领导的统治阶级正在策划一场入侵他们所知的摩羯座世界，即地球！的阴谋。在通往毫无防备的地球的通道被打开之前，拓哉必须与那些被压迫的奴隶一起，找到一种方法来阻止佐巴的黑暗势力。为了做到这一点，他必须首先获得最后一个雅皮族（the Yappie）的爱与信任，雅皮族是那些奴隶们祖先的守护者。这项任务需要更多的勇气和胆气，因为最后一个雅皮族不仅是一位可爱的少女，她还是一条龙！","name":"カプリコン","name_cn":"摩羯座","tags":[{"name":"OVA","count":3,"total_cont":0},{"name":"独立ova","count":1,"total_cont":0},{"name":"真鍋譲治","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"アウベック","count":1,"total_cont":0},{"name":"1991年","count":1,"total_cont":0},{"name":"今西隆志","count":1,"total_cont":0},{"name":"漫画改","count":1,"total_cont":0},{"name":"渡辺信一郎","count":1,"total_cont":0},{"name":"1991","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"摩羯座"},{"key":"别名","value":[{"v":"风神战士"},{"v":"Capricorn"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1991年4月5日"},{"key":"动画制作","value":"AUBECK（アウベック）"},{"key":"制作协力","value":"アニメアール、スタジオ・ムー、ダスト、アニメーション501、アトリエふくろう、アイワークス、スタジオ絵夢、サン企画、サムタック企画、スタジオ天、きのプロダクション、R3 Company"},{"key":"製作","value":"大陸書房"},{"key":"制片人","value":"松浦まさこ、高野宏；担当制片人：皆川卓哉、金沢靖彦"}],"rating":{"rank":0,"total":7,"count":{"1":0,"2":0,"3":1,"4":2,"5":3,"6":0,"7":0,"8":0,"9":1,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":0,"dropped":2,"wish":6,"collect":8,"doing":0},"id":427808,"eps":1,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1991-04-05","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/76/b8/542273_uBZv1.jpg","grid":"https://lain.bgm