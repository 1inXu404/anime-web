[{"date":"1968-01-12","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/33/23/503698_iJLgN.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/33/23/503698_iJLgN.jpg","large":"https://lain.bgm.tv/pic/cover/l/33/23/503698_iJLgN.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/33/23/503698_iJLgN.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/33/23/503698_iJLgN.jpg"},"summary":"　　在制作电视系列动画时，为了让赞助方和电视台了解成片会是一部怎样的动画，而制作的用来演示成片效果的动画。这部《多罗罗》的样片，与正式播出时的版本相比，更加忠实于原作。为了让观众易于接受，正式播出的版本对角色的脸和个性都进行不少改动。从结果来看，虽然有一些改动得到观众们认可，但也有一些最后走向完全预料之外的方向。另外，虽然样片是彩色版本，但正式版因预算削减而制作成了黑白动画。本片讲述了出生时就被诅咒、失去身体部位的百鬼丸，与小毛贼多罗罗一起踏上降妖除魔的旅程，降伏48只妖怪，最终变回完整的“人类”的故事。","name":"どろろ パイロットフィルム","name_cn":"多罗罗 样片","tags":[{"name":"漫画改","count":4,"total_cont":0},{"name":"TV","count":3,"total_cont":0},{"name":"1968","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"1968年1月","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"虫Production","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"手冢治虫","count":1,"total_cont":0},{"name":"补旧番","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"多罗罗 样片"},{"key":"话数","value":"1"},{"key":"放送开始","value":"1968年1月12日"},{"key":"片长","value":"14分钟"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":2,"7":1,"8":0,"9":0,"10":0},"score":5.8},"total_episodes":0,"collection":{"on_hold":1,"dropped":1,"wish":9,"collect":15,"doing":3},"id":503698,"eps":1,"meta_tags":["TV","日本","漫画改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1968-01-03","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/14/ca/40379_GRKRL.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/14/ca/40379_GRKRL.jpg","large":"https://lain.bgm.tv/pic/cover/l/14/ca/40379_GRKRL.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/14/ca/40379_GRKRL.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/14/ca/40379_GRKRL.jpg"},"summary":"妖怪漫画の巨匠・水木しげるの代