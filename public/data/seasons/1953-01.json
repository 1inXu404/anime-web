[{"date":"1953-01-10","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ee/28/634630_j6u4J.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ee/28/634630_j6u4J.jpg","large":"https://lain.bgm.tv/pic/cover/l/ee/28/634630_j6u4J.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ee/28/634630_j6u4J.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ee/28/634630_j6u4J.jpg"},"summary":"　　又是一个晴朗的日子，小老鼠杰瑞打开冰箱门，小心翼翼地搬出里面的奶酪，同时还得提防老对手汤姆的袭击。谁知狡猾的汤姆正趴在冰箱的上面，带着嘲笑的神情注视着杰瑞的一举一动。接下来，汤姆对杰瑞发动了一连串猛烈的攻势，毫无防备的小老鼠遭到最为惨烈的戏弄，还从上到下沾满了白色的药水。另一边，正躺在沙发上看杂志的汤姆听到听到一则紧急消息：一只小白鼠从实验室逃了出来，此前他吃了足以炸毁整座城市的炸弹，因此千万不能振动小白鼠。听到新闻的汤姆吓破了胆，而杰瑞决定将计就计，好好戏耍可恶的老猫。\r\n　　面对随时可能爆炸的小白鼠，汤姆的磨难开始了……","name":"The Missing Mouse","name_cn":"可怕的白鼠","tags":[{"name":"1950s","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"短片","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"可怕的白鼠"},{"key":"上映年度","value":"1953年1月10日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0046078"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":2,"8":0,"9":0,"10":0},"score":6.2},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":7,"doing":0},"id":634630,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1953-01-03","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/bd/cf/280547_Z5TnN.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/bd/cf/280547_Z5TnN.jpg","large":"https://lain.bgm.tv/pic/cover/l/bd/cf/280547_Z5TnN.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/bd/cf/280547_Z5TnN.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/bd/cf/280547_Z5TnN.jpg"},"summary":"","name":"Don't Give Up the Sheep","name_cn":"不要放弃羊","tags":[{"name":"短片","count":9,"total_cont":0},{"name":"美国","count":5,"total_cont":0},{"name":"1953","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"Chuck_Jones","coun