[{"date":"1935-06-26","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/29/9a/149198_rzki5.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/29/9a/149198_rzki5.jpg","large":"https://lain.bgm.tv/pic/cover/l/29/9a/149198_rzki5.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/29/9a/149198_rzki5.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/29/9a/149198_rzki5.jpg"},"summary":"　　夜幕降临，万籁俱寂。高高的大树上，知更鸟考克·罗宾（Purv Pullen 配音）穿着庄重的礼服，在心爱的姑娘珍妮（Matha Wentworth 配音）窗前一展歌喉，唱起最动听和充满爱意的情歌。可就在这最为浪漫的时刻，一个身影偷偷出现在林间，它射出一只利箭，刺中考克·罗宾的胸膛。可怜的知更鸟应声摔到树下，惊醒了沉睡的鸟儿们，也吓到老乌鸦酒吧的酒客。警车和救护车响着刺耳的警笛冲来，粗暴的警察冲入酒吧，抓住胆小的黑鸟、混迹帮派的麻雀和傻乎乎的布谷鸟投入警车，等待猫头鹰法官（Billy Bletcher 配音）的审判。究竟是谁沙乐考克·罗宾？ \r\n　　本片根据同名原著改编，并荣获1936年威尼斯电影节最佳动画片特别提及。","name":"Who Killed Cock Robin?","name_cn":"谁杀害了知更鸟先生？","tags":[{"name":"短片","count":9,"total_cont":0},{"name":"1935","count":4,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"美国","count":2,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"威尼斯电影节","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"Disney","count":1,"total_cont":0},{"name":"4(-1)","count":1,"total_cont":0},{"name":"1930s","count":1,"total_cont":0},{"name":"30s","count":1,"total_cont":0},{"name":"1929","count":1,"total_cont":0},{"name":"Silly-Symphony","count":1,"total_cont":0},{"name":"David·Hand","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"谁杀害了知更鸟先生？"},{"key":"别名","value":[{"v":"Silly Symphony Series"}]},{"key":"上映年度","value":"1935-06-26"},{"key":"片长","value":"8min"},{"key":"类型","value":"喜剧 / 动画 / 悬疑 / 短片 / 歌舞 / 家庭"},{"key":"IMDb ID","value":"tt0027212"},{"key":"语言","value":"英语"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"David Hand"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":10,"count":{"1":1,"2":0,"3":0,"4":2,"5":3,"6":2,"7":1,"8":1,"9":0,"10":0},"score":5.1},"total_episo