[{"date":"1991-02-22","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d3/17/77605_LZuZu.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d3/17/77605_LZuZu.jpg","large":"https://lain.bgm.tv/pic/cover/l/d3/17/77605_LZuZu.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d3/17/77605_LZuZu.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d3/17/77605_LZuZu.jpg"},"summary":"『特命武装検事・黒木豹介』シリーズなどで知られるハードロマン作家、門田泰明のSFバイオレンス・アクション小説をOVA化。監督は『遠い海から来たCOO』などで知られる今沢哲男。キャストは田中秀幸、鶴ひろみ、藤田淑子ほか。主題歌には中村雅俊の『絆』が起用されている。 \r\n　　外科医の右京列は、患者の脳から不気味な腫瘍を摘出する。それはやがておぞましい怪物へと変化し、病院の人々を次々と襲撃。なんとその腫瘍は、5000年の時を超えて蘇った縄文帝国軍団の“魔獣”だったのだ。観音像の力で超人的なパワーを得た右京は、魔獣たちを率いる夜叉王を倒すために立ち上がる。","name":"捜獣戦士 サイキック・ウォーズ","name_cn":"搜兽战士 超能战争","tags":[{"name":"OVA","count":15,"total_cont":0},{"name":"1991","count":7,"total_cont":0},{"name":"毒","count":3,"total_cont":0},{"name":"战斗","count":2,"total_cont":0},{"name":"其他","count":2,"total_cont":0},{"name":"OVA-01","count":2,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"独立ova","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"搜兽战士 超能战争"},{"key":"别名","value":[{"v":"Psychic War"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1991年2月22日"},{"key":"导演","value":"今沢哲男"}],"rating":{"rank":0,"total":13,"count":{"1":5,"2":3,"3":1,"4":1,"5":3,"6":0,"7":0,"8":0,"9":0,"10":0},"score":2.5},"total_episodes":0,"collection":{"on_hold":2,"dropped":9,"wish":19,"collect":18,"doing":2},"id":77605,"eps":1,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1991-02-22","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/48/52/92946_Lk0rL.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/48/52/92946_Lk0rL.jpg","large":"https://lain.bgm.tv/pic/cover/l/48/52/92946_Lk0rL.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/48/52/92946_Lk0rL.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/48/52/92946_Lk0rL.jpg"},"summary":"　「週刊ヤングマガジン」に連載された、すぎむらしんいちのバイクアクション・コミックが原作。監督はサンリオのアニメ作品などで知られる大庭秀昭、キャラクターデザインと作画監督は、『装甲騎兵ボトムズ』『蒼き流星SPTレイズナー』などの作画監督や公式イラストでも知られるベテラン、谷口守泰。キャストは山寺宏一、山口健一、林原めぐみほか。\r\n　バイクを愛する高校生マサオは、買ったばかりの新車「ヤマハFZR」を、スズキの名車カタナを駆る鎧姿のライダーに沈められてしまう。翌日、転校生の沢村を見たマサオは、彼があのライダーだと直感ほどなく街は、暴走族を蹴散らす一匹狼“サムライダー”の噂で持ちきりに。マサオはバイクに違法改造を施し、奴を倒そうと決意する。一方、サムライダーに恨みを持つ暴走族の追撃も激化。その争いに、いつしかマサオも巻き込まれていく。本物の排気音を使った、迫力あるバイク走行シーンが見どころ。","name":"サムライダー","name_cn":"武士骑士","tags":[{"name":"OVA","count":3,"total_cont":0},{"name":"1991","count":1,"total_cont":0},{"name":"独立ova","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"大庭秀昭","count":1,"total_cont":0},{"name":"山本優","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"武士骑士"},{"key":"别名","value":[{"v":"サムライダー 謎の転校生"},{"v":"Samuraider: Nazo no Tenkousei"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1991年2月22日"},{"key":"时长","value":"50分"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":1,"3":0,"4":0,"5":1,"6":1,"7":0,"8":0,"9":0,"10":1},"score":5.8},"total_episodes":0,"collection":{"on_hold":3,"dropped":4,"wish":7,"collect":6,"doing":0},"id":92946,"eps":1,"meta_tags":["OVA","漫画改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1991-02-21","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f3/d7/92947_Hhy3T.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f3/d7/92947_Hhy3T.jpg","large":"https://lain.bgm.tv/pic/cover/l/f3/d7/92947_Hhy3T.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f3/d7/92947_Hhy3T.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f3/d7/92947_Hhy3T.jpg"},"summary":"『デビルマン』、『マジンガーZ』といった永井豪原作のキャラクター達をSD化したアニメーション。そもそもの始まりは飯田つとむ(現･飯田馬之介)が仕事合間の息抜きに描いた落描きが永井豪の目にとまり、非常に喜んだことからだった。ギャグとパロディをジャンルとしているが、物語の内容としてはシリアスなストーリーに仕上がっている。","name":"CBキャラ 永井豪ワールド","name_cn":"永井豪的Q版世界","tags":[{"name":"OVA","count":31,"total_cont":0},{"name":"永井豪","count":25,"total_cont":0},{"name":"1990","count":17,"total_cont":0},{"name":"飯田馬之介","count":13,"total_cont":0},{"name":"