:9,"10":2},"score":7.7},"total_episodes":0,"collection":{"on_hold":9,"dropped":8,"wish":131,"collect":75,"doing":9},"id":61649,"eps":35,"meta_tags":["TV","日本","漫画改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1996-07-06","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/bc/87/158799_sywKi.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/bc/87/158799_sywKi.jpg","large":"https://lain.bgm.tv/pic/cover/l/bc/87/158799_sywKi.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/bc/87/158799_sywKi.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/bc/87/158799_sywKi.jpg"},"summary":"鬼の手を用いて悪霊退治を行う小学校教師の活躍を描いたTVアニメの劇場版を、「東映アニメフェア」内のプログラムとして上映されたもので、シリーズ第一弾。\r\n気の弱い少女・飯島久美子は指名手配中の犯罪者を偶然にも目撃し、勇気を出して警察に通報する。逃走中に天狗塚に衝突し重傷を負って逮捕された犯人は、やがてその恨みを悪霊に利用され怪人黒マントを生みだすのだった。その後、久美子がつけていた赤いリボンを目印にして、イニシャルがK・Iの少女が次々に襲われていく。狙われた久美子や子供たちを護るため、担任教師であるぬ～べ～は敢然と立ち上がった！\r\n都市伝説をモチーフにした、いかにも『ぬ～べ～』らしい雰囲気の一作。同時上映の『鬼太郎』がスペクタクル大作『大海獣』だったので、バランスが取れている？　人気ヒロインのゆきめも登場した。","name":"（超）劇場版!地獄先生ぬ〜べ〜","name_cn":"地狱教师 剧场版","tags":[{"name":"剧场版","count":17,"total_cont":0},{"name":"1996","count":13,"total_cont":0},{"name":"東映アニメーション","count":5,"total_cont":0},{"name":"置鮎龍太郎","count":4,"total_cont":0},{"name":"笠原留美","count":4,"total_cont":0},{"name":"貝澤幸男","count":3,"total_cont":0},{"name":"喵帕斯记录~","count":2,"total_cont":0},{"name":"富田祐弘","count":2,"total_cont":0},{"name":"漫画改","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"旧番","count":2,"total_cont":0},{"name":"横山健次","count":1,"total_cont":0},{"name":"神魔","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"1996年","count":1,"total_cont":0},{"name":"1996年七月番","count":1,"total_cont":0},{"name":"志水淳児","count":1,"total_cont":0},{"name":"1996年7月","count":1,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"地狱教师 剧场版"},{"key":"别名","value":[{"v":"地狱教师 天狗传说"},{"v":"(超)劇場版!地獄先生ぬ〜べ〜「正義之手 