[{"date":"1982-10-30","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/67/e0/210920_gn4f9.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/67/e0/210920_gn4f9.jpg","large":"https://lain.bgm.tv/pic/cover/l/67/e0/210920_gn4f9.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/67/e0/210920_gn4f9.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/67/e0/210920_gn4f9.jpg"},"summary":"１９８Ｘ年。アメリカは対戦略核ミサイル用の戦闘衛星の実験を行い成功する。だがこの実験後、戦闘衛星の生みの親であるバート・ゲイン博士はソ連のスパイに拉致され、原潜でモスクワまで連れ去られる事件が発生。アメリカは機密保持のために博士ごと原潜を核魚雷で沈めてしまう。米ソの緊張は一気に高まり、東西ドイツでも国境付近では一触即発の状況に。そんな中、西ドイツの空軍基地にソ連の最新鋭戦闘機が亡命を求めて不時着した…。","name":"FUTURE WAR 198X年","name_cn":"未来战争 198X年","tags":[{"name":"剧场版","count":22,"total_cont":0},{"name":"1982","count":13,"total_cont":0},{"name":"原创","count":10,"total_cont":0},{"name":"东映","count":8,"total_cont":0},{"name":"東映","count":6,"total_cont":0},{"name":"战争","count":4,"total_cont":0},{"name":"1982年","count":3,"total_cont":0},{"name":"80年代","count":2,"total_cont":0},{"name":"1982年10月","count":2,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"国产","count":1,"total_cont":0},{"name":"秋季","count":1,"total_cont":0},{"name":"反战","count":1,"total_cont":0},{"name":"舛田利雄","count":1,"total_cont":0},{"name":"1982年十月番","count":1,"total_cont":0},{"name":"胜间田具治","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"未来战争 198X年"},{"key":"别名","value":[{"v":"フューチャーウォー198X年"}]},{"key":"上映年度","value":"1982年10月30日"},{"key":"片长","value":"125分"},{"key":"导演","value":"舛田利雄、勝間田具治"},{"key":"脚本","value":"高田宏治"},{"key":"制作","value":"横井三郎"},{"key":"制作总指挥","value":"渡邊亮徳"},{"key":"音乐","value":"横山菁児"},{"key":"撮影","value":"白井久男、寺尾三千代"},{"key":"編集","value":"千蔵豊、吉川泰弘"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":23,"count":{"1":0,"2":0,"3":0,"4":0,"5":6,"6":3,"7":12,"8":2,"9":0,"10":0},"score":6.4},"total_episodes":0,"collection":{"on_hold":2,"dropped":5,"wish":34,"collect":38,"doing":3},"id":210920,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"lo