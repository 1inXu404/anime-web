，导致两位主创William Hanna和Joseph Barbera无法获得米高梅的支持制作下一部猫鼠动画，直到德州达拉斯某些影院强烈呼吁，米高梅才为主创开了绿灯。也正是从这部起，汤姆（Tom）和杰瑞（Jerry）才正式成了两位主角的名字。","date":"1941-07-19","images":null,"rating":{"rank":0,"total":35,"score":6.7,"count":{"1":0,"2":0,"3":0,"4":3,"5":1,"6":9,"7":15,"8":6,"9":1,"10":0}},"tags":[{"name":"短片","count":21},{"name":"猫和老鼠","count":10},{"name":"欧美","count":8},{"name":"1941","count":8},{"name":"美国","count":5},{"name":"剧场版","count":3},{"name":"米高梅","count":3},{"name":"原创","count":3},{"name":"1940s","count":2},{"name":"威廉·汉纳","count":1}],"eps":1,"collection":{"wish":4,"collect":80,"doing":1,"on_hold":0,"dropped":6}}]