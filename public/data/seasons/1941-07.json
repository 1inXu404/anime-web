[{"date":"1941-07-19","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d2/d5/262573_9xyxU.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d2/d5/262573_9xyxU.jpg","large":"https://lain.bgm.tv/pic/cover/l/d2/d5/262573_9xyxU.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d2/d5/262573_9xyxU.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d2/d5/262573_9xyxU.jpg"},"summary":"　　宁静的夜晚，并向在黑暗的房间内闪着明亮的光。原来小老鼠杰瑞正在偷奶酪，虽然分外警惕，然而他还是被淘气的老猫汤姆暗中跟踪。汤姆并不急于抓住他，而是不断在杰瑞的奶酪上放置重物，对他进行戏耍。不过，汤姆也是个监守自盗的家伙，他与杰瑞新一轮的战争由此展开…… \r\n　　本片为“猫和老鼠（Tom & Jerry）”系列第二部作品，首部Puss Gets the Boots虽然获得奥斯卡的提名，但是反响平平，导致两位主创William Hanna和Joseph Barbera无法获得米高梅的支持制作下一部猫鼠动画，直到德州达拉斯某些影院强烈呼吁，米高梅才为主创开了绿灯。也正是从这部起，汤姆（Tom）和杰瑞（Jerry）才正式成了两位主角的名字。","name":"The Midnight Snack","name_cn":"午夜点心","tags":[{"name":"短片","count":21,"total_cont":0},{"name":"猫和老鼠","count":10,"total_cont":0},{"name":"1941","count":8,"total_cont":0},{"name":"欧美","count":8,"total_cont":0},{"name":"美国","count":5,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"William.Hanna","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"威廉·汉纳","count":1,"total_cont":0},{"name":"Joseph.Barbera","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"午夜点心"},{"key":"别名","value":[{"v":"夜中のつまみ食い"}]},{"key":"上映年度","value":"1941年7月19日"},{"key":"片长","value":"8分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":36,"count":{"1":0,"2":0,"3":0,"4":3,"5":1,"6":10,"7":15,"8":6,"9":1,"10":0},"score":6.6},"total_episodes":0,"collection":{"on_hold":0,"dropped":6,"wish":4,"collect":81,"doing":1},"id":262573,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1941-07-11","platform":"剧场版","images":{