[{"date":"1944-07-22","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/fa/0d/262702_gywYC.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/fa/0d/262702_gywYC.jpg","large":"https://lain.bgm.tv/pic/cover/l/fa/0d/262702_gywYC.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/fa/0d/262702_gywYC.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/fa/0d/262702_gywYC.jpg"},"summary":"　　这一天，小老鼠杰瑞被汤姆追得慌不择路。突然，他听到附近传来了呼救声。声音来自大狗史派克（比利·布兰彻 Billy Bletcher 饰），他被捉狗队关进汽车里，只好哀求杰瑞帮他逃出牢笼。在杰瑞的帮助下，史派克重获自由，为了答谢小恩人，史派克承诺杰瑞遇到困难时，只要吹口哨他就会立刻赶到。不久，杰瑞落入汤姆的猫爪，眼看就要成了汤姆的早餐，杰瑞情急之中吹响口哨，史派克便如一阵风赶来，狠狠教训了汤姆。杰瑞屡试不爽，有了这个忠诚强大的保镖后他胆量大增，却不知汤姆已经想出绝佳的办法对付他…… \r\n　　本片是大狗史派克第二次出场，不过却是他首次开口说话。","name":"The Bodyguard","name_cn":"保镖","tags":[{"name":"短片","count":20,"total_cont":0},{"name":"猫和老鼠","count":8,"total_cont":0},{"name":"1944","count":6,"total_cont":0},{"name":"欧美","count":6,"total_cont":0},{"name":"美国","count":4,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"原创","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"电影","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"保镖"},{"key":"上映年度","value":"1944-07-22"},{"key":"片长","value":"7分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":41,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":8,"7":16,"8":12,"9":2,"10":1},"score":7.2},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":6,"collect":86,"doing":1},"id":262702,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]