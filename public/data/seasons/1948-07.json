[{"date":"1948-07-17","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/7b/73/263193_OkztZ.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/7b/73/263193_OkztZ.jpg","large":"https://lain.bgm.tv/pic/cover/l/7b/73/263193_OkztZ.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/7b/73/263193_OkztZ.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/7b/73/263193_OkztZ.jpg"},"summary":"　　这一天，院子里照例发生了惊天动地的大战。汤姆、杰瑞以及斯派克三方会战，屋里乱作一团，家具器皿飞来飞去。三个冤家从屋里打到屋外，没有停歇。突然，斯派克止住了他们。他觉得这种打打闹闹的日子太没意思，于是希望彼此握手言欢，从此休战。在他屋里震慑之下，汤姆和杰瑞勉强同意了。此后，他们像模像样地签订了和平条约，从此展开了充满温馨与关爱的新生活。比如汤姆会贴心地为杰瑞盖上被子，杰瑞会将斯派克垂下的舌头推回嘴里，斯派克则会早早起床准备早餐。遇到危险时，他们也会第一时间冲出来营救伙伴。 \r\n　　只是不知道，这样的和平究竟能维持多久……","name":"The Truce Hurts","name_cn":"休战的伤害","tags":[{"name":"短片","count":22,"total_cont":0},{"name":"猫和老鼠","count":9,"total_cont":0},{"name":"欧美","count":9,"total_cont":0},{"name":"1948","count":8,"total_cont":0},{"name":"美国","count":7,"total_cont":0},{"name":"米高梅","count":4,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"Short_film","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"William.Hanna","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"Joseph.Barbera","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"休战的伤害"},{"key":"上映年度","value":"1948-07-17"},{"key":"片长","value":"7分38秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":43,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":3,"7":14,"8":19,"9":5,"10":1},"score":7.6},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":5,"collect":92,"doing":1},"id":263193,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1948-07-09","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/fc/8c/359176_bsswY.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/fc/8c/359176_bsswY.jpg