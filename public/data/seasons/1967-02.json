[{"date":"1967-02-24","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/86/ff/634483_BUxVL.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/86/ff/634483_BUxVL.jpg","large":"https://lain.bgm.tv/pic/cover/l/86/ff/634483_BUxVL.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/86/ff/634483_BUxVL.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/86/ff/634483_BUxVL.jpg"},"summary":"　　伴随着巨大的轰鸣声，一颗人造卫星发射到了外太空，它的目的地是那个宛如巨大轮盘赌的一号空间站。卫星里载满了供宇航员们日常所用的物资。传送带将物资缓缓运入舱内，其中包含一枚巨大的奶酪，这引起了空间站内另一名住客——小老鼠杰瑞的兴趣。他随即动身窃取奶酪，无意中触发了警报系统。老猫汤姆是空间站的警卫，他从监控屏上看到了杰瑞，随即命令机器猫前去拦截。谁知机器猫遭到杰瑞的戏耍，反过来给汤姆带来巨大的麻烦。\r\n　　无奈之下，汤姆只得亲自上阵，他找来超级强大的激光枪，和小老鼠在空间站内展开一场超现实的星球大战……","name":"O-Solar Meow","name_cn":"太阳系的猫叫声","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"1960-1969","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"太阳系的猫叫声"},{"key":"上映年度","value":"1967年2月24日"},{"key":"片长","value":"7分钟"},{"key":"导演","value":"Abe Levitow,Chuck Jones"},{"key":"IMDb","value":"tt0062061"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":0,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":5,"doing":0},"id":634483,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1967-02-15","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/5d/36/79940_70Wce.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/5d/36/79940_70Wce.jpg","large":"https://lain.bgm.tv/pic/cover/l/5d/36/79940_70Wce.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/5d/36/79940_70Wce.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/5d/36/79940_70Wce.jpg"},"summary":"　白土三平の同名長編漫画を大島渚が映画化。原画をそのまま撮影しアフレコするという、実験的な手法は賛否両論を呼んだ。声のキャストには大島組の常連である山本圭、小山明子、佐藤慶らが名を連ねた。室町時代、伏影城の城主は家老の坂上主膳に謀られ非業の死を遂げる。城主の息子である結城重太郎は辛うじて逃げ延び、父の仇を討つ機会を伺っていた。数年後、重太郎は城下に現れるが、主膳の妹で忍者の螢火に重症を負わされてしまう。そんな彼を救ったのは、伏影城に恨みを抱く忍者の影丸だった。","name":"忍者武芸帳","name_cn":"忍者武艺帐","tags":[{"name":"剧场版","count":11,"total_cont":0},{"name":"1967","count":9,"total_cont":0},{"name":"白土三平","count":5,"total_cont":0},{"name":"摄影漫画","count":4,"total_cont":0},{"name":"大岛渚","count":4,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"独立剧场版","count":2,"total_cont":0},{"name":"大島渚","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"忍者","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"佐佐木守","count":1,"total_cont":0},{"name":"暴力血腥","count":1,"total_cont":0},{"name":"ppt","count":1,"total_cont":0},{"name":"佐々木守","count":1,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"忍者武艺帐"},{"key":"别名","value":[{"v":"Band of Ninja"}]},{"key":"上映年度","value":"1967年2月15日"},{"key":"片长","value":"135分钟"},{"key":"导演","value":"大島渚"},{"key":"制作","value":"中島正幸、山口卓治、大島渚"},{"key":"脚本","value":"佐々木守、大島渚"},{"key":"摄影","value":"高田昭"},{"key":"音乐","value":"林光"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":15,"count":{"1":0,"2":1,"3":0,"4":1,"5":5,"6":3,"7":2,"8":2,"9":1,"10":0},"score":5.9},"total_episodes":0,"collection":{"on_hold":4,"dropped":8,"wish":23,"collect":21,"doing":1},"id":79940,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]