[{"date":"1956-12-14","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/83/7d/634795_0qP67.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/83/7d/634795_0qP67.jpg","large":"https://lain.bgm.tv/pic/cover/l/83/7d/634795_0qP67.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/83/7d/634795_0qP67.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/83/7d/634795_0qP67.jpg"},"summary":"　　在一个晴朗的日子里，宁静的后院中史派克和儿子泰克头戴厨师帽，正愉快地聊天。史派克准备为儿子做顿烤肉，他准备好一应器具与食材，从最初倾倒汽油、点燃煤球工序做起，虽然状况不断，不过史派克还是充满喜悦地为儿子示范这一切。就在这时，那对冤家汤姆和杰瑞又吵吵闹闹地跑了过来，杰瑞仓皇之中钻进了煤球袋子里，汤姆则不管不顾一通翻腾。好不容易赶走老猫，史派克又无意间将滚得全身漆黑的杰瑞扔进炉子，烫得小老鼠嗷嗷直叫。看来，这对父子的烤肉计划将要泡汤了……","name":"Barbecue Brawl","name_cn":"父子烤肉野餐","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"父子烤肉野餐"},{"key":"上映年度","value":"1956年12月14日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0048986"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":1,"7":1,"8":0,"9":0,"10":0},"score":5.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634795,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]