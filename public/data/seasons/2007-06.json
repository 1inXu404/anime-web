71年1月连载了林静一的代表作『赤色挽歌』。あがた森魚出于对这一作品的共鸣创作了同名主题歌。对白、画面和音乐的完美结合，使得这一作品作为当时风俗的象征盛行一时。\r\n　　这个凄美的爱情故事历四十年而弥新，今次演变为以「声漫」这一新的映像形式表现的作品。原画翻新，脚本，导演，都由林静一亲自参与，并且在あがた森魚和铃木庆一的协助下担任音乐导演。这次的作品更起用曾因钢琴弹唱会受到关注的歌手浜田真理子翻唱「赤色挽歌」，作为插曲为作品增添一抹新色。　　","date":"2007-06-21","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c0/60/59919_lr6Bk.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c0/60/59919_lr6Bk.jpg","large":"https://lain.bgm.tv/pic/cover/l/c0/60/59919_lr6Bk.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c0/60/59919_lr6Bk.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c0/60/59919_lr6Bk.jpg"},"rating":{"rank":5079,"total":114,"score":6.3,"count":{"1":0,"2":0,"3":2,"4":6,"5":22,"6":30,"7":36,"8":16,"9":1,"10":1}},"tags":[{"name":"短片","count":39},{"name":"2007","count":37},{"name":"OVA","count":29},{"name":"林静一","count":24},{"name":"剧场版","count":15},{"name":"东映","count":14},{"name":"SHORTS","count":6},{"name":"人生","count":5},{"name":"東映アニメーション","count":5},{"name":"赤色エレジー","count":4},{"name":"漫画改","count":3}],"eps":1,"collection":{"wish":135,"collect":164,"doing":5,"on_hold":6,"dropped":6}},{"id":20691,"type":2,"name":"猫ラーメン","name_cn":"猫拉面","summary":"","date":"2007-06-22","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e9/00/20691_sJTWt.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e9/00/20691_sJTWt.jpg","large":"https://lain.bgm.tv/pic/cover/l/e9/00/20691_sJTWt.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e9/00/20691_sJTWt.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e9/00/20691_sJTWt.jpg"},"rating":{"rank":3575,"total":53,"score":6.5,"count":{"1":0,"2":0,"3":1,"4":1,"5":4,"6":23,"7":14,"8":7,"9":3,"10":0}},"tags":[{"name":"泡面番","count":26},{"name":"2007","count":13},{"name":"TV","count":12},{"name":"日常系","count":9},{"name":"漫画改","count":7},{"name":"治愈","count":5},{"name":"flash","count":4},{"name":"2007夏アニメ","count":4},{"name":"S-inc.","count":3},{"name":"猫拉面","count":3}],"eps":13,"collection":{"wish":42,"collect":88,"doing":2,"on_ho