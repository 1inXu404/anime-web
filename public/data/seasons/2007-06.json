。许多天后姐妹俩在沙滩上找到了海员的尸体，妹妹祈求姐姐把海员做成了“人干”永久的留在了自己身边……","name":"The Pearce Sisters","name_cn":"黑色姐妹花","tags":[{"name":"短片","count":9,"total_cont":0},{"name":"2007","count":7,"total_cont":0},{"name":"英国","count":4,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"欧洲","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"黑色姐妹花"},{"key":"别名","value":[{"v":"黑色姊妹花 / Adelfes Pearce"}]},{"key":"上映年度","value":"2007-06-11"},{"key":"片长","value":"9min"},{"key":"官方网站","value":"http://www.pearcesisters.co.uk/"},{"key":"制片国家/地区","value":"英国"},{"key":"语言","value":"英语"},{"key":"导演","value":"Luis Cook"},{"key":"编剧","value":"Luis Cook / Kirkham Jackson"},{"key":"主演","value":"Len Gray / Dan Williamson"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":8,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":4,"7":1,"8":0,"9":2,"10":0},"score":6.8},"total_episodes":0,"collection":{"on_hold":1,"dropped":3,"wish":6,"collect":20,"doing":0},"id":137294,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"2007-06-10","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/49/7a/37573_QCUMp.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/49/7a/37573_QCUMp.jpg","large":"https://lain.bgm.tv/pic/cover/l/49/7a/37573_QCUMp.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/49/7a/37573_QCUMp.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/49/7a/37573_QCUMp.jpg"},"summary":"","name":"名探偵ゴードン","name_cn":"名侦探哥顿","tags":[{"name":"短片","count":43,"total_cont":0},{"name":"谷口崇","count":35,"total_cont":0},{"name":"2007","count":24,"total_cont":0},{"name":"WEB","count":17,"total_cont":0},{"name":"原创","count":14,"total_cont":0},{"name":"推理","count":9,"total_cont":0},{"name":"讽刺","count":8,"total_cont":0},{"name":"cult","count":7,"total_cont":0},{"name":"日本动画","count":5,"total_cont":0},{"name":"独立动画","count":4,"total_cont":0},{"name":"ONA","count":4,"total_cont":0},{"name":"OVA","count":3,"total_cont":0},{"name":"2006","count":3,"t