c/cover/l/e6/fa/10598_0x1UI.jpg"},"summary":"近未来的纽约，在荒凉的曼哈顿岛上出现了一个男人。他的名字叫科林麦克劳德。身为不死者的他，只要不被斩首就不会死。他在两千多年间经历无数次的生死轮回，一直追赶着杀害他爱妻的宿敌马库斯。另一方面，在纽约地下抵抗组织工作的女子达丽雅，为拯救被流行病毒所威胁的同胞，决定前往军阀居住的巨塔夺取疫苗。在偶然的情况下，科林与达丽雅相遇了。在得知城市的统治者是马库斯之后，他和达丽雅怀着共同的目标一起闯进了城市的巨塔，开始了生死难料的行动。","name":"Highlander: The Search for Vengeance","name_cn":"高地人：复仇之旅","tags":[{"name":"剧场版","count":67,"total_cont":0},{"name":"川尻善昭","count":57,"total_cont":0},{"name":"MADHouse","count":37,"total_cont":0},{"name":"2007","count":30,"total_cont":0},{"name":"原创","count":21,"total_cont":0},{"name":"奇幻","count":13,"total_cont":0},{"name":"滨崎博嗣","count":11,"total_cont":0},{"name":"战斗","count":9,"total_cont":0},{"name":"补番","count":7,"total_cont":0},{"name":"电影","count":6,"total_cont":0},{"name":"执念","count":5,"total_cont":0},{"name":"中庸","count":3,"total_cont":0},{"name":"日本","count":3,"total_cont":0},{"name":"2007年","count":2,"total_cont":0},{"name":"科幻","count":2,"total_cont":0},{"name":"乳首","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"美国","count":2,"total_cont":0},{"name":"阿部恒","count":2,"total_cont":0},{"name":"独立剧场版","count":2,"total_cont":0},{"name":"废土","count":1,"total_cont":0},{"name":"DaveB.Mitchell","count":1,"total_cont":0},{"name":"HankBanks","count":1,"total_cont":0},{"name":"剧场","count":1,"total_cont":0},{"name":"2007年6月","count":1,"total_cont":0},{"name":"2021","count":1,"total_cont":0},{"name":"18禁","count":1,"total_cont":0},{"name":"剧场版2","count":1,"total_cont":0},{"name":"剧场动画","count":1,"total_cont":0},{"name":"AlistairAbell","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"高地人：复仇之旅"},{"key":"别名","value":[{"v":"ハイランダー"},{"v":"HIGHLANDER ハイランダー 〜ディレクターズカット版〜"}]},{"key":"上映年度","value":"2008年7月5日（日本）"},{"key":"片长","value":"86分钟、96分钟（导演剪辑版）"},{"key":"原作","value":"ハイランダー 悪魔の戦士"},{"key":"导演","value":"川尻善昭"},{"key":"脚本","value":"David Abramowitz"},{"key":"演出","value":"浜崎博嗣"},{"key":"作画监督助理","value":"箕輪豊、藤田しげる、桜井邦彦、奥田佳子、佐々木昌彦"},{"key":"动画制作","value":"MADHOUSE"},{"ke