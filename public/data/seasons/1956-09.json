[{"date":"1956-09-07","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/21/0c/634791_v5T35.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/21/0c/634791_v5T35.jpg","large":"https://lain.bgm.tv/pic/cover/l/21/0c/634791_v5T35.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/21/0c/634791_v5T35.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/21/0c/634791_v5T35.jpg"},"summary":"　　阳光明媚、和风煦煦的海滩上，几只怪模怪样的猫正在用杠铃、哑铃锻炼身体。与此同时，身着夸张红色泳衣的汤姆抱着一大堆行李和食物陪着妖艳矜持的女友来到海滩，他完全没有注意到正躺在沙滩上晒太阳的杰瑞，一下子将遮阳伞插到杰瑞身上，将其压进沙滩里。杰瑞虽然气愤，不过全然不像跟这个见到女人就智商下降的傻瓜计较。他从沙子里爬出来，另找一个地方晒太阳，可是汤姆总将吃剩下的垃圾扔到杰瑞身上，令小老鼠忍无可忍。刚刚赶跑捣乱的杰瑞，汤姆意外发现女友竟然被体魄强健、正在健身的黑猫吸引走了。\r\n　　他按捺不住心底的嫉妒，开始朝着黑猫反攻，各种笑话也频频发生……","name":"Muscle Beach Tom","name_cn":"海滩上练肌肉","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"海滩上练肌肉"},{"key":"上映年度","value":"1956年9月7日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0049526"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":0,"7":1,"8":0,"9":0,"10":0},"score":5.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":1,"collect":6,"doing":0},"id":634791,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]