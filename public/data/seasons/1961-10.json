[{"date":"1961-10-26","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0f/64/634851_8ZnUi.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0f/64/634851_8ZnUi.jpg","large":"https://lain.bgm.tv/pic/cover/l/0f/64/634851_8ZnUi.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0f/64/634851_8ZnUi.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0f/64/634851_8ZnUi.jpg"},"summary":"　　多么安闲自在的一天，汤姆趴在房子的正中央酣然入睡。这时，他看见主人拿着鱼竿器材走出门外。原来主人要去郊外游玩，汤姆连忙打起精神，带着自己的装备登上汽车。虽然他不希望小老鼠杰瑞也一同前往，可是那个聪明的小家伙还是上了车，甚至一度把汤姆扔了下去。汤姆好不容易追上主人，他与杰瑞斗智斗勇，结果误砸了主人的脑袋。主人恼羞成怒，回过头痛揍这只坏猫，全然不顾危险的交通情况。遗憾的是汤姆并未得到教训，他继续和杰瑞争吵，期间不免惹出更多危险的情况。\r\n　　粒径一波三折，惊现恐怖的旅途终于结束。他们抵达目的地，可是汤姆还在想方设法抓住讨厌的杰瑞…… ","name":"Down and Outing","name_cn":"落魄出游","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"落魄出游"},{"key":"上映年度","value":"1961年10月26日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0054822"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":0,"7":1,"8":0,"9":0,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":5,"doing":0},"id":634851,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1961-10-05","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/51/16/132393_TKZ14.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/51/16/132393_TKZ14.jpg","large":"https://lain.bgm.tv/pic/cover/l/51/16/132393_TKZ14.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/51/16/132393_TKZ14.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/51/16/132393_TKZ14.jpg"},"summary":"　　年仅四岁的小宝宝马罗，和很多生长快乐家庭的孩子一样，从小娇生惯养，养尊处优，父母的指示他从来不听，从早到晚“NO，NO”个不停，仿佛没有一件令他满意的事。然而他的命运却意外发生转变，这一天小马罗竟然收到一封征兵通知书。奇怪的是，周围的人似乎根本没对他的年龄提出质疑。还不到一米的小马罗就这样和一大群高大的成年人接受军方审查、体检，最终作为一名新兵被送入军营训练。无休无止的艰苦训练，教官咆哮般的训斥和命令，永远也做不完的苦工，令柔弱的小马罗不堪重负。他同过各种渠道声明自己只有四岁，可是根本没人理会，大家都把他看成了一名应该为国家捐躯奉献的勇猛战士…… \r\n　　本片荣获第33届奥斯卡金像奖最佳动画短片奖。","name":"Munro","name_cn":"马罗","tags":[{"name":"短片","count":13,"total_cont":0},{"name":"奥斯卡","count":8,"total_cont":0},{"name":"欧美","count":6,"total_cont":0},{"name":"讽刺","count":4,"total_cont":0},{"name":"1961","count":3,"total_cont":0},{"name":"美军","count":2,"total_cont":0},{"name":"4岁boy军训","count":1,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"中庸","count":1,"total_cont":0},{"name":"Oscars","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"短片&OVA","count":1,"total_cont":0},{"name":"子供向","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"马罗"},{"key":"别名","value":[{"v":"Munro: I'm only four!"}]},{"key":"上映年度","value":"1961-10-05"},{"key":"片长","value":"9 分钟"},{"key":"IMDb链接","value":"tt0054100"},{"key":"语言","value":"英语"},{"key":"制片国家/地区","value":"美国 / Czechoslovakia"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 家庭"},{"key":"编剧","value":"Jules Feiffer"},{"key":"主演","value":"Howard Morris / Seth Deitch"},{"key":"导演","value":"吉恩·戴奇"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":18,"count":{"1":1,"2":0,"3":2,"4":0,"5":6,"6":5,"7":4,"8":0,"9":0,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":3,"collect":42,"doing":1},"id":132393,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]