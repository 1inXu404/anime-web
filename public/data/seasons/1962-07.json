[{"id":615799,"type":2,"name":"もぐらのモトロ","name_cn":"鼹鼠莫多罗","summary":"","date":"1962-07-19","images":null,"rating":{"rank":0,"total":1,"score":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0}},"tags":[{"name":"短片","count":1},{"name":"剧场版","count":1},{"name":"日本","count":1},{"name":"子供向","count":1}],"eps":1,"collection":{"wish":1,"collect":1,"doing":0,"on_hold":0,"dropped":1}},{"id":634863,"type":2,"name":"Dicky Moe","name_cn":"大白鲸","summary":"　　在一个古朴宁静的海边小镇，不远处的海中心停靠着一艘老式的帆船。船上面色苍白的船长正大发雷霆，他踱来踱去，骂声不止，发誓要抓到那条凶猛非常的大白鲸（Dicky Moe）。水手们战战兢兢，生怕成为大白鲸或者船长的另一个牺牲品，于是纷纷弃船而去。与此同时，饥饿的汤姆正在码头上寻找食物，结果被船长抓住充当临时船员。没有任何办法，汤姆只得按照船长的命令清洗甲板，偏偏遇上了捣乱的杰瑞，不由得令他的工作多了许多的障碍和麻烦。\r\n　　在接下来的一段时间，汤姆既要躲开愤怒的船长，同时设法抓住悠闲自在的杰瑞。意外不断的海员生活，汤姆和杰瑞最为难忘的一段经历……","date":"1962-07-20","images":null,"rating":{"rank":0,"total":3,"score":5.3,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":0,"7":1,"8":0,"9":0,"10":0}},"tags":[{"name":"短片","count":2},{"name":"猫和老鼠","count":1},{"name":"剧场版","count":1},{"name":"1960s","count":1}],"eps":0,"collection":{"wish":0,"collect":4,"doing":0,"on_hold":0,"dropped":0}}]