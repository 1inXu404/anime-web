[{"date":"1967-05-05","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e1/5c/634491_59KBr.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e1/5c/634491_59KBr.jpg","large":"https://lain.bgm.tv/pic/cover/l/e1/5c/634491_59KBr.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e1/5c/634491_59KBr.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e1/5c/634491_59KBr.jpg"},"summary":"　　蔚蓝的大海，迷人的小岛，加勒比迷人的风光吸引着来自世界各地的游客，连汤姆这只懒惰的老猫和顽皮机灵的小老鼠杰瑞也随着游轮来到这里度假。汤姆从舷窗望见大海的美景，更有身形矫健的男人站在冲浪板上与海浪嬉戏。他再也按捺不住激动的心，夹着冲浪板便冲了出去，也许他太过心急，先是撞到门框，然后又接二连三跌倒甲板、舢板和沙滩上，引得杰瑞一阵阵咋舌。\r\n　　好不容易来到海上，汤姆乘着巨大的浪头划了起来。突然，一只巨大的鲨鱼狞笑着等在他的前方，汤姆奋力滑动冲浪板躲避鲨鱼的攻击，速度快得竟然飞了起来，却也撞倒了石头上。看来这又是一个注定不平静的假期……","name":"Surf-Bored Cat","name_cn":"冲浪猫","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1960s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"冲浪猫"},{"key":"上映年度","value":"1967年5月5日"},{"key":"片长","value":"7分钟"},{"key":"导演","value":"Abe Levitow,Chuck Jones"},{"key":"IMDb","value":"tt0062321"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":1,"7":2,"8":0,"9":0,"10":0},"score":6},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":5,"doing":0},"id":634491,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]