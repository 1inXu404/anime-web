400/pic/cover/l/6a/54/60429_W9XIN.jpg"},"rating":{"rank":4554,"total":108,"score":6.4,"count":{"1":0,"2":0,"3":0,"4":7,"5":16,"6":30,"7":37,"8":16,"9":1,"10":1}},"tags":[{"name":"迪士尼","count":34},{"name":"欧美","count":30},{"name":"2009","count":29},{"name":"剧场版","count":23},{"name":"Disney","count":20},{"name":"动画电影","count":11},{"name":"电影","count":7},{"name":"美国","count":6},{"name":"公主系列","count":4},{"name":"童话改","count":3}],"eps":1,"collection":{"wish":19,"collect":214,"doing":4,"on_hold":2,"dropped":9}},{"id":2462,"type":2,"name":"ONE PIECE FILM STRONG WORLD","name_cn":"航海王：强者天下","summary":"时间是“大海贼时代”，某天得知故乡“东海”发生危机的草帽海贼团，打算暂时中断冒险返回东海，此时他们看到空中出现一艘莫名的海贼船，由于奈美预测到眼前即将出现暴风雨，并利用从那艘船上丢下来的“音贝”作通知，暴风雨过后海贼船的主人“金狮子”狮鬼来到千里阳光号上，表示要运用他的“飘浮果实”能力载路飞等人回到东海当作谢礼，令路飞等人相当兴奋，谁知途中狮鬼却突然解除了千里阳光号的浮力，并趁机掳走奈美，原来狮鬼看上了奈美能用身体感知气候的能力，想让她成为自己海贼团的航海士，路飞等人则跟着千里阳光号一起从上空坠落到浮游岛“STRONG WORLD”，四处分散的伙伴们被迫与岛上各种进化的凶暴珍兽战斗。\r\n\r\n传说中的海贼“金狮子”狮鬼，其实力跟“海贼王”高路·D·罗杰与“白胡子”爱德华·纽哥特不相上下，并且从罗杰的时代就掀起大暴乱的传说海贼。20年前成为“深海大监狱”因佩尔中首位逃狱成功的囚犯，逃狱后的20年誓言要向全世界复仇的狮鬼，踏出复仇计划的第一步就是摧毁整个东海，为了保护故乡和伙伴，立志成为“海贼王”的路飞与狮鬼展开顶尖对决，到底谁能战胜并称霸这片海洋…？\r\n\r\n\r\n\r\n[简介原文]\r\n東の海、壊滅!? 生ける伝説・シキの恐るべき野望とはー!?\r\n\r\n旅を続ける麦わらの一味に、突然のニュースが飛び込んできた！　東の海、壊滅…？　故郷の危機に、引き返そうとするルフィたちの前に、上空から謎の海賊船が現れた。空飛ぶその船に乗っていたのは、悪魔の実の能力者〝金獅子のシキ〟！　かつて海賊王ゴールド・ロジャーと対決し、大監獄インペルダウンから脱獄した伝説の海賊だった。そしてシキは航海士・ナミを強奪して飛び去っていく――。ルフィたちの運命を賭けた冒険が、今始まる―!!!","date":"2009-12-12","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/10/c6/2462_F24sN.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/10/c6/2462_F24sN.jpg","large":"https://lain.bgm.tv/pic/cover/l/10/c6/2462_F24sN.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/10/c6/2462_F24sN.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/10/c6/2462_F24sN.jpg"},"rating":{"rank":1511,"total":1659,"score":7.3,"count":{"1":2,"2":2,"3":4,"4":12,"5":56,"6":252,"7":676,"8":462,"9":131,"10":62}},"tags":[{"name":"剧场版","count":530},{"name":"海贼王","count":371},{"name":"热血","count":211},{"name":"2009","count":183},{"name":"ONEPIECE","count":136},{"name":"东映","count":125},{"name":"JUMP","count":93},{"name":"十周年","count":92},{"name":"原创","count":83},{"name":"尾田栄一郎","count":67},{"name":"战斗","count":66}],"eps":1,"collection":{"wish":115,"collect":2845,"doing":18,"on_hold":22,"dropped":35}},{"id":3483,"type":2,"name":"宇宙戦艦ヤマト 復活篇","name_cn":"宇宙战舰大和号 复活编","summary":"时代设定在距离前作约20年后的西历2220年，大和号已经沉入了深海17年。但此时对人类来说最宝贵的地球却受到了前所未有的大危机，它将在半年后被不断向地球移动的黑洞卷入。这个黑洞有着300倍于太阳的质量，它巨大的重力影响下，连光线都能完全吸入，并迅速地向地球逼近。受此威胁，3亿地球人决定移民到距地球二万七千光年的星球。由地球联邦组织移民船队，准备搬到跑地球2万7千光年的恒星系阿玛尔居住。但却受到神秘的大舰队的攻击。导致第一次和第二次的船队都遭到毁灭。于是，古代进作为第三次移民团的护卫舰司令，乘坐着从冰冷的海水中浮出的大和号再度起航。\r\n但是在遥远宇宙的彼方，为了阻止地球人的移民计划，星际国家联合的SUS舰队正伏击在前方……","date":"2009-12-12","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/cb/95/3483_uOq44.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/cb/95/3483_uOq44.jpg","large":"https://lain.bgm.tv/pic/cover/l/cb/95/3483_uOq44.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/cb/95/3483_uOq44.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/cb/95/3483_uOq44.jpg"},"rating":{"rank":6498,"total":71,"score":5.8,"count":{"1":1,"2":1,"3":5,"4":8,"5":13,"6":19,"7":16,"8":6,"9":0,"10":2}},"tags":[{"name":"剧场版","count":33},{"name":"2009","count":13},{"name":"科幻","count":11},{"name":"宇宙战舰大和号","count":10},{"name":"XEBEC","count":7},{"name":"石原慎太郎","count":5},{"name":"西崎义展","count":3},{"name":"2009年12月","count":3},{"name":"日本动画","count":3},{"name":"西崎義展","count":2},{"name":"原创","count":2}],"eps":1,"collection":{"wish":71,"collect":130,"doing":7,"on_hold":5,"dropped":12}},{"id":58054,"type":2,"name":"人間失格 ディレクターズカット版","name_cn":"人间失格 剧场版","summary":"叶藏生于二战时日本不愁吃穿的政治富家，是个体弱多病的家族末子，又从小看遍人情冷暖、正面背面的一套，所以感觉自己人生没有意义，从小学会看别人脸色、讨别人笑容。他想当一个出色的画家却被政治家老爸全盘否定。长大后更觉得人生没有意义，交了一个恶友整天两人参加革命团体、或者纵情生色，后来跟一个酒吧女人寻死却只有自己活下来还差点被起诉，结果连父母兄弟也觉得他的人生没有意义，家里人都跟他断绝了关系。于是他醒悟想要活得有个人样，去找以前的旧友求救，却被报社当时接触过他与酒家女殉情的女记者带回家。他本想在这家人家做一个能保护女记者和她女儿的好男人，却被女儿茂子的一句“杀人犯”给赶了回来。后来他遇到一个很纯洁很相信别人的女孩结婚，妻子又因为为了让叶藏的漫画畅销而与编辑通奸，于是他对人间彻底失望，在妻子企图自杀时却抢过安眠药自己服下，虽被洗胃救活，但逃出医院后仍苟延残喘着走向死亡。","date":"2009-