[{"date":"1956-01-27","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/4c/a4/634787_kmkSq.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/4c/a4/634787_kmkSq.jpg","large":"https://lain.bgm.tv/pic/cover/l/4c/a4/634787_kmkSq.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/4c/a4/634787_kmkSq.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/4c/a4/634787_kmkSq.jpg"},"summary":"　　夜幕降临，寂静的社区内，一所大房子里传来了吵闹声。原来汤姆正在追赶小老鼠杰瑞，结果打破了许多器皿，令女主人非常生气。主人责令他打扫碎片，汤姆虽然心又不满，可还是气鼓鼓地打扫起来。这时，桌子上一份报纸的招募启事引起了他的兴趣。启事写道寻找一个志愿者和老妇人环游世界。对汤姆来说，这可真是一个摆脱现有枯燥生活的好机会。他扔掉手中的扫帚和簸箕，夹着报纸前去应聘。\r\n　　谁知，应聘的地点竟然是一桩破烂阴森的古堡，而所谓的老妇人竟然是一名长相丑陋的巫婆。虽然想转身逃跑，可是老巫婆根本不容他拒绝，便带着汤姆飞上了天空……","name":"The Flying Sorceress","name_cn":"会飞的巫婆","tags":[{"name":"剧场版","count":2,"total_cont":0},{"name":"短片","count":2,"total_cont":0},{"name":"1950-1959","count":1,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"会飞的巫婆"},{"key":"上映年度","value":"1956年1月27日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0049221"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":1,"7":1,"8":0,"9":0,"10":0},"score":5.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634787,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]