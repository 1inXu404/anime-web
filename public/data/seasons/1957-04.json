[{"date":"1957-04-19","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/74/2e/634800_76199.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/74/2e/634800_76199.jpg","large":"https://lain.bgm.tv/pic/cover/l/74/2e/634800_76199.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/74/2e/634800_76199.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/74/2e/634800_76199.jpg"},"summary":"　　一如既往，汤姆和杰瑞又在大房子内展开追逐战。就在此时，外面传来了敲门声，随后一封信从门缝处塞了进来。汤姆打开查看，信件来自他的表弟乔治。乔治是一只胆小焦虑的猫，他尤其害怕老鼠。此次他即将前来造访表哥，唯一希望的是表哥能提前做好准备，确保不会有老鼠在房间内。汤姆看完信后，迅速将杰瑞堵在老鼠洞内，并用木板钉了起来。过了一会儿，乔治如约而至，他和汤姆长得一模一样，唯一不同的是永远战战兢兢，充满焦虑。没过多久，全然不知情的杰瑞逃了出来，他看中桌子上的美食，谁知却吓坏了乔治。杰瑞以为汤姆出了什么问题，于是用各种办法吓唬这只可怜的猫，当然没有料到将凶恶的汤姆和胆小的乔治搞混了……","name":"Timid Tabby","name_cn":"胆小的猫咪","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"胆小的猫咪"},{"key":"上映年度","value":"1957年4月19日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0051086"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":0,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634800,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]