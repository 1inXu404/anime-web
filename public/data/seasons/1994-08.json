[{"date":"1994-08-26","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/7a/c6/78050_J7TL1.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/7a/c6/78050_J7TL1.jpg","large":"https://lain.bgm.tv/pic/cover/l/7a/c6/78050_J7TL1.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/7a/c6/78050_J7TL1.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/7a/c6/78050_J7TL1.jpg"},"summary":"漫画家・有馬一郎の同題青年コミックを各巻およそ50分の全2巻によるOVA化。監督はサンライズ作品の演出などを多数こなしてきた関田修によるもの。名門女子高校への赴任が決まった新人教師の時郎。だがその始業式の朝、時郎は電車の中でひとりの女子がコンドーム入りのカバンを落とす現場を目撃してしまう。やがて時郎はその女子が自分の受け持つクラスの生徒＝みやこであることを知った。教師として彼女をなんとかせねばと決意した時郎はみやこの家庭訪問を敢行。普段は一人暮らしのみやこだが、運良く彼女の父親と対面できた時郎はお酒の勢いでみやこの世話をすると約束してしまう。これを機に時郎とみやこは教師と生徒という間柄でありながら、同棲生活を始めてしまうのだった……。本作の実制作はJ.C.STAFFが担当。脚本は数多くのアニメや特撮番組を手がけている川崎ヒロユキが執筆した。","name":"他人の関係","name_cn":"他人的关系","tags":[{"name":"OVA","count":20,"total_cont":0},{"name":"1994","count":8,"total_cont":0},{"name":"师生","count":6,"total_cont":0},{"name":"漫改","count":6,"total_cont":0},{"name":"天野由梨","count":5,"total_cont":0},{"name":"森川智之","count":4,"total_cont":0},{"name":"独立ova","count":4,"total_cont":0},{"name":"漫画改","count":3,"total_cont":0},{"name":"里番","count":3,"total_cont":0},{"name":"肉","count":3,"total_cont":0},{"name":"関田修","count":2,"total_cont":0},{"name":"J.C.STAFF","count":2,"total_cont":0},{"name":"福利","count":2,"total_cont":0},{"name":"富山敬","count":2,"total_cont":0},{"name":"关田修","count":2,"total_cont":0},{"name":"川崎ヒロユキ","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"山泽实","count":1,"total_cont":0},{"name":"1994年","count":1,"total_cont":0},{"name":"杀必死","count":1,"total_cont":0},{"name":"NTR","count":1,"total_cont":0},{"name":"节操社","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"TV","count":1,"total_cont":0},{"name":"恋爱","count":1,"total_cont":0},{"name":"堀川りょう","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"他人的关系"},{"key":"别名","value":[{"v":"Homeroom Affairs"