[{"date":"1945-08-25","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/09/75/225870_B90hi.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/09/75/225870_B90hi.jpg","large":"https://lain.bgm.tv/pic/cover/l/09/75/225870_B90hi.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/09/75/225870_B90hi.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/09/75/225870_B90hi.jpg"},"summary":"故事的开头，大坏狼正在追逐小红帽。小红帽夺路狂逃，她突然转过身叫停了大坏狼，并带他来到动画标题板前，告诉他题目是“大坏狼追灰姑娘”，所以你不能再追我。大坏狼一听言之有理，于是放走了小红帽，随即换上西装革履，并叫来了一辆出租车飞速驶向灰姑娘的家。身材曼妙的灰姑娘打开门，令大坏狼狂躁不已。他想方设法要冲进房里，不过最终都被灰姑娘挫败。之后灰姑娘给仙女打电话，请对方帮她变出舞会的服装。灰姑娘如愿以偿穿上考究的服装驾驶豪车去参加舞会，仙女则打扮入时要和大坏狼约会。 \r\n　　好好的童话故事被改的乱七八糟，大坏狼、灰姑娘、仙女这三角关系该如何收场……","name":"Swing Shift Cinderella","name_cn":"夜班灰姑娘","tags":[{"name":"短片","count":14,"total_cont":0},{"name":"1945","count":8,"total_cont":0},{"name":"欧美","count":7,"total_cont":0},{"name":"美国","count":4,"total_cont":0},{"name":"米高梅","count":2,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"Tex_Avery","count":1,"total_cont":0},{"name":"WarnerBros.Animation","count":1,"total_cont":0},{"name":"动画百佳","count":1,"total_cont":0},{"name":"1940s","count":1,"total_cont":0},{"name":"TexAvery","count":1,"total_cont":0},{"name":"HeckAllen","count":1,"total_cont":0},{"name":"Metro-Goldwyn-Mayer","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"夜班灰姑娘"},{"key":"上映年度","value":"1945年8月25日"},{"key":"片长","value":"7分43秒"},{"key":"导演","value":"Tex Avery"},{"key":"脚本","value":"Heck Allen"},{"key":"类型","value":"喜剧 / 动画 / 短片"},{"key":"制片国家/地区","value":"美国"},{"key":"语言","value":"英语"},{"key":"话数","value":"1"},{"key":"动画制作","value":"Metro-Goldwyn-Mayer (MGM)"},{"key":"IMDb","value":"tt0038143"}],"rating":{"rank":0,"total":19,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":5,"7":10,"8":1,"9":0,"10":1},"score":6.7},"total_episodes":0,"collection":{"on_hold":2,"dropped":3,"wish"