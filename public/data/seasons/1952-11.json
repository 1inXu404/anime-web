[{"date":"1952-11-29","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/be/86/634627_7FmYd.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/be/86/634627_7FmYd.jpg","large":"https://lain.bgm.tv/pic/cover/l/be/86/634627_7FmYd.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/be/86/634627_7FmYd.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/be/86/634627_7FmYd.jpg"},"summary":"　　阳光明媚的一天，大狗史派克正兴致勃勃地建造属于自己的狗窝，他手执图纸，满心欢喜地畅想狗窝建造好的样子，当然还要在门口挂上“甜蜜小家（Home, Sweet Home）”的牌子。不过，两个不速之客扰乱了他的计划。一阵锅碗瓢盆交响曲过后，小老鼠杰瑞和老猫汤姆先后跑出房子。汤姆追得兴起，抄起狗窝上的一块木板追赶，这可惹恼了史派克。史派克抓住汤姆，警告他们不许破坏自己的盖屋计划。\r\n　　强敌在前，汤姆当然满口答应。可是刚刚摆脱了史派克的狗掌，他又跟杰瑞展开了不顾一切的追逐。只可怜史派克，辛辛苦苦搭建狗窝，却总是遭到无情的破坏……","name":"The Dog House","name_cn":"狗屋","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"狗屋"},{"key":"上映年度","value":"1952年11月29日"},{"key":"片长","value":"6分钟"},{"key":"IMDb","value":"tt0044554"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":0,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":7,"doing":0},"id":634627,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1952-11-27","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f3/4d/243278_ZLL84.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f3/4d/243278_ZLL84.jpg","large":"https://lain.bgm.tv/pic/cover/l/f3/4d/243278_ZLL84.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f3/4d/243278_ZLL84.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f3/4d/243278_ZLL84.jpg"},"summary":"","name":"Madeline","name_cn":"玛德琳","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"upa","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"Robert.Cannon","count":1,"total_cont":0},{"name