[{"date":"1998-07-26","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a1/9a/1867_jn0NB.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a1/9a/1867_jn0NB.jpg","large":"https://lain.bgm.tv/pic/cover/l/a1/9a/1867_jn0NB.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a1/9a/1867_jn0NB.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a1/9a/1867_jn0NB.jpg"},"summary":"《ONE PIECE 打倒！海贼强萨克！》（日语：ONE PIECE 倒せ!海賊ギャンザック）是于1998年在Jump Festa上映的《ONE PIECE》第一部OVA版动画，本作制作公司为Production I.G，导演为谷口悟朗，角色原案为尾田荣一郎。\r\n\r\n本片和后来的电视版动画不同，是赛璐珞动画。配音员也有所不同（路飞声优为高乃丽，佐罗声优为高木涉，奈美声优为丰口惠）。另外，此片还被滨崎达弥改编成小说热卖。 \r\n\r\n路飞他们三人在海上漂流的时候，小船被突然出现的巨大长颈龙和炮弹击沉而漂到某座岛，再那里他们遇到了穿着盔甲，手持长斧的少女梅达卡，路飞从她口中得知统治著这座岛屿的，是自称海贼贵族的恶棍强萨克，不但岛上的食物都被抢走，连居民都被抓去当建造“恶魔塔”的劳工…… ","name":"ONE PIECE 倒せ!海賊ギャンザック","name_cn":"航海王：打倒！海贼强萨克！","tags":[{"name":"海贼王","count":97,"total_cont":0},{"name":"OVA","count":89,"total_cont":0},{"name":"1998","count":57,"total_cont":0},{"name":"剧场版","count":48,"total_cont":0},{"name":"ProductionI.G","count":29,"total_cont":0},{"name":"ONEPIECE","count":26,"total_cont":0},{"name":"Production.I.G","count":26,"total_cont":0},{"name":"热血","count":25,"total_cont":0},{"name":"谷口悟朗","count":22,"total_cont":0},{"name":"原创","count":20,"total_cont":0},{"name":"战斗","count":15,"total_cont":0},{"name":"冒险","count":14,"total_cont":0},{"name":"尾田荣一郎","count":13,"total_cont":0},{"name":"漫画改","count":6,"total_cont":0},{"name":"热血类","count":6,"total_cont":0},{"name":"JUMP","count":5,"total_cont":0},{"name":"日本","count":5,"total_cont":0},{"name":"漫改","count":5,"total_cont":0},{"name":"奇幻","count":4,"total_cont":0},{"name":"童年","count":3,"total_cont":0},{"name":"马越嘉彦","count":3,"total_cont":0},{"name":"90年代","count":2,"total_cont":0},{"name":"海贼","count":2,"total_cont":0},{"name":"动作","count":2,"total_cont":0},{"name":"北嶋博明","count":2,"total_cont":0},{"name":"特别篇","count":1,"total_cont":0},{"name":"集英社","count":1,"total_cont":0},{"name":"1998年","count":1,"total_cont":0},{"name":"日本动画","count