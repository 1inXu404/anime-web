:"1998年7月3日"},{"key":"播放结束","value":"1999年1月29日"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":1,"8":0,"9":0,"10":1},"score":7},"total_episodes":0,"collection":{"on_hold":1,"dropped":3,"wish":3,"collect":3,"doing":0},"id":421004,"eps":31,"meta_tags":["TV","日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1998-07-03","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/05/4f/532366_9ykG0.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/05/4f/532366_9ykG0.jpg","large":"https://lain.bgm.tv/pic/cover/l/05/4f/532366_9ykG0.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/05/4f/532366_9ykG0.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/05/4f/532366_9ykG0.jpg"},"summary":"最新デジタル技術を駆使した、日本初の劇場用3Dアニメーション映画。前作同様、男子入場客の獲得を狙って企画製作された。映像プログラムの制作費は3億円強が投じられた。レポーター役として奥菜恵が登場する他、キティやばつ丸などのサンリオキャラクターも登場する。この奥菜恵はエンディングテーマの歌唱も担当している。過去に手を加えて歴史を書き換えるという時空犯罪を繰り返すTPレディによって原始時代のゲンシクンは化石にされてしまい、25世紀のタマシティから発掘されて大和博士によって甦った。超人的な身体能力を買われたゲンシクンは時空探偵に任命され、TPレディの追跡の任務が下される。10月1日のテレビアニメ放送に先行して上映された。所要時間20分。提供は安田火災海上保険。","name":"時空探偵ゲンシクン","name_cn":"时空侦探","tags":[],"infobox":[{"key":"中文名","value":"时空侦探"},{"key":"上映年度","value":"1998年7月3日"},{"key":"片长","value":"20分"},{"key":"其他","value":"游乐设施电影"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":0,"7":0,"8":0,"9":0,"10":0},"score":4},"total_episodes":0,"collection":{"on_hold":0,"dropped":2,"wish":2,"collect":1,"doing":0},"id":532366,"eps":0,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1998-07-02","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/3d/8a/37905_B5zW5.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/3d/8a/37905_B5zW5.jpg","large":"https://lain.bgm.tv/pic/cover/l/3d/8a/37905_B5zW5.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/3d/8a/37905_B5zW5.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/3d/8a/37905_B5zW5.jpg"},"summary":"影技这部作品，是根据冈田芽武老师同名漫画改变的架空幻想体裁的动画。就TV版来说，出现时间说早不早说晚不晚，不过其确实有称为名作的条件。以其热血的剧情和庞大的背景构架吸引了大批支持者。内容也很上进，讲述背负不幸过去的少年奋发上进追逐梦想。在保卫祖国的同时对抗恶势力且中间充斥着友情亲情与爱情……同时也揭露了战争的残酷性。作为亮点，我认为是剧中众多充满个性的角色以及耀眼炫目的战斗场面。制作组在两部OVA之后吸取了经验完成了TV版的制作，而TV版的也就成为了系列的巅峰之作。之后的新作 クルダ流交杀法の秘密 除了画面质量在各方面都远不及前作…… 　　故事的主要场景クルダ作为佣兵王国拥有两千年历史。而代表这个国家的最强佣兵是拥有セヴァール称号的修练斗士们，他们以其强大不可思议的战斗能力成为守护国家的支柱及敌人惧怕的对象。而我们的主角第59代修练斗士shadow skill[影技] 的エレ・ラグ更是以14岁的史上超低年龄得到这称号的一人，同时需要注意的是她还是位少女。而故事就是从她和义弟ガウ・バン的旅行中开始的。 　　作为修练斗士担负了国家荣誉的重任，但是エレ并没有其应有的威严，随人拥有强大的力量，但为人总是大大咧咧，做事欠缺思考，且爱赊账酗酒导致生活中充斥着还账的声音。但她极为关心周围的人且有很强的正义感和责任感，就因为她是这样的人，才更加让人觉得亲近，也因此ガウ成了他的弟弟，咒符师フォウリー成为了她的挚友，接受了キュオ成为伙伴……一行变得更加热闹了…… 　　然而即使平时再怎么自由，一到战时身为セヴァール责任还是使她必须投身战火之中。作为守护圣王国アシュリアーナ东方的壁垒，クルダ在面对ソーウルファン王国的侵略之时，エレ遵从国王命令，去保护隐居在两国边境的著名的武器打造专家，同时也是她哥哥的ディアス・ラグ。故事也因此进入高潮，带出了エレ的过去，带出了历史上的强者，带出了蛰伏已久的阴谋势力…… 　　与OVA不同的是TV版的登场人物凑然增多，几乎涵盖了漫画版的所有人物，并且起用了大批人气声优使得充满个性的人物所构成错综复杂的人际关系得到了充分体现，唯一的缺点大概就是配角们由于过于出彩使得第一男主角的ガウ・バン尽管贯穿全剧但存在感仍然异常薄弱……","name":"影技 SHADOW SKILL","name_cn":"影技","tags":[{"name":"TV","count":27,"total_cont":0},{"name":"1998","count":21,"total_cont":0},{"name":"林原めぐみ","count":18,"total_cont":0},{"name":"漫画改","count":17,"total_cont":0},{"name":"studiodeen","count":11,"total_cont":0},{"name":"战斗","count":9,"total_cont":0},{"name":"1998年7月","count":8,"total_cont":0},{"name":"姐弟","count":8,"total_cont":0},{"name":"补旧番","count":4,"total_cont":0},{"name":"忘记剧情","count":4,"total_cont":0},{"name":"漫改","count":3,"total_cont":0},{"name":"补番","count":3,"total_cont":0},{"name":"日漫","count":2,"total_cont":0},{"name":"须永司","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"TVA","count":2,"total_cont":0},{"name":"須永司","count":2,"total_cont":0},{"name":"松岡章夫","count":1,"total_cont":0},{"name":"スタジオディーン","count":1,"total_cont":0},{"name":"林原惠","count":1,"total_cont":0},{"name":"兄妹","count":1,"total_cont":0},{"name":"嫁衣社","count":1,"total_cont":0},{"name":"1998夏","count":1,"total_cont":0},{"name":"神op","