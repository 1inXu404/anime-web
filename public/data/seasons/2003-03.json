ropped":26}},{"id":38217,"type":2,"name":"MUNTO","name_cn":"蒙特","summary":"　　《MUNTO》是京都动画于2003年推出的一部奇幻风格的OVA。作为京都动画的首部原创作品，《MUNTO》第一部就因宏大的世界观和细腻的镜头表现赢得了赞誉，尽管在商业上并不是特别成功，但其制作水准足以令同时期多数OVA相形见绌。2005年，京都动画带来了《MUNTO》的第二部《MUNTO～穿越时空之壁》。《穿越时空之壁》延续前作的剧情，更加入了天上界的势力斗争，气势宏大的魔神大战也是不容错过的卖点。制作班底依然是前作的原班人马。","date":"2003-03-18","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a4/5d/38217_W0Ib3.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a4/5d/38217_W0Ib3.jpg","large":"https://lain.bgm.tv/pic/cover/l/a4/5d/38217_W0Ib3.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a4/5d/38217_W0Ib3.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a4/5d/38217_W0Ib3.jpg"},"rating":{"rank":6946,"total":258,"score":6,"count":{"1":3,"2":3,"3":8,"4":19,"5":51,"6":73,"7":64,"8":26,"9":9,"10":2}},"tags":[{"name":"OVA","count":150},{"name":"京阿尼","count":118},{"name":"2003","count":73},{"name":"原创","count":68},{"name":"木上益治","count":45},{"name":"MUNTO","count":38},{"name":"奇幻","count":29},{"name":"京都动画","count":25},{"name":"京都","count":15},{"name":"京都アニメーション","count":12},{"name":"魔幻","count":12}],"eps":2,"collection":{"wish":276,"collect":379,"doing":8,"on_hold":33,"dropped":27}},{"id":9996,"type":2,"name":"或る旅人の日記","name_cn":"某个旅人的日记","summary":"在卓塔利亚旅行的多朵夫.罗多尔的不可思议之旅。为大人写的，温暖著心头的故事。","date":"2003-03-19","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/81/26/9996_CaB3B.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/81/26/9996_CaB3B.jpg","large":"https://lain.bgm.tv/pic/cover/l/81/26/9996_CaB3B.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/81/26/9996_CaB3B.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/81/26/9996_CaB3B.jpg"},"rating":{"rank":2110,"total":311,"score":7.1,"count":{"1":0,"2":0,"3":1,"4":4,"5":13,"6":65,"7":120,"8":83,"9":14,"10":11}},"tags":[{"name":"短片","count":185},{"name":"2003","count":106},{"name":"加藤久仁生","count":82},{"name":"治愈","count":66},{"name":"原创","count":54},{"name":"WEB","count":43},{"name":"旅行系","count":35},{"name":"文艺","count":27