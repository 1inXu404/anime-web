9/74/93885_9GRge.jpg","large":"https://lain.bgm.tv/pic/cover/l/b9/74/93885_9GRge.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b9/74/93885_9GRge.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b9/74/93885_9GRge.jpg"},"summary":"『伝説巨神イデオン』などへの制作協力で、80年代のファンに馴染み深いアニメ制作会社スタジオビーボォーが手がけたファンタジーOVA。\r\n　ハン族の戦士レックとフレネーはその実力を見込まれ、ムロロン族の村の警護を任される。村を襲って女性をさらう巨大変形メカのペンギーンに対し、ムロロン族はレックとフレネーが活躍してくれるものと期待していたが、その結果は必ずしも芳しくない。やがて敵の本拠地ダンギーン山へ向けて攻撃が行われることとなり、レックとフレネーのほかに村の若者のシリルとコロラ、そして謎の少女クーリィが攻撃隊として出発。切り立った山の内部へ何とか潜入をはたす一同だったが。\r\n　本作はビーボォーの代表格でもあるアニメーター湖川友謙が監督を務めたファンタジーOVA『グリード』と同様の趣向の作品で、同氏の代表作となるべく作られた意欲作である。","name":"COOL COOL BYE","name_cn":"","tags":[{"name":"OVA","count":6,"total_cont":0},{"name":"独立ova","count":2,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"SF","count":1,"total_cont":0},{"name":"田中真弓","count":1,"total_cont":0},{"name":"Bebow","count":1,"total_cont":0},{"name":"科幻","count":1,"total_cont":0},{"name":"湖川友謙","count":1,"total_cont":0},{"name":"1986","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"80年代","count":1,"total_cont":0},{"name":"野沢雅子","count":1,"total_cont":0},{"name":"80s","count":1,"total_cont":0},{"name":"山田栄子","count":1,"total_cont":0}],"infobox":[{"key":"别名","value":[{"v":"クール・クール・バイ"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1986-01-21"},{"key":"原作","value":"湖川友謙"},{"key":"导演","value":"湖川友謙"},{"key":"分镜","value":"ビーボオー"},{"key":"企画","value":"山川紀生"},{"key":"制片人","value":"林大三郎"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":1,"3":0,"4":1,"5":0,"6":3,"7":0,"8":0,"9":0,"10":0},"score":4.8},"total_episodes":0,"collection":{"on_hold":2,"dropped":6,"wish":12,"collect":6,"doing":1},"id":93885,"eps":1,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1986-01-19","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/57/71/134960_YQ9yS.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/57/71/134960_YQ9yS.jpg","large":"https://lain.bgm.tv/pic/cover/l/57/71/134960_YQ9yS.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/57/71/134960_YQ9yS.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/57/71/134960_YQ9yS.jpg"},"summary":"帕蒂·霍普巴比特和她的家人来到了枫叶镇，与一群友善的动物作伴。在一次火车劫案中，一个狡猾的小偷偷走了她父亲的邮袋，逃进了森林。于是帕蒂就紧跟在小偷后面去追回邮袋。在从小偷手里拿回包的过程中，她结识了一个和她同龄的名叫鲍比·库曼诺夫的男孩，并合计一同摧毁王尔德狼的阴谋。在他们与王尔德狼斗智斗勇并最终逃脱后，他们成功地把邮袋安全送回了她父亲的手里。不久，兔子一家在枫树镇安顿下来，成为邮递员，帕蒂和博比之间苦涩而甜蜜的友谊开始开花结果。\r\n故事背景设定在20世纪20年代的加拿大，而棕榈城的故事背景设定在20世纪80年代的美国西海岸。","name":"メイプルタウン物語","name_cn":"枫城物语","tags":[{"name":"TV","count":4,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"佐藤顺一","count":3,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"东映动画","count":2,"total_cont":0},{"name":"1986","count":2,"total_cont":0},{"name":"年番&大长篇","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"东映","count":1,"total_cont":0},{"name":"柳川茂","count":1,"total_cont":0},{"name":"一","count":1,"total_cont":0},{"name":"几原邦彦","count":1,"total_cont":0},{"name":"80年代","count":1,"total_cont":0},{"name":"子供","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"枫城物语"},{"key":"别名","value":[{"v":"动物城"},{"v":"动物村"},{"v":"枫叶镇物语"},{"v":"动物小英雄"},{"v":"Maple Town Stories"}]},{"key":"话数","value":"52"},{"key":"放送开始","value":"1986年1月19日"},{"key":"放送星期","value":"星期日"},{"key":"播放结束","value":"1987年1月11日"},{"key":"音乐","value":"小坂明子"},{"key":"系列监督","value":"佐藤順一"},{"key":"人物设定","value":"二宮常雄"},{"key":"脚本","value":"朝倉千筆、柳川茂、金春智子、久保田圭司、まるおけいこ、益子幸代"},{"key":"分镜","value":"佐藤順一、久岡敬史、設楽博、貝沢幸男 [ 貝澤幸男 ] 、岡佳広、山口頼房、角銅博之"},{"key":"演出","value":"佐藤順一、久岡敬史、設楽博、貝沢幸男 [ 貝澤幸男 ] 、岡佳広、山口頼房、角銅博之"},{"key":"作画监督","value":"小松原一男、昆進之介、星川信芳、古沢日出夫、青山充、荒木伸吾、二宮常雄、西城隆詞、安藤正浩、及川博史、姫野美智、伊藤奈緒美、松山まや、尾鷲英俊"},{"key":"美术监督","value":"小林祐子、河野尋美、有川知子、須藤栄子、吉田智子、田原優子、和田いづみ"},{"key":"制片人","value":"鍋島進二（朝日放送）、春日東（旭通信社）、山口康男"},{"key":"助理制片人","value":"佐川祐子（旭通信社）、高橋尚子"},{"key":"美术设计","value":"小林祐子、有川知子"},{"key":"制作管理","value":"製作担当：横井三郎"},{"key":"协力","value"