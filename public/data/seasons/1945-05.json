[{"id":275358,"type":2,"name":"The Mouse Comes to Dinner","name_cn":"鼠来晚餐","summary":"　　猫和老鼠剧场短片系列第18集。\r\n　　女佣“两只鞋”准备好了一桌丰盛的晚餐，杰瑞暗中伺机而动，汤姆也借机邀请小母猫图茨前来赴宴。汤姆让杰瑞在一旁做服务员，杰瑞则利用餐桌上的各种食物和器具给汤姆捣乱，甚至还出现了模仿“掷瓶礼”的场面……","date":"1945-05-05","images":null,"rating":{"rank":0,"total":34,"score":7.4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":5,"7":14,"8":10,"9":3,"10":1}},"tags":[{"name":"短片","count":18},{"name":"猫和老鼠","count":9},{"name":"欧美","count":8},{"name":"1945","count":5},{"name":"美国","count":4},{"name":"米高梅","count":3},{"name":"剧场版","count":3},{"name":"原创","count":3},{"name":"1940s","count":2},{"name":"童年","count":2}],"eps":1,"collection":{"wish":3,"collect":80,"doing":2,"on_hold":0,"dropped":6}}]