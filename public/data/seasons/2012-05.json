a3/f1/67818_rB9Pr.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a3/f1/67818_rB9Pr.jpg","large":"https://lain.bgm.tv/pic/cover/l/a3/f1/67818_rB9Pr.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a3/f1/67818_rB9Pr.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a3/f1/67818_rB9Pr.jpg"},"rating":{"rank":3445,"total":55,"score":6.6,"count":{"1":0,"2":0,"3":0,"4":2,"5":5,"6":20,"7":16,"8":11,"9":1,"10":0}},"tags":[{"name":"短片","count":28},{"name":"欧美","count":15},{"name":"2012","count":13},{"name":"奥斯卡提名","count":8},{"name":"粘土","count":5},{"name":"乡村音乐","count":3},{"name":"爱的妥协","count":3},{"name":"中庸","count":2},{"name":"剧场版","count":2},{"name":"双重视角","count":2},{"name":"头向下","count":2}],"eps":1,"collection":{"wish":23,"collect":74,"doing":1,"on_hold":2,"dropped":5}},{"id":106923,"type":2,"name":"Le magasin des suicides","name_cn":"自杀专卖店","summary":"死气沉沉的法国小城，一家有口皆碑的老店却格外生意兴隆。原来这家祖传老店代代皆以贩卖自杀产品著称。在如此灰暗恐怖的小镇上，自杀成了当地居民稀松平常之事，这也是小店异常火爆的原因。经营此店的老板三岛了无生气，老板娘更是日日愁眉苦脸。他们早就丧失了对生活的热情，终日郁郁不安。长期贩卖自杀用品，让他们濒临崩溃的边缘。幸好他们的一双儿女还热爱着生活，尤其是他们的小儿子阿伦，笑容总是挂在他的脸上。然而，阿伦热爱生活的态度却威胁着老店的经营，父亲想尽办法让阿伦变得消沉，甚至把阿伦逼上了绝路…… \r\n\r\n本部极富想象力的法国动画电影，改编自法国漫画家让·特磊的畅销小说。曾执导《理发师的情人》等影片的法国导演帕特利斯·勒孔特，此次首度尝试制作动画影片。影片不仅处处体现着法式特有的黑色幽默，还加入了大量歌舞元素，借这些载歌载舞的动画人物之口，道出生与死间的深刻哲理。","date":"2012-05-24","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/7f/d3/106923_d78TO.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/7f/d3/106923_d78TO.jpg","large":"https://lain.bgm.tv/pic/cover/l/7f/d3/106923_d78TO.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/7f/d3/106923_d78TO.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/7f/d3/106923_d78TO.jpg"},"rating":{"rank":3408,"total":255,"score":6.8,"count":{"1":1,"2":2,"3":1,"4":5,"5":17,"6":60,"7":117,"8":39,"9":7,"10":6}},"tags":[{"name":"法国","count":65},{"name":"欧美","count":57},{"name":"动画电影","count":38},{"name":"2012","count":34},{"name":"剧场版","count":33},{"name":"讽刺","count":31},{"name":"自杀专卖店","count":23},{"name":"电影","count":16},{"name":"音乐","count":14