当时的自己…　　 ","name":"超時空世紀オーガス","name_cn":"超时空世纪","tags":[{"name":"TV","count":38,"total_cont":0},{"name":"萝卜","count":31,"total_cont":0},{"name":"1983","count":24,"total_cont":0},{"name":"科幻","count":19,"total_cont":0},{"name":"原创","count":17,"total_cont":0},{"name":"石黑升","count":14,"total_cont":0},{"name":"人渣桂","count":12,"total_cont":0},{"name":"TMS","count":10,"total_cont":0},{"name":"速水奖","count":7,"total_cont":0},{"name":"机战","count":7,"total_cont":0},{"name":"石黒昇","count":6,"total_cont":0},{"name":"日本","count":6,"total_cont":0},{"name":"羽田健太郎","count":5,"total_cont":0},{"name":"超时空系列","count":4,"total_cont":0},{"name":"松崎健一","count":3,"total_cont":0},{"name":"80","count":2,"total_cont":0},{"name":"トムス・エンタテインメント","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"1980s","count":2,"total_cont":0},{"name":"补","count":2,"total_cont":0},{"name":"robo","count":2,"total_cont":0},{"name":"1983年7月","count":2,"total_cont":0},{"name":"80年代","count":2,"total_cont":0},{"name":"80s","count":1,"total_cont":0},{"name":"音乐×","count":1,"total_cont":0},{"name":"美树本晴彦","count":1,"total_cont":0},{"name":"待補1","count":1,"total_cont":0},{"name":"大野木宽","count":1,"total_cont":0},{"name":"1993","count":1,"total_cont":0},{"name":"阅","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"超时空世纪"},{"key":"别名","value":[{"v":"Choujikuu Seiki Orguss"},{"v":"超时空世纪ORGUSS"},{"v":"时空争霸战"},{"v":"时空战警"}]},{"key":"话数","value":"35"},{"key":"放送开始","value":"1983年7月3日"},{"key":"放送星期","value":"星期日"},{"key":"官方网站","value":"https://www.tms-e.co.jp/alltitles/1980s/048101.html"},{"key":"播放电视台","value":"毎日放送"},{"key":"其他电视台","value":"TBS"},{"key":"播放结束","value":"1984年4月8日"},{"key":"音乐","value":"羽田健太郎"},{"key":"Copyright","value":"©ビックウェスト・TMS"},{"key":"製作","value":"毎日放送、東京ムービー新社"},{"key":"演出","value":"西森明良（西森章）、三家本泰美、福島和美、井内秀治、秋山勝仁、鍋島修、吉田浩、所一生、高橋ナオヒト、石黒昇、いいじままさかつ（飯島正勝）"},{"key":"脚本","value":"松崎健一、富田祐弘、大野木寛、西村宏"},{"key":"作画监督","value":"美樹本晴彦、西森明良（西森章）、上野ケン、角谷哲生、泉口薫、しまだひであき、本橋秀之、菊地城二、