部分もあった。\r\n\r\n  また、ラストはエルチとジロンを中心に皆が走るところまでは一緒だが、死亡したと思われたアーサー・ランクが登場し、失明したエルチに対して治療を申し出るというものになっている。この改変について富野は「誰も死なない作品」とするとの決定の元に制作されたこともあり、「TV版でのアーサーの死とエルチの失明が、作品全体のムードに対して後味の悪い物として心に引っかかっていたため」とコメントしている。","name":"ザブングル グラフィティ","name_cn":"萨芬格尔·涂鸦","tags":[{"name":"剧场版","count":12,"total_cont":0},{"name":"富野由悠季","count":11,"total_cont":0},{"name":"1983","count":10,"total_cont":0},{"name":"SUNRISE","count":7,"total_cont":0},{"name":"大瀧進矢","count":3,"total_cont":0},{"name":"サンライズ","count":3,"total_cont":0},{"name":"总集篇","count":3,"total_cont":0},{"name":"横尾まり","count":3,"total_cont":0},{"name":"萝卜","count":2,"total_cont":0},{"name":"原创","count":2,"total_cont":0},{"name":"robo","count":2,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0},{"name":"机战","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"五武冬史","count":1,"total_cont":0},{"name":"1983年7月","count":1,"total_cont":0},{"name":"冒险","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"1983年","count":1,"total_cont":0},{"name":"鈴木良武","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"萨芬格尔·涂鸦"},{"key":"上映年度","value":"1983年7月9日"},{"key":"片长","value":"84分钟"},{"key":"导演","value":"富野由悠季"},{"key":"动画制作","value":"サンライズ"},{"key":"话数","value":"1"},{"key":"原作","value":"富野由悠季、鈴木良武"},{"key":"录音","value":"藤野貞義、東京テレビセンター"},{"key":"演出","value":"菊池一仁(構成演出)"},{"key":"摄影","value":"旭プロダクション"},{"key":"音乐制作","value":"名古屋テレビ音楽出版、サンライズ音楽出版/サンライズミュージック(指田英司)"},{"key":"演出助理","value":"鈴木行、関田修、滝沢敏文、加瀬充子、今川泰宏"},{"key":"制作协力","value":"内田健二、中川一敏、目崎一彦、渡辺努、杉島邦久、福田倫子"},{"key":"製作","value":"日本サンライズ(伊藤昌典)  协力：名古屋テレビ、創通エージェンシー"},{"key":"发行","value":"松竹、スタンダードサイズ"}],"rating":{"rank":0,"total":19,"count":{"1":0,"2":0,"3":1,"4":0,"5":5,"6":5,"7":5,"8":3,"9":0,"10":0},"score":6.2},"total_episodes":0,"collection":{"on_hold":1,"dropped":8,"wish":18,"collect":31,"doing":3},"id":192783,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"