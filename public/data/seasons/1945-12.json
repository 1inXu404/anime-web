[{"id":132372,"type":2,"name":"Quiet Please!","name_cn":"请安静！","summary":"　　一如既往，家庭大战再次爆发，老猫汤姆和老鼠杰瑞的追逐战将家里闹得天翻地覆。唯一不同的是，今天老狗在家睡觉，猫鼠大战搅扰了它的美梦。不堪其扰的老狗警告汤姆不准制造噪音，否则要它好看。胆小的汤姆点头应允，随后继续追逐。而此时战争发生了变化，汤姆追逐杰瑞的同时想尽办法不弄出声响，而杰瑞则故意制造噪音，打算吵醒老狗，让汤姆好看。老狗的介入让它们的追逐战变得紧张刺激而又妙趣横生…… \r\n　　本片荣获1946年奥斯卡最佳动画短片奖。","date":"1945-12-22","images":null,"rating":{"rank":1292,"total":87,"score":7.5,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":10,"7":30,"8":34,"9":5,"10":5}},"tags":[{"name":"短片","count":44},{"name":"欧美","count":22},{"name":"猫和老鼠","count":21},{"name":"米高梅","count":14},{"name":"奥斯卡","count":13},{"name":"1945","count":12},{"name":"美国","count":9},{"name":"1940s","count":9},{"name":"搞笑","count":6},{"name":"MGM","count":4},{"name":"欢乐","count":4}],"eps":1,"collection":{"wish":9,"collect":184,"doing":1,"on_hold":1,"dropped":9}}]