"images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d1/94/107454_b4PYb.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d1/94/107454_b4PYb.jpg","large":"https://lain.bgm.tv/pic/cover/l/d1/94/107454_b4PYb.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d1/94/107454_b4PYb.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d1/94/107454_b4PYb.jpg"},"summary":"故事述说一位名叫百鬼丸的男孩，因为父亲梦想称霸乱世，于是与四十八只魔神做出约定，将百鬼丸的身体分为48个部份，让魔神拿走。所以百鬼丸为了拿回自己的身体器官便出发讨伐魔神，途中遇上小偷多罗罗，展开与妖怪战斗的冒险。\r\n\r\n故事中带有强烈的讽刺意味，例如战争不断，但只有平民百姓受苦；当百鬼丸替村民杀死妖怪后，反而被赶出村，表现出人情冷漠；而其中板门之卷带有讽刺柏林墙及板门店。","name":"どろろ","name_cn":"多罗罗","tags":[{"name":"手塚治虫","count":86,"total_cont":0},{"name":"多罗罗","count":66,"total_cont":0},{"name":"1969","count":45,"total_cont":0},{"name":"TV","count":44,"total_cont":0},{"name":"漫画改","count":40,"total_cont":0},{"name":"战国时期","count":26,"total_cont":0},{"name":"战斗","count":22,"total_cont":0},{"name":"虫Production","count":22,"total_cont":0},{"name":"百鬼丸","count":20,"total_cont":0},{"name":"致郁","count":17,"total_cont":0},{"name":"日本","count":12,"total_cont":0},{"name":"虫制作","count":10,"total_cont":0},{"name":"2019.1","count":7,"total_cont":0},{"name":"残缺的身体","count":7,"total_cont":0},{"name":"漫改","count":6,"total_cont":0},{"name":"热血","count":3,"total_cont":0},{"name":"经典","count":3,"total_cont":0},{"name":"日漫","count":2,"total_cont":0},{"name":"治愈","count":2,"total_cont":0},{"name":"虫プロダクション","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"名作","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"怀旧","count":1,"total_cont":0},{"name":"60年代","count":1,"total_cont":0},{"name":"泪目","count":1,"total_cont":0},{"name":"妖怪","count":1,"total_cont":0},{"name":"上下","count":1,"total_cont":0},{"name":"魔幻","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"多罗罗"},{"key":"别名","value":[{"v":"どろろと百鬼丸"},{"v":"Dororo"}]},{"key":"话数","value":"26"},{"key":"放送开始","value":"1969年4月6日"},{"key":"放送星期","value":"星