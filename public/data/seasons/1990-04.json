[{"date":"1990-04-28","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/05/18/100492_mJY4M.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/05/18/100492_mJY4M.jpg","large":"https://lain.bgm.tv/pic/cover/l/05/18/100492_mJY4M.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/05/18/100492_mJY4M.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/05/18/100492_mJY4M.jpg"},"summary":"　20世紀のアメリカ文学界で、シートンを継ぐ動物文学作家ともいわれた小説家メル・エリス。彼が著した同題の長編小説を原作にした、劇場用アニメ作品。\r\n　少年ラセットは、野生の白い狼グレイと、兄弟のような絆の中で成長した。だが町の有力者ショットの飼犬ボクサー犬が、鎖に繋がれて自由の利かないグレイを愚弄。怒ったグレイはボクサー犬をかみ殺した。恨みに思ったショットはグレイに「人食い狼」の悪名を付して抹殺を図り、一方ラセットはグレイの安全のため、遠方の国立森林公園内の狼の保護地区に連れていこうと考えた。苦難の旅路を行くラセットとグレイ。彼らを待つ運命は？\r\n　少年と狼の心の交流を描く長編アニメ。脚本は『転校生』『さびしんぼう』など大林宣彦監督の秀作群で有名な剣持亘が執筆。アニメ製作はグループ・タックが担当し、監督は同社のアニメ映画『タッチ3　君が通り過ぎたあとに』の前田庸生が務めた。","name":"走れ!白いオオカミ","name_cn":"奔跑吧！白狼","tags":[{"name":"独立剧场版","count":4,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"1990","count":2,"total_cont":0},{"name":"前田康夫","count":2,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0},{"name":"日本动画电影考察","count":1,"total_cont":0},{"name":"グループ・タック","count":1,"total_cont":0},{"name":"剣持亘","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"奔跑吧！白狼"},{"key":"别名","value":[{"v":"Hashire! Shiroi Ookami"}]},{"key":"上映年度","value":"1990年4月28日"},{"key":"片长","value":"84分"},{"key":"导演","value":"前田康夫"},{"key":"製作","value":"藤田健"},{"key":"人物设定","value":"対木重次"},{"key":"原作","value":"メル・エリス"},{"key":"脚本","value":"剣持亘"},{"key":"作画監督","value":"江口摩吏介"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":6,"count":{"1":0,"2":1,"3":0,"4":0,"5":2,"6":2,"7":0,"8":1,"9":0,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":3,"dropped":5,"wish":12,"collect":7,"doing":2},"id":100492,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1990-04-28","platform":"剧场版","images":{"small":"https