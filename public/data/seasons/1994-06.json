赶尽杀绝。\r\n\r\n辛巴逃亡中遇到了机智的丁满和善良的彭彭，他们抚养辛巴长成雄壮的大狮子，鼓励他回去森林复国。在接下来一场复国救民的斗争中，辛巴真正长成一个坚强的男子汉，领会了责任的真谛。\r\n\r\n简介来自豆瓣（https://movie.douban.com/subject/1301753/）。","name":"The Lion King","name_cn":"狮子王","tags":[{"name":"迪士尼","count":894,"total_cont":0},{"name":"童年","count":785,"total_cont":0},{"name":"欧美","count":560,"total_cont":0},{"name":"剧场版","count":514,"total_cont":0},{"name":"狮子王","count":473,"total_cont":0},{"name":"1994","count":356,"total_cont":0},{"name":"Disney","count":232,"total_cont":0},{"name":"动画电影","count":211,"total_cont":0},{"name":"经典","count":199,"total_cont":0},{"name":"童年的经典","count":124,"total_cont":0},{"name":"原创","count":96,"total_cont":0},{"name":"美国","count":95,"total_cont":0},{"name":"励志","count":91,"total_cont":0},{"name":"电影","count":68,"total_cont":0},{"name":"家里买的第一套VCD","count":33,"total_cont":0},{"name":"迪斯尼","count":19,"total_cont":0},{"name":"剧情系","count":18,"total_cont":0},{"name":"1990s","count":9,"total_cont":0},{"name":"90年代","count":9,"total_cont":0},{"name":"1994年","count":9,"total_cont":0},{"name":"奇幻","count":9,"total_cont":0},{"name":"成长","count":8,"total_cont":0},{"name":"冒险","count":7,"total_cont":0},{"name":"战斗","count":6,"total_cont":0},{"name":"动物","count":6,"total_cont":0},{"name":"欧美动画","count":6,"total_cont":0},{"name":"RogerAllers","count":5,"total_cont":0},{"name":"RobMinkoff","count":4,"total_cont":0},{"name":"动画","count":4,"total_cont":0},{"name":"美漫","count":4,"total_cont":0}],"infobox":[{"key":"中文名","value":"狮子王"},{"key":"别名","value":[{"v":"獅子王"},{"v":"The Lion King 3D"},{"v":"狮子王3D"}]},{"key":"上映年度","value":"1994年6月15日"},{"key":"片长","value":"89分钟"},{"key":"官方网站","value":"http://movies.disney.com/the-lion-king"},{"key":"其他上映时间","value":"1995年7月15日(中国大陆) / 2011年9月16日(美国-3D)"},{"key":"IMDb_id","value":"tt0110357"},{"key":"导演","value":"Roger Allers、Rob Minkoff"},{"key":"原案","value":"Burny Mattinson、Barry Johnson、Lorna Cook、Thom Enriquez、Andy Gaskill、Gary Trousdale、Jim Capobianco、Kevin Harkey、Jorgen Klubien、Chris San