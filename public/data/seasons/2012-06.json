.6,"count":{"1":0,"2":0,"3":1,"4":0,"5":0,"6":2,"7":0,"8":1,"9":0,"10":1}},"tags":[{"name":"短片","count":5},{"name":"2012","count":4},{"name":"欧美","count":2},{"name":"西班牙","count":2},{"name":"无","count":1}],"eps":0,"collection":{"wish":4,"collect":12,"doing":1,"on_hold":1,"dropped":5}},{"id":197889,"type":2,"name":"再见雨天","name_cn":"","summary":"灰暗的雨季，男孩与狐狸相遇，两个“孩子”两个世界，一个潮湿而压抑的城市，一个明亮而需水的自然，在这个忧愁而留有希望的童话里，在想象打通时空的故事里，一把雨伞一朵花恰好在一起，让人微笑、略觉触动，忆起雨季中的温暖情绪。 \r\n　　本片由作者北极的夏天mium（本名郑雅文）独自制作完成，中国传媒大学动画2012届毕业作品。","date":"2012-06-18","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/b4/f5/197889_it8Ow.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/b4/f5/197889_it8Ow.jpg","large":"https://lain.bgm.tv/pic/cover/l/b4/f5/197889_it8Ow.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b4/f5/197889_it8Ow.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b4/f5/197889_it8Ow.jpg"},"rating":{"rank":0,"total":8,"score":5.9,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":4,"7":2,"8":0,"9":0,"10":0}},"tags":[{"name":"短片","count":6},{"name":"国产","count":3},{"name":"2012","count":3},{"name":"郑雅文","count":3},{"name":"毕设","count":1}],"eps":1,"collection":{"wish":2,"collect":15,"doing":0,"on_hold":1,"dropped":4}},{"id":42850,"type":2,"name":"Brave","name_cn":"勇敢传说","summary":"从远古时候起，有关宏大战争及奇幻史诗的故事就在神秘的苏格兰高地流传；如今一段全新的传奇徐徐展开：一位勇气过人，不愿受约束的公主，却因为叛逆无意中犯下大错，让家庭及王国陷入重重危机。她不得不直面传统、命运，以及高地上最可怕的野兽，才有可能扭转乾坤，化险为夷。改变命运如箭在弦！这，就是《勇敢传说》(BRAVE)。\r\n\r\n梅莉达是一名经验丰富，手艺高超的弓箭手，也是佛格国王与艾莉诺皇后的女儿，苏格兰高地的公主。她生性活泼，长着一头蓬乱的红发，不愿与传统为伍。爱武装不爱红妆的梅莉达一心向往自由，不愿受到宫廷生活的束缚，因此与母亲产生矛盾。在一次比武招亲的大会上，她与母亲的矛盾达到顶点，导致她鲁莽地向密林巫婆许下“改变命运”的愿望，然而这个愿望的魔力却远超梅莉达的想象与控制，带来不可预知的可怕后果……！梅莉达不得不直面命运，诚心感悟勇气真谛，才有可能打破凶险的魔咒，拯救自己的王国与家庭！","date":"2012-06-19","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/52/16/42850_97Yzn.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/52/16/42850_97Yzn.jpg","large":"https://lain.bgm.tv/pic/cover/l/52/16/42850_97Yzn.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/52/16/42850_97Yzn.jpg","common":"https:/