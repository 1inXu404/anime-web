鱼的肉是众人趋之若鹜的珍贵药材，凡是食用它的人，即可获得永生不死的荣耀。在一次偶然中，渔夫涌太和伙伴们捕获了一奇怪的肉块，鬼使神差中，三人分食了此物，不久之后，其中的两人暴毙，而不知是幸运还是不幸，从这天起，幸存下来的涌太成为了不死之人。经过了几百年是世事变迁，涌太终于无法忍受独活的孤独和寂寞，他决定走遍世界各地，发誓要找到解除永生诅咒的方法。\r\n　　在世界的某处，被村人监禁的名叫真鱼的女子在姥姥的哄骗下吃下了人鱼的肉。涌太和真鱼，当两人相遇时，命运之轮开始转动，两个背负着永生罪孽的人，踏上了充满危险和死亡的逃亡道路。 ","name":"人魚の森","name_cn":"人鱼之森","tags":[{"name":"OVA","count":113,"total_cont":0},{"name":"高桥留美子","count":66,"total_cont":0},{"name":"1991","count":56,"total_cont":0},{"name":"漫画改","count":40,"total_cont":0},{"name":"悬疑","count":34,"total_cont":0},{"name":"人鱼之森","count":24,"total_cont":0},{"name":"川井宪次","count":24,"total_cont":0},{"name":"MADHouse","count":21,"total_cont":0},{"name":"山寺宏一","count":15,"total_cont":0},{"name":"奇幻","count":15,"total_cont":0},{"name":"不死","count":13,"total_cont":0},{"name":"漫改","count":11,"total_cont":0},{"name":"90年代","count":8,"total_cont":0},{"name":"一石小百合","count":7,"total_cont":0},{"name":"日本","count":5,"total_cont":0},{"name":"日本动画","count":5,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"PASTEL","count":3,"total_cont":0},{"name":"动画","count":3,"total_cont":0},{"name":"水谷贵哉","count":3,"total_cont":0},{"name":"高山みなみ","count":2,"total_cont":0},{"name":"恋爱","count":2,"total_cont":0},{"name":"高橋留美子","count":2,"total_cont":0},{"name":"水谷貴哉","count":2,"total_cont":0},{"name":"大久保昌一良","count":2,"total_cont":0},{"name":"补旧番","count":2,"total_cont":0},{"name":"高山南","count":2,"total_cont":0},{"name":"1990s","count":2,"total_cont":0},{"name":"1991年","count":2,"total_cont":0},{"name":"90s","count":2,"total_cont":0}],"infobox":[{"key":"中文名","value":"人鱼之森"},{"key":"别名","value":[{"v":"Mermaid Forest"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1991年8月16日"},{"key":"原作","value":"高橋留美子"},{"key":"导演","value":"水谷貴哉"},{"key":"人物设定","value":"一石小百合"},{"key":"脚本","value":"大久保昌一良"},{"key":"音乐","value":"川井憲次"},{"key":"音响监督","value":"本田保則"},{"key":"动画制作","value":"オービー企画"},{"key":"片长","value":"55分钟"}],"rating":{"rank":3378,"total":214,"count":{"1":3,"2":1,"3":2,"4":3,"5":17