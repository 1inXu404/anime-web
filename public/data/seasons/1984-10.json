[{"date":"1984-10-28","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/82/1f/108939_XwE36.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/82/1f/108939_XwE36.jpg","large":"https://lain.bgm.tv/pic/cover/l/82/1f/108939_XwE36.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/82/1f/108939_XwE36.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/82/1f/108939_XwE36.jpg"},"summary":"　アニメ会社ぴえろ（当時はスタジオぴえろ）の魔法少女アニメ第1弾『魔法の天使クリィミーマミ』の後日談を描いたOVA。\r\n　人気アイドル歌手のクリィミーマミが突然の引退をしてから2ヶ月が経過。マミの正体である森沢優は普通の女の子として生活し、かつての相棒ネガとポジに似たノラネコを見つけてそれぞれノラネガとノラポジと命名する。だがその一方、マミの所属していた芸能プロ・パルテノンプロダクションではマミが復帰すると報道。もちろん優や彼女のボーイフレンドの俊夫にとっても初耳だった。この真相を追うべく調べる優たちだが、その前には謎の少女・早川愛の姿が？\r\n　本作はTVシリーズで完結した作品のその後を完全新作のOVAで描くという趣向の嚆矢的存在。作画スタッフのひとりはTVシリーズでも評判の高かったアニメーターの後藤真砂子が務めている。","name":"魔法の天使クリィミーマミ 永遠のワンスモア","name_cn":"我是小甜甜 永远的再一次","tags":[{"name":"OVA","count":16,"total_cont":0},{"name":"1984","count":9,"total_cont":0},{"name":"小林治","count":7,"total_cont":0},{"name":"原创","count":7,"total_cont":0},{"name":"伊藤和典","count":5,"total_cont":0},{"name":"IDOL","count":4,"total_cont":0},{"name":"StudioPierrot","count":3,"total_cont":0},{"name":"Studio_Pierrot","count":3,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"ぴえろ","count":3,"total_cont":0},{"name":"怀旧","count":2,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"望月智充","count":1,"total_cont":0},{"name":"太田貴子","count":1,"total_cont":0},{"name":"馬飼野康二","count":1,"total_cont":0},{"name":"小丑社","count":1,"total_cont":0},{"name":"水島裕","count":1,"total_cont":0},{"name":"1980s","count":1,"total_cont":0},{"name":"魔法少女","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"我是小甜甜 永远的再一次"},{"key":"话数","value":"1"},{"key":"发售日","value":"1984年10月28日"},{"key":"备注","value":"TVシリーズの総集編+続編"},{"key":"片长","value":"85分"}],"rating":{"rank":0,"total":23,"count":{"1":0,"2":0,"3":1,"4":2,"5":4,"6":8,"7":6,"8":2,"9":0,"10":0},"score":6},"total_episodes":0,"collection":{"on_hold":3,"dropped":9,"wish":28,"collect":