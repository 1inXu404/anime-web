た男子は少しずつ心変わりして顔八に味方するようになり、彼女もショックで不登校状態に。学園はこのまま顔八の思うがままにされるのだろうか。 \r\n　　本作の見どころのひとつは、個性派俳優として頭角を現わしはじめた竹中直人が顔八を怪演している点。監督と作画監督は『北斗の拳』などで知られる芦田豊雄が務めた。","name":"恐怖のバイオ人間 最終教師","name_cn":"恐怖人间 最终教师","tags":[{"name":"OVA","count":25,"total_cont":0},{"name":"搞笑","count":11,"total_cont":0},{"name":"独立ova","count":7,"total_cont":0},{"name":"1988","count":6,"total_cont":0},{"name":"漫改","count":6,"total_cont":0},{"name":"漫画改","count":4,"total_cont":0},{"name":"J.C.STAFF","count":4,"total_cont":0},{"name":"AnimateFilm","count":4,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"笠原弘子","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"アニメイトフィルム","count":2,"total_cont":0},{"name":"芦田豊雄","count":2,"total_cont":0},{"name":"1988年","count":1,"total_cont":0},{"name":"屋良有作","count":1,"total_cont":0},{"name":"校园","count":1,"total_cont":0},{"name":"战斗","count":1,"total_cont":0},{"name":"喜剧","count":1,"total_cont":0},{"name":"伊武紋人","count":1,"total_cont":0},{"name":"肉番","count":1,"total_cont":0},{"name":"下限","count":1,"total_cont":0},{"name":"OAD","count":1,"total_cont":0},{"name":"伊武紋太","count":1,"total_cont":0},{"name":"80年代","count":1,"total_cont":0},{"name":"科幻","count":1,"total_cont":0},{"name":"吐槽","count":1,"total_cont":0},{"name":"竹中直人","count":1,"total_cont":0},{"name":"奇葩","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"恐怖人间 最终教师"},{"key":"别名","value":[{"v":"恐怖的生化人 最终教师"},{"v":"The Ultimate Teacher"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1988-02-06"},{"key":"链接","value":[{"v":"http://www.jcstaff.co.jp/sakuhin/nenpyo/1988/02_saishukyosi/saishukyosi.htm"}]},{"key":"导演","value":"芦田豊雄"},{"key":"原作","value":"山本貴嗣"},{"key":"脚本","value":"伊武紋太"},{"key":"作画监督","value":"芦田豊雄"},{"key":"美术监督","value":"石津節子"},{"key":"摄影监督","value":"安津畑隆"},{"key":"音响监督","value":"松浦典良"},{"key":"音乐","value":"大谷幸"}],"rating":{"rank":0,"total":43,"count":{"1":0,"2":0,"3":6,"4":14,"5":12,"6":7,"7":3,"8":1,"9":0