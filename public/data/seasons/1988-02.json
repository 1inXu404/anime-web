意志を覚醒させる。\r\n　フィアナ、ロッチナと合流したものの、キリコは秘密結社の戦闘母艦に捕われてしまう。だが、それはすべて、これまで全銀河を操ってきた謎の意志・ワイズマンの定めた筋書きであった。導かれるままに人工天体へ赴いたキリコは、ワイズマンに後継者として指名される。キリコは神の子としての運命を受け入れた。\r\n　やがてクエントに戻ったキリコの前に、ギルガメスとバララントの連合軍が立ちはだかる。全銀河を敵としてただ一人、キリコはワイズマンのもとへ向かう……。","name":"装甲騎兵ボトムズ クエント","name_cn":"装甲骑兵 昆特","tags":[{"name":"OVA","count":10,"total_cont":0},{"name":"1988","count":5,"total_cont":0},{"name":"SUNRISE","count":5,"total_cont":0},{"name":"高橋良輔","count":3,"total_cont":0},{"name":"サンライズ","count":2,"total_cont":0},{"name":"总集篇","count":2,"total_cont":0},{"name":"robo","count":2,"total_cont":0},{"name":"科幻","count":2,"total_cont":0},{"name":"高桥良辅","count":1,"total_cont":0},{"name":"1980-1989","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"1988年2月","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"机甲","count":1,"total_cont":0},{"name":"萝卜","count":1,"total_cont":0},{"name":"1988年","count":1,"total_cont":0},{"name":"原創","count":1,"total_cont":0},{"name":"郷田ほづみ","count":1,"total_cont":0},{"name":"吉川惣司","count":1,"total_cont":0},{"name":"机战","count":1,"total_cont":0},{"name":"五武冬史","count":1,"total_cont":0},{"name":"装甲騎兵ボトムズ","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"装甲骑兵 昆特"},{"key":"别名","value":[{"v":"Soukou Kihei Votoms: Quaint"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1988年2月20日"},{"key":"官方网站","value":"https://www.sunrise-inc.co.jp/work/detail.php?cid=221"},{"key":"原作","value":"高橋良輔"},{"key":"人物设计","value":"塩山紀生"},{"key":"机械设计","value":"大河原邦男"},{"key":"脚本","value":"五武冬史(鈴木良武)、吉川惣司、鳥海尽三、高橋良輔"},{"key":"音乐","value":"乾裕樹"},{"key":"主题歌演出","value":"TETSU(織田哲郎)"},{"key":"动画制作","value":"サンライズ第7スタジオ"},{"key":"美术监督","value":"東條俊寿、岡田和夫、中山益男、宮前光春"},{"key":"剪辑","value":"鶴渕映画"}],"rating":{"rank":0,"total":18,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":10,"7":2,"8":1,"9":2,"10":0},"score":6.4},"total_episodes":0,"collection":{"on_hold":1,"dropped":9,"wish":13,"collect":27,"doing":1},"id"