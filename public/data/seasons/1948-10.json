[{"date":"1948-10-30","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/da/7d/275349_6XOHz.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/da/7d/275349_6XOHz.jpg","large":"https://lain.bgm.tv/pic/cover/l/da/7d/275349_6XOHz.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/da/7d/275349_6XOHz.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/da/7d/275349_6XOHz.jpg"},"summary":"　　这一天，带着博士帽的汤姆雄赳赳气昂昂地站在房子中央。他的旁边是一块黑板，上面画着示意图和说明文字，“老鼠住在洞里，猫抓老鼠”。他拿着教鞭反复陈述这些话，而教授的对象则是一只完全不在状态的灰色小猫。小猫的消极态度令汤姆颇为不满，他不断训斥，谁知杰瑞偷偷爬上黑板，修改了汤姆的教学内容。汤姆愤怒不已，于是命令小猫马上投入实践，抓拿这个闯入课堂的小捣蛋鬼。小猫惟命是从，结果空有一番蛮力，不断遭到戏耍，还阴差阳错成了杰瑞的好朋友，不断学习“猫鼠一家”的新知识。 \r\n　　眼前的一切都令汤姆大为光火，他既要培训小猫的捕鼠能力，还要时刻想办法赶走捣乱的杰瑞……","name":"Professor Tom","name_cn":"汤姆教授","tags":[{"name":"短片","count":21,"total_cont":0},{"name":"猫和老鼠","count":9,"total_cont":0},{"name":"1948","count":9,"total_cont":0},{"name":"欧美","count":8,"total_cont":0},{"name":"美国","count":8,"total_cont":0},{"name":"原创","count":4,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"MGM","count":2,"total_cont":0},{"name":"米高梅","count":2,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"剧场版-02","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"汤姆教授"},{"key":"别名","value":[{"v":"博士教学班"}]},{"key":"上映年度","value":"1948年10月30日"},{"key":"片长","value":"7分17秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":34,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":9,"7":14,"8":8,"9":1,"10":0},"score":6.9},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":2,"collect":88,"doing":2},"id":275349,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]