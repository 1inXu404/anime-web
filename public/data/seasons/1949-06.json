[{"id":359446,"type":2,"name":"Winter Storage","name_cn":"冬天的粮食储备","summary":"春去秋来，大森林中，松鼠兄弟钢牙奇奇和大鼻帝帝正在准备过冬的食物。奇奇努力工作，结果发现帝帝正躲在火柴盒里呼呼大睡。好不容易叫醒了这个懒惰的同伴，然而他们赖以过冬的食物——橡果竟然所剩无几。这时，欢快的唐老鸭来到树林里。他正准备在树林中间的空地上种橡树，他所背的那满满一袋橡果自然成了两只调皮的小松鼠的猎物。跟随唐老鸭的脚步，小松鼠重新将埋在地里的橡果挖出来，甚至干脆弄破了唐老鸭的口袋偷走全部的橡果。他们的举动惹恼了爱发脾气的唐老鸭，唐老鸭气愤地设下陷阱。一轮橡果争夺战在森林间热热闹闹地展开了……","date":"1949-06-03","images":null,"rating":{"rank":0,"total":3,"score":6,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":0,"7":2,"8":0,"9":0,"10":0}},"tags":[{"name":"短片","count":4},{"name":"1949","count":4},{"name":"迪士尼","count":3},{"name":"美国","count":2},{"name":"唐老鸭","count":2},{"name":"欧美","count":2},{"name":"奇奇与蒂蒂","count":1},{"name":"剧场版","count":1}],"eps":1,"collection":{"wish":1,"collect":10,"doing":1,"on_hold":1,"dropped":4}},{"id":280570,"type":2,"name":"House of Tomorrow","name_cn":"明日住宅","summary":"","date":"1949-06-11","images":null,"rating":{"rank":0,"total":21,"score":6.6,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":7,"7":8,"8":2,"9":0,"10":1}},"tags":[{"name":"短片","count":14},{"name":"美国","count":5},{"name":"欧美","count":4},{"name":"1949","count":4},{"name":"米高梅","count":2},{"name":"1940s","count":2},{"name":"原创","count":2},{"name":"动画","count":1},{"name":"1940-1949","count":1},{"name":"7(+2)","count":1},{"name":"上世纪","count":1}],"eps":1,"collection":{"wish":9,"collect":38,"doing":0,"on_hold":2,"dropped":2}}]