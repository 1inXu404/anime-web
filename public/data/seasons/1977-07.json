pic/cover/l/09/2c/37216_3yJ8X.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/09/2c/37216_3yJ8X.jpg","large":"https://lain.bgm.tv/pic/cover/l/09/2c/37216_3yJ8X.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/09/2c/37216_3yJ8X.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/09/2c/37216_3yJ8X.jpg"},"summary":"『鋼鉄ジーグ』『マグネロボ ガ・キーン』に続くマグネロボシリーズの第三弾。また、スポンサーのタカラの「マグネモシリーズ第4弾」と当時の広告に記載されている。なお、マグネモシリーズ第2弾は『ゴワッパー5 ゴーダム』である。\r\n\r\n地球から11光年離れたイプシロン星のシャイディーン総統は、地球の加藤博士が研究している惑星間を自由に移動できるタイムリンクル理論の存在を危惧し、地球に特使を派遣して加藤博士に共同開発を提案しようとしていた。\r\n\r\nだが、親善使節団（シャイザック）を任された爬虫類型人類である司令官ゴルテウスは、自らの欲望（我侭）を優先させて命令に背き地球侵略を開始してしまう。\r\n\r\nそしてタイムリンクル理論が完成することで、母星に越権と不祥事が発覚することを恐れたゴルテウスは、加藤博士の家族を人質に取り研究を止めさせようとする。\r\n\r\n母と兄を人質に取られた加藤博士の息子ユージは仲間達とともに、合体指令メカ・ペンタゴラスと状況に応じ変形合体が可能な巨大ロボ・バラタックでゴルテウスのムチャクチャでヘンテコな作戦を阻止していく。","name":"超人戦隊バラタック","name_cn":"超人战队Barattack","tags":[{"name":"TV","count":5,"total_cont":0},{"name":"1977","count":4,"total_cont":0},{"name":"東映アニメーション","count":3,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"robo","count":2,"total_cont":0},{"name":"ロボットアニメ","count":2,"total_cont":0},{"name":"潘恵子","count":2,"total_cont":0},{"name":"70","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"待补","count":1,"total_cont":0},{"name":"1977年7月","count":1,"total_cont":0},{"name":"空","count":1,"total_cont":0},{"name":"星山博之","count":1,"total_cont":0},{"name":"水島裕","count":1,"total_cont":0},{"name":"西沢信孝","count":1,"total_cont":0},{"name":"三ツ矢雄二","count":1,"total_cont":0},{"name":"萝卜","count":1,"total_cont":0},{"name":"机战","count":1,"total_cont":0},{"name":"1977年","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"超人战队Barattack"},{"key":"别名","value":[{"v":"无敌巴拉达"}]},{"key":"话数","value":"31"},{"key":"放送开始","value":"1977年7月3日"},{"key":"放送星期","value":"星期日"},{"key":"官方网站","value":"http://www.toei-anim.co.jp/lineup/tv/barat