[{"date":"1958-08-23","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/01/91/132390_f77VO.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/01/91/132390_f77VO.jpg","large":"https://lain.bgm.tv/pic/cover/l/01/91/132390_f77VO.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/01/91/132390_f77VO.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/01/91/132390_f77VO.jpg"},"summary":"　　中世纪亚瑟王的城堡内，国王正和圆桌骑士召开会议，商议如何夺回被黑骑士偷走的歌剑。说归容易，实行很难，黑骑士将歌剑交给喷火巨龙守护，圆桌骑士们闻风丧胆。这时亚瑟王的弄臣兔八哥却嘲笑“只有傻瓜才会想取回歌剑”，于是生气的国王派它前往。 \r\n　　兔八哥硬着头皮只身闯入黑骑士的城堡，恰逢黑骑士和火龙正在睡觉，它顺利地取回歌剑。苏醒的歌剑大声歌唱，惊醒了黑骑士和火龙。围绕这把宝剑，兔八哥和邪恶的敌人展开激烈而有趣的争夺战…… \r\n　　本片荣获1959年奥斯卡最佳动画短片奖。","name":"Knighty Knight Bugs","name_cn":"勇敢骑士兔八哥","tags":[{"name":"短片","count":22,"total_cont":0},{"name":"欧美","count":14,"total_cont":0},{"name":"奥斯卡","count":10,"total_cont":0},{"name":"1958","count":9,"total_cont":0},{"name":"兔八哥耍龙骑士","count":4,"total_cont":0},{"name":"兔八哥","count":3,"total_cont":0},{"name":"童年","count":3,"total_cont":0},{"name":"W·B","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"亚瑟王与圆桌武士","count":2,"total_cont":0},{"name":"欢乐","count":2,"total_cont":0},{"name":"华纳","count":2,"total_cont":0},{"name":"美国","count":2,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"WarnerBros.Animation","count":1,"total_cont":0},{"name":"Oscars","count":1,"total_cont":0},{"name":"FrizFreleng","count":1,"total_cont":0},{"name":"Friz.Freleng","count":1,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"1950-1959","count":1,"total_cont":0},{"name":"WarrenFoster","count":1,"total_cont":0},{"name":"子供向","count":1,"total_cont":0},{"name":"动画短片","count":1,"total_cont":0},{"name":"短片&OVA","count":1,"total_cont":0},{"name":"无排名","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"勇敢骑士兔八哥"},{"key":"上映年度","value":"1958-08-23"},{"key":"片长","value":"6 分钟"},{"key":"IMDb链接","value":"tt0051825"},{"key":"语言","value":"英语"},{"key":"制