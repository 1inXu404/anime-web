[{"date":"1941-10-31","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f9/e2/64087_j69TC.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f9/e2/64087_j69TC.jpg","large":"https://lain.bgm.tv/pic/cover/l/f9/e2/64087_j69TC.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f9/e2/64087_j69TC.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f9/e2/64087_j69TC.jpg"},"summary":"       本片是是迪斯尼的第4部经典动画，其主题曲Baby Mine获得了奥斯卡最佳音乐片配乐奖奥斯卡最佳歌曲提名。1981年有人用这一动画形象建立了同名棋牌类游戏。改编自 Helen Aberson与 Harold Pearl 的著作《Dumbo, the Flying Elephant》\r\n       丹波是马戏团的一头小象，因为长着一双蓝眼睛和一对超大号的耳朵而成为大家嘲笑的对象。要在马戏团里立住脚，必须会一手绝活才行，可是丹波什么也不会，为此它很苦恼，这时，老鼠蒂莫西给了它安慰和帮助。一次，丹波失足掉进了盛着香槟酒的水桶，灌得酩酊大醉。这次意外事故却使丹波发现它可以靠扑扇它的大耳朵飞到空中。于是，丹波一夜之间成了观众最喜爱的小飞象，从此，母亲再也不必为儿子的未来犯愁了。 而珍宝太太也终于重获自由，母子俩从此快乐的生活在一起。","name":"Dumbo","name_cn":"小飞象","tags":[{"name":"剧场版","count":55,"total_cont":0},{"name":"欧美","count":54,"total_cont":0},{"name":"1941","count":48,"total_cont":0},{"name":"迪士尼","count":39,"total_cont":0},{"name":"Disney","count":35,"total_cont":0},{"name":"童年","count":27,"total_cont":0},{"name":"动画电影","count":25,"total_cont":0},{"name":"子供向","count":11,"total_cont":0},{"name":"美国","count":10,"total_cont":0},{"name":"1940s","count":9,"total_cont":0},{"name":"迪斯尼","count":7,"total_cont":0},{"name":"电影","count":7,"total_cont":0},{"name":"原创","count":4,"total_cont":0},{"name":"美国动画","count":3,"total_cont":0},{"name":"象","count":2,"total_cont":0},{"name":"Walt_Disney_Animation_Studios","count":2,"total_cont":0},{"name":"欧美动画","count":1,"total_cont":0},{"name":"早于1980年","count":1,"total_cont":0},{"name":"1980年前","count":1,"total_cont":0},{"name":"童年回忆","count":1,"total_cont":0},{"name":"7(+2)","count":1,"total_cont":0},{"name":"童年系列","count":1,"total_cont":0},{"name":"米老鼠","count":1,"total_cont":0},{"name":"20世纪","count":1,"total_cont":0},{"name":"DickHuemer","count":1,"total_cont":0},{"name":"种族","count":1,"total_cont":0},{"name":"7","count":1,"total_cont":0},{"name":"2000前","count":1,"total_cont":0},{"