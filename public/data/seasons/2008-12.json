over/l/c8/5b/115250_SfBbS.jpg","large":"https://lain.bgm.tv/pic/cover/l/c8/5b/115250_SfBbS.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c8/5b/115250_SfBbS.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c8/5b/115250_SfBbS.jpg"},"rating":{"rank":0,"total":26,"score":6.2,"count":{"1":0,"2":0,"3":1,"4":0,"5":6,"6":7,"7":10,"8":2,"9":0,"10":0}},"tags":[{"name":"欧美","count":10},{"name":"短片","count":8},{"name":"2008","count":6},{"name":"蓝天工作室","count":3},{"name":"治愈","count":3},{"name":"搞笑","count":2},{"name":"美国","count":1},{"name":"3D","count":1},{"name":"剧场版","count":1},{"name":"其它","count":1}],"eps":1,"collection":{"wish":5,"collect":46,"doing":1,"on_hold":2,"dropped":5}},{"id":30121,"type":2,"name":"Mia et le Migou","name_cn":"米芽米咕人","summary":"在南美洲的一个村庄里，一个叫米娅的小女孩，因为每晚都梦见在远方工作的父亲，为他担忧，而独自踏上了寻找父亲的道路。而同时，她的父亲在森林深处一个开发工地中也真的遇到了危险，那里的隧道发生了奇怪的坍塌，他被困在了里面，生死不明。原来这次工程所在的大山里的那片古老森林，据说是被诅咒的森林，里面有着神秘的怪物。米娅为了去见父亲，不顾路上人们的劝告，一直朝着森林前进……\r\n\r\n\r\n法国动画电影。本片是导演雅克-雷米·吉雷尔德（Jacques-Rémy Girerd）继《青蛙的预言》（哗啦哗啦漂流记）之后的第二部动画长片。获得了2009年的欧洲电影奖的最佳动画奖（the European Film Award for Best Animated Feature）。","date":"2008-12-10","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/03/90/30121_4bp21.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/03/90/30121_4bp21.jpg","large":"https://lain.bgm.tv/pic/cover/l/03/90/30121_4bp21.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/03/90/30121_4bp21.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/03/90/30121_4bp21.jpg"},"rating":{"rank":0,"total":9,"score":7,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":0,"7":3,"8":4,"9":0,"10":0}},"tags":[{"name":"剧场版","count":5},{"name":"欧美","count":3},{"name":"法国","count":3},{"name":"动画电影","count":3},{"name":"2008","count":2},{"name":"电影","count":2},{"name":"2008年","count":1},{"name":"00","count":1},{"name":"题材风格不合","count":1},{"name":"1分钟弃","count":1},{"name":"8+","count":1}],"eps":1,"collection":{"wish":14,"collect":13,"doing":2,"on_hold":4,"dropped":4}},{"id":194165,"type":2,"name":"大成建設テレビCM"