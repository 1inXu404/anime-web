[{"date":"2006-02-27","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/1f/53/547004_91ZdI.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/1f/53/547004_91ZdI.jpg","large":"https://lain.bgm.tv/pic/cover/l/1f/53/547004_91ZdI.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/1f/53/547004_91ZdI.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/1f/53/547004_91ZdI.jpg"},"summary":"　子供たちがふとしたことから集中豪雨に遭遇し、仲良しの「はれるん」に危機一髪、救われます。 危ない目にあって、はじめて天気予報というものが大切であり、警報や注意報が人命を守るためにいかに重要であるかということに気付きます。\r\n　また、話の後半では気象観測や天気予報に関する知識を中心とした気象庁の主な業務（地震・火山・津波、地球環境等）の解説を行い、大雨や地震・津波等の自然災害から身を守るためのポイント（大雨警報・注意報が出ているときは川に近づかない。海辺で地震を感じたら津波が来るかもしれないから高台に逃げる）も盛り込まれています。","name":"教えて！はれるん ～気象庁ってどんなとこ？～","name_cn":"","tags":[{"name":"日本","count":1,"total_cont":0}],"infobox":[{"key":"话数","value":"1"},{"key":"放送开始","value":"2006年2月27日"},{"key":"官方网站","value":"https://www.jma.go.jp/jma/kishou/books/oshiete/index.html"},{"key":"片长","value":"17分"},{"key":"制作年代","value":"2006年1月"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":0,"7":0,"8":0,"9":0,"10":0},"score":4},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":1,"collect":1,"doing":0},"id":547004,"eps":1,"meta_tags":["短片","日本","子供向","WEB"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"2006-02-25","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/b0/b1/837_60KBS.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/b0/b1/837_60KBS.jpg","large":"https://lain.bgm.tv/pic/cover/l/b0/b1/837_60KBS.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b0/b1/837_60KBS.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b0/b1/837_60KBS.jpg"},"summary":"　　人类与机器共存的世界——完全被管制统治的“不需要感情的乐园”穹顶城市Romdo。在那个乐园都市里发生了谜一般的杀人事件，追踪事件的市民情报局的年轻的职业女性Lil·Meier。然后，在她的身边出现了神秘的留言「awakening」……\r\n\r\n　　注意到这个留言的Lil突然遭到了异型怪人的攻击。袭击她的怪物到底是什么人，然后，与此相关的人物又是……不久之后，缠绕着如同螺旋般织成的谜、无形的声音引诱着Lil走向未知的外世界。\r\n\r\n　　充满着暗淡的色彩与静寂，散发光芒的都市设定，叫做Autoreiv的机器人。时而哲学性的构思中所派生的人物造诣的外围中，经过反复推敲的故事就此展开了。加上连续登场的异型怪人、机械、动作等视觉的脱离常规表现，以美貌的检察官Lil为中心,被操纵的拥有人类外表的，其实是被称作Proxy展开了交织错杂的秘密与无法想象到的真实。","name":"Ergo Proxy","name_cn":"死亡代理人","tags":[{"name":"科幻","count":367,"total_cont":0},{"name":"死亡代理人","count":299,"total_cont":0},{"name":"Manglobe","count":273,"total_cont":0},{"name":"2006","count":250,"total_cont":0},{"name":"TV","count":246,"total_cont":0},{"name":"GONZO","count":212,"total_cont":0},{"name":"原创","count":193,"total_cont":0},{"name":"灰暗","count":157,"total_cont":0},{"name":"內涵系","count":108,"total_cont":0},{"name":"烟熏妆","count":84,"total_cont":0},{"name":"未来","count":73,"total_cont":0},{"name":"村瀬修功","count":56,"total_cont":0},{"name":"內涵","count":43,"total_cont":0},{"name":"补番","count":39,"total_cont":0},{"name":"千年后","count":26,"total_cont":0},{"name":"村濑修功","count":25,"total_cont":0},{"name":"意识流","count":22,"total_cont":0},{"name":"2006年1月","count":21,"total_cont":0},{"name":"日本","count":21,"total_cont":0},{"name":"佐藤大","count":19,"total_cont":0},{"name":"2006年2月","count":16,"total_cont":0},{"name":"OPED美","count":14,"total_cont":0},{"name":"恩田尚之","count":12,"total_cont":0},{"name":"悬疑","count":11,"total_cont":0},{"name":"2006年","count":11,"total_cont":0},{"name":"日本动画","count":9,"total_cont":0},{"name":"SF","count":7,"total_cont":0},{"name":"池頼広","count":6,"total_cont":0},{"name":"渡边信一郎","count":6,"total_cont":0},{"name":"哲学","count":5,"total_cont":0}],"infobox":[{"key":"中文名","value":"死亡代理人"},{"key":"别名","value":[{"v":"エルゴプラクシー"}]},{"key":"话数","value":"23"},{"key":"放送开始","value":"2006年2月25日"},{"key":"放送星期","value":"星期六"},{"key":"播放电视台","value":"WOWOW"},{"key":"播放结束","value":"2006年7月29日"},{"key":"导演","value":"村瀬修功"},{"key":"音乐","value":"池頼広"},{"key":"Copyright","value":"©manglobe/Geneon Universal Entertainment./GENEON[USA]/WOWOW"},{"key":"原作","value":"Manglobe"},{"key":"企画","value":"小林真一郎、川村明廣、後藤秀樹、北浦宏之（WOWOW)"},{"key":"人物设定","value":"恩田尚之"},{"key":"色彩设计","value":"山崎紀代美"},{"key":"摄影监督","value":"山田和弘"},{"key":"音响监督","value":"百瀬慶一"},{"key":"音乐制作","va