ic/cover/l/d8/73/379624_T96DI.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d8/73/379624_T96DI.jpg","large":"https://lain.bgm.tv/pic/cover/l/d8/73/379624_T96DI.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d8/73/379624_T96DI.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d8/73/379624_T96DI.jpg"},"summary":"国内首部以抗日为题材的大型三维动画系列片，该片共36集，每集15分钟。\r\n该片以抗日为题材，讲述了生活在东北帽儿山脚下的虎子、妞妞和铁蛋三个孩子与日军小队斗智斗勇的故事，表现了中国人民不屈不挠的民族精神。该片采用三维动画制作，人物造型夸张生动。\r\n在东北的白山黑水之间，有一座险峻的山峰，它有一个很有趣的名字，叫帽儿山，因它的主峰就像一顶尖尖的毡帽，传说是神仙的帽子掉落在此，故而得名。在帽儿山脚下，维持日本军队在东北的给养和重要战略物资运输的中东铁路从这里蜿蜒穿过。日本军队为了保证铁路线的畅通和运输安全，在帽儿山小站派驻了一个守备小分队。","name":"帽儿山的鬼子兵","name_cn":"帽儿山的鬼子兵","tags":[{"name":"国产","count":6,"total_cont":0},{"name":"中国","count":3,"total_cont":0},{"name":"TV","count":3,"total_cont":0},{"name":"搞笑","count":2,"total_cont":0},{"name":"子供向","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"喜剧","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"洗脑","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"2006","count":1,"total_cont":0},{"name":"冒险","count":1,"total_cont":0},{"name":"历史","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"帽儿山的鬼子兵"},{"key":"别名","value":[{"v":"帽儿山的游击队"}]},{"key":"话数","value":"36"},{"key":"放送开始","value":"2006年2月4日"},{"key":"在线播放平台","value":"腾讯视频、优酷"},{"key":"播放电视台","value":"中央电视台少儿频道"},{"key":"其他电视台","value":"炫动卡通卫视"},{"key":"导演","value":"殷立夫"},{"key":"链接","value":[{"k":"bilibili","v":"https://www.bilibili.com/video/BV1tE411q7Qk/"},{"k":"优酷","v":"https://v.youku.com/video?spm=a2hkt.13141534.card_7.d_1_7&s=7f5db626ab9f11e0a046&scm=20140719.rcmd.298649.show_7f5db626ab9f11e0a046&vid=XNDk3MzM5OTY0"}]},{"key":"脚本","value":"王嘉文"},{"key":"制片人","value":"王丽、吉喆"},{"key":"配音","value":"傅娜、靖丹凤、侯冰玉、王锐、尹汉异、马永周、高明、 姜萍、姚宪海"},{"key":"出品人","value":"王志强"},{"key":"监制","value":"王昭军"},{"key":"艺术顾问","value":"王伟建"}],"rating":{"rank":0,"total":9,"count":{"1":2,"2":1,"3":2,"4":0,"5":3,"6":1,"7":0,"8":0,"9":0,"10":0},"score":3.4