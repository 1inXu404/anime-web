[{"date":"1951-01-25","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/84/ec/132379_KrWOw.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/84/ec/132379_KrWOw.jpg","large":"https://lain.bgm.tv/pic/cover/l/84/ec/132379_KrWOw.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/84/ec/132379_KrWOw.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/84/ec/132379_KrWOw.jpg"},"summary":"　　可爱的小男孩杰瑞德降生在一个平凡的家庭，但不久他的父母便发现了严重的问题。小杰瑞德始终不会说话，张开嘴竟是“砰砰”的音效！杰瑞德的爸爸连忙联系医生，检查过后，医生认定这便是杰瑞德独特的说话方式，无药可医。 \r\n　　随着年龄的增长，杰瑞德嘴里的声响种类越来越多，火车声、汽车声、鸟叫甚至炸药爆炸，无所不能。她的母亲已经习惯，父亲却还无法接受这样的事实。上学的第一天，杰瑞德便被学校退回，周围的小朋友也疏远他，父亲见他更一脸不耐烦。伤心的杰瑞德决定离家出走，然而一件事改变了他的人生…… \r\n　　2006年6月在Annecy国际动画电影节上评选出的“动画的世纪·100部作品”第29名。","name":"Gerald McBoing-Boing","name_cn":"砰砰杰瑞德","tags":[{"name":"短片","count":32,"total_cont":0},{"name":"欧美","count":14,"total_cont":0},{"name":"upa","count":12,"total_cont":0},{"name":"1951","count":12,"total_cont":0},{"name":"美国","count":11,"total_cont":0},{"name":"奥斯卡","count":11,"total_cont":0},{"name":"口技","count":5,"total_cont":0},{"name":"1950s","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"1950-1959","count":2,"total_cont":0},{"name":"子供向","count":2,"total_cont":0},{"name":"动画百佳","count":2,"total_cont":0},{"name":"中庸","count":1,"total_cont":0},{"name":"1950","count":1,"total_cont":0},{"name":"福祸相依","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"Oscars","count":1,"total_cont":0},{"name":"Robert.Cannon","count":1,"total_cont":0},{"name":"哥伦比亚","count":1,"total_cont":0},{"name":"undefined","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"短片&OVA","count":1,"total_cont":0},{"name":"50s","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"Robert·Cannon","count":1,"total_cont":0},{"name":"老害最爱","count":1,"total_cont":0},{"name":"脑洞","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"砰砰杰瑞德"},{"key":"上映年度","value":"1951-01-25"},{"key":"片长","value":"8 分钟