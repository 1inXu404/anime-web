[{"date":"1949-02-26","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/6d/a0/275351_aY92R.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/6d/a0/275351_aY92R.jpg","large":"https://lain.bgm.tv/pic/cover/l/6d/a0/275351_aY92R.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/6d/a0/275351_aY92R.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/6d/a0/275351_aY92R.jpg"},"summary":"　　在一个平凡的夜晚，淘气的汤姆将杰瑞用绳子拴起来，自顾自靠在沙发上玩起了老鼠溜溜球。这时，女主人的声音响起。主人命令汤姆去外面睡觉，可是窗外漆黑一片，而且下起了瓢泼大雨。汤姆极度郁闷，迈着沉重的步伐走向大门口。突然，女主人的一句话启发了他，他假装感冒，终于得到主人的怜悯，得以在屋中睡觉。杰瑞将一切看在眼里，他想方设法整治这个狡猾的老对头。小老鼠找来红色的墨水点在汤姆的脸上，造成汤姆感染麻疹的假象。汤姆大为震惊，倍感不适。 \r\n　　而杰瑞则诡计频出，一会儿为汤姆吃药，一会儿给他降温一会儿又为他取暖，将汤姆折腾得不亦乐乎……","name":"Polka-Dot Puss","name_cn":"斑点猫","tags":[{"name":"短片","count":21,"total_cont":0},{"name":"欧美","count":9,"total_cont":0},{"name":"猫和老鼠","count":9,"total_cont":0},{"name":"1949","count":8,"total_cont":0},{"name":"美国","count":4,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"原创","count":2,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"剧场版-02","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"斑点猫"},{"key":"上映年度","value":"1949-02-26"},{"key":"片长","value":"8分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":33,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":11,"7":15,"8":6,"9":0,"10":0},"score":6.8},"total_episodes":0,"collection":{"on_hold":1,"dropped":4,"wish":5,"collect":79,"doing":1},"id":275351,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]