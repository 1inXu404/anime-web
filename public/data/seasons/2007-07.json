count":25}],"eps":26,"collection":{"wish":423,"collect":589,"doing":34,"on_hold":85,"dropped":50}},{"id":6849,"type":2,"name":"ぽてまよ","name_cn":"蛋黄酱萝莉","summary":"森山素直是个喜欢面包的无口系沉默中学生。有天，他在自家冰箱里发现一只长着黑色猫耳和尾巴的二头身谜样生物，取名为POTEMAYO并圈养起来。软绵绵又可爱的POTEMAYO在素直的学校里也拥有很高的人气。后来，森山家的冰箱里又冒出一只同类型的谜样生物“松露子”，不知为何松露子将POTEMAYO视为对手。故事就这样围绕着两只奇妙生物还有素直与其各具特色的同学们欢乐地展开了。","date":"2007-07-06","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ec/b9/6849_2me12.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ec/b9/6849_2me12.jpg","large":"https://lain.bgm.tv/pic/cover/l/ec/b9/6849_2me12.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ec/b9/6849_2me12.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ec/b9/6849_2me12.jpg"},"rating":{"rank":3572,"total":246,"score":6.7,"count":{"1":1,"2":0,"3":1,"4":6,"5":28,"6":60,"7":93,"8":39,"9":14,"10":4}},"tags":[{"name":"治愈","count":80},{"name":"萝莉","count":62},{"name":"TV","count":52},{"name":"萌","count":52},{"name":"J.C.STAFF","count":48},{"name":"花澤香菜","count":34},{"name":"2007年7月","count":30},{"name":"2007","count":26},{"name":"蛋黄酱","count":23},{"name":"花泽香菜","count":22},{"name":"喜多村英梨","count":19}],"eps":12,"collection":{"wish":255,"collect":419,"doing":55,"on_hold":43,"dropped":45}},{"id":104803,"type":2,"name":"はぴはぴクローバー","name_cn":"快乐小兔幸运草","summary":"小学館の少女漫画誌「ちゃお」連載の竜山さゆりの漫画を原作にしたアニメ作品。キッズステーションほかで全26話を放送。主人公のちまは、三日月森に住む元気なうさぎの女の子。ある日、彼女の通う学校にメルという転入生がやってきた。ちまはメルのために三日月森を案内し、翌日も一緒に遊ぶ約束をして別れたが……。ちまとその仲間たちを中心に、森に住む動物たちのほのぼのとした日常を描写。仲間や家族など大切なことを教えてくれるストーリー。三日月森の大人はいずれも有職者で仕事に就くことが森の一員の証など、細かい設定にもこだわりが。","date":"2007-07-06","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/1a/52/104803_VQjqi.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/1a/52/104803_VQjqi.jpg","large":"https://lain.bgm.tv/pic/cover/l/1a/52/104803_VQjqi.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/1a/52/104803_VQjqi.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/1a/52/104803_VQjqi.jpg"},"rating":{"rank":0,"total":1,"score":5,"count":{"1":0,"