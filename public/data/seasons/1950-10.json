[{"date":"1950-10-21","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/14/84/634569_9739R.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/14/84/634569_9739R.jpg","large":"https://lain.bgm.tv/pic/cover/l/14/84/634569_9739R.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/14/84/634569_9739R.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/14/84/634569_9739R.jpg"},"summary":"　　平静的一天，汤姆家的餐桌上拜访了一只刚刚出炉、香飘四溢的美味烧鸡。馋嘴的汤姆偷偷掰下一根鸡腿，准备带到外面享用。谁知他忙里出错，不小心打破了桌子上的水杯。女主人闻声大喊，汤姆连忙敲打墙壁，叫出了懵懂无知的小老鼠杰瑞，并将鸡腿塞到杰瑞手中。此时女主人刚好赶到，看到拿着鸡腿的杰瑞当然火冒三丈，命令汤姆抓住这个小偷。汤姆耀武扬威，迅速抓住杰瑞跑出门外。他放掉杰瑞，独自美美地享受了那只鸡腿。\r\n　　平白无故蒙冤的杰瑞咽不下这口气，他看到正在附近睡觉的大狗史派克，于是计上心头，将史派克怀里的骨头棒子偷了出来，塞进正躺在树下打盹的汤姆的手中……","name":"The Framed Cat","name_cn":"被陷害的猫","tags":[{"name":"1950s","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"短片","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"被陷害的猫"},{"key":"别名","value":[{"v":"贪吃的猫"}]},{"key":"上映年度","value":"1950年10月21日"},{"key":"片长","value":"7分钟"},{"key":"导演","value":"Joseph Barbera,William Hanna"},{"key":"IMDb","value":"tt0042476"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":0,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":5,"doing":0},"id":634569,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1950-10-07","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/6a/de/243267_FWd1q.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/6a/de/243267_FWd1q.jpg","large":"https://lain.bgm.tv/pic/cover/l/6a/de/243267_FWd1q.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/6a/de/243267_FWd1q.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/6a/de/243267_FWd1q.jpg"},"summary":"　　在繁华城市一隅，某座大厦坐落着名为“赏鸟协会”的组织，但是讽刺的是这里生活着贪婪馋嘴的黑猫西尔韦斯特（梅尔·布兰科 Mel Blanc 配音）。此时，它正拿着一台望远镜张望对面的断臂公寓。在公寓某个窗口放着一只鸟笼子，可爱俏皮的金丝雀崔蒂（梅尔·布兰科 Mel Blanc 配音）此时也拿着望远镜望向西尔韦斯特这边。崔蒂显然也发现了大坏猫，同时预感到危险将至。无所畏惧的西尔韦斯特狂奔冲向断臂公寓，谁知却遭到崔蒂的主人老奶奶的一顿胖揍。 ","name":"Canary Row","name_cn":"小小鸟智斗黑猫","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"华纳","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"小小鸟智斗黑猫"},{"key":"别名","value":[{"v":"崔弟智斗大坏猫"}]},{"key":"上映年度","value":"1950-10-07"},{"key":"片长","value":"7分钟"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 家庭"},{"key":"导演","value":"Friz Freleng"},{"key":"主演","value":"Mel Blanc"},{"key":"IMDb链接","value":"tt0042304"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":1,"dropped":2,"wish":2,"collect":7,"doing":0},"id":243267,"eps":0,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]