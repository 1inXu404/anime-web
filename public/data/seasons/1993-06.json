[{"date":"1993-06-25","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/4d/fc/116207_6u6DM.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/4d/fc/116207_6u6DM.jpg","large":"https://lain.bgm.tv/pic/cover/l/4d/fc/116207_6u6DM.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/4d/fc/116207_6u6DM.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/4d/fc/116207_6u6DM.jpg"},"summary":"","name":"Pops","name_cn":"","tags":[{"name":"OVA","count":32,"total_cont":0},{"name":"MADHouse","count":19,"total_cont":0},{"name":"浅香守生","count":16,"total_cont":0},{"name":"1993","count":14,"total_cont":0},{"name":"漫画改","count":12,"total_cont":0},{"name":"漫改","count":9,"total_cont":0},{"name":"恋爱","count":7,"total_cont":0},{"name":"1993年","count":5,"total_cont":0},{"name":"治愈","count":3,"total_cont":0},{"name":"独立ova","count":3,"total_cont":0},{"name":"1993年四月番","count":2,"total_cont":0},{"name":"1993年6月","count":2,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"北尾胜","count":1,"total_cont":0},{"name":"90-94","count":1,"total_cont":0},{"name":"高屋敷英夫","count":1,"total_cont":0},{"name":"其他","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0}],"infobox":[{"key":"话数","value":"1"},{"key":"发售日","value":"1993年6月25日"}],"rating":{"rank":0,"total":41,"count":{"1":0,"2":1,"3":4,"4":8,"5":16,"6":9,"7":2,"8":0,"9":0,"10":1},"score":5},"total_episodes":0,"collection":{"on_hold":2,"dropped":6,"wish":23,"collect":53,"doing":0},"id":116207,"eps":1,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1993-06-25","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/00/5d/614315_EJ6sV.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/00/5d/614315_EJ6sV.jpg","large":"https://lain.bgm.tv/pic/cover/l/00/5d/614315_EJ6sV.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/00/5d/614315_EJ6sV.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/00/5d/614315_EJ6sV.jpg"},"summary":"1993년 대원동화와 한국방송공사가 공동으로 애니화하여 동년 6월 25일부터 9월 17일까지 KBS 2TV에서 금요일 오후 시간대에 방송되었고, 1995년 1월 27일부터 4월 21일까지 같은 채널에서 같은 요일 오후 6시마다 재편성됐다. 1997년 6월 15일부터 7월 27일까지 1TV 일요일 낮 시간대에 재방한 뒤, 1998년 8월 23일부터 9월 27일까지 또 했다. 이 작품은 2020 우주의 원더키디, 날아라 슈퍼보드, 아기공룡 둘리와 함께 대한민국의 어린이들과 함께한 만화영화이다. 책임프로듀서(감독)는 양관우, 프로듀서는 민영문과 최수형 PD[14], 조연출은 이천우, 작화연출은 안진모, 색지정은 한미라, 음악은 안문석과 이남홍, 음향효과는 최경상, 그래픽 디자인은 진수아 등이 각각 맡았다.\r\n\r\n주제가 작사는 김혜진, 작곡은 안문규, 노래는 서장원과 장숙희가 각각 맡았다.\r\n\r\n마법 주문이 익숙할 만큼 꽤 유명한 데다가 방영되었을 때도 달려라 하니나 아기공룡 둘리, 머털도사, 날아라 슈퍼보드급까지는 아니지만 그래도 상당한 인기작이었고 한동안 둘리, 슈퍼보드, 원더키디와 함께 일요일 오후 반복재방 편성의 한 축이기도 하였는데, 어찌된 영문인지 1990년대 이후에 지상파는 커녕 케이블 방송에서의 재방송조차 드물거나 안 되고 있는 작품이다. 도담이와 토리토리, 사랑의 학교, 내친구 까꿍이, 요정핑크 등과 더불어서 불가사의하게 실종되어버린 1990년대 한국 애니 작품이기도 하다. 케이블 방송업계는 맨날 한 거 또 하지 말고 할 거 없으면 이런 예전 거 발굴해서 재방하라는 목소리가 있지만 업계는 요지부동이다.[15][16]\r\n\r\n그렇게 재방영 소식이 없다가 다행히 2021년 대원미디어 유튜브 채널 '대플릭스'에서 벡터맨 다음으로 마법사의 아들 코리를 공개 업로드할 예정이 있었으나 3월 2일에 대플릭스 유튜브 채널 계정이 해지가 되어 취소되었다가 4월 22일에 다시 부활하면서 두치와 뿌꾸보다 먼저 업로드됐다. 그런데 또다시 폭발해서 채널을 복구하든지, 네이버TV 대원미디어 채널로 옮기든지 해야 볼 수 있을것 같은데, <지구용사 벡터맨>처럼 KBS랑 저작권 문제가 원만히 해결되어야 할 듯하다. 그런데 알고보니 유튜브의 기계(AI)적 채널 삭제라는게 밝혀졌다.\r\n\r\n2022년 5월 5일부터 3일 동안 KBS 멀티플랫폼편성국의 유튜브 채널 '옛날티비'를 통해 업로드됐다.","name":"마법사의 아들 코리","name_cn":"","tags":[{"name":"韩国","count":1,"total_cont":0},{"name":"奇幻","count":1,"total_cont":0},{"name":"TV","count":1,"total_cont":0}],"infobox":[{"key":"话数","value":"13"},{"key":"放送开始","value":"1993年6月25日"},{"key":"放送星期","value":"每周五下午6点"},{"key":"播放电视台","value":"KBS 2TV"},{"key":"播放结束","value":"1993年9月17日"},{"key":"音乐","value":"안문규、이남홍"},{"key":"链接","value":[{"k":"위키백과","v":"https://ko.wikipedia.org/wiki/마법사의_아들_코리"},{"k":"나무위키","v":"https://namu.wiki/w/마법사의 아들 코리"},{"k":"KMDb","v":"https://www.kmdb.or.kr/db/kor/detail/movie/K/10519"}]},{"key":"Copyright","value":"ⓒ 1993 고형석 대원동화 All rights reserved."},{"key":"原作","value":"고행석"},{"key":"企画","value":"윤대작 (KBS)、대원동화(제작)"},{"key":"总导演","value":"양관우"},{"key":"制片人","value":"민영문、최수형、양관우(책임)"},{"key":"音响监督","value":"최경상"},{"key":"动画制作","value":"대