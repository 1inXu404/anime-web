[{"date":"1977-10-29","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/63/a9/72356_60P86.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/63/a9/72356_60P86.jpg","large":"https://lain.bgm.tv/pic/cover/l/63/a9/72356_60P86.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/63/a9/72356_60P86.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/63/a9/72356_60P86.jpg"},"summary":"カナダのケベック州にある、開拓牧場の一人娘・シャルロットは、父・アンドレと平穏に暮らしていた。しかし彼女が12歳の誕生日を迎えると、アンドレは重要な秘密を打ち明ける。母・シモーヌは生きていること、そして自身はフランス大貴族・モントバーン家の跡取りであったが、身分を嫌ってカナダへ渡ってきたことを。\r\n\r\nアンドレはシモーヌをフランスから呼び戻そうとしたが、その矢先、事故死してしまう。父亡き後、牧場を乗っ取ろうとする人の陰謀にも負けず、けなげに生きていく。\r\n\r\nやがて、母と祖父に会うためフランスへ。謎の少年・ナイトをはじめ人々の蔭からの支えにより、母との再会を果たす。メイフラワーが咲き誇る5月に、シャルは自分の幸せをかみしめると同時に、父が亡くなってからのこれまでの苦労を思い出しながら、助けてくれた人たちへの感謝の気持ちで胸が一杯になるのだった。","name":"若草のシャルロット","name_cn":"大地儿女","tags":[{"name":"TV","count":4,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"1977","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"大地儿女"},{"key":"话数","value":"30"},{"key":"放送开始","value":"1977年10月29日"},{"key":"放送星期","value":"星期六"},{"key":"播放电视台","value":"テレビ朝日"},{"key":"播放结束","value":"1978年5月27日"},{"key":"摄影监督","value":"熊瀬哲郎（第1話 - 第17話）、荻原亨"},{"key":"制片人","value":"根来昭"},{"key":"美术板","value":"大山哲史（第7話 - 第17話、第19話）"},{"key":"剪辑","value":"古池東風、上遠野英俊"},{"key":"现象","value":"東京現像所"},{"key":"协力","value":"オムニバス・プロモーション、シネビーム"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":4,"dropped":7,"wish":12,"collect":4,"doing":5},"id":72356,"eps":30,"meta_tags":["TV","日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1977-10-27","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f5/bf/137280_a5Y1w.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f5/bf/137280_a5Y1w.jpg","large":"https://lain.bgm.tv/pic/cover/l/f5/bf/137280_a5Y1w.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f5/bf/137280_a5Y1w.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f5/bf/137280_a5Y1w.jpg"},"summary":"　　本片用极其简朴的线条描绘了一个奇幻而又夹杂着黑色幽默的故事。 \r\n　　圣诞节前夕，一位拾荒老人在垃圾池边上捡到一个盒子，捡回后经过自己的精心打扮，幻想着节日到来之际自己所需要的礼物。而不幸的是，天气越来越寒冷，老人不得不躲进盒子里御寒。最终，星星进入了盒子里，带走了老人的灵魂。本片充满盎然童心、以无限好奇观察着这彷如万花筒般的世界，而老人最终在盒子中逝世，无疑又给人淡淡的忧伤。","name":"An Old Box","name_cn":"旧盒子","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"1977","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"Paul.Driessen","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"旧盒子"},{"key":"别名","value":[{"v":"Une vieille boîte"}]},{"key":"上映年度","value":"1977-10-27"},{"key":"片长","value":"9min"},{"key":"制片国家/地区","value":"加拿大"},{"key":"语言","value":"无对白"},{"key":"导演","value":"Paul Driessen"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":6,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":4,"7":0,"8":0,"9":0,"10":0},"score":5.5},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":3,"collect":11,"doing":0},"id":137280,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1977-10-10","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/22/6f/189004_FBu8a.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/22/6f/189004_FBu8a.jpg","large":"https://lain.bgm.tv/pic/cover/l/22/6f/189004_FBu8a.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/22/6f/189004_FBu8a.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/22/6f/189004_FBu8a.jpg"},"summary":"在日本比赛中，车手速水俊介因为忽视了监督指导让车子损坏，比赛完后其被解雇。但他爸爸的朋友岚银二郎出现邀请他加入自己方的皇帝车队。车队用的车是俊介爸爸设计的跑车。 ","name":"激走!ルーベンカイザー","name_cn":"激走！鲁滨皇帝","tags":[{"name":"TV","count":2,"total_cont":0},{"name":"1977","count":2,"total_cont":0},{"name":"1977年十月番","count":1,"total_cont":0},{"name":"1977年10月","count":1,"total_cont":0}