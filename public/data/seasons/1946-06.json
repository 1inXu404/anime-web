[{"date":"1946-06-29","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/b6/f7/262835_827HD.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/b6/f7/262835_827HD.jpg","large":"https://lain.bgm.tv/pic/cover/l/b6/f7/262835_827HD.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b6/f7/262835_827HD.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b6/f7/262835_827HD.jpg"},"summary":"　　平凡的一天，汤姆和小老鼠杰瑞再次展开了一场惊险刺激的大混战，虽然木棍、铁棒、铁铲等十八般武器全部用上，但是汤姆根本就不是杰瑞的对手，反而被对方耍得团团转，疲于奔命。万般无奈之下，汤姆根据报纸上的广告向灭鼠公司求助。过了不久，高傲的捕鼠高手幸运小子来了。他先是将一枚螺母做成奶酪的样子，杰瑞果然上当，将其吞到了肚子了，结果被幸运小子抓住。不过杰瑞毕竟是一只身经百战的超级小老鼠，他很快就适应了灭鼠公司的抓捕方式，任凭对方用毒气、炸药或者任何凶器，即使汤姆和幸运小子两人齐上阵也毫不畏惧，更为激烈的战争旋即展开了……","name":"Trap Happy","name_cn":"捕鼠大队","tags":[{"name":"短片","count":18,"total_cont":0},{"name":"猫和老鼠","count":10,"total_cont":0},{"name":"欧美","count":9,"total_cont":0},{"name":"1946","count":7,"total_cont":0},{"name":"美国","count":5,"total_cont":0},{"name":"米高梅","count":4,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"60年代前","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"约瑟夫·巴伯拉","count":1,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"捕鼠大队"},{"key":"上映年度","value":"1946-06-29"},{"key":"片长","value":"7分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":37,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":4,"7":15,"8":15,"9":1,"10":1},"score":7.4},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":4,"collect":88,"doing":1},"id":262835,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1946-06-07","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/15/41/241711_QQ54I.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/15/41/241711_QQ54I.jpg","large":"https://lain.bgm.tv/p