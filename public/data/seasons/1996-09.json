変更されている。武は鬼河原家の3兄弟の末弟であり、長兄トモル（漢字は不明）が失踪し武自身も父とは犬猿の仲であるため、事件で父や次兄の元に怒鳴り込んだ際に長兄の失踪は父の汚いやり口に反発してのことだと推測を事実であるかのようにまくし立てるなど父と末子の間の溝は大きい。しかし、ポリマーの活躍や車錠のドジっぷりは健在。また、今作で鬼河原武/ポリマーを演じた置鮎龍太郎は、オリジナル版で同役を演じた曽我部和恭の引退後、持ち役を数多く引き継いでいる。","name":"新破裏拳ポリマー","name_cn":"新破里拳Polimar","tags":[{"name":"OVA","count":56,"total_cont":0},{"name":"新房昭之","count":51,"total_cont":0},{"name":"梅津泰臣","count":39,"total_cont":0},{"name":"1996","count":28,"total_cont":0},{"name":"龙之子","count":26,"total_cont":0},{"name":"J.C.STAFF","count":23,"total_cont":0},{"name":"原创","count":22,"total_cont":0},{"name":"科幻","count":17,"total_cont":0},{"name":"石浜真史","count":8,"total_cont":0},{"name":"独立ova","count":5,"total_cont":0},{"name":"90年代","count":4,"total_cont":0},{"name":"破里拳Polimar","count":3,"total_cont":0},{"name":"龙之子Production","count":3,"total_cont":0},{"name":"タツノコプロ","count":3,"total_cont":0},{"name":"柿沼秀樹","count":2,"total_cont":0},{"name":"1996年","count":2,"total_cont":0},{"name":"90s","count":2,"total_cont":0},{"name":"95-99s","count":1,"total_cont":0},{"name":"特摄","count":1,"total_cont":0},{"name":"1990-1999","count":1,"total_cont":0},{"name":"FF","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"SF","count":1,"total_cont":0},{"name":"石滨真史","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"95-99","count":1,"total_cont":0},{"name":"补番","count":1,"total_cont":0},{"name":"剧集","count":1,"total_cont":0},{"name":"置鮎龍太郎","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"新破里拳Polimar"},{"key":"别名","value":[{"v":"Shin Hurricane Polymer"},{"v":"New Hurricane Polymar"},{"v":"New Hariken Polymar"},{"v":"新旋风侠"}]},{"key":"话数","value":"2"},{"key":"发售日","value":"1996年9月21日"},{"key":"官方网站","value":"http://www.tatsunoko.co.jp/works/archive/ova_polymar.html"},{"key":"制作","value":"タツノコプロダクション"},{"key":"执行制片人","value":"蛭田元二 (コロムビアエデュテインメント) → 石塚淳三郎 (日本コロムビア) 、吉田健二"},{"key":"企画","value":"九里一平、成嶋弘毅"},{"key":"制片人","value":"