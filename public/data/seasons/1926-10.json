[{"date":"1926-10-29","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/4c/18/258989_d0a9l.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/4c/18/258989_d0a9l.jpg","large":"https://lain.bgm.tv/pic/cover/l/4c/18/258989_d0a9l.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/4c/18/258989_d0a9l.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/4c/18/258989_d0a9l.jpg"},"summary":"玄奘三蔵(げんじょうさんぞう)が大乗の仏典を取りに、西天竺への旅に出る。途中で、いたずらが過ぎて観世音菩薩に大岩に閉じ込められた孫悟空を助ける。三蔵法師の弟子になった孫悟空は、娘に襲い掛かっている豚の化け物を懲らしめ、猪八戒として弟子に加える。また河童の化け物も沙悟浄と名を改め、弟子に加わる。孫悟空が怪物を大石に封じ、手に入れた球を投げると、雪を頂いた霊山が現われる。それは大乗の経典を蔵する雄宝殿である。三蔵法師が雄宝殿の如来様へ経典を授けて頂くように頼むと、如来様は経典は龍の車に乗って送るであろうと言われる。","name":"切紙細工 西遊記 孫悟空物語","name_cn":"孙悟空物语","tags":[{"name":"短片","count":6,"total_cont":0},{"name":"1926","count":6,"total_cont":0},{"name":"大藤信郎","count":5,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"千代纸映画社","count":2,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"千代紙映画社","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"1920s","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"孙悟空物语"},{"key":"上映年度","value":"1926年10月29日"},{"key":"片长","value":"8min"},{"key":"制作","value":"自由映画研究所（千代紙映画社）"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":8,"count":{"1":1,"2":0,"3":1,"4":0,"5":3,"6":1,"7":1,"8":1,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":5,"collect":19,"doing":2},"id":258989,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1926-10-12","platform":"剧场版","images":{"small":"","grid":"","large":"","medium":"","common":""},"summary":"","name":"怠け太郎と何にも仙人","name_cn":"","tags":[{"name":"旧物","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"上映年度","value":"1926年10月12日"},{"key":"片长","value":"12min"},{"key":"话数","value":"1"}],"rating