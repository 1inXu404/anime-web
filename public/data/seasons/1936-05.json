[{"date":"1936-05-30","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/03/24/241576_yO5Y2.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/03/24/241576_yO5Y2.jpg","large":"https://lain.bgm.tv/pic/cover/l/03/24/241576_yO5Y2.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/03/24/241576_yO5Y2.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/03/24/241576_yO5Y2.jpg"},"summary":"　　夜深人静，米奇（沃特·迪斯尼 Walt Disney 配音）阅罢睡前小说《爱丽丝梦游仙境》后倒头便睡。日有所思，夜有所梦。刚刚进入梦乡的米奇，便从身体里走出来，穿过了墙上的镜子。镜子另一边的世界看似与对面相同，不过所有的家具似乎都具有了生命。米奇吃了胡桃夹子丢掉的核桃仁，身体发生了奇迹般的变化，竟然缩成一个小人。他与电话、扑克牌、红桃皇后尽情摇摆，载歌载舞，整个房间都洋溢着喜悦的气氛。但是，米奇和红桃皇后亲昵的舞姿惹来红桃国王的不快，他拔出佩剑与米奇展开连番激烈的搏杀，更派出扑克大军扑向这个来路不明的情敌。 \r\n　　这个夜晚，对米奇来说是如此的不平凡…… ","name":"Thru the Mirror","name_cn":"镜中奇遇记","tags":[{"name":"短片","count":29,"total_cont":0},{"name":"迪士尼","count":15,"total_cont":0},{"name":"1936","count":15,"total_cont":0},{"name":"Disney","count":11,"total_cont":0},{"name":"美国","count":11,"total_cont":0},{"name":"欧美","count":10,"total_cont":0},{"name":"1930-1939","count":2,"total_cont":0},{"name":"David.Hand","count":2,"total_cont":0},{"name":"独立短片","count":2,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"童年","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"David·Hand","count":1,"total_cont":0},{"name":"Mickey","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"1930s","count":1,"total_cont":0},{"name":"30s","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"镜中奇遇记"},{"key":"上映年度","value":"1936-05-30"},{"key":"片长","value":"9 分钟 / Argentina: 10 分钟"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 歌舞 / 家庭 / 奇幻"},{"key":"制片国家/地区","value":"美国"},{"key":"语言","value":"英语"},{"key":"导演","value":"David Hand"},{"key":"编剧","value":"William Cottrell、Joe Grant"},{"key":"主演","value":"Walt Disney"},{"key":"IMDb id","value":"tt0028378"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":43,"count":{"1":1,"2":0,"3":0,"4":0,"5":4,"6":7,"7":15,"8"