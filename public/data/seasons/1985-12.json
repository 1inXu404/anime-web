/cover/l/de/c5/214258_Q8IiJ.jpg","large":"https://lain.bgm.tv/pic/cover/l/de/c5/214258_Q8IiJ.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/de/c5/214258_Q8IiJ.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/de/c5/214258_Q8IiJ.jpg"},"summary":"OVA揺籃期の1985年ににっかつビデオフィルムズが発売した、オリジナルのスペース活劇ロマン。\r\n　宇宙に君臨する軍事国家ベンティカ帝国。同国と敵対する警察惑星G・P・Pは、帝国の存亡の鍵を握るとされる記憶喪失の少女ムーマを牢獄から救出した。ムーマの保護に当たるのはG・P・Pの女性エージェント、ケイト。そのケイトにG・P・P上層部から次の指示が下る。それは帝国打倒のため、もう一人の要人を非公式に連行せよというもの。相手の名はバビ少年。だが彼は現在、刑務所惑星に殺人罪で懲役中の重罪犯罪人だった。\r\n　監督はアニメーターから演出家に転向した影山楙倫で、これが初の監督作品になる。アニメの制作は影山が所属していたスタジオ、カナメ・プロが担当。当時、同プロにいた人気アニメーター・いのまたむつみも、本作の美形敵役アイズマンのキャラクターデザインなどで作品に参加した。","name":"バビ・ストック I 果てしなき標的","name_cn":"","tags":[{"name":"OVA","count":8,"total_cont":0},{"name":"1985","count":4,"total_cont":0},{"name":"影山楙倫","count":3,"total_cont":0},{"name":"KanameProduction","count":3,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"SF","count":2,"total_cont":0},{"name":"古谷徹","count":2,"total_cont":0},{"name":"寺田憲史","count":2,"total_cont":0},{"name":"カナメプロダクション","count":1,"total_cont":0}],"infobox":[{"key":"别名","value":[{"v":"BAVI STOCK-I"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1985年12月10日"}],"rating":{"rank":0,"total":2,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":0,"8":0,"9":0,"10":0},"score":5.5},"total_episodes":0,"collection":{"on_hold":2,"dropped":4,"wish":9,"collect":5,"doing":0},"id":214258,"eps":1,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]