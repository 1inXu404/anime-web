走去，原来他的妻子正在孵化小鸭。经过痛苦漫长的等待，毛茸茸的小鸭子相继破壳而出。看着健康可爱的孩子，鸭爸爸欣喜过望，狂亲自己的老婆。正在这时，最后一枚蛋也蠢蠢欲动，结果出来的竟是一只傻乎乎的白色小鸭子。这可气坏了鸭爸爸，他怀疑老婆不忠，于是两口子发生争吵，最终鸭爸爸绝情离去。鸭妈妈不甘示弱，决心独自抚养这群孩子。她带着宝贝儿们游泳嬉闹，却独独不喜欢那个令她失去爱人的白色小鸭子。小白鸭受尽其他小动物的奚落，自认为丑陋的他悲伤不已…… \r\n　　本片荣获1940年奥斯卡电影节最佳动画短片奖。","name":"Ugly Duckling","name_cn":"丑小鸭","tags":[{"name":"短片","count":34,"total_cont":0},{"name":"欧美","count":29,"total_cont":0},{"name":"迪士尼","count":20,"total_cont":0},{"name":"1939","count":15,"total_cont":0},{"name":"奥斯卡","count":13,"total_cont":0},{"name":"Disney","count":9,"total_cont":0},{"name":"美国","count":8,"total_cont":0},{"name":"剧场版","count":7,"total_cont":0},{"name":"丑小鸭","count":7,"total_cont":0},{"name":"1930s","count":6,"total_cont":0},{"name":"WaltDisney","count":3,"total_cont":0},{"name":"先驱","count":2,"total_cont":0},{"name":"Oscars","count":2,"total_cont":0},{"name":"童话","count":2,"total_cont":0},{"name":"7WA","count":1,"total_cont":0},{"name":"1939年4月","count":1,"total_cont":0},{"name":"排名低了","count":1,"total_cont":0},{"name":"7","count":1,"total_cont":0},{"name":"2D","count":1,"total_cont":0},{"name":"中庸","count":1,"total_cont":0},{"name":"7(+2)","count":1,"total_cont":0},{"name":"童年","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"短片&OVA","count":1,"total_cont":0},{"name":"欧美动画","count":1,"total_cont":0},{"name":"寓言","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"IP","count":1,"total_cont":0},{"name":"1930-1939","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"丑小鸭"},{"key":"上映年度","value":"1939-04-07"},{"key":"片长","value":"9 分钟"},{"key":"IMDb链接","value":"tt0032071"},{"key":"语言","value":"无对白"},{"key":"制片国家/地区","value":"美国"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 家庭"},{"key":"导演","value":"Jack Cutting"},{"key":"话数","value":"1"}],"rating":{"rank":4142,"total":84,"count":{"1":0,"2":1,"3":0,"4":1,"5":13,"6":25,"7":35,"8":6,"9":1,"10":2},"score":6.5},"total_episodes":0,"collection":{"on_hold":4,"dropped"