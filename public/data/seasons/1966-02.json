剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1966-02-05","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/05/77/183295_X441C.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/05/77/183295_X441C.jpg","large":"https://lain.bgm.tv/pic/cover/l/05/77/183295_X441C.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/05/77/183295_X441C.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/05/77/183295_X441C.jpg"},"summary":"1960年代に子供たちの間で「シェー」の一大ブームを巻き起こした赤塚不二夫のギャグ漫画をアニメ化。長男のおそ松以下、カラ松、チョロ松、一松、十四松そしてトド松は、ちょっと目には両親にも区別がつかないほどのそっくりな六つ子の兄弟。小さいがケンカっぱやいチビ太や、おフランス帰りを自称するイヤミなど、さまざまな人々とともに六つ子たちは今日も大騒ぎ。アニメの製作は赤塚不二夫も在籍していたスタジオ・ゼロ、そしてチルドレンズコーナーがメインで担当。チルドレンズコーナーは東映アニメーション（当時は東映動画）ゆかりのスタッフによる製作会社で、本作の作画も当時としては格別のクオリティを誇示していた。また、OPテーマのひとつを藤田まことが歌唱したこともトピックのひとつ。","name":"おそ松くん","name_cn":"阿松","tags":[{"name":"TV","count":7,"total_cont":0},{"name":"1966年","count":6,"total_cont":0},{"name":"日本","count":5,"total_cont":0},{"name":"1966","count":4,"total_cont":0},{"name":"生肉","count":4,"total_cont":0},{"name":"1966年2月","count":3,"total_cont":0},{"name":"漫画改","count":3,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"以前的","count":2,"total_cont":0},{"name":"东映","count":2,"total_cont":0},{"name":"漫改","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"1966年一月番","count":1,"total_cont":0},{"name":"阿松","count":1,"total_cont":0},{"name":"零工作室チルドレンズ・コーナー","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"阿松"},{"key":"别名","value":[{"v":"我系西瓜刨"},{"v":"おそ松くん (1965)"}]},{"key":"话数","value":"104"},{"key":"放送开始","value":"1966年2月5日"},{"key":"播放结束","value":"1967年3月25日"},{"key":"音乐","value":"渡辺浦人（第50話まで）→三保敬太郎（第51話から）"},{"key":"企划","value":"毎日放送、チルドレンズ・コーナー、スタジオ・ゼロ"},{"key":"动画制作","value":"チルドレンズ・コーナー、スタジオ・ゼロ"},{"key":"分镜","value":"鈴木伸一、永沢詢、広田清、北川今、於田次郎、藤正紀、関龍二、高木厚"},{"key":"制作管理","value":"上野壽夫"}],"rating":{"rank":0,"total":7,"count":{"1":0,"2":0,"3":0,"4":3,"5":3,"6":0,"7":0,"8":1,"9":0,"10":0},"score"