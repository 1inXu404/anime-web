[{"date":"1929-11-15","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d0/c9/133739_Yg7QG.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d0/c9/133739_Yg7QG.jpg","large":"https://lain.bgm.tv/pic/cover/l/d0/c9/133739_Yg7QG.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d0/c9/133739_Yg7QG.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d0/c9/133739_Yg7QG.jpg"},"summary":"　　美丽的原始大草原上，欢快的米奇（沃尔特·迪斯尼 Walt Disney 配音）正站在一头不断跳跃的大象身上演奏手风琴，欢快的音乐连冷峻的秃鹫都受到感染，于是随之起舞。米奇发现了秃鹫，命令大象停下，他也滑了下来，随即从裤子里掏出一把猎枪，悄悄靠近闭目养神的秃鹫。谁知他的猎枪爆了枪膛，还被秃鹫嘲笑了一番。米奇十分气愤，举枪挥了过去，谁知却惹恼了旁边的狗熊和狮子。危难当前，惶恐的米奇噘起嘴吹响了口哨。音乐再次响起，所有的小动物们都跳起舞蹈，世界名曲以别致的方式演绎，引起了动物们的热烈欢迎。 \r\n　　快乐的音乐会并未结束，开始朝着下一轮高潮行进…… ","name":"Jungle Rhythm","name_cn":"丛林乐章","tags":[{"name":"短片","count":5,"total_cont":0},{"name":"1929","count":3,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"考古","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"Yankee_Doodle","count":1,"total_cont":0},{"name":"系列短片","count":1,"total_cont":0},{"name":"蓝色多瑙河","count":1,"total_cont":0},{"name":"1920-1929","count":1,"total_cont":0},{"name":"Disney","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"慢节奏","count":1,"total_cont":0},{"name":"UB_IWERKS","count":1,"total_cont":0},{"name":"鬃毛hula","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"丛林乐章"},{"key":"上映年度","value":"1929-11-15"},{"key":"片长","value":"7分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0020049"},{"key":"类型","value":"喜剧 / 短片 / 歌舞 / 家庭 / 儿童"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"华特·迪斯尼"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":9,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":1,"7":2,"8":3,"9":1,"10":0},"score":7},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":1,"collect":19,"doing":0},"id":133739,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]