[{"date":"1932-08-13","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/33/4d/133761_CgB6r.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/33/4d/133761_CgB6r.jpg","large":"https://lain.bgm.tv/pic/cover/l/33/4d/133761_CgB6r.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/33/4d/133761_CgB6r.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/33/4d/133761_CgB6r.jpg"},"summary":"　　夜幕降临，万籁俱尽。简朴的小屋内烛火闪烁。身着睡衣的米奇（沃尔特•迪斯尼 Walt Disney 配音）和爱犬布鲁托（品托•考维格 Pinto Colvig 配音）趴在床头坐着睡前祷告，他希望上帝保佑自己、米妮、布鲁托，让每个人都能得到幸福。祷告完毕，米奇心满意足地上床睡觉。布鲁托希望能跟主人睡在一起，结果被布鲁托赶回了自己的狗窝，心情十分低落。米奇则亲吻勒米妮的照片，熄灭蜡烛后安然入睡。见此情景，布鲁托悄悄爬进米奇的杯子里，高兴地舔舐小主人的脸。 \r\n　　米奇在梦中误以为是米妮在亲吻他，他梦见终于和女友走入婚姻殿堂，他们结成幸福美满的家庭。白天米奇在院子里浇水，送子鹤将数十个小宝宝丢进他家的烟囱。这群孩子真是调皮，将米奇的家闹得天翻地覆……","name":"Mickey's Nightmare","name_cn":"米奇的梦魇","tags":[{"name":"1932","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"短片","count":2,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"迪士尼","count":1,"total_cont":0},{"name":"衔子waves","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"1930s","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"梦魇","count":1,"total_cont":0},{"name":"Pluto","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"米奇的梦魇"},{"key":"上映年度","value":"1932-08-13"},{"key":"片长","value":"7分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0023216"},{"key":"类型","value":"喜剧 / 短片 / 家庭"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"Burt Gillett"},{"key":"主演","value":"Walt Disney / Pinto Colvig / Marcellite Garner"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":1,"9":0,"10":0},"score":6.6},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":2,"collect":16,"doing":0},"id":133761,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]