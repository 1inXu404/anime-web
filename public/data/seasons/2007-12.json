g","large":"https://lain.bgm.tv/pic/cover/l/6e/09/6499_iU8tC.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/6e/09/6499_iU8tC.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/6e/09/6499_iU8tC.jpg"},"rating":{"rank":7175,"total":67,"score":5.5,"count":{"1":2,"2":1,"3":2,"4":10,"5":15,"6":25,"7":7,"8":3,"9":1,"10":1}},"tags":[{"name":"OVA","count":29},{"name":"搞笑","count":14},{"name":"若本规夫","count":11},{"name":"性转换","count":7},{"name":"穿越","count":7},{"name":"2007","count":7},{"name":"无节操","count":7},{"name":"三国","count":6},{"name":"补番","count":5},{"name":"变身","count":5},{"name":"森山雄治","count":5}],"eps":4,"collection":{"wish":40,"collect":94,"doing":4,"on_hold":12,"dropped":17}},{"id":70301,"type":2,"name":"戦乙女スヴィア","name_cn":"战乙女苏菲亚","summary":"世界崩壊の危機は迫っていた―――全ての発端は神族ロキの裏切りから始まった。ロキは神族でありながら巨人族と冥府族の手を組ませ、神々が住まう世界アースガルドを侵略を開始、神族は激しく抵抗するもロキのまさに神謀の前に天界の戦士たちは悉く撃破され、ついに世界の主たるオーディンまでも捕らえられてしまう。\r\nしかしオーディンはロキたちに屈する事を拒絶、逆に世界を支える世界樹の水源を封印して世界樹が枯死するよう図る。\r\n曰く、「共に滅びたくなければ我を解放せよ」　捨て身の恫喝であったがオーディンは本気であった。世界樹の枯死は世界の終わりを意味する。窮地に陥ったロキたちであったが、水源を封印している門には封印を解くための鍵があり、そしてその鍵は天界で未だに頑強に抵抗を続ける戦乙女スヴィアとシグルドの清き処女の子宮に封印されている事をつきとめる。\r\n「彼の乙女を穢せば封印が解け子宮から鍵をひり出すとか！」\r\n「我ら彼の乙女に恨みあり！　巨人とその眷属の魔羅が犯しぬいてやろう！」\r\n「いや我らこそ！　冥族の堕落の触手こそが彼の乙女を穢し得よう！」\r\nこうして再びロキの指揮のもと、スヴィアとシグルドを陥れる邪悪なる姦計が、神族の最後の希望、ヴァルキリーの英雄に忍び寄る……！","date":"2007-12-28","images":null,"rating":{"rank":5556,"total":284,"score":6.4,"count":{"1":4,"2":1,"3":5,"4":11,"5":41,"6":99,"7":69,"8":36,"9":10,"10":8}},"tags":[{"name":"里番","count":257},{"name":"凌辱","count":80},{"name":"触手","count":78},{"name":"PIXY","count":70},{"name":"调教","count":57},{"name":"人兽","count":55},{"name":"戦乙女ヴァルキリー","count":51},{"name":"OVA","count":44},{"name":"2007","count":44},{"name":"胁迫","count":28},{"name":"扶她","count":25}],"eps":4,"collection":{"wish":282,"collect":548,"doing":45,"on_hold":47,"dropped":40}},{"id":72915,"type":2,"name":"遙かなる時空の中で3 紅の月","name_cn":"遥远时空中3 红之月","summary":"主人公・春日望美是个普通高中生少女，被选为了「白龙的神子」，经过时空转移来到了正不断扩大中的源平合战的异世界。故事更深入一步，主人公与八叶一一相遇并招揽他们成为同伴。共同战斗，共度难关加深了同伴间的羁绊。但是，在这个战乱的时期也是一种障碍，所想之人无法联结在一起。时而会迎来悲伤的结局……不过，在故事途中主人公会获得穿越时空的力量。回到过去，将悲剧的命运改变，帮助同伴和重要的人。从这里开始，主人公的时空穿越是为了实现恋爱的战斗的真正开始。（","date":"2007-12-28","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/3c/42/72915_R7RdR.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/3c/42/72915_R7RdR.jpg","large":"https://lain.bgm.tv/pic/cover/l/3c/42/72915_R7RdR.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/3c/42/72915_R7RdR.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/3c/42/72915_R7RdR.jpg"},"rating":{"rank":0,"total":37,"score":6,"count":{"1":0,"2":0,"3":1,"4":2,"5":9,"6":13,"7":9,"8":3,"9":0,"10":0}},"tags":[{"name":"乙女向","count":12},{"name":"OVA","count":11},{"name":"2007","count":7},{"name":"石田彰","count":4},{"name":"関智一","count":3},{"name":"乙女动画","count":3},{"name":"三木眞一郎","count":3},{"name":"游戏改","count":2},{"name":"TV","count":2},{"name":"梦太Company","count":2},{"name":"暗荣","count":1}],"eps":1,"collection":{"wish":19,"collect":72,"doing":1,"on_hold":6,"dropped":6}},{"id":812,"type":2,"name":"劇場版 空の境界 第二章 殺人考察(前)","name_cn":"剧场版 空之境界 第二章 杀人考察（前）","summary":"我很想杀了你。\r\n春、发现了身穿和服的你。和你打招呼了。很诧异似的走了。不久之后你与我有了极少的言语交流。但是，你却有谁都不能知道的秘密。\r\n——那是，无法抑制的破坏欲。\r\n这是还在高中生的时候，16岁的两仪式与黑桐干也相逢的故事。\r\n一直都不想和他人扯上任何关系的式吸引了干也的注意，并想和式之间产生某种关联。\r\n当时并未注意到这就是恋情。不久之后他们开始一点点拥有共同的空间，而那时他的日子的确过的十分安稳。\r\n——直到街上出现了连续猎奇的杀人事件。\r\n有一天，干也与一个名叫织的，存在于式身体中另一个人格相遇了。\r\n肯定的式与否定的织。\r\n相反，却拥有同样思考方式与嗜好的两个式，对于干也来说渐渐变的越来越混乱。\r\n如此，在干也的胸中就产生一个预感。\r\n每夜，不断进行着猎奇杀人事件的人是谁？\r\n当然预感只是预感而不是事实，若不是自己亲眼看到其杀人身姿的话是无法相信的，为了确认这个预感，他暗暗的下了决心 —— 当他到达了杀人考察的真相之后,已经是3年后的事情了。\r\n去两仪家获得一些蛛丝马迹的条件、不为人所知的“式们”的关系、在血泊中站立的少女,在不知不觉中第二章的开幕已经开始引导了式与干也命运的轨迹。","date":"2007-12-29","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/81/e7/812_511mm.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/81/e7/812_511mm.jpg","large":"https://lain.bgm.tv/pic/cover/l/81/e7/812_511mm.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/81/e7/812_511mm.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/81/e7/812_511mm.jpg"},"rating":{"rank":459,"total":10074,"score":7.8,"count":{"1":14,"2":4,"3":8,"4":32,"5":141,"6":704,"7":2766,"8":4529,"9":1269,"10":607}},"tags":[{"name":"空之境界","count":2184},{"name":"剧场版","count":2165},{"name":"Type-Moon","count":1980},{"name":"ufotable","count":1419},{"name":"奈须きのこ","count":1152},{"name":"梶浦由紀","count":866},{"name":"2007","count":827},{"name":"两仪式","count":724},{"name":"杀人考察","count":428},{"name":"奇幻","count":353},{"name":"空の境界","count":350}],"eps":1,"collection":{"wish":1039,"collect":16687,"doing":115,"on_hold":119,"dropped":30}},{"id":28604,"type":2,"name":"圣诞映像","name_cn":"","summary":"圣诞映像是电动画2008年出品的一部动画短片，由礼物和黄金岛两个故事组成下面是介绍。\r\n\r\n世界不会因为圣诞变美好，但圣诞毕竟是圣诞。\r\n两个恰巧发生在圣诞的故事。电动画十五个孩子的胡思乱想。\r\n\r\n圣诞映像01 礼物\r\n作品说明: 红衣红帽子的不一定是圣诞老人；\r\n希望你快乐的一定不止圣诞老人；\r\n2008年，电动画TINKID的首次亮相——圣诞映像会，\r\n祝所有好孩子新年快乐。 \r\n\r\n圣诞映像02 黄金岛\r\n作品说明: 杀手在圣诞夜完成了最后一次任务，他得到了足以改变后半生的巨额酬劳。当他背向追捕的警察，迈出逃生的最后一步时，枪声与圣诞的钟声同时响起…\r\n圣诞不是每个人的礼物，但圣诞毕竟是圣诞。\r\n2008年，电动画TINKID的《圣诞映像》第二弹--黄金岛，\r\n祝所有好孩子和坏孩子，都成为幸福的孩子 ","date":"2007-12-29","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/9e/4c/28604_3JenX.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/9e/4c/28604_3JenX.jpg","large":"https://lain.bgm.tv/pic/cover/l/9e/4c/28604_3JenX.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/9e/4c/28604_3JenX.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/9e/4c/28604_3JenX.jpg"},"rating":{"rank":0,"total":9,"score":6.2,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":4,"7":2,"8":1,"9":0,"10":0}},"tags":[{"name":"短片","count":9},{"name":"国产","count":7},{"name":"WEB","count":4},{"name":"电动画","count":4},{"name":"2007","count":2},{"name":"中国","count":2},{"name":"原创","count":1},{"name":"动画","count":1}],"eps":2,"collection":{"wish":10,"collect":16,"doing":0,"on_hold":0,"dropped":2}},{"id":171423,"type":2,"name":"星の記憶","name_cn":"星之记忆","summary":"2007年冬開催のコミックマーケット73にて販売された。\r\n月と幻想郷を舞台としたSF作品である。\r\n\r\n同人作品にも関わらず、榊原ゆい、植田佳奈などの有名声優の起用で話題となった。また、SOUND HOLIC内でも活動していた歌手の高橋菜々としほり(Shihori)も本作で声優に挑戦している。\r\n\r\nルナ・マリウス役の園部好徳は、作中での他すべての男性キャストを担当している。前述した有名声優に隠れている印象こそあるものの、彼もまたポケットモンスター各シリーズや鋼の錬金術師などのアニメ、また多数の洋画の吹き替え等に出演歴があるベテラン声優であり、同人アニメでの起用は異例である。\r\n星の記憶の作中冒頭ではルナ幹部達による軍の会議のシーンがある。園部好徳によって一人四役が演じ分けられており、プロの声優の実力を垣間見る事ができる。\r\n\r\nまた当時まだデビューして間もなかった声優の原田ひとみが出演していた。","date":"2007-12-29","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/00/f3/171423_qgnrq.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/00/f3/171423_qgnrq.jpg","large":"https://lain.bgm.tv/pic/cover/l/00/f3/171423_qgnrq.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/00/f3/171423_qgnrq.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/00/f3/171423_qgnrq.jpg"},"rating":{"rank":0,"total":11,"score":6.1,"count":{"1":0,"2":0,"3":1,"4":1,"5":2,"6":3,"7":2,"8":1,"9":0,"10":1}},"tags":[{"name":"同人","count":4},{"name":"2007","count":4},{"name":"东方","count":4},{"name":"日本动画","count":1},{"name":"短片","count":1},{"name":"クッキー☆","count":1},{"name":"东方project","count":1},{"name":"2007年","count":1},{"name":"2007年十月番","count":1}],"eps":1,"collection":{"wish":15,"collect":20,"doing":0,"on_hold":1,"dropped":3}},{"id":88564,"type":2,"name":"第2回東方M-1ぐらんぷり","name_cn":"第二届东方M-1漫才大赛","summary":"","date":"2007-12-31","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/b4/d1/88564_I6AEE.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/b4/d1/88564_I6AEE.jpg","large":"https://lain.bgm.tv/pic/cover/l/b4/d1/88564_I6AEE.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b4/d1/88564_I6AEE.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b4/d1/88564_I6AEE.jpg"},"rating":{"rank":1603,"total":155,"score":7.3,"count":{"1":0,"2":0,"3":1,"4":4,"5":5,"6":13,"7":61,"8":59,"9":8,"10":4}},"tags":[{"name":"同人","count":42},{"name":"東方M-1","count":36},{"name":"东方","count":34},{"name":"東方Project","count":27},{"name":"2007","count":21},{"name":"搞笑","count":14},{"name":"东方漫才","count":14},{"name":"OVA","count":12},{"name":"东方project","count":7},{"name":"漫才","count":6},{"name":"M-1","count":6}],"eps":1,"collec