[{"id":113127,"type":2,"name":"西遊記","name_cn":"西游记","summary":"　　本片改编自手冢治虫的漫画《我的孙悟空》。影片讲述了孙悟空从花果山石猴成长为三藏法师仆从，从石中诞生后成为猴王，后因大闹天宫被压五行山，经点化随三藏法师西天取经。途中，孙悟空与猪八戒、沙悟净结识，共同克服艰险，最终抵达天地取得经文。","date":"1960-08-14","images":null,"rating":{"rank":0,"total":43,"score":5.5,"count":{"1":1,"2":0,"3":4,"4":3,"5":9,"6":18,"7":6,"8":1,"9":1,"10":0}},"tags":[{"name":"剧场版","count":30},{"name":"1960","count":23},{"name":"手塚治虫","count":20},{"name":"东映","count":13},{"name":"小说改","count":10},{"name":"白川大作","count":8},{"name":"西游记","count":7},{"name":"藪下泰司","count":7},{"name":"东映动画","count":5},{"name":"東映アニメーション","count":3},{"name":"日本动画","count":3}],"eps":1,"collection":{"wish":31,"collect":75,"doing":3,"on_hold":2,"dropped":9}}]