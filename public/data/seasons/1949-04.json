[{"date":"1949-04-30","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f8/cc/132376_2ILoM.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f8/cc/132376_2ILoM.jpg","large":"https://lain.bgm.tv/pic/cover/l/f8/cc/132376_2ILoM.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f8/cc/132376_2ILoM.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f8/cc/132376_2ILoM.jpg"},"summary":"　　老鼠之家将小尼皮送到杰瑞这里过感恩节，小尼皮似乎永远处在饥饿的状态，而杰瑞的窝里空空如也，没有任何可以果腹的东西。走投无路的杰瑞铤而走险，带着小尼皮去喝汤姆盘子里的奶。汤姆醒来，将奶一饮而尽，两个小家伙还得继续挨饿。 \r\n　　幸运的是，家中的女仆为感恩节准备了丰富的晚餐，杰瑞又打起了晚餐的主意。不过狡猾嘴馋的汤姆怎可能视而不见？他一面干扰杰瑞和小尼皮的行动，一面偷刮油水，双方必然爆发一场大战…… \r\n　　本片荣获1949年奥斯卡最佳动画短片奖。","name":"The Little Orphan","name_cn":"小孤儿","tags":[{"name":"短片","count":61,"total_cont":0},{"name":"欧美","count":36,"total_cont":0},{"name":"猫和老鼠","count":33,"total_cont":0},{"name":"美国","count":18,"total_cont":0},{"name":"米高梅","count":17,"total_cont":0},{"name":"1949","count":16,"total_cont":0},{"name":"奥斯卡","count":16,"total_cont":0},{"name":"搞笑","count":12,"total_cont":0},{"name":"欢乐","count":10,"total_cont":0},{"name":"1940s","count":8,"total_cont":0},{"name":"原创","count":6,"total_cont":0},{"name":"猫","count":5,"total_cont":0},{"name":"MGM","count":4,"total_cont":0},{"name":"子供向","count":4,"total_cont":0},{"name":"短片&OVA","count":2,"total_cont":0},{"name":"1940-1949","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"7(+2)","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"Nibble","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"TV","count":1,"total_cont":0},{"name":"Tom&Jerry","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"经典","count":1,"total_cont":0},{"name":"Hanna","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"Barbera","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"奥斯卡获奖动画短片","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"小孤儿"},{"key":"上映年度","value":"194