[{"date":"1968-02-18","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0f/f9/137116_rdUf8.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0f/f9/137116_rdUf8.jpg","large":"https://lain.bgm.tv/pic/cover/l/0f/f9/137116_rdUf8.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0f/f9/137116_rdUf8.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0f/f9/137116_rdUf8.jpg"},"summary":"　　人的一生，快乐总是非常有时，不过几个阶段，大部分的时间段，生活就像罐头一样被固定了模式。 \r\n　　细数快乐的阶段，人在做孩童时拥有幻梦是之一，然而孩童是不可能长久地停留在幻梦中的，家长的声音压迫着让他只能在学校和家之间两点一线往返。青年时期，恋爱是快乐的，但到了谈婚论嫁时，模式便会不请自来。孩子的诞生也是快乐的，但无趣的生活不会因此变得有趣，人往往会用婚外情妄图将这无趣填补，却往往为了孩子又过两点一线的生活。","name":"Una vita in scatola","name_cn":"罐头人生","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"意大利","count":3,"total_cont":0},{"name":"1968","count":2,"total_cont":0},{"name":"60s","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"Bruno_Bozzetto","count":1,"total_cont":0},{"name":"Bozzetto","count":1,"total_cont":0},{"name":"欧洲","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"罐头人生"},{"key":"别名","value":[{"v":"A Life in a Tin"}]},{"key":"上映年度","value":"1968-02-18"},{"key":"片长","value":"6:30"},{"key":"制片国家/地区","value":"意大利"},{"key":"语言","value":"意大利语"},{"key":"导演","value":"Bruno Bozzetto"},{"key":"编剧","value":"Bruno Bozzetto"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":3,"count":{"1":1,"2":0,"3":0,"4":0,"5":0,"6":1,"7":1,"8":0,"9":0,"10":0},"score":4.7},"total_episodes":0,"collection":{"on_hold":0,"dropped":3,"wish":4,"collect":9,"doing":1},"id":137116,"eps":1,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1968-02-14","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/70/01/523049_9BDdz.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/70/01/523049_9BDdz.jpg","large":"https://lain.bgm.tv/pic/cover/l/70/01/523049_9BDdz.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/70/01/523049_9BDdz.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/7