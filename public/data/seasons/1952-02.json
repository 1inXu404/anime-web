[{"date":"1952-02-16","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/97/bb/634589_jp4M0.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/97/bb/634589_jp4M0.jpg","large":"https://lain.bgm.tv/pic/cover/l/97/bb/634589_jp4M0.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/97/bb/634589_jp4M0.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/97/bb/634589_jp4M0.jpg"},"summary":"　　春去秋来，北雁南飞，萧瑟的季节又孕育着新的希望。野鸭家族也列队向着温暖的南方前进，在队伍的末尾，一只破壳未久的小野鸭努力扇动着翅膀，紧紧跟随在家人和朋友的身后。突然，他们的下方传来阵阵刺耳的枪声，贪婪的汤姆躲在草丛中向天鸣枪，准备打下野鸭来打打牙祭。结果有一枪打中了小野鸭的翅膀，他虽然还向跟着伙伴，可是最终无奈地跌落下来。他缓缓地落在了农场内的大树旁，小老鼠杰瑞听见动静从洞里走出来，杰瑞看见汤姆正狂奔过来，于是连忙将小野鸭推进了洞里，并为他悉心治疗。\r\n　　可是这只小鸭子太过焦急，而且也不吸取教训，伤还没好就非冲出去追赶同伴，结果三番五次落入汤姆的圈套……","name":"The Duck Doctor","name_cn":"医治小鸭","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"1950-1959","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"医治小鸭"},{"key":"上映年度","value":"1952年2月16日"},{"key":"片长","value":"7分钟"},{"key":"导演","value":"Joseph Barbera,William Hanna"},{"key":"IMDb","value":"tt0044571"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":0,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634589,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1952-02-09","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/88/a5/280544_oB7d7.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/88/a5/280544_oB7d7.jpg","large":"https://lain.bgm.tv/pic/cover/l/88/a5/280544_oB7d7.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/88/a5/280544_oB7d7.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/88/a5/280544_oB7d7.jpg"},"summary":"","name":"Magical Maestro","name_cn":"魔术大师","tags":[{"name":"短片","count":9,"total_cont":0},{"name