[{"date":"1988-05-27","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/82/fe/46955_MZkFr.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/82/fe/46955_MZkFr.jpg","large":"https://lain.bgm.tv/pic/cover/l/82/fe/46955_MZkFr.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/82/fe/46955_MZkFr.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/82/fe/46955_MZkFr.jpg"},"summary":"　　在某个名为NP的城市，警察厅遭投诉最多的是战车队，尤其是其中一辆名为“布拿巴力”的特别战车。“布拿巴力”是为了适应城市作战的特殊需要而制造的坦克，体积超小，甚至可以通过窄小的门驶入建筑物内，动作机动灵活，同时装备完备，配有能发射穿甲弹的主炮、速射机枪、烟雾弹、催泪弹、AA GUN make by whyarmy以及一些不知名的东西，连钩状履带都是特制的（用来破坏路面吗？）。操作这辆坦克的是被称为警署的炸弹组合的本作主人公莉安娜和亚路，面对罪犯，他们总是能够机敏勇敢地将其捕获，不过总是会对环境造成巨大的破坏（怪不得会有这么多投诉）。 ","name":"ドミニオン","name_cn":"特搜战车队","tags":[{"name":"OVA","count":35,"total_cont":0},{"name":"1988","count":18,"total_cont":0},{"name":"漫画改","count":17,"total_cont":0},{"name":"J.C.STAFF","count":17,"total_cont":0},{"name":"士郎正宗","count":12,"total_cont":0},{"name":"科幻","count":12,"total_cont":0},{"name":"真下耕一","count":10,"total_cont":0},{"name":"独立ova","count":7,"total_cont":0},{"name":"漫改","count":3,"total_cont":0},{"name":"80年代","count":3,"total_cont":0},{"name":"机战","count":3,"total_cont":0},{"name":"搞笑","count":3,"total_cont":0},{"name":"85-89","count":2,"total_cont":0},{"name":"石山贵明","count":2,"total_cont":0},{"name":"石山タカ明","count":2,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"待補0","count":1,"total_cont":0},{"name":"1988年","count":1,"total_cont":0},{"name":"其他","count":1,"total_cont":0},{"name":"6","count":1,"total_cont":0},{"name":"看完就删","count":1,"total_cont":0},{"name":"エイジェント21","count":1,"total_cont":0},{"name":"1980s","count":1,"total_cont":0},{"name":"2022","count":1,"total_cont":0},{"name":"鶴ひろみ","count":1,"total_cont":0},{"name":"SF","count":1,"total_cont":0},{"name":"1984-1988","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"特搜战车队"},{"key":"别名","value":[{"v":"特搜机动队"},{"v":"Dominion"}]},{"key":"话数","value":"4"},{"key