[{"name":"BONES","count":138},{"name":"OVA","count":122},{"name":"菅野洋子","count":71},{"name":"2004","count":68},{"name":"原创","count":60},{"name":"冈村天斋","count":41},{"name":"狼雨","count":23},{"name":"信本敬子","count":17},{"name":"全灭","count":11},{"name":"宫野真守","count":11},{"name":"奇幻","count":10}],"eps":4,"collection":{"wish":333,"collect":395,"doing":11,"on_hold":27,"dropped":13}},{"id":16221,"type":2,"name":"天罰エンジェルラビィ☆","name_cn":"天罚-天使拉比","summary":"这是工画堂游戏的OVA作品。\r\n以工画堂KOGADO出品的一部游戏<天使小夜曲>Angelic Serenade(AS)的人设作为基本模型，但是剧情却大有转变，主要讲述的是在<天使小夜曲>中几个主要人物通过不同的方式进行战斗，消灭地面上的不安因素，为饱经苦难的人们带去幸福与快乐。由于她们是以天界—类似于太空站的地方作为基地，所以她们被称为天使。\r\n\r\nOVA作只是表现了部分剧情：\r\n拉诗蒂=法森，代号：天使拉比，是第二十七代天使。因为真正的魔力被封印，所以16岁的年龄实际看上去只有12岁。天使拉比被派往地球帮助地球人解决困难。到了地球以后，她发现了恶势力的传教组织「阿特路易」在压迫村民，另外还有很久以前的「大魔法战争」后留下的怪兽武器。为了和他们做斗争，拉比请求上级解开了封印，打败了敌人，拯救了村民。\r\n\r\n部分背景和设定：\r\n时间是在遥远的未来。\r\n由于科学和魔法的融合，给人类生活带来了很大的改革。\r\n月面上建造了集结魔法科学的菁华之「魔法都市soisariamu」，在那里进行着日复一日从不间断的研究，而研究的成果带给人们莫大的财富。但是那个荣华的时代在权利的争夺下，地球和月面间发生了「大魔法战争」毁灭了一切，地球，灭亡了。  \r\n在地球上幸存的人类花费了数千年的时间，建立起新的文明。但是，在DNA攻击和元素变换等等被禁止的武器都使用的「大魔法战争」所造成的损害仍处处可见，威胁人类生存的各式各样异变（巨大生物、妖怪、暴走机械、兵器等）也都还仍然存留在世界上，残存至现今的人们在没有科学﹑魔法的庇护下，只能胆颤心惊的生存着、祈求着这些威胁的离开。\r\n但是，面对这些胁威，有着不怯惧而勇于面对的存在：「天界」的「天使」们。","date":"2004-01-23","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/02/fc/16221_56QqT.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/02/fc/16221_56QqT.jpg","large":"https://lain.bgm.tv/pic/cover/l/02/fc/16221_56QqT.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/02/fc/16221_56QqT.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/02/fc/16221_56QqT.jpg"},"rating":{"rank":0,"total":38,"score":5,"count":{"1":1,"2":1,"3":2,"4":12,"5":12,"6":5,"7":1,"8":2,"9":1,"10":1}},"tags":[{"name":"OVA","count":20},{"name":"2004","count":13},{"name":"AIC","count":10},{"name":"石平信司","count":7},{"name":"游戏改","count":5},{"name":"独立ova","count":5},{"name":"山田光洋","count":4},{"name":"飯塚雅弓","count":3},{"name":"战斗","count":2},{"name":"野中藍","count":1},{"name":"游戏","count":1}],"eps":1,"collection":{"