[{"date":"1943-12-25","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/2b/d7/262699_rk0CR.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/2b/d7/262699_rk0CR.jpg","large":"https://lain.bgm.tv/pic/cover/l/2b/d7/262699_rk0CR.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/2b/d7/262699_rk0CR.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/2b/d7/262699_rk0CR.jpg"},"summary":"　　在玩具随意摆放的房间里，小女孩南希正大声斥责躲在角落里的汤姆，她把汤姆当作一个不听话的小娃娃，甚至还把他抓出来包上尿布塞到婴儿床内。面对这个专横跋扈的小主人，平时耀武扬威的汤姆也没了脾气，只得任由南希摆布。突然，他发现南希塞过来的奶瓶里的奶水分外好喝，于是这个馋嘴的家伙干脆卖乖装起婴儿，大喝奶水，还摆出各种幼稚的动作。这一切都被小老鼠杰瑞看在眼里，他大声嘲笑汤姆，并模仿他的动作，惹得汤姆恼羞成怒。一场猫鼠大战就这样爆发了…… \r\n　　本片是动画人Ray Patterson从迪斯尼过档华纳后参与制作的首部Tom & Jerry系列动画片。","name":"Baby Puss","name_cn":"宝贝猫","tags":[{"name":"短片","count":19,"total_cont":0},{"name":"猫和老鼠","count":8,"total_cont":0},{"name":"欧美","count":7,"total_cont":0},{"name":"1943","count":5,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"60年代前","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"米高梅","count":2,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"先驱","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"童年回忆","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"宝贝猫"},{"key":"上映年度","value":"1943-12-25"},{"key":"片长","value":"7分40秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":38,"count":{"1":0,"2":0,"3":2,"4":2,"5":9,"6":12,"7":8,"8":5,"9":0,"10":0},"score":6},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":3,"collect":80,"doing":1},"id":262699,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]