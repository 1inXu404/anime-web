grid":"https://lain.bgm.tv/r/100/pic/cover/l/f8/62/53736_rEjMy.jpg","large":"https://lain.bgm.tv/pic/cover/l/f8/62/53736_rEjMy.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f8/62/53736_rEjMy.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f8/62/53736_rEjMy.jpg"},"summary":"　江戸城本丸は南野小学校に通う5年生の男の子。勉強もスポーツもパッとしないが、同級生の美少女・河合伊代菜に密かに想いを寄せている。ある日、クラスの席替えで乱暴者のじゃば夫の隣になって、本丸はすっかり困ってしまう。すると、絵本作家の父から借りていた魔法の本が反応し、中から不思議な男の子が飛び出してきた！「たるる～♪　我こそは大魔法使いタルるート様だあ～！」そのタルるートくんは、本丸の願いごとを叶えてくれるという。半信半疑の本丸は、こんな願いごとをする。「ぼくの友だちになってください！」こうして友だちになった二人は、学校で街でご近所で、摩訶不思議な大騒ぎを次々と巻き起こしてゆく。どんな騒ぎかって？それは見てのお楽しみ。","name":"まじかる☆タルるートくん","name_cn":"幻法小魔星","tags":[{"name":"1990","count":6,"total_cont":0},{"name":"漫画改","count":3,"total_cont":0},{"name":"TV","count":3,"total_cont":0},{"name":"山内重保","count":2,"total_cont":0},{"name":"東映アニメーション","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"菅良幸","count":1,"total_cont":0},{"name":"动","count":1,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"90s","count":1,"total_cont":0},{"name":"经典","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"优秀子供向","count":1,"total_cont":0},{"name":"东映","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"东映动画","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"幻法小魔星"},{"key":"别名","value":[{"v":"小魔星"}]},{"key":"话数","value":"87"},{"key":"放送开始","value":"1990年9月2日"},{"key":"播放结束","value":"1992年5月10日"},{"key":"音乐","value":"横山菁児"},{"key":"原作","value":"江川達也"},{"key":"系列构成","value":"菅良幸"},{"key":"人物设定","value":"大倉雅彦"},{"key":"美术设计","value":"浦田又治"},{"key":"製作担当","value":"横井三郎、藤本芳弘"},{"key":"制作","value":"ABC・ASATSU・東映動画"},{"key":"制片人","value":"平尾知也(ABC) 、佐川祐子(ASATSU) 、旗野義文、関弘美"},{"key":"系列监督","value":"山内重保"}],"rating":{"rank":0,"total":7,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":4,"7":1,"8":1,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"