lain.bgm.tv/r/100/pic/cover/l/02/e6/2215_9Gfbo.jpg","large":"https://lain.bgm.tv/pic/cover/l/02/e6/2215_9Gfbo.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/02/e6/2215_9Gfbo.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/02/e6/2215_9Gfbo.jpg"},"summary":"来克在玩魔方的时候，魔方突然变大了。好奇的来克进入到魔方世界里。原来魔方大厦是由二十六个“方国”组成的，有装在罐头里的家长、玻璃国、火车国和星座号油轮等等非常有趣的国家。来克在这些国家里开始了一系列神奇的历险。\r\n该影片第1集《玻璃城》、第2集《装在罐头里的爸爸妈妈》、第3集《神奇的日历》获第二届中国影视动画展播二等奖，第八集《头盔城》获1993年广播电影电视部优秀影片奖和第十四届中国电影“金鸡奖”提名。\r\n《魔方大厦》原计划拍成26集，由于专业人才流失，资金匮乏，拍至10集暂告一段落。","name":"魔方大厦","name_cn":"魔方大厦","tags":[{"name":"国产","count":312,"total_cont":0},{"name":"郑渊洁","count":286,"total_cont":0},{"name":"童年","count":207,"total_cont":0},{"name":"魔方大厦","count":174,"total_cont":0},{"name":"猎奇","count":169,"total_cont":0},{"name":"上海美术电影制片厂","count":126,"total_cont":0},{"name":"恐怖","count":86,"total_cont":0},{"name":"TV","count":82,"total_cont":0},{"name":"内涵","count":76,"total_cont":0},{"name":"1990","count":61,"total_cont":0},{"name":"童话","count":40,"total_cont":0},{"name":"80后","count":29,"total_cont":0},{"name":"cult","count":19,"total_cont":0},{"name":"90年代","count":17,"total_cont":0},{"name":"中国","count":17,"total_cont":0},{"name":"本土动画","count":13,"total_cont":0},{"name":"小说改","count":13,"total_cont":0},{"name":"动画","count":6,"total_cont":0},{"name":"1999","count":5,"total_cont":0},{"name":"国产动画","count":4,"total_cont":0},{"name":"上美","count":4,"total_cont":0},{"name":"奇幻","count":4,"total_cont":0},{"name":"童年阴影","count":4,"total_cont":0},{"name":"1990年9月","count":3,"total_cont":0},{"name":"1990年","count":3,"total_cont":0},{"name":"1990s","count":3,"total_cont":0},{"name":"顾汉昌","count":3,"total_cont":0},{"name":"补完","count":2,"total_cont":0},{"name":"童年的经典","count":2,"total_cont":0},{"name":"原创","count":2,"total_cont":0}],"infobox":[{"key":"中文名","value":"魔方大厦"},{"key":"别名","value":[{"v":"ルービック・キューブ"}]},{"key":"话数","value":"10"},{"key":"放送开始","value":"1990年9月"},{"key":"播放结束","value":"1994年10月"},{"key":"导演","value":"查侃"},{"key"