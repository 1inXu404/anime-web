[{"id":119279,"type":2,"name":"Go! プリンセスプリキュア","name_cn":"Go! Princess 光之美少女","summary":"梦想是成为公主的春野遥，于新的学期正式成为寄宿学校贵族学园的初中一年级生，准备展开期待已久的新生活。就在此时，她目睹邪恶势力把人通往梦想的“门”紧密封闭，并染上浓厚的绝望。然后在机缘巧合之下，她集齐了希望王国彼方王子誓死守护的公主香水及装扮锁匙，变身成为光之美少女——花神天使，开始奋勇对抗敌人。","date":"2015-02-01","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f5/72/119279_5v8yG.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f5/72/119279_5v8yG.jpg","large":"https://lain.bgm.tv/pic/cover/l/f5/72/119279_5v8yG.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f5/72/119279_5v8yG.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f5/72/119279_5v8yG.jpg"},"rating":{"rank":439,"total":646,"score":7.8,"count":{"1":6,"2":1,"3":0,"4":4,"5":11,"6":41,"7":142,"8":277,"9":120,"10":44}},"tags":[{"name":"光之美少女","count":261},{"name":"TV","count":196},{"name":"2015","count":155},{"name":"原创","count":137},{"name":"東映アニメーション","count":133},{"name":"东映","count":104},{"name":"公主Q娃","count":79},{"name":"プリキュア","count":66},{"name":"百合","count":53},{"name":"田中裕太","count":44},{"name":"2015年1月","count":37}],"eps":50,"collection":{"wish":559,"collect":930,"doing":192,"on_hold":106,"dropped":76}},{"id":555563,"type":2,"name":"兔子帮之勇闯螃蟹岛","name_cn":"兔子帮之勇闯螃蟹岛","summary":"本季讲述了兔子帮为了寻找在第一季中失踪的大中爸爸，和小中一起来到了螃蟹岛，在岛上他们遇见了被贪狼星君改造了的兔子们。 这些兔子分为两派，一派是以蟹枝为首的囚徒“蟹枝帮”，另一派是守岛上尉鸥枝和鲨枝。故事围绕逃离螃蟹岛而展开，在此期间兔子帮还要肩负化解“蟹枝帮”与“兔子帮”父辈之间的恩怨，使得岛上的改造兔们能够真正脱离贪狼星君的控制，得到自由。","date":"2015-02-04","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/5d/c8/555563_5z70r.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/5d/c8/555563_5z70r.jpg","large":"https://lain.bgm.tv/pic/cover/l/5d/c8/555563_5z70r.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/5d/c8/555563_5z70r.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/5d/c8/555563_5z70r.jpg"},"rating":{"rank":0,"total":4,"score":5.5,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":3,"7":0,"8":0,"9":0,"10":0}},"tags":[{"name":"TV","count":2},{"name":"国产","count":2},{"name":"中国","count":2}],"eps":26,"collection":{"wish