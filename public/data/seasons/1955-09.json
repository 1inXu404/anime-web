[{"date":"1955-09-17","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f4/b8/132386_22v2r.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f4/b8/132386_22v2r.jpg","large":"https://lain.bgm.tv/pic/cover/l/f4/b8/132386_22v2r.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f4/b8/132386_22v2r.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f4/b8/132386_22v2r.jpg"},"summary":"　　墨西哥边境线上，一群面黄肌瘦的小老鼠对着不远处的奶酪工厂望眼欲穿，然而他们却无法靠近，因为邪恶的希尔维斯特猫（Mel Blanc 配音）守在必经之路上。墨西哥鼠派出的敢死队接连遭受失败，万般无奈下，只得求助素有飞毛腿之称的冈萨雷斯（Mel Blanc 配音）。 \r\n　　冈萨雷斯欣然同意，来到边境线上，与希尔维斯特展开一场精彩刺激的奶酪攻防战，最终大获全胜。 \r\n　　本片荣获1956年奥斯卡最佳动画短片奖。","name":"Speedy Gonzales","name_cn":"飞毛腿冈萨雷斯","tags":[{"name":"短片","count":18,"total_cont":0},{"name":"欧美","count":8,"total_cont":0},{"name":"奥斯卡","count":7,"total_cont":0},{"name":"1955","count":5,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"W·B","count":3,"total_cont":0},{"name":"欢乐","count":2,"total_cont":0},{"name":"跑来跑去","count":2,"total_cont":0},{"name":"大笨猫","count":2,"total_cont":0},{"name":"华纳","count":2,"total_cont":0},{"name":"FrizFreleng","count":1,"total_cont":0},{"name":"Oscars","count":1,"total_cont":0},{"name":"WarrenFoster","count":1,"total_cont":0},{"name":"子供向","count":1,"total_cont":0},{"name":"短片&OVA","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"墨西哥","count":1,"total_cont":0},{"name":"1950-1959","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"WarnerBros.Animation","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"1950s","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"飞毛腿冈萨雷斯"},{"key":"上映年度","value":"1955-09-17"},{"key":"片长","value":"7 分钟"},{"key":"IMDb链接","value":"tt0048649"},{"key":"语言","value":"英语 / 西班牙语"},{"key":"制片国家/地区","value":"美国"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 家庭"},{"key":"导演","value":"弗里兹 弗里伦 (Friz Freleng)"},{"key":"编剧","value":"Warren Foster"},{"key":"话数","value":"