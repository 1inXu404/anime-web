[{"date":"1975-09-06","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/84/1a/533981_7DVPT.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/84/1a/533981_7DVPT.jpg","large":"https://lain.bgm.tv/pic/cover/l/84/1a/533981_7DVPT.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/84/1a/533981_7DVPT.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/84/1a/533981_7DVPT.jpg"},"summary":"　　Return to the Planet of the Apes is a short-lived animated series, by DePatie-Freleng Enterprises in association with 20th Century Fox Television, based upon Planet of the Apes by Pierre Boulle. Boulle's novel had previously been adapted in a series of movies, beginning with the 1968 Planet of the Apes starring Charlton Heston. Unlike the film, its sequels, and the 1974 live-action television series, which involved a primitive ape civilization, Return to the Planet of the Apes depicted a technologically advanced society, complete with automobiles, film, and television; as such it more closely resembled both Boulle's original novel and early concepts for the first Apes movie which were changed due to budgetary limitations in the late 1960s.","name":"Return to the Planet of the Apes","name_cn":"重返人猿星球","tags":[{"name":"美国","count":1,"total_cont":0},{"name":"小说改","count":1,"total_cont":0},{"name":"冒险","count":1,"total_cont":0},{"name":"TV","count":1,"total_cont":0},{"name":"科幻","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"重返人猿星球"},{"key":"话数","value":"13"},{"key":"放送开始","value":"1975年9月6日"},{"key":"播放电视台","value":"NBC"},{"key":"播放结束","value":"1975年11月29日"},{"key":"音乐","value":"Dean Elliott"},{"key":"原作","value":"Pierre Boulle"},{"key":"企画","value":"David H. DePatie、Friz Freleng"},{"key":"动画制作","value":"DePatie–Freleng Enterprises"},{"key":"製作","value":"DePatie–Freleng Enterprises、20th Century Fox Television"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":1,"dropped":1,"wish":2,"collect":1,"doing":0},"id":533981,"eps":13,"meta_tags":["科幻","TV","冒险","小说改","美国"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1975-09-06","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/43/0f/278571_3w568.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/43/0f/278571_3w568.jpg","large":"https://lain.bgm.tv/pic/cover/l/43/0f/278571_3w568.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/43/0f/278571_3w568.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/43/0f/278571_3w568.jpg"},"summary":"Here, in a much toned down, non-violent, Yogi Bear and Boo Boo-esque format, the long-popular Tom and Jerry, after years of fighting, have finally become the best of friends in episodes wherein they roamed the world competing in sports, enduring on-the-job misadventures, running afoul of dastardly villains, solving mysteries and helping others. Some of the time, they are pretty competitive against each other. Quacker appears only once in this series, with Don Messick voicing the duckling. The characters Toodles Galore, Butch, Lightning, Topsy, Meathead, Tyke, Tuffy, Mammy Two Shoes, Joan and George do not appear in this show. Also, Jerry wears a red bow tie in the series.","name":"The Tom and Jerry Show","name_cn":"新版猫和老鼠","tags":[{"name":"TV","count":13,"total_cont":0},{"name":"童年","count":9,"total_cont":0},{"name":"1975","count":8,"total_cont":0},{"name":"欧美","count":8,"total_cont":0},{"name":"搞笑","count":6,"total_cont":0},{"name":"Animation","count":2,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"剧集","count":1,"total_cont":0},{"name":"1975年","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"新版猫和老鼠"},{"key":"别名","value":[{"v":"The Tom and Jerry Show (1975)"},{"v":"The New Tom & Jerry Show"},{"v":"The New Tom and Jerry Show"}]},{"key":"话