pic/cover/l/08/0a/5229_YfvuJ.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/08/0a/5229_YfvuJ.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/08/0a/5229_YfvuJ.jpg"},"rating":{"rank":0,"total":35,"score":6.5,"count":{"1":0,"2":0,"3":0,"4":0,"5":7,"6":10,"7":12,"8":6,"9":0,"10":0}},"tags":[{"name":"剧场版","count":15},{"name":"2005","count":8},{"name":"XEBEC","count":6},{"name":"洛克人","count":6},{"name":"EXE","count":4},{"name":"Forte","count":2},{"name":"好基友","count":2},{"name":"加戸誉夫","count":1},{"name":"子供向","count":1},{"name":"优秀子供向","count":1},{"name":"热血","count":1}],"eps":1,"collection":{"wish":17,"collect":55,"doing":1,"on_hold":3,"dropped":6}},{"id":396902,"type":2,"name":"劇場版デュエル・マスターズ 闇の城の魔龍凰","name_cn":"剧场版 决斗大师 黑暗之城的魔龙凰","summary":"暗黒の闇の力に覆われたヤーク島。そこでデュエルを行うと、召還したクリーチャーが実体化する。島のハデス城に住む、謎のデュエリスト・オルフェと姉のエレクトラは、恐るべき計画を実行するためにデュエル大会を開催した。\r\n日本一のデュエリスト・切札勝舞（きりふだしょうぶ）をはじめ、強いデュエリストたちがヤーク島のデュエル大会に集結。そこでエレクトラから、この大会の真の目的が明らかにされた。それは、負けたデュエリストからパワーを吸い取り、不滅の肉体を持つクリーチャー・神滅竜騎（しんめつりゅうき）ガルザークを解放すること。そして、世界を闇に包み込み、人類を滅亡させる…。世界を闇から守るために、勝舞はオルフェとの危険なデュエルへ挑む!!","date":"2005-03-12","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ed/17/396902_ZtsvI.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ed/17/396902_ZtsvI.jpg","large":"https://lain.bgm.tv/pic/cover/l/ed/17/396902_ZtsvI.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ed/17/396902_ZtsvI.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ed/17/396902_ZtsvI.jpg"},"rating":{"rank":0,"total":2,"score":4,"count":{"1":0,"2":0,"3":0,"4":2,"5":0,"6":0,"7":0,"8":0,"9":0,"10":0}},"tags":[{"name":"剧场版","count":1},{"name":"2005","count":1},{"name":"空","count":1},{"name":"A･C･G･T","count":1}],"eps":0,"collection":{"wish":2,"collect":6,"doing":1,"on_hold":0,"dropped":2}},{"id":411213,"type":2,"name":"TrashBox","name_cn":"","summary":"","date":"2005-03-13","images":null,"rating":{"rank":0,"total":2,"score":2,"count":{"1":0,"2":2,"3":0,"4":0,"5":0,"6":0,"7":0,"8":0,"9":0,"10":0}},"tags":[{"name":"3D里番","count"