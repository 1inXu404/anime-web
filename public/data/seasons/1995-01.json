[{"date":"1995-01-31","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/44/ac/112503_uoyp5.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/44/ac/112503_uoyp5.jpg","large":"https://lain.bgm.tv/pic/cover/l/44/ac/112503_uoyp5.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/44/ac/112503_uoyp5.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/44/ac/112503_uoyp5.jpg"},"summary":"剧情叙述公元994年的苏格兰城堡，有一群帮助人类捍卫城堡的夜行神龙，他们日间为石像、夜间为神龙，由Goliath所领导。但是却因为人类的阴谋，神龙们几乎被摧毁殆尽。仅存的神龙虽然躲过一劫，但却沉睡了千年之久。当他们醒来时发现世界已经变了，他们如今身处在纽约曼哈顿的现代都会，是由百万富翁 Xanatos将整个城堡移建过来，他希望这群神龙能为他所用。但是历经人类背叛险遭灭族的夜行神龙，如今还会再度相信人类吗？","name":"Gargoyles: The Heroes Awaken","name_cn":"夜行神龙电影版","tags":[{"name":"夜行神龙","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"Disney_Television_Animation","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"夜行神龙电影版"},{"key":"别名","value":[{"v":"暗黑之翼：神龙归来"},{"v":"夜行神龙"}]},{"key":"上映年度","value":"1995-01-31"},{"key":"片长","value":"82分钟"},{"key":"话数","value":"1"},{"key":"imdb_id","value":"tt12229416"},{"key":"导演","value":"Saburo Hashimoto, Takamitsu Kawamura, Kazuo Terada"},{"key":"编剧","value":"Eric Luke, Michael Reaves"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":1,"7":1,"8":0,"9":1,"10":0},"score":6.5},"total_episodes":0,"collection":{"on_hold":1,"dropped":6,"wish":3,"collect":8,"doing":1},"id":112503,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1995-01-27","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e7/7d/32493_TJgws.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e7/7d/32493_TJgws.jpg","large":"https://lain.bgm.tv/pic/cover/l/e7/7d/32493_TJgws.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e7/7d/32493_TJgws.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e7/7d/32493_TJgws.jpg"},"summary":"《战ー少女伊库赛利翁》是1995年1月27日发售的OVA作品。全2话。为1993年“冒险!伊库萨3”的续集、并发售同名广播剧CD和小说（角川ス