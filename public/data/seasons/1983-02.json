[{"date":"1983-02-13","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/31/83/40001_b8U33.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/31/83/40001_b8U33.jpg","large":"https://lain.bgm.tv/pic/cover/l/31/83/40001_b8U33.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/31/83/40001_b8U33.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/31/83/40001_b8U33.jpg"},"summary":"阳光明媚的一天，友引市的居民们相继受到婚礼邀请函，但是男女主角令他们大为震惊。女方名叫埃儿，是某星球的女王，男方竟是那个宇宙最大花心男——诸星当。这一消息迅速在友引市流传，拉姆的支持者们对阿当进行严刑逼供，愤怒的拉姆更是大发雷霆，电光四射。殊不知一切源于十数年前，幼稚园时期的阿当游戏中踩到埃尔的影子，按照对方星球的规定，他在将来会成为埃儿星的驸马。为了营建心中理想的庞大后宫，阿当执意前往。而拉姆和她的朋友们也将展开一场夺回阿当的大作战……","name":"うる星やつら オンリー・ユー","name_cn":"福星小子1 爱星球之恋","tags":[{"name":"剧场版","count":97,"total_cont":0},{"name":"押井守","count":92,"total_cont":0},{"name":"1983","count":61,"total_cont":0},{"name":"高桥留美子","count":38,"total_cont":0},{"name":"StudioPierrot","count":38,"total_cont":0},{"name":"福星小子","count":33,"total_cont":0},{"name":"漫画改","count":32,"total_cont":0},{"name":"漫改","count":16,"total_cont":0},{"name":"搞笑","count":13,"total_cont":0},{"name":"高田明美","count":9,"total_cont":0},{"name":"日本","count":9,"total_cont":0},{"name":"金春智子","count":8,"total_cont":0},{"name":"ぴえろ","count":7,"total_cont":0},{"name":"1980s","count":5,"total_cont":0},{"name":"山下将仁","count":4,"total_cont":0},{"name":"电影","count":4,"total_cont":0},{"name":"天野正道","count":3,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"恋爱","count":3,"total_cont":0},{"name":"80年代","count":3,"total_cont":0},{"name":"校园","count":3,"total_cont":0},{"name":"映画","count":3,"total_cont":0},{"name":"安濃高志","count":2,"total_cont":0},{"name":"原创","count":2,"total_cont":0},{"name":"小林泉美","count":2,"total_cont":0},{"name":"上妻晋作","count":2,"total_cont":0},{"name":"小丑社","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"1983年","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0}],"infobox":[{"key":"中文名","value":"福星小子1 爱星球之恋"},{"key":"别名","value":[{"v":"福星小子1 Only You