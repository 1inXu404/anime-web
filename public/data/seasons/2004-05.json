的动画纪录片，同时希望这位落魄大师重新出山。雷恩拒绝了他的请求，3年后雷恩逝世…… \r\n　　本片荣获2005年奥斯卡最佳动画短片奖；2004年戛纳电影节柯达短片奖和青年评论家最佳短片奖；2004年渥太华国际动画片电影节大奖；2004年棕榈泉国际短片电影节评委会最佳动画片奖","name":"Ryan","name_cn":"瑞恩","tags":[{"name":"短片","count":31,"total_cont":0},{"name":"奥斯卡","count":12,"total_cont":0},{"name":"欧美","count":11,"total_cont":0},{"name":"加拿大","count":9,"total_cont":0},{"name":"2004","count":7,"total_cont":0},{"name":"盲人摸象","count":3,"total_cont":0},{"name":"ChrisLandreth","count":3,"total_cont":0},{"name":"短片&OVA","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"3D","count":2,"total_cont":0},{"name":"2000s","count":2,"total_cont":0},{"name":"艺术家可能连正常人都不是","count":2,"total_cont":0},{"name":"2000-2009","count":2,"total_cont":0},{"name":"落魄动画艺术家纪录片","count":2,"total_cont":0},{"name":"艺术家","count":2,"total_cont":0},{"name":"讽刺凡人","count":2,"total_cont":0},{"name":"8(+3)","count":1,"total_cont":0},{"name":"US","count":1,"total_cont":0},{"name":"实拍与3D","count":1,"total_cont":0},{"name":"神","count":1,"total_cont":0},{"name":"暗示了某种缺陷","count":1,"total_cont":0},{"name":"AM","count":1,"total_cont":0},{"name":"破烂人设","count":1,"total_cont":0},{"name":"RyanLarkin","count":1,"total_cont":0},{"name":"艺术片","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"加拿大动画","count":1,"total_cont":0},{"name":"访谈","count":1,"total_cont":0},{"name":"其他","count":1,"total_cont":0},{"name":"平静","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"瑞恩"},{"key":"别名","value":[{"v":"拯救大师雷恩"}]},{"key":"上映年度","value":"2004-05-17 加拿大"},{"key":"片长","value":"Canada: 14 分钟 / Argentina: 14 分钟(Buenos Aires Festival Internacional de Cine Independiente)"},{"key":"官方网站","value":"www.nfb.ca/ryan/"},{"key":"导演","value":"Chris Landreth"},{"key":"主演","value":"Ryan Larkin / Chris Landreth / Felicity Fanjoy / Derek Lamb"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":35,"count":{"1":0,"2":0,"3":2,"4":2,"5":1,"6":9,"7":14,"8":6,"9":1,"10":0},"score":6.5},"total_episodes":0,"collection":{"