[{"date":"1988-04-30","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c5/b2/3621_CrZsC.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c5/b2/3621_CrZsC.jpg","large":"https://lain.bgm.tv/pic/cover/l/c5/b2/3621_CrZsC.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c5/b2/3621_CrZsC.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c5/b2/3621_CrZsC.jpg"},"summary":"魔神坛斗士（日语：鎧伝サムライトルーパー，台湾译作铠传，港澳译作铠甲圣斗士）是日本日升动画制作的原创动画，TV版共39集，另有3部OVA。1988年4月30日至1989年3月4日在名古屋电视台播放。中国大陆由辽艺引进。\r\n在很久很久以前，那是个极富传奇色彩的时代。罪恶的势力在世界上横行霸道，在人民要求和平和拯救的祈祷声中，一位神斗士出现了。据传说，这位斗士身穿金光闪闪的盔甲，他将恶魔们赶了出去。然而，恶魔们又卷土重来，企图建立起庞大的仇恨王国。他们发动了一场战争，企图控制人类世界。他们利用各自的魔力大肆淫威，人类的抵抗对他们毫无威胁。然而，有五位青年身穿神盔甲，与阿拉哥的尤加世界展开了殊死的搏斗，他们就是——魔神坛斗士！","name":"鎧伝サムライトルーパー","name_cn":"魔神坛斗士","tags":[{"name":"童年","count":136,"total_cont":0},{"name":"铠甲系","count":96,"total_cont":0},{"name":"热血","count":83,"total_cont":0},{"name":"魔神坛斗士","count":67,"total_cont":0},{"name":"SUNRISE","count":65,"total_cont":0},{"name":"TV","count":63,"total_cont":0},{"name":"1988","count":40,"total_cont":0},{"name":"儿时萌","count":37,"total_cont":0},{"name":"格斗","count":29,"total_cont":0},{"name":"铠传","count":29,"total_cont":0},{"name":"少年系","count":22,"total_cont":0},{"name":"80后","count":22,"total_cont":0},{"name":"矢立肇","count":18,"total_cont":0},{"name":"经典","count":17,"total_cont":0},{"name":"日本","count":14,"total_cont":0},{"name":"原创","count":11,"total_cont":0},{"name":"战斗","count":9,"total_cont":0},{"name":"动画","count":7,"total_cont":0},{"name":"奇幻","count":5,"total_cont":0},{"name":"草尾毅","count":5,"total_cont":0},{"name":"サンライズ","count":4,"total_cont":0},{"name":"池田成","count":4,"total_cont":0},{"name":"1988年","count":4,"total_cont":0},{"name":"高橋良輔","count":3,"total_cont":0},{"name":"80年代","count":3,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"塩山紀生","count":2,"total_cont":0},{"name":"没看全","count":2,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"1988年4月","count":2,"total_cont":0}],"infobox":