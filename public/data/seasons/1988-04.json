层，分别由多恶达以及他手下的大将所支配，每一层各有不同的特式，例如第二界层是一个以怪异为背景的世界、第三界层是一个极炎热的世界、第四界层是一个极冰冷的世界、第五界层是一个高度污染的世界、第六界层是一个魔法世界。\r\n\r\n每个大将也有五个左右的部下（最少是第四界层，只有两个左右）。","name":"魔神英雄伝ワタル","name_cn":"魔神英雄传","tags":[{"name":"童年","count":597,"total_cont":0},{"name":"魔神英雄传","count":387,"total_cont":0},{"name":"TV","count":275,"total_cont":0},{"name":"SUNRISE","count":200,"total_cont":0},{"name":"怀旧","count":163,"total_cont":0},{"name":"1988","count":158,"total_cont":0},{"name":"神龙斗士","count":144,"total_cont":0},{"name":"儿时萌","count":138,"total_cont":0},{"name":"原创","count":96,"total_cont":0},{"name":"那些电视里还放动画的日子","count":89,"total_cont":0},{"name":"童年啊","count":72,"total_cont":0},{"name":"国语配音","count":60,"total_cont":0},{"name":"林原女王","count":48,"total_cont":0},{"name":"萝卜","count":36,"total_cont":0},{"name":"日本","count":27,"total_cont":0},{"name":"奇幻","count":24,"total_cont":0},{"name":"战斗","count":22,"total_cont":0},{"name":"魔神英雄伝ワタル","count":19,"total_cont":0},{"name":"机战","count":19,"total_cont":0},{"name":"热血","count":15,"total_cont":0},{"name":"田中真弓","count":15,"total_cont":0},{"name":"子供向","count":15,"total_cont":0},{"name":"经典","count":13,"total_cont":0},{"name":"80年代","count":11,"total_cont":0},{"name":"动画","count":10,"total_cont":0},{"name":"井内秀治","count":9,"total_cont":0},{"name":"1988年","count":8,"total_cont":0},{"name":"1988年4月","count":8,"total_cont":0},{"name":"幻想","count":6,"total_cont":0},{"name":"林原惠","count":6,"total_cont":0}],"infobox":[{"key":"中文名","value":"魔神英雄传"},{"key":"话数","value":"45"},{"key":"放送开始","value":"1988年4月15日"},{"key":"放送星期","value":"星期五"},{"key":"官方网站","value":"http://www.mashin-eiyuuden-wataru.net/wataru1"},{"key":"播放电视台","value":"日本电视台"},{"key":"播放结束","value":"1989年3月31日"},{"key":"音乐","value":"兼崎順一、門倉聡"},{"key":"原作","value":"矢立肇"},{"key":"总导演","value":"井内秀治"},{"key":"企画","value":"サンライズ"},{"key":"系列构成","value":"小山高生"},{"key":"人物设定","value":"芦田豊雄"},{"key":"机械设定","value":"中沢数宣"},{"key":"美术监督","value":"池田繁美"},{"key":"色彩设计","value":"山崎恭子"},{"key":"摄影监督","valu