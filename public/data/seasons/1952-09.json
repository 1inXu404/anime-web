e":"BUNNY","count":1,"total_cont":0},{"name":"Warner_Bros.","count":1,"total_cont":0},{"name":"Chuck.Jones","count":1,"total_cont":0},{"name":"搞笑","count":1,"total_cont":0},{"name":"Charles_M._Jones","count":1,"total_cont":0},{"name":"The_Vitaphone_Corporation","count":1,"total_cont":0},{"name":"Merrie_Melodies","count":1,"total_cont":0},{"name":"Michael_Maltese","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"猎兔季节"},{"key":"上映年度","value":"1952-09-20"},{"key":"片长","value":"7分钟"},{"key":"Copyright","value":"Warner Bros. Pictures"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":19,"count":{"1":0,"2":0,"3":1,"4":0,"5":3,"6":7,"7":6,"8":2,"9":0,"10":0},"score":6.2},"total_episodes":0,"collection":{"on_hold":2,"dropped":6,"wish":6,"collect":35,"doing":0},"id":36234,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1952-09-19","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/23/9b/241614_nAyds.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/23/9b/241614_nAyds.jpg","large":"https://lain.bgm.tv/pic/cover/l/23/9b/241614_nAyds.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/23/9b/241614_nAyds.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/23/9b/241614_nAyds.jpg"},"summary":"　　这是一个无比晴朗的好时节，米老鼠自家的院子摆上了一张餐桌。这时米奇捧着一个巨大的蛋糕从屋子里走出来，身后跟着他忠实的狗狗布鲁托。等蛋糕摆上桌子才发现，原来今天是布鲁托的生日，好心的小主人为他的爱犬准备了一个生日派对，派对还邀请了许多老鼠宝宝。布鲁托无时无刻不想尝一口美味的蛋糕，但是米奇要求他必须先洗个澡，虽然不情愿，他还是洗了个干干净净。少顷，老鼠宝宝们蜂拥而至，他们送来了小红拖车的礼物，还强迫布鲁托进行各种各样高难度的游戏。 ","name":"Pluto's Party","name_cn":"布鲁托的派对","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"欧美","count":3,"total_cont":0},{"name":"Disney","count":2,"total_cont":0},{"name":"1952","count":2,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"1950-1959","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"1950s","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"布鲁托的派对"},{"key":"上映年度","value":"1952-09-19"},{"key":"片长","value":"7 分钟 / Argentina: 8 分钟"},{"key":"导演","value":"Milt Schaffer"},{"key":"编剧","value":"Bill Berg / Leo Salkin"},{"key":"主演","value":"Ruth Clifford / Pinto Colvig"},{"key":"IMDb ID","value":"tt0045038"}],"rating":{"rank":0,"total":8,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":3,"7":2,"8":1,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":1,"dropped":3,"wish":1,"collect":14,"doing":0},"id":241614,"eps":0,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1952-09-06","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/53/81/634621_OyEy4.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/53/81/634621_OyEy4.jpg","large":"https://lain.bgm.tv/pic/cover/l/53/81/634621_OyEy4.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/53/81/634621_OyEy4.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/53/81/634621_OyEy4.jpg"},"summary":"　　宁静祥和的一天，女主人前后左右打扫卫生，忙碌不停，而汤姆则悠哉悠哉地躺在地板上地板上睡大觉，全然不将女主人放在眼里。另一边，小老鼠杰瑞大摇大摆将奶酪搬回窝里，汤姆连看都懒得看。主人似乎对他彻底失望了，全然不怒。这时门铃声响起，快递送来了女主人期盼已久的物品——Mechano机器猫，不用喂食，不会烦人，也全无杂毛，干净高效。从现在起，它将代替汤姆承担捉老鼠的工作。机器猫不负众望，轻松抓到杰瑞将其赶了出去，气馁的汤姆只得拿着行李离开。\r\n　　但是如临大敌的杰瑞决不会允许这种事情发生，他必须和汤姆联合起来……","name":"Push-Button Kitty","name_cn":"机器猫","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"机器猫"},{"key":"上映年度","value":"1952年9月6日"},{"key":"片长","value":"6分钟"},{"key":"IMDb","value":"tt0045059"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":2,"8":0,"9":0,"10":0},"score":6.2},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":7,"doing":0},"id":634621,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":null,"platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/b7/81/370445_UYM5R.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/b7/81/370445_UYM5R.jpg","large":"https://lain.bgm.tv/pic/cover/l/b7/81/370445_UYM5R.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b7/81/370445_UYM5R.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b7/81/370445_UYM5R.jpg"},"summary":"片中的国王至尊无上，穷奢极欲，且喜怒无常，动辄就将人打入地牢（是用按钮和活动地板，让人跌入地牢），就连他的心腹密探探长也难逃一劫。他是个瘸子，又是斗鸡眼，为他画像的画师也或因为画的太真（腿和眼都画）或因为画的太假（画的很完美）而跌入地牢，只有一个画师把他画成了一条腿踏在石头上举枪瞄准猎物方才逃过此难。讽刺的是，真的国王却被画里的国王也打入了地牢（真的很象路易十四），假国王的脾气性格和真国王完全一样，他强迫一幅画中的牧羊姑娘和自己结婚，而姑娘却爱上了另一幅画中的一个扫烟囱的小子。姑娘和小伙子在小鸟的帮助下，一时逃过了追兵，但最终由于小鸟被抓，小伙子和小鸟也被关进地牢。他们团结了在那里的老百姓，冲出了地牢，在国王与牧羊姑娘的婚礼上推翻了国王。 ","name":"La bergère et le ramoneur","name_cn":"通烟囱工人与牧羊女","tags":[{"name":"剧场版","count":3,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"60年代前","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"通烟囱工人与牧羊女"},{"key":"别名","value":[{"k":"USA","v":"The Curious Adventures of Mr. Wonderbird"},{"k":"Japan (Japanese title)","v":"やぶにらみの暴君"},{"k":"又名","v":"国王与小鸟"}]},{"key":"上映年度","value":"1952年9月"},{"key":"片长","value":"63分钟"},{"key":"导演","value":"Paul Grimault"},{"key":"制片国家/地区","value":"法国"},{"key":"语言","value":"英语 / 法语"},{"key":"IMDb","value":"tt0044414"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":2,"7":0,"8":0,"9":0,"10":0},"score":5.5},"total_episodes":0,"collection":{"on_hold":1,"dropped":2,"wish":12,"collect":8,"doing":1},"id":370445,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]