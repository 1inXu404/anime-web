n_hold":0,"dropped":5,"wish":3,"collect":2,"doing":1},"id":258895,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1930-12-05","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/fb/55/133725_8mKvv.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/fb/55/133725_8mKvv.jpg","large":"https://lain.bgm.tv/pic/cover/l/fb/55/133725_8mKvv.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/fb/55/133725_8mKvv.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/fb/55/133725_8mKvv.jpg"},"summary":"　　一望无际的西部荒原上，走来了歌声不断的商队。在商队的第一辆车上，坐着米奇（沃尔特·迪斯尼 Walt Disney 配音）和他的女朋友米妮（玛西丽特·加纳 Marcellite Garner 配音），他们在谈论恐怖的印第安人，米奇自然表现出勇猛的气概，决然不怕任何危险。在不远处的悬崖上，印第安人的哨兵发现了商队，他飞奔回到营地，向伙伴们通报了这一消息，族人们于是起身，围着篝火跳起仪式般的庆祝舞蹈。 \r\n　　另一边，商队的人们也在晚间围坐在一起，弹琴唱歌，欢快无比，俄而一名老人也唱起忧伤的歌曲，令闻者伤心落泪。就在这时，印第安人向他们袭来，攻防战随即展开……","name":"Pioneer Days","name_cn":"开拓的日子","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"1930","count":3,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"刻板印象","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"Oh!_Susanna","count":1,"total_cont":0},{"name":"1930-1039","count":1,"total_cont":0},{"name":"The_Irish_Washerwoman","count":1,"total_cont":0},{"name":"Disney","count":1,"total_cont":0},{"name":"考古","count":1,"total_cont":0},{"name":"Columbia_Picture_Corp.","count":1,"total_cont":0},{"name":"印第安人","count":1,"total_cont":0},{"name":"诈兵","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"开拓的日子"},{"key":"上映年度","value":"1930-12-05"},{"key":"片长","value":"7分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0021252"},{"key":"类型","value":"喜剧 / 爱情 / 短片 / 家庭 / 西部"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"Burt Gillett"},{"key":"主演","value":"Walt Disney / Marcellite Garner"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":1,"8"