[{"date":"1991-10-25","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/f2/bc/103180_q7bhh.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/f2/bc/103180_q7bhh.jpg","large":"https://lain.bgm.tv/pic/cover/l/f2/bc/103180_q7bhh.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/f2/bc/103180_q7bhh.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/f2/bc/103180_q7bhh.jpg"},"summary":"　1988年から1991年まで「週刊少年サンデー」で連載され、第35回小学館漫画賞を受賞した、なかいま強原作の名作相撲漫画のオリジナルビデオアニメーション。監督は小沢一浩、脚本は広瀬襄が担当。来年度以降で廃部が決まった武蔵山高校相撲部。そんな相撲部のたった一人の部員である五所瓦角が、部の有終の美を飾るため、団体戦で優勝できるメンバーを他の部活から集めはじめるというストーリー。五所瓦の熱意に感じ入り、集まりはじめる個性的なメンバーたち。彼らは即席チームながら、一致団結して、それぞれの強みを活かした自分なりの方法で、次々と地区予選を勝ち進んでいく。","name":"うっちゃれ五所瓦","name_cn":"","tags":[{"name":"OVA","count":3,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"1990","count":1,"total_cont":0},{"name":"独立ova","count":1,"total_cont":0}],"infobox":[{"key":"话数","value":"1"},{"key":"发售日","value":"1991-10-25"},{"key":"导演","value":"小沢一浩"},{"key":"原作","value":"なかいま強"},{"key":"脚本","value":"広瀬襄"},{"key":"人物设定","value":"梶谷光春"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":1,"3":0,"4":0,"5":2,"6":0,"7":0,"8":0,"9":1,"10":0},"score":5.3},"total_episodes":0,"collection":{"on_hold":4,"dropped":5,"wish":5,"collect":5,"doing":2},"id":103180,"eps":1,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1991-10-24","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/7f/2a/78066_L7V11.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/7f/2a/78066_L7V11.jpg","large":"https://lain.bgm.tv/pic/cover/l/7f/2a/78066_L7V11.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/7f/2a/78066_L7V11.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/7f/2a/78066_L7V11.jpg"},"summary":"　一年一度的光畫部例行旅遊又來了，春風高中光畫部（攝影社）一行人興沖沖地出發，結果才搭上火車，就發現是西園寺的陰謀，他們必須搭著火車（電車），在限定時間內收集完成旅程各車站的紀念戳印，否則一切旅費就得自費，為了社費的存亡，光畫部這些傢伙，「悠哉悠哉」地展開電車之旅………… ","name":"究極超人あ~る","name_cn":"究极超人R","tags":[{"name":"OVA","count":10,"tota