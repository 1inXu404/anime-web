取られることになるが、イングランドの伝説的選手であり町医者のロブソンに才能を見出されイタリアに留まることが決まり、サンポデスタを辞めロブソンの下で指導を受けることになった。\r\n\r\n光は弱小チームのコロンブスを牽引してジェノバ・カップで活躍すると、イタリア少年サッカー大会に出場するジェノバ代表に選ばれるなど、ライバルたちも光の才能を注視するようになる。その後もロブソンの提案によりイタリア大会で対戦したライバルをはじめ世界中から優秀な選手を集めた混成チーム「J・ウイングス」を結成してヨーロッパ大会四カ国対抗戦やジュニアチャンピオンズカップに出場するなど活躍の場を広げていく。","name":"燃えろ!トップストライカー","name_cn":"意甲小旋风","tags":[{"name":"TV","count":13,"total_cont":0},{"name":"原创","count":11,"total_cont":0},{"name":"1991","count":10,"total_cont":0},{"name":"童年","count":8,"total_cont":0},{"name":"足球","count":5,"total_cont":0},{"name":"90年代","count":4,"total_cont":0},{"name":"康村諒","count":3,"total_cont":0},{"name":"1991年10月","count":3,"total_cont":0},{"name":"黒田昌郎","count":2,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"年番","count":1,"total_cont":0},{"name":"日本アニメーション","count":1,"total_cont":0},{"name":"没看全","count":1,"total_cont":0},{"name":"童年向","count":1,"total_cont":0},{"name":"竞技","count":1,"total_cont":0},{"name":"NipponAnimation","count":1,"total_cont":0},{"name":"运动","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"体育","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"伊倉一恵","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"意甲小旋风"},{"key":"别名","value":[{"v":"燃烧吧！顶级射手"}]},{"key":"话数","value":"49"},{"key":"放送开始","value":"1991年10月10日"},{"key":"放送星期","value":"星期四"},{"key":"官方网站","value":"https://www.nippon-animation.co.jp/work/1623/"},{"key":"播放电视台","value":"テレビ東京"},{"key":"播放结束","value":"1992年9月24日"},{"key":"导演","value":"康村諒"},{"key":"音乐","value":"山本純ノ介"},{"key":"Copyright","value":"©NIPPON ANIMATION CO., LTD.1991"},{"key":"人物设定","value":"岡迫亘弘"},{"key":"总作画监督","value":"岡迫亘弘"},{"key":"系列构成","value":"黒田昌郎"},{"key":"美术监督","value":"川口正明"},{"key":"美术设计","value":"工藤剛一"},{"key":"色彩设计","value":"小山明子"},{"key":"摄影监督","value":"鳥越一志"},{"key":"剪辑","value":"黒木公子、目黒広志"},{"key":"音响监督","value":"山田悦司"},{"key":"录音","value":"佐藤千明"},{"key":"音效","value":"庄司