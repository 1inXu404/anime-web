[{"id":266001,"type":2,"name":"Jerry-Go-Round","name_cn":"四处窜的杰瑞","summary":"《猫和老鼠》（Tom and Jerry）剧场短片系列第145集，也是查克·琼斯制作的第18集。\r\n\r\n杰瑞被汤姆追逐，逃进了一家马戏团。杰瑞替大象拔掉了脚上的钉子，大象为报答杰瑞，多次教训了仍在马戏团里四处追逐杰瑞的汤姆。\r\n\r\n标题是游乐园常见项目旋转木马(merry-go-round)的谐音双关语。","date":"1966-03-03","images":null,"rating":{"rank":0,"total":18,"score":6.8,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":4,"7":10,"8":2,"9":1,"10":0}},"tags":[{"name":"短片","count":12},{"name":"猫和老鼠","count":6},{"name":"美国","count":5},{"name":"欧美","count":4},{"name":"1966","count":3},{"name":"米高梅","count":2},{"name":"原创","count":2},{"name":"剧场版","count":2},{"name":"1960s","count":1},{"name":"查克琼斯","count":1}],"eps":1,"collection":{"wish":6,"collect":49,"doing":1,"on_hold":0,"dropped":7}},{"id":435508,"type":2,"name":"Rock 'n' Rodent","name_cn":"摇滚舞会","summary":"　　汤姆上好闹钟准备睡觉，杰瑞却到了起床时间。杰瑞沐浴打扮之后悄悄出门来到老鼠俱乐部，作为鼓手参与了老鼠乐队的演奏。乐队的喧嚣吵到了睡梦中的汤姆。汤姆想要阻止乐队的演奏，却总是失败。","date":"1966-03-15","images":null,"rating":{"rank":0,"total":6,"score":6.3,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":2,"7":2,"8":1,"9":0,"10":0}},"tags":[{"name":"短片","count":3},{"name":"剧场版","count":2},{"name":"欧美","count":2},{"name":"米高梅","count":1},{"name":"猫和老鼠","count":1},{"name":"美国","count":1},{"name":"1966","count":1},{"name":"1960-1969","count":1},{"name":"1960s","count":1}],"eps":0,"collection":{"wish":2,"collect":10,"doing":0,"on_hold":0,"dropped":2}}]