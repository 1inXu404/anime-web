[{"id":6776,"type":2,"name":"名探偵コナン コナンvsキッドvsヤイバ 宝刀争奪大決戦!!","name_cn":"柯南对基德对铁剑 宝刀争夺大决战","summary":"　　峰静香和佐也香母女拜托毛利小五郎保护家中的宝刀，原因是怪盗基德发出预告，将要盗取宝刀据为己有。听到谈话的少年侦探团自然不会错过这个大好机会，他们跟随小五郎和小兰来到峰家。在这里，他们遇见了蛮横的老婆婆、天真的剑客铁刃以及自信满满的风雷藏，当然还有峰家的奇怪宠物们。小五郎听信了雷藏的话，放心大胆地和剑十郎开怀畅饮起来。\r\n　　到了指定时间，基德潜入峰家，不过他这一次的行动可不轻松。先是遭到宠物秃鹫的撞击，接着又要连续使用美人计搞定峰家的女人们，而小小的铁刃也同样是个难缠的对手。另一方面，柯南偶然尝到峰家一种奇怪的药物，竟然发现它可以使自己变身，然而让他意想不到的事情发生了……    \r\n© 豆瓣","date":"2000-10-01","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e5/ba/6776_bA2h2.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e5/ba/6776_bA2h2.jpg","large":"https://lain.bgm.tv/pic/cover/l/e5/ba/6776_bA2h2.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e5/ba/6776_bA2h2.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e5/ba/6776_bA2h2.jpg"},"rating":{"rank":5897,"total":540,"score":6.3,"count":{"1":1,"2":2,"3":6,"4":23,"5":64,"6":206,"7":171,"8":54,"9":5,"10":8}},"tags":[{"name":"OVA","count":220},{"name":"柯南","count":85},{"name":"名侦探柯南","count":71},{"name":"名探偵コナン","count":68},{"name":"2001","count":53},{"name":"推理","count":46},{"name":"TMS","count":36},{"name":"基德","count":36},{"name":"原创","count":26},{"name":"2000","count":23},{"name":"柯南对基德对铁剑的宝刀争夺大战","count":22}],"eps":1,"collection":{"wish":85,"collect":1031,"doing":9,"on_hold":23,"dropped":11}},{"id":126640,"type":2,"name":"King of the Hill (Season 5)","name_cn":"一家之主 第五季","summary":"The fifth season of King of the Hill originally aired Sundays at 7:30-8:00 pm from October 1, 2000 to May 13, 2001. The Region 1 DVD was released on November 22, 2005. The Region 2 DVD was released on February 26, 2007. The Region 4 DVD was released on April 28, 2008.","date":"2000-10-01","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/64/a0/126640_0RVN0.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/64/a0/126640_0RVN0.jpg","large":"https://lain.bgm.tv/pic/cover/l/64/a0/126640_0RVN0.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/64/a0/126640_0RVN0.jpg","common":"https://lain.bgm.tv/