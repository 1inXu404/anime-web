四天，歌修没能系统练习演出曲目，但他的演出却……\r\n　　本片根据宫泽贤治的童话改编。  ","name":"セロ弾きのゴーシュ","name_cn":"大提琴手高修","tags":[{"name":"剧场版","count":106,"total_cont":0},{"name":"高畑勋","count":73,"total_cont":0},{"name":"1982","count":59,"total_cont":0},{"name":"小说改","count":41,"total_cont":0},{"name":"宫泽贤治","count":31,"total_cont":0},{"name":"高畑勲","count":28,"total_cont":0},{"name":"音乐","count":24,"total_cont":0},{"name":"吉卜力","count":21,"total_cont":0},{"name":"OH!プロダクション","count":13,"total_cont":0},{"name":"OH-Production","count":10,"total_cont":0},{"name":"1980s","count":9,"total_cont":0},{"name":"才田俊次","count":8,"total_cont":0},{"name":"动画电影","count":4,"total_cont":0},{"name":"日本","count":4,"total_cont":0},{"name":"奇幻","count":3,"total_cont":0},{"name":"补旧番","count":3,"total_cont":0},{"name":"佐々木秀樹","count":3,"total_cont":0},{"name":"日本动画","count":3,"total_cont":0},{"name":"肝付兼太","count":3,"total_cont":0},{"name":"治愈","count":3,"total_cont":0},{"name":"80年代","count":3,"total_cont":0},{"name":"映画","count":3,"total_cont":0},{"name":"間宮芳生","count":3,"total_cont":0},{"name":"椋尾篁","count":3,"total_cont":0},{"name":"80s","count":2,"total_cont":0},{"name":"1982年","count":2,"total_cont":0},{"name":"雨森雅司","count":2,"total_cont":0},{"name":"电影","count":2,"total_cont":0},{"name":"アニメ映画","count":2,"total_cont":0},{"name":"轻小说改","count":2,"total_cont":0}],"infobox":[{"key":"中文名","value":"大提琴手高修"},{"key":"别名","value":[{"v":"大提琴手"},{"v":"Goshu the Cellist"}]},{"key":"上映年度","value":"1982年1月23日"},{"key":"片长","value":"61:30"},{"key":"话数","value":"1"},{"key":"导演","value":"高畑勲"},{"key":"原作","value":"宮沢賢治"},{"key":"人物设定","value":"才田俊次"},{"key":"演奏","value":"東京室内楽協会、NHK交響楽団"},{"key":"大提琴独奏","value":"矢島光雄"},{"key":"合唱","value":"兒童合唱団トマト"}],"rating":{"rank":2851,"total":190,"count":{"1":0,"2":0,"3":0,"4":2,"5":7,"6":56,"7":74,"8":45,"9":5,"10":1},"score":6.9},"total_episodes":0,"collection":{"on_hold":14,"dropped":16,"wish":189,"collect":253,"doing":10},"id":17351,"eps":1,"meta_tags":["剧场版","小说改"],"volumes":0,"series":