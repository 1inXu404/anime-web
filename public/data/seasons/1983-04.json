s":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/87/ff/25420_xVr85.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/87/ff/25420_xVr85.jpg","large":"https://lain.bgm.tv/pic/cover/l/87/ff/25420_xVr85.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/87/ff/25420_xVr85.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/87/ff/25420_xVr85.jpg"},"summary":"1983年在日本播出，由东京MOVIE制作的拥有梦幻般人气的《乔琪姑娘》（又名《淘气小雪儿》）这部动画的原作是井泽满，然后由以漫画《小甜甜》而知名的少女漫画家五十岚优美子担当漫画执笔，在当时的少女漫画界引起了一阵惊喜。本作于九十年代末期传入中国大陆，可以说是中国的漫迷最早的一批少女漫画之一。清新的画风，可爱如同洋娃般的人物设定同样获得了相当的好评，至今仍有当时的漫迷对它今今不忘。\r\n　　二男一女，经典少女漫画的套路啊……\r\n　　故事讲述的是一位开朗又天真浪漫的少女小雪儿，与母亲、两位哥哥——阿贝尔与阿瑟在澳大利亚的希德尼牧场幸福地生活着。但是有一天，她无意间知道了自己是在婴儿时期被身为流放犯人的父亲遗弃在森林的孩子，同时也知道了自己平时戴在手腕上当作精神寄托的黄金手镯是父亲留给自己的唯一纪念。为了寻找自己亲生之父——偶然有过一面之缘的罗埃尔，小雪儿独自一人踏上了去英国的旅途。而不再把她当成自己的妹妹，而当作一个女性去爱的两位兄长，也分别追随她的脚步来到了英国。　　 ","name":"レディジョージィ","name_cn":"淘气小雪儿","tags":[{"name":"TV","count":4,"total_cont":0},{"name":"子供向？","count":2,"total_cont":0},{"name":"1983","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"東京ムービー新社","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"山本百合子","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"堀秀行","count":1,"total_cont":0},{"name":"待補1","count":1,"total_cont":0},{"name":"吉田しげつぐ","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"漫画改","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"淘气小雪儿"},{"key":"别名","value":[{"v":"乔琪姑娘"},{"v":"Lady Georgie"}]},{"key":"话数","value":"45"},{"key":"放送开始","value":"1983年4月9日"},{"key":"播放结束","value":"1984年2月25日"},{"key":"导演","value":"チーフディレクター：吉田しげつぐ"},{"key":"音乐","value":"渡辺岳夫"},{"key":"原作","value":"いがらしゆみこ、井沢満"},{"key":"人物设定","value":"高畑順三郎"}],"rating":{"rank":0,"total":4,"count":{"1":2,"2":0,"3":0,"4":0,"5":0,"6":1,"7":1,"8":0,"9":0,"10":0},"score":3.8},"total_episodes":0,"collection":{"on_hold":2,"dropped":11,"wish":27,"collect":6,"doing":2},"id":25420,"eps":45,"meta_tags":["TV","日本","漫画