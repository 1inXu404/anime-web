[{"date":"1941-02-14","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/b5/28/241604_ztjF4.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/b5/28/241604_ztjF4.jpg","large":"https://lain.bgm.tv/pic/cover/l/b5/28/241604_ztjF4.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b5/28/241604_ztjF4.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b5/28/241604_ztjF4.jpg"},"summary":"　　阳光明媚的一天，心情愉悦的米妮（塞尔玛·博德曼 Thelma Boardman 配音）哼着小曲，从烤箱捧出喷香诱人的蛋糕。蛋糕的香气飘啊飘，刚好被路过的米奇（沃尔特·迪斯尼 Walt Disney 配音）闻到。米奇垂涎欲滴，祈求米妮能分给他一点，但是被这位高傲的小姐拒绝了。于是米奇许诺帮助米妮打扫院落，以换取吃蛋糕的资格。得到女主人的同意后，米奇充满干劲地开始打扫起来。就在这时，一个恼人的家伙来了，它是一个桀骜不驯的小旋风，见到工作的米奇，小旋风赶上前惹出了不少的乱子。","name":"The Little Whirlwind","name_cn":"小旋风","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"1941","count":3,"total_cont":0},{"name":"欧美","count":3,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"Disney","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"小旋风"},{"key":"上映年度","value":"1941-02-14"},{"key":"片长","value":"8分钟"},{"key":"导演","value":"Riley Thomson"},{"key":"主演","value":"Walt Disney"},{"key":"IMDb ID","value":"tt0033838"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":2,"8":1,"9":0,"10":0},"score":6.8},"total_episodes":0,"collection":{"on_hold":0,"dropped":2,"wish":1,"collect":13,"doing":0},"id":241604,"eps":0,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1941-02-01","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e8/6b/198736_2XK2g.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e8/6b/198736_2XK2g.jpg","large":"https://lain.bgm.tv/pic/cover/l/e8/6b/198736_2XK2g.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e8/6b/198736_2XK2g.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e8/6b/198736_2XK2g.jpg"},"summary":"","name":"カンガルーの誕生日","name_cn":"袋鼠过生日","tags":[{"name":"短片","count":6,"total_cont