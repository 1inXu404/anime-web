[{"date":"1929-06-26","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/22/9f/133721_1z3H1.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/22/9f/133721_1z3H1.jpg","large":"https://lain.bgm.tv/pic/cover/l/22/9f/133721_1z3H1.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/22/9f/133721_1z3H1.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/22/9f/133721_1z3H1.jpg"},"summary":"　　农舍的一角，米奇（沃尔特·迪斯尼 Walt Disney 配音）和他的乐队成员们正在进行热烈、快乐的露天演出，他们别具一格的演出得到了农户们的热烈欢迎。一曲结束，五只鸭子女郎顺序而出，踩着节拍跳起舞蹈；接着公鸡、母鸡又上演了家庭生活暴力剧，也得到不错的反响。第三个出场的是猪小姐，她高亢刺耳的歌声遭到全场嘘声，演唱被迫草草结束。接下来是米奇自弹自唱，伴随着跳跃的钢琴声和俏皮的歌曲，米奇吸引了全场的注意力。表演渐入高潮，米奇还挑起轻快的踢踏舞。他成了全场演出最大的亮点……","name":"Mickey's Follies","name_cn":"米奇干的傻事","tags":[{"name":"短片","count":5,"total_cont":0},{"name":"1929","count":4,"total_cont":0},{"name":"剧场版","count":4,"total_cont":0},{"name":"欧美","count":3,"total_cont":0},{"name":"考古","count":2,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"米妮","count":1,"total_cont":0},{"name":"UB_IWERKS","count":1,"total_cont":0},{"name":"斗鸡","count":1,"total_cont":0},{"name":"演奏","count":1,"total_cont":0},{"name":"Mickey_theme_song","count":1,"total_cont":0},{"name":"系列短片","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"1920-1929","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"Disney","count":1,"total_cont":0},{"name":"soap","count":1,"total_cont":0},{"name":"米奇","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"米奇干的傻事"},{"key":"上映年度","value":"1929-06-26"},{"key":"片长","value":"7分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0020168"},{"key":"类型","value":"喜剧 / 短片 / 歌舞 / 家庭"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"Wilfred Jackson"},{"key":"主演","value":"华特·迪斯尼 / Marcellite Garner"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":10,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":2,"7":4,"8":1,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":1,"collect":24,"doing":0},"id":133721,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1929-06-18","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/47/bb/198038_7McCc.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/47/bb/198038_7McCc.jpg","large":"https://lain.bgm.tv/pic/cover/l/47/bb/198038_7McCc.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/47/bb/198038_7McCc.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/47/bb/198038_7McCc.jpg"},"summary":"太郎さんは動物たちの乗っている列車の車掌さん。ブタの親子が座席を占有しており、ヤギのお爺さんが座れない。太郎さんはブタの荷物を網棚に載せ、ヤギのお爺さんに席を空けてやる。カバの夫婦がバナナを食べ、皮を通路に捨てる。通りかかったツルのお嬢さんがバナナの皮に滑る。太郎さんがカバを注意する。シロクマが洗面所を使っているが、トンネルに入り、窓から入ってきた煤で真っ黒になる。入れ替わりにツルのお嬢さんが顔を洗おうとするが、洗面所の水がない。「牛飲馬食」の諺どおり、ウシが大酒を飲み、ウマが弁当を大食い。ウシが飲み終った一升瓶を窓から投げ捨てると、線路作業員のサルに当たり、怪我をする。サルは怒って仲間とともにトロッコで汽車を追いかける。汽車に乗り込んだサルたちは、ウシに猛烈に抗議。太郎さんが仲裁するが、みんな一塊になって列車の外に投げ出される。","name":"太郎さんの汽車","name_cn":"太郎的火车","tags":[{"name":"1929","count":9,"total_cont":0},{"name":"剧场版","count":5,"total_cont":0},{"name":"短片","count":5,"total_cont":0},{"name":"青地忠三","count":4,"total_cont":0},{"name":"村田安司","count":4,"total_cont":0},{"name":"1929年","count":3,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"旧物","count":2,"total_cont":0},{"name":"1929年6月","count":2,"total_cont":0},{"name":"梦","count":2,"total_cont":0},{"name":"桜グラフ","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"定格","count":1,"total_cont":0},{"name":"摄影","count":1,"total_cont":0},{"name":"火车","count":1,"total_cont":0},{"name":"1980年前","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"太郎的火车"},{"key":"别名","value":[{"v":"Tarosan no Kisha"},{"v":"Taro-san no Kisha"}]},{"key":"上映年度","value":"1929年6月18日"},{"key":"片长","value":"5min"},{"key":"话数","value":"1"},{"key":"制作","value":"横浜シネマ商会（ヨコシネ ディー アイ エー）"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":2,"5":3,"6":0,"7":0,"8":0,