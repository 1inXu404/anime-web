ount":20},{"name":"子安武人","count":14},{"name":"1995","count":12},{"name":"腐","count":12},{"name":"漫画改","count":7},{"name":"里番","count":7},{"name":"三木真一郎","count":5},{"name":"日本","count":5}],"eps":1,"collection":{"wish":38,"collect":190,"doing":4,"on_hold":7,"dropped":21}},{"id":407,"type":2,"name":"平成狸合戦ぽんぽこ","name_cn":"平成狸合战","summary":"　　在日本人心目中，狸猫是一种神秘的动物，它们会使用一种类似障眼法的幻术，身体可以变成任意形状，或者把树叶变成钱什么的用来欺骗人类。在《百变狸猫》中，一群住在东京附近的狸猫就想利用这种幻术吓唬人类，借此使社区新建工程搁置，可惜因为内部和外部的各种原因，结局还是挺无奈的。\r\n　　故事为一群住在东京多摩丘陵森林的狸子们，在原本安逸的生活环境突然遭到人类的住宿建设计划给破坏掉。备感生存危机的狸子们为了自保；决定重新练起古时狸子们所留下的变身术，并派遣两名使者前去佐渡及四国寻找狸子长老们协助、以能够和人类一决胜负… 。","date":"1994-07-16","images":null,"rating":{"rank":543,"total":1872,"score":7.7,"count":{"1":3,"2":0,"3":5,"4":10,"5":36,"6":140,"7":509,"8":804,"9":272,"10":93}},"tags":[{"name":"吉卜力","count":702},{"name":"剧场版","count":572},{"name":"高畑勋","count":470},{"name":"1994","count":326},{"name":"原创","count":207},{"name":"宮崎駿","count":202},{"name":"奇幻","count":187},{"name":"环保系","count":149},{"name":"生态保护","count":104},{"name":"宫崎骏","count":72},{"name":"高畑勲","count":71}],"eps":1,"collection":{"wish":953,"collect":2664,"doing":44,"on_hold":74,"dropped":28}},{"id":27578,"type":2,"name":"グスコーブドリの伝記","name_cn":"古斯柯布多力传记","summary":"　　原作来自宫泽贤治的同名童话。出生在伊哈特卜大森林里的古斯柯布多力，因为冻灾导致的饥荒，和父母、妹妹妮莉离散。布多力来到种植稻田的农户红胡子家里帮忙，他学习古柏博士的著书，成功地治好了稻田的病害，但第二年冻灾和干旱的夹击下，稻田颗粒无收。布多力在古柏博士的介绍下，来到伊哈特卜火山局工作，跟随潘内纳姆技师，学习如何科学利用火山造福农业。之后，他又邂逅了妹妹妮莉，妮莉已经结婚，生活得十分幸福。布多力为了帮助更多的人免受冻灾之害，再次独身踏上旅程。","date":"1994-07-16","images":null,"rating":{"rank":0,"total":28,"score":6.8,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":6,"7":14,"8":4,"9":1,"10":0}},"tags":[{"name":"剧场版","count":26},{"name":"1994","count":15},{"name":"中村隆太郎","count":14},{"name":"小说改","count":11},{"name":"1994年","count":6},{"name":"独立剧场版","count":5},{"name":"あにまる屋","count":3},{"name":"エクラアニマル","count":3},{"name":"治愈","count":2},{"name":"剧场","count":2},{"name":"日本动漫","count":2}],"eps":1,"collection":{"wish":62,"collect":40,"doing":7,"on_hold":10,"dropped":6}},{"id":38426,"ty