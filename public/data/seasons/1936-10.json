[{"date":"1936-10-31","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/86/f5/132360_R7Xpi.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/86/f5/132360_R7Xpi.jpg","large":"https://lain.bgm.tv/pic/cover/l/86/f5/132360_R7Xpi.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/86/f5/132360_R7Xpi.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/86/f5/132360_R7Xpi.jpg"},"summary":"      居住在城市的老鼠给住在乡间的表弟写了封信，希望它能到城市里来生活一段时间。接到信后，表弟哼着欢快地小曲进城了。过惯了乡下无拘无束的生活，表弟发现城里的规矩似乎格外多。首先在表哥家不能大声说话，然后门口那个放置着食物的奇怪夹子不能随便碰。好在表哥足够热心，带着它爬上了餐桌。这里有着闻所未闻的精美食物，表弟仿佛到了天堂一般，它畅快地吃了起来，还把自己灌得醉眼朦胧，步履蹒跚。酒足饭饱之后，该到休息时间了，兄弟俩却发现一只老猫守在洞口。接着酒劲儿，不知天高地厚的小表弟向天敌发起了挑战……","name":"The Country Cousin","name_cn":"乡下老表","tags":[{"name":"短片","count":41,"total_cont":0},{"name":"欧美","count":25,"total_cont":0},{"name":"迪士尼","count":16,"total_cont":0},{"name":"1936","count":15,"total_cont":0},{"name":"Disney","count":12,"total_cont":0},{"name":"奥斯卡","count":11,"total_cont":0},{"name":"美国","count":8,"total_cont":0},{"name":"WaltDisneyPictures","count":5,"total_cont":0},{"name":"搞笑","count":5,"total_cont":0},{"name":"欢乐","count":4,"total_cont":0},{"name":"1930s","count":3,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"1930-1939","count":2,"total_cont":0},{"name":"考古","count":1,"total_cont":0},{"name":"Wilfred·Jackson","count":1,"total_cont":0},{"name":"其它","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"Oscars","count":1,"total_cont":0},{"name":"动物","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"1936年","count":1,"total_cont":0},{"name":"动画史经典","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"SillySymphonies","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"1936年10月","count":1,"total_cont":0},{"name":"经典","count":1,"total_cont":0},{"name":"Silly-Symphony","count":1,"total_cont":0},{"name":"cartoon","count":1,"total_cont":0},{"name":"David·Hand","count":1,"total_cont":0}],"i