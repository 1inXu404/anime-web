[{"date":"1975-02-11","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c0/f4/579053_Z77x7.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c0/f4/579053_Z77x7.jpg","large":"https://lain.bgm.tv/pic/cover/l/c0/f4/579053_Z77x7.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c0/f4/579053_Z77x7.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c0/f4/579053_Z77x7.jpg"},"summary":"　　《封神榜》是张英电影公司1975年出品的台湾动画长片，由张志辉执导，改编自漫画家蔡志忠同名漫画。该片为两岸三地首部宽银幕彩色动画电影，采用日本进口赛璐珞片与颜料制作，美术设计由蔡志忠主笔，角色造型融入崔福生、苗可秀等演员形象，二郎神以李小龙为原型 。\r\n　　影片以商周之战为背景，讲述姜子牙奉元始天尊之命辅佐周文王讨伐纣王的故事。纣王受妲己蛊惑残害百姓，周国在姜子牙治理下日渐强盛，引发商朝闻太师与申公豹联手进攻。双方借助仙魔之力展开对决，最终姜子牙在万能神帮助下击败反派，助周文王推翻商朝。影片结合神话元素与漫画风格，角色设计融合现实人物特征，展现善恶对抗主题。","name":"封神榜","name_cn":"封神榜","tags":[{"name":"香港","count":1,"total_cont":0},{"name":"台湾","count":1,"total_cont":0},{"name":"小说改","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"封神榜"},{"key":"别名","value":[{"v":"The Story of Chinese Gods"},{"v":"ドラゴン水滸伝"}]},{"key":"上映年度","value":"1975年2月11日"},{"key":"片长","value":"78分钟"},{"key":"导演","value":"张志辉（张镇宗、蔡志忠与侯胜辉）"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":0,"7":0,"8":0,"9":0,"10":0},"score":4},"total_episodes":0,"collection":{"on_hold":0,"dropped":1,"wish":1,"collect":1,"doing":1},"id":579053,"eps":0,"meta_tags":["剧场版","小说改","台湾","香港"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]