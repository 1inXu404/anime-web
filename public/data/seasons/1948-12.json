:6.9},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":4,"collect":83,"doing":1},"id":275350,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1948-12-03","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/10/5e/241611_7I7NB.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/10/5e/241611_7I7NB.jpg","large":"https://lain.bgm.tv/pic/cover/l/10/5e/241611_7I7NB.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/10/5e/241611_7I7NB.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/10/5e/241611_7I7NB.jpg"},"summary":"　　这一天，米奇（James MacDonald 配音）提着篮子独自来到动物园。他驻足海豹馆前，看这些滑稽可爱的小精灵玩耍，时不时还掏出鲜鱼投进去喂食，令米奇乐而忘返。这时，有一只调皮的小海豹偷偷溜出笼子，钻进了篮子内。米奇毫不知情，屋子提着篮子回到家中。忠实的布鲁托迎了过来，希望小主人能给它带来好吃的东西，当然它最终失望了。篮筐的异常动静引起了布鲁托的注意，终于它发现小海豹的存在。布鲁托试图提醒米奇不速之客的到来，可是米奇完全没有领会布鲁托的意思。 ","name":"Mickey and the Seal","name_cn":"米奇和海豹","tags":[{"name":"欧美","count":5,"total_cont":0},{"name":"短片","count":4,"total_cont":0},{"name":"迪士尼","count":3,"total_cont":0},{"name":"1948","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"Disney","count":2,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"1940s","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"米奇和海豹"},{"key":"上映年度","value":"1948-12-03"},{"key":"片长","value":"7分钟"},{"key":"导演","value":"Charles A. Nichols"},{"key":"编剧","value":"Nick George / Milt Schaffer"},{"key":"主演","value":"James MacDonald / Pinto Colvig"},{"key":"IMDb ID","value":"tt0040588"}],"rating":{"rank":0,"total":8,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":3,"7":2,"8":1,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":2,"wish":2,"collect":17,"doing":0},"id":241611,"eps":0,"meta_tags":[],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]