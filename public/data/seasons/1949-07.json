[{"date":"1949-07-09","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/b1/14/275353_GM2NM.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/b1/14/275353_GM2NM.jpg","large":"https://lain.bgm.tv/pic/cover/l/b1/14/275353_GM2NM.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b1/14/275353_GM2NM.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b1/14/275353_GM2NM.jpg"},"summary":"　　这一天，汤姆正躺在壁炉前面睡觉。杰瑞偷偷从洞里出来，打算趁这个死对头睡觉的时候找点儿吃的。可是，汤姆根本没有睡熟，他悄悄睁开眼，盯着杰瑞的一举一动，时刻准备冲上前去。杰瑞果然中计，结果遭到狡猾的老猫的追捕。可是在混乱中，汤姆不慎把一架钢琴从楼梯上拉下来，他被狠狠地撞在墙上，随即失去了知觉。就在这时，一道喜乐庄严的光芒出现在空中，与此同时还出现了一部金黄色的电梯。汤姆的灵魂懵懵懂懂乘电梯来到天国车站。这里聚集了许多因各种事故死去的猫儿，他们都得到允许乘上前往天国的列车。 \r\n　　而经常欺负杰瑞的汤姆，则必须在1小时内得到杰瑞的谅解，否则将落入恐怖的地狱……","name":"Heavenly Puss","name_cn":"猫儿上天堂","tags":[{"name":"短片","count":27,"total_cont":0},{"name":"欧美","count":16,"total_cont":0},{"name":"猫和老鼠","count":12,"total_cont":0},{"name":"1949","count":9,"total_cont":0},{"name":"美国","count":8,"total_cont":0},{"name":"米高梅","count":4,"total_cont":0},{"name":"原创","count":4,"total_cont":0},{"name":"剧场版","count":3,"total_cont":0},{"name":"MGM","count":2,"total_cont":0},{"name":"Short_film","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"6(+1)","count":1,"total_cont":0},{"name":"威廉·汉纳","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"猫儿上天堂"},{"key":"别名","value":[{"v":"天堂的猫"}]},{"key":"上映年度","value":"1949年7月9日"},{"key":"片长","value":"7分48秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":44,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":9,"7":16,"8":12,"9":4,"10":2},"score":7.3},"total_episodes":0,"collection":{"on_hold":3,"dropped":4,"wish":3,"collect":107,"doing":1},"id":275353,"eps":1,"meta_tags":["剧场版","欧美"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]