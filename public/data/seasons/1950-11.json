[{"date":"1950-11-25","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/47/2d/634571_DVpG1.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/47/2d/634571_DVpG1.jpg","large":"https://lain.bgm.tv/pic/cover/l/47/2d/634571_DVpG1.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/47/2d/634571_DVpG1.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/47/2d/634571_DVpG1.jpg"},"summary":"　　夜深人静，白日里喧嚣的台球馆变得鸦雀无声。可是，黑漆漆的屋内却还有一张桌子亮着灯。原来顽皮的汤姆趁没人之际偷偷溜了进来大过球瘾，他自信满满，不过球技却不敢恭维，好在是自娱自乐，偶尔耍点小聪明也无可厚非。正当他玩兴正酣时，睡在某个球洞里的杰瑞却受到了打扰。迷迷糊糊的小老鼠险些被从天而降的球砸中脑袋，继而又被挤在两球中间。他弄气冲冲地出去寻找扰民的家伙，结果反落在了汤姆的手中，遭到对方好一阵戏耍。或是被台球列车碾压过去，或是踩着黑8跳火圈。小老鼠疲于奔命，而汤姆乐不可支。\r\n　　当然，猫鼠大战从来都是有来有往，激烈的战争就在台球馆内展开了……","name":"Cue Ball Cat","name_cn":"台球猫","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"1950-1959","count":1,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"台球猫"},{"key":"上映年度","value":"1950年11月25日"},{"key":"片长","value":"7分钟"},{"key":"导演","value":"Joseph Barbera,William Hanna"},{"key":"IMDb","value":"tt0042360"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":3,"8":0,"9":0,"10":0},"score":6.4},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":8,"doing":0},"id":634571,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]