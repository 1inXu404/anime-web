ルは闇主のとぼけた態度にイライラしつつも、ついに目指す亜珠の城へたどり着く。だがそこに待つ美青年・乱華、彼は魔性の道を選んだラエスリールの実弟リーダイルであり、姉の持つ黄金の瞳＝魅了眼を狙う……。本作の実制作はマジックバスが担当。","name":"破妖の剣 漆黒の魔性","name_cn":"破妖之剑 漆黑的魔性","tags":[{"name":"OVA","count":10,"total_cont":0},{"name":"草尾毅","count":6,"total_cont":0},{"name":"小说改","count":5,"total_cont":0},{"name":"独立ova","count":5,"total_cont":0},{"name":"鹤ひろみ","count":2,"total_cont":0},{"name":"各方面都不错","count":2,"total_cont":0},{"name":"鶴ひろみ","count":2,"total_cont":0},{"name":"篠原惠美","count":1,"total_cont":0},{"name":"速水奖","count":1,"total_cont":0},{"name":"1992","count":1,"total_cont":0},{"name":"扭曲的爱","count":1,"total_cont":0},{"name":"屋良有作","count":1,"total_cont":0},{"name":"7分","count":1,"total_cont":0},{"name":"梁田清之","count":1,"total_cont":0},{"name":"笠原弘子","count":1,"total_cont":0},{"name":"广中雅志","count":1,"total_cont":0},{"name":"奇幻","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"破妖之剑 漆黑的魔性"},{"key":"别名","value":[{"v":"Hayou no tsurugi: Shikkoku no mashou"}]},{"key":"话数","value":"2"},{"key":"发售日","value":"1992-12-25"},{"key":"原作","value":"前田珠子"},{"key":"导演","value":"四分一節子"},{"key":"脚本","value":"小出一巳"},{"key":"分镜","value":"胡桃野蛍樹"},{"key":"演出","value":"木村真一郎"},{"key":"人物设定","value":"小林ゆかり"},{"key":"作画监督","value":"小林ゆかり"},{"key":"企画","value":"中野和雄、吉田久幸"},{"key":"制片人","value":"宮直樹、本郷保、松崎義之"},{"key":"动画制作","value":"マジックバス"}],"rating":{"rank":0,"total":10,"count":{"1":0,"2":1,"3":1,"4":0,"5":2,"6":3,"7":2,"8":0,"9":0,"10":1},"score":5.7},"total_episodes":0,"collection":{"on_hold":3,"dropped":6,"wish":19,"collect":24,"doing":1},"id":92574,"eps":2,"meta_tags":["OVA"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1992-12-24","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/6d/2f/445943_1Sgcb.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/6d/2f/445943_1Sgcb.jpg","large":"https://lain.bgm.tv/pic/cover/l/6d/2f/445943_1Sgcb.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/6d/2f/