[{"date":"1986-08-24","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/97/60/112592_bGSHa.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/97/60/112592_bGSHa.jpg","large":"https://lain.bgm.tv/pic/cover/l/97/60/112592_bGSHa.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/97/60/112592_bGSHa.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/97/60/112592_bGSHa.jpg"},"summary":"该作品是为24小时电视节目制作的第9部特别动画，再次由手塚制作公司负责制作。手塚治虫则积极参与，担任原作、脚本、导演三重角色。故事采用类似于雷·布莱伯利的《火星纪事》中多元化剧集的呈现方式，以21世纪末人类迈向宇宙的时代作为背景，讲述了一段动人的爱情故事。剧情设定则与《火之鸟：望乡篇》相似。一对新婚夫妇踏上了宇宙之旅，然而丈夫因宇宙病不幸突然离世，女主角因此被孤独地留在了浩瀚宇宙之中。这个情节设定与《火之鸟》存在着相似之处。在这个故事中，女主角是一位如同麦当娜般深受众人喜爱的女性，为了拯救她，女主角地球时代的朋友们结伴踏上宇宙探险之旅。“用爱拯救地球”“只有爱才能拯救人类”——这部手塚特别动画作品再次强调了爱的力量和重要性。","name":"銀河探査2100年 ボーダープラネット","name_cn":"银河探查2100年 Border Planet","tags":[{"name":"手塚治虫","count":7,"total_cont":0},{"name":"剧场版","count":6,"total_cont":0},{"name":"TVSP","count":3,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"TV","count":2,"total_cont":0},{"name":"富山敬","count":2,"total_cont":0},{"name":"独立剧场版","count":2,"total_cont":0},{"name":"1986","count":2,"total_cont":0},{"name":"SF","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"1986年","count":1,"total_cont":0},{"name":"东映动画","count":1,"total_cont":0},{"name":"東映アニメーション","count":1,"total_cont":0},{"name":"富田耕生","count":1,"total_cont":0},{"name":"科幻","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"银河探查2100年 Border Planet"},{"key":"别名","value":[{"v":"死亡之谜"},{"v":"Galaxy Investigation 2100: Border Planet"}]},{"key":"话数","value":"1"},{"key":"放送开始","value":"1986年8月24日"},{"key":"播放电视台","value":"日本テレビ"},{"key":"导演","value":"手塚治虫"},{"key":"脚本","value":"手塚治虫"},{"key":"人物设定","value":"小原渉平"},{"key":"机械设定","value":"小原渉平"},{"key":"总作画监督","value":"高橋信也"}],"rating":{"rank":0,"total":16,"count":{"1":1,"2":0,"3":0,"4":2,"5":5,"6":2,"7":2,"8":4,"9":0,"10":0},"score":5.8},"total_ep