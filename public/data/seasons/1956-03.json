[{"date":"1956-03-23","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/1d/ce/634789_G0V4i.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/1d/ce/634789_G0V4i.jpg","large":"https://lain.bgm.tv/pic/cover/l/1d/ce/634789_G0V4i.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/1d/ce/634789_G0V4i.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/1d/ce/634789_G0V4i.jpg"},"summary":"　　在一户庭院内的大树上，啄木鸟妈妈正端坐树梢织毛衣。她看了看表，发现已到中午时分，于是小心翼翼包好身下的鸟蛋，竖上了“吃午饭”的牌子，随后悠然自得地离开。可她前脚刚刚走掉，啄木鸟蛋便开始躁动。鸟蛋滚出了窝，竟一路滑到树下，钻进房间地板，跑到小老鼠杰瑞的屁股下面。杰瑞被鸟蛋惊醒，这时候蛋壳破裂，可爱的小啄木鸟误以为杰瑞就是他的妈妈，于是对其亲昵不已。令杰瑞头疼的是，啄木鸟宝贝把他家所有的木质结构家具全部啄成碎末。杰瑞忍无可忍，将小家伙赶出门外。\r\n　　失落的小啄木鸟在院子里漫无目的游走，谁知却惹到了贪婪的老猫汤姆……","name":"The Egg and Jerry","name_cn":"杰瑞妈妈","tags":[{"name":"1950s","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"短片","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"杰瑞妈妈"},{"key":"上映年度","value":"1956年3月23日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0049173"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":1,"8":0,"9":0,"10":0},"score":6},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":4,"doing":0},"id":634789,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]