易被他吓怕呢!!不过,他也有发奋的时候,中间他会看看那本\"怎样成为漂亮面包\"的书……\r\n\r\n　　烤焦面包的故事在日本激励了许许多多的人。很多人在失败的时候想到了有着和自己相同命运的烤焦面包，就觉得不那么孤单而打起精神来了。","name":"こげぱん","name_cn":"烤焦面包","tags":[{"name":"泡面番","count":36,"total_cont":0},{"name":"治愈","count":30,"total_cont":0},{"name":"TV","count":28,"total_cont":0},{"name":"2001","count":21,"total_cont":0},{"name":"石田彰","count":16,"total_cont":0},{"name":"烤焦面包","count":15,"total_cont":0},{"name":"励志","count":10,"total_cont":0},{"name":"人生","count":9,"total_cont":0},{"name":"可愛","count":9,"total_cont":0},{"name":"烤焦麵包","count":7,"total_cont":0},{"name":"2001年10月","count":6,"total_cont":0},{"name":"StudioPierrot","count":5,"total_cont":0},{"name":"泡面","count":5,"total_cont":0},{"name":"折笠富美子","count":4,"total_cont":0},{"name":"原创","count":4,"total_cont":0},{"name":"ぴえろ","count":3,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"小原秀一","count":2,"total_cont":0},{"name":"治愈系","count":2,"total_cont":0},{"name":"治癒","count":2,"total_cont":0},{"name":"日本动画","count":2,"total_cont":0},{"name":"勵志","count":1,"total_cont":0},{"name":"喜剧","count":1,"total_cont":0},{"name":"动画","count":1,"total_cont":0},{"name":"温馨","count":1,"total_cont":0},{"name":"深刻","count":1,"total_cont":0},{"name":"7(+2)","count":1,"total_cont":0},{"name":"漫改","count":1,"total_cont":0},{"name":"01-10","count":1,"total_cont":0},{"name":"漫画改","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"烤焦面包"},{"key":"别名","value":[{"v":"Kogepan"}]},{"key":"话数","value":"10"},{"key":"放送开始","value":"2001年11月5日"},{"key":"官方网站","value":"http://pierrot.jp/title/kogepan/"},{"key":"播放结束","value":"2001年11月16日"},{"key":"Copyright","value":"©ソニー・マガジンズ／ポニーキャニオン／アニマックスブロードキャスト・ジャパン／ぴえろ"},{"key":"原作","value":"たかはしみき（サンエックス） ソニー・マガジンズ刊 『こげぱん』絵本シリーズより"},{"key":"導演","value":"小原秀一"},{"key":"腳本","value":"はぎのまさこ"},{"key":"作畫","value":"小原秀一、花岡佳子"},{"key":"音樂","value":"安田毅"},{"key":"動畫檢查","value":"豊島光子、山田玲子"},{"key":"編輯","value":"植松淳一"},{"key":"剪輯","value":"ジェイフォース"},{"key":"音響效果","value":"武藤晶子"},{"key":