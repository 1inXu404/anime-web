3154_8XvUy.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/74/56/23154_8XvUy.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/74/56/23154_8XvUy.jpg"},"rating":{"rank":8151,"total":152,"score":5.5,"count":{"1":0,"2":5,"3":10,"4":19,"5":38,"6":46,"7":23,"8":8,"9":0,"10":3}},"tags":[{"name":"OVA","count":72},{"name":"秋之回忆","count":49},{"name":"GAL改","count":37},{"name":"2001","count":36},{"name":"恋爱","count":23},{"name":"校园","count":21},{"name":"MemoriesOff","count":13},{"name":"游戏改","count":12},{"name":"日本","count":10},{"name":"剧场版","count":8},{"name":"崩！","count":7}],"eps":3,"collection":{"wish":131,"collect":265,"doing":22,"on_hold":21,"dropped":20}},{"id":28238,"type":2,"name":"キカイダー01 THE ANIMATION","name_cn":"电脑奇侠01","summary":"　　紧接着漫画中电脑奇侠01登场后的剧情发展，并且出现了原创角色电脑奇侠00。但主角依旧是次郎，因为在这部OVA中只有次郎拥有良心回路，也因此只有次郎可以不受基鲁教授控制。原本以为已死的基鲁教授利用电脑黑魔的身体再度复活。在发现基鲁的阴谋之后，三名电脑奇侠以及因妹妹被杀而反叛的美人侠联手攻击基鲁的要塞。但是由于没有良心回路这个关键的零件，三人均被俘虏并改造成基鲁的奴仆。\r\n　　至于因良心回路而不被侵蚀的电脑奇侠，基鲁并不打算轻易拆下良心回路，而是装上一个自以为完美的附加零件“服从回路”，是对一切邪恶念头与命令均会回答Yes的干扰零件。但是本以为可以完全压倒良心回路的服从回路，却意外因两者对抗发生融合。最终流泪杀死哥哥01以及弟弟00的次郎，面对惊恐的基鲁说道：“对，我学会说谎了。”正因为本来纯粹的次郎的灵魂被污染而学会了说谎，于是他才得以骗过测试机器而被放出。\r\n　　“我应该永远都会被良心和邪念所折磨吧。”这是次郎杀死基鲁前最后所说的话。OVA的结局以极度悲凉的气氛收场，原本兄弟姐妹5人团聚后再次只剩下次郎一人，而成功拥有完整人类灵魂的次郎，就像他自己预测的那样，永远被良心和邪念所折磨，走向自己的终点…… ","date":"2001-11-21","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a1/ed/28238_7UdJt.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a1/ed/28238_7UdJt.jpg","large":"https://lain.bgm.tv/pic/cover/l/a1/ed/28238_7UdJt.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a1/ed/28238_7UdJt.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a1/ed/28238_7UdJt.jpg"},"rating":{"rank":1509,"total":70,"score":7.4,"count":{"1":0,"2":0,"3":1,"4":1,"5":3,"6":7,"7":26,"8":18,"9":10,"10":4}},"tags":[{"name":"OVA","count":43},{"name":"2001","count":29},{"name":"石ノ森章太郎","count":15},{"name":"漫画改","count":11},{"name":"StudioOX","count":8},{"name":"大西信介","count":6},{"name":"漫改","count":5},{"name":"元永庆太郎","count":4},{"name":"科幻","