[{"date":"1957-06-07","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/bb/c6/634805_rPQ2r.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/bb/c6/634805_rPQ2r.jpg","large":"https://lain.bgm.tv/pic/cover/l/bb/c6/634805_rPQ2r.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/bb/c6/634805_rPQ2r.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/bb/c6/634805_rPQ2r.jpg"},"summary":"　　安逸宁静的某个夜晚，杰瑞安坐家中一边看书一边吃着老鼠夹子上的奶酪。这时门铃声响起，他起身开门，发现外面根本没有任何人。当然他没注意到自己的脚下，一只灰色的小老鼠见开了门，自顾自走了进去。杰瑞回转过身，发现小灰鼠正冒险去摘老鼠夹子上的奶酪。他赶忙救了那个小家伙，并看了小灰鼠带来的心。原来眼前穿着尿布的小老鼠是他的侄子尼波尔，表哥拜托杰瑞帮忙照看，并特别叮嘱尼波尔是一个经常处于饥饿状态的老鼠。没有办法，杰瑞只得带着侄子外出觅食，他们从汤姆的食盆里偷牛奶，在刚刚准备丰盛的餐桌上大快朵颐，谁知竟惹到了酣睡的汤姆……","name":"Feedin' the Kiddie","name_cn":"喂养小孩","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"喂养小孩"},{"key":"上映年度","value":"1957年6月7日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0050384"}],"rating":{"rank":0,"total":3,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":1,"8":0,"9":0,"10":0},"score":6},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":5,"doing":0},"id":634805,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]