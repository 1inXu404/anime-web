[{"date":"1930-09-22","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/81/fd/133724_qwJ1g.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/81/fd/133724_qwJ1g.jpg","large":"https://lain.bgm.tv/pic/cover/l/81/fd/133724_qwJ1g.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/81/fd/133724_qwJ1g.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/81/fd/133724_qwJ1g.jpg"},"summary":"　　最新一期的报纸登载了骇人听闻的消息，一头凶恶残暴的杀人猩猩从动物园逃出，报纸警告市民锁好房门，以免受到伤害，并悬赏巨额奖金捉拿大猩猩。米奇（沃尔特·迪斯尼 Walt Disney 配音）读到这则消息惶恐不安，他打电话给女朋友米妮（玛西丽特·加纳 Marcellite Garner 配音），提醒她千万小心，不要落到大猩猩的手中。可是，米妮似乎不为所动，她甚至隔着电话用钢琴弹奏了名为《All Alone》的欢快曲调，让米奇知道她十分安全。 \r\n　　也许米奇过于紧张了，可是米妮又似乎过于乐观。正在她弹琴的时候，大猩猩钻进她的院子，慢慢逼向了欢歌中的米妮。刺耳的尖叫声划破夜空……","name":"The Gorilla Mystery","name_cn":"大猩猩的秘密","tags":[{"name":"1930","count":3,"total_cont":0},{"name":"短片","count":3,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"欧美","count":2,"total_cont":0},{"name":"迪士尼","count":2,"total_cont":0},{"name":"绳缚","count":1,"total_cont":0},{"name":"逃出","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"空屋","count":1,"total_cont":0},{"name":"4(-1)","count":1,"total_cont":0},{"name":"1930-1939","count":1,"total_cont":0},{"name":"气氛","count":1,"total_cont":0},{"name":"大猩猩","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"Disney","count":1,"total_cont":0},{"name":"米奇","count":1,"total_cont":0},{"name":"1930s","count":1,"total_cont":0},{"name":"米妮","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"大猩猩的秘密"},{"key":"上映年度","value":"1930-09-22"},{"key":"片长","value":"7分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0020932"},{"key":"制片国家/地区","value":"美国"},{"key":"类型","value":"爱情 / 短片 / 家庭"},{"key":"导演","value":"Burt Gillett"},{"key":"主演","value":"Walt Disney / Marcellite Garner"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":6,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":3,"7":1,"8":1,"9":0,"10":0},"score":6.2},"total_episodes":0,"collection":{"on_hold":0,