ta_tags":["日本"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1990-03-23","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e7/16/73016_FaPha.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e7/16/73016_FaPha.jpg","large":"https://lain.bgm.tv/pic/cover/l/e7/16/73016_FaPha.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/e7/16/73016_FaPha.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/e7/16/73016_FaPha.jpg"},"summary":"小镇发生一连串秒杀事件，受害者都是年轻女性，原来这是素戈鸣尊为了阻止地龙借女性身体复活而为。被附身的是该镇中学生朱砂晃一。和他青梅竹马的同校女生照美由于相貌丑陋经常被同学欺负，但是有一天却突然变美了。原来照美暗恋晃一的心被地龙所利用，借用其身体复活。照美不断吸收周围有生命的东西的生命力，最后还吞噬了照美的身体，变身成巨龙大肆破坏。在修行者小夜子的协助下，附身晃一的现身并与地龙战斗。最终重伤之下终于封住了地龙。 ","name":"暗黒神伝承 武神","name_cn":"暗黑武神传","tags":[{"name":"OVA","count":14,"total_cont":0},{"name":"J.C.STAFF","count":5,"total_cont":0},{"name":"原创","count":3,"total_cont":0},{"name":"神魔","count":2,"total_cont":0},{"name":"榊原良子","count":1,"total_cont":0},{"name":"若本规夫","count":1,"total_cont":0},{"name":"日高法子","count":1,"total_cont":0},{"name":"1990","count":1,"total_cont":0},{"name":"大张我信你啊","count":1,"total_cont":0},{"name":"冷门","count":1,"total_cont":0},{"name":"1990年","count":1,"total_cont":0},{"name":"90年代","count":1,"total_cont":0},{"name":"速水奖","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"中庸","count":1,"total_cont":0},{"name":"山崎理","count":1,"total_cont":0},{"name":"奇幻","count":1,"total_cont":0},{"name":"独立ova","count":1,"total_cont":0},{"name":"战斗","count":1,"total_cont":0},{"name":"龙","count":1,"total_cont":0},{"name":"井上和彦","count":1,"total_cont":0},{"name":"变身类","count":1,"total_cont":0},{"name":"角色后备","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"暗黑武神传"},{"key":"话数","value":"3"},{"key":"发售日","value":"1990年3月23日"},{"key":"开始","value":"1990年3月23日"},{"key":"结束","value":"1992年1月24日"},{"key":"脚本","value":"山崎理"},{"key":"作画监督","value":"大貫健一、大張正己"},{"key":"音乐","value":"長岡成貢"},{"key":"美术监督","value":"砂川千里"},{"key":"色彩设计","value":"武内和子（第2・3話）"},{"