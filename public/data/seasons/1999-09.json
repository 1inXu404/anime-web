寻宝，危机重重。地球军的基特大佐下令炮击「机械防护罩」，不料这个星球却开始发生核融反应，眼看整个行星即将毁灭，却仍然不见小纯与美佑的踪影…… Sol-bianca经过漫长的太空航行停泊在一个小行星的宇宙港，由於这个星球的政府实施治安民营化政策，所以人们为了保护自己只好倚靠金钱或自身的武力。布斯达是个脑部经过强化改造的超能者，为了暗杀这个星球的女总统，趁机抢夺了Sol-bianca太空船，艾裴莉、小纯、费芙等人都成为人质，姜倪为了解救伙伴的性命，只身与布斯达控制的怪兽兵团展开血腥的战斗……","name":"太陽の船 ソルビアンカ","name_cn":"太阳之船 SOL BIANCA","tags":[{"name":"OVA","count":40,"total_cont":0},{"name":"AIC","count":22,"total_cont":0},{"name":"1999","count":15,"total_cont":0},{"name":"科幻","count":12,"total_cont":0},{"name":"越智博之","count":11,"total_cont":0},{"name":"恩田尚之","count":8,"total_cont":0},{"name":"SF","count":7,"total_cont":0},{"name":"女性","count":5,"total_cont":0},{"name":"独立ova","count":5,"total_cont":0},{"name":"榊原良子","count":5,"total_cont":0},{"name":"补番","count":5,"total_cont":0},{"name":"赛璐珞","count":3,"total_cont":0},{"name":"三井秀樹","count":2,"total_cont":0},{"name":"松本梨香","count":2,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"北爪宏幸","count":1,"total_cont":0},{"name":"机战","count":1,"total_cont":0},{"name":"旧番","count":1,"total_cont":0},{"name":"90s","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"秋山胜仁","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"南康宏","count":1,"total_cont":0},{"name":"日漫","count":1,"total_cont":0},{"name":"宫岛依里","count":1,"total_cont":0},{"name":"中川聪","count":1,"total_cont":0},{"name":"小杉十郎太","count":1,"total_cont":0},{"name":"吉田彻","count":1,"total_cont":0},{"name":"三井秀树","count":1,"total_cont":0},{"name":"1999年","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"太阳之船 SOL BIANCA"},{"key":"别名","value":[{"v":"Sol Bianca"},{"v":"SOL BIANCA The Legacy"}]},{"key":"话数","value":"6"},{"key":"发售日","value":"1999年9月24日"},{"key":"开始","value":"1999年9月24日"},{"key":"结束","value":"2000年10月6日"},{"key":"导演","value":"越智博之"},{"key":"脚本","value":"三井秀樹"},{"key":"音乐","value":"長岡成貢"},{"key":"动画制作","value":"AIC"}],"rating":{"rank":0,"total":50,"count":{"1":0,"2":0,"3":4,"4":5,"5":15,"6":16,"7":9,"8":1,"9":0,"10":0},"score":5.5},