ps://lain.bgm.tv/pic/cover/l/b2/f3/37239_Vz55X.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/b2/f3/37239_Vz55X.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/b2/f3/37239_Vz55X.jpg"},"summary":"異星の侵略軍に95％までが征服された地球を舞台とした、ハードな世界観を誇る巨大ロボットアニメ。　マゼラン星の天体ガニメデの突然変異生物・ヘドロン皇帝は、王家を含むガニメデの人民を洗脳。己の侵略兵団に変えてその魔手を地球にも伸ばす。だがガニメデ王家の血を引く若者ジミー・オリオンを仲間に迎えた地球の秘密部隊・合身戦隊は、反撃の切り札となる巨大戦闘ロボ・メカンダーロボを建造。ガニメデ軍に戦いを挑む。だがそれは、敵の中に洗脳された実母メデューサがいるジミーにとって、辛く長い戦いの始まりでもあった。脚本の陶山智、演出の富野由悠季（当時・喜幸）など異才のスタッフが集結した、ロボットアニメの秀作。","name":"合身戦隊メカンダーロボ","name_cn":"合身战队麦康达机器人","tags":[{"name":"1977","count":6,"total_cont":0},{"name":"原创","count":4,"total_cont":0},{"name":"和光PRODUCTION","count":4,"total_cont":0},{"name":"TV","count":4,"total_cont":0},{"name":"萝卜","count":3,"total_cont":0},{"name":"1977年3月","count":2,"total_cont":0},{"name":"robo","count":2,"total_cont":0},{"name":"机战","count":2,"total_cont":0},{"name":"海堂清彦","count":2,"total_cont":0},{"name":"日本","count":2,"total_cont":0},{"name":"曽我部和行","count":2,"total_cont":0},{"name":"70s","count":1,"total_cont":0},{"name":"和光プロダクション","count":1,"total_cont":0},{"name":"待補1","count":1,"total_cont":0},{"name":"新田義方","count":1,"total_cont":0},{"name":"1970s","count":1,"total_cont":0},{"name":"70","count":1,"total_cont":0},{"name":"三季番","count":1,"total_cont":0},{"name":"3クール","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"机甲","count":1,"total_cont":0},{"name":"陶山智","count":1,"total_cont":0},{"name":"ロボットアニメ","count":1,"total_cont":0},{"name":"神谷明","count":1,"total_cont":0},{"name":"TVA","count":1,"total_cont":0},{"name":"赛璐珞","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"合身战队麦康达机器人"},{"key":"别名","value":[{"v":"合身战队机器人Mechander"},{"v":"合身战队Mechander Robo"},{"v":"电磁超人飞金刚"},{"v":"金刚小宝贝"}]},{"key":"话数","value":"35"},{"key":"放送开始","value":"1977年3月3日"},{"key":"播放电视台","value":"東京12チャンネル（现：テレビ東京）"},{"key":"播放结束","value":"1977年12月29日"},{"key":"导演","value":"新田義方（チーフディレクター制を採用しておらず、