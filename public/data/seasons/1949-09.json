[{"id":275354,"type":2,"name":"The Cat and the Mermouse","name_cn":"猫与人鱼鼠","summary":"　　炎炎夏日，汤姆正坐在海边沙滩之上，他从容不迫地在身上涂上防晒霜和护肤霜，然后挖了一个沙坑躺了进去，又用毛巾盖住头部小作休息。这时候，快乐的小老鼠杰瑞扛着鱼竿从远处走来，他根本没注意沙子下面还躺着汤姆，于是自顾自走了上去，没留神还掉进汤姆嘴里，以致毛巾差点把汤姆噎死。 \r\n　　生气的老猫发现杰瑞惊扰了自己的小憩，于是跟上前去捣乱。两个冤家又是一通你来我往的争斗，最终汤姆被狠狠地砸中脑袋，掉入大海。不会游泳的汤姆奋力挣扎，可是依旧沉到了海底，他忽然发现自己可以在海底呼吸，而且见到了一个和杰瑞一模一样的小美人鱼……","date":"1949-09-03","images":null,"rating":{"rank":0,"total":30,"score":7.1,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":6,"7":13,"8":8,"9":1,"10":1}},"tags":[{"name":"短片","count":20},{"name":"猫和老鼠","count":11},{"name":"欧美","count":9},{"name":"1949","count":7},{"name":"美国","count":5},{"name":"原创","count":4},{"name":"米高梅","count":3},{"name":"1940s","count":2},{"name":"Short","count":1},{"name":"剧场版-02","count":1}],"eps":1,"collection":{"wish":6,"collect":76,"doing":1,"on_hold":1,"dropped":5}},{"id":280526,"type":2,"name":"Little Rural Riding Hood","name_cn":"田园小红帽","summary":"","date":"1949-09-17","images":null,"rating":{"rank":0,"total":21,"score":6.3,"count":{"1":1,"2":0,"3":1,"4":0,"5":3,"6":4,"7":9,"8":2,"9":0,"10":1}},"tags":[{"name":"短片","count":12},{"name":"1949","count":7},{"name":"美国","count":6},{"name":"欧美","count":5},{"name":"Tex_Avery","count":2},{"name":"米高梅","count":2},{"name":"1940s","count":2},{"name":"MGM","count":1},{"name":"Tex·Avery","count":1},{"name":"补","count":1},{"name":"1940-1949","count":1}],"eps":0,"collection":{"wish":5,"collect":35,"doing":0,"on_hold":2,"dropped":5}},{"id":280518,"type":2,"name":"The Ragtime Bear with Mister Magoo","name_cn":"爵士熊与马古先生","summary":"","date":"1949-09-29","images":null,"rating":{"rank":0,"total":11,"score":6,"count":{"1":0,"2":0,"3":0,"4":1,"5":1,"6":7,"7":1,"8":1,"9":0,"10":0}},"tags":[{"name":"短片","count":9},{"name":"美国","count":5},{"name":"1949","count":5},{"name":"欧美","count":2},{"name":"upa","count":2},{"name":"1940s","count":2},{"name":"40s","count":1},{"name":"哥伦比亚","count":1},{"name":"5(0)","count":1},{"name":"约翰·哈布雷","count":1},{"name":"Hubley","count":1}],"e