[{"date":"1952-07-26","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/08/7b/634617_26yw5.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/08/7b/634617_26yw5.jpg","large":"https://lain.bgm.tv/pic/cover/l/08/7b/634617_26yw5.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/08/7b/634617_26yw5.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/08/7b/634617_26yw5.jpg"},"summary":"　　大狗史派克趾高气扬在院子里散步，结果不慎踩到了一枚钉子。他疼得嗷嗷大叫，痛苦哀号，甚至在小老鼠杰瑞为他拔掉钉子后还兀自沉浸在虚妄的痛苦之中。事后，史派克十分感激杰瑞的仗义，于是送给他一只铃铛，承诺杰瑞遇到困难时只要摇动铃铛史派克就会飞奔前来营救。刚刚告别史派克，杰瑞便遭到老猫汤姆的袭击，当然铃铛拯救了杰瑞，汤姆遭到大狗的一顿胖揍。\r\n　　三番五次失败的捕捉之后，汤姆彻底臣服于杰瑞，违心送上香甜可口的奶酪。正当绝望之时，却发现社会正号召主人们将家犬拴起来。对汤姆来说，这无疑是报复杰瑞的绝好机会……","name":"Fit to Be Tied","name_cn":"有恩必报","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"有恩必报"},{"key":"上映年度","value":"1952年7月26日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0044620"}],"rating":{"rank":0,"total":4,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":2,"8":0,"9":0,"10":0},"score":6.3},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":0,"collect":6,"doing":0},"id":634617,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1952-07-12","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/69/33/470441_IM7yO.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/69/33/470441_IM7yO.jpg","large":"https://lain.bgm.tv/pic/cover/l/69/33/470441_IM7yO.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/69/33/470441_IM7yO.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/69/33/470441_IM7yO.jpg"},"summary":"Spike gets a job running the house for a hibernating bear. Only problem is that same bear is VERY noise-sensitive, and Spike's got a rival that wants his job.","name":"Rock-a-bye Bear","name_cn":"摇滚再见熊","tags":[{"name":"美国","count":2,"total_cont":0},{"name":"1952","