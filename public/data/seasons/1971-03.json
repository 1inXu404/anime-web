score":0},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":3,"collect":3,"doing":0},"id":311292,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1971-03-17","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ce/66/378810_pHnJ4.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ce/66/378810_pHnJ4.jpg","large":"https://lain.bgm.tv/pic/cover/l/ce/66/378810_pHnJ4.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ce/66/378810_pHnJ4.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ce/66/378810_pHnJ4.jpg"},"summary":"富士見学園高校の一年になったこずえと、家業の青果店を継いだ努は、互いに励まし合う親友だった。その頃、こずえの胸には八木沢三姉妹の三位一体攻撃が焼きついて離れなかった。この三姉妹のいる寺堂院高校は、三年連続インターハイで優勝。この攻撃を破らなければこずえ達に栄光はない。そして、こずえ達の血の滲む練習は繰り返され、向かえた寺堂院高校との決勝戦。だが、その最中に努が交通事故で危篤という知らせが届いた。悲しみを胸に、こずえは力の限り新しい技・ダブルアタックに挑戦した。","name":"アタックNo.1 涙の不死鳥","name_cn":"剧场版 排球甜心：泪之不死鸟","tags":[{"name":"旧物","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"剧场版 排球甜心：泪之不死鸟"},{"key":"别名","value":[{"v":"Attack No.1: Namida no Fushichou"}]},{"key":"上映年度","value":"1971年3月17日"},{"key":"原作","value":"浦野千賀子"},{"key":"脚本","value":"田村多津夫、辻真先、七条門、山崎晴哉、伊東恒久"},{"key":"作画监督","value":"竹内留吉、中村英一"},{"key":"美术监督","value":"池田準"},{"key":"摄影监督","value":"清水達正"},{"key":"音乐","value":"渡辺岳夫"},{"key":"录音监督","value":"山崎あきら"},{"key":"演出","value":"黒川文男"},{"key":"Copyright","value":"浦野千賀子・ＴＭＳ"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":0,"7":0,"8":0,"9":0,"10":0},"score":4},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":7,"collect":4,"doing":0},"id":378810,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1971-03-09","platform":"其他","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/eb/c6/617243_J9hHH.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/eb/c6/617243_J9hHH.jpg","large":"https://lain.bgm.tv/pic/cover/l/eb/c6/617243_J9hHH.jpg","medium