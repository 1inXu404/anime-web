[{"date":"1933-02-18","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/d6/6c/133772_QhAwb.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/d6/6c/133772_QhAwb.jpg","large":"https://lain.bgm.tv/pic/cover/l/d6/6c/133772_QhAwb.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/d6/6c/133772_QhAwb.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/d6/6c/133772_QhAwb.jpg"},"summary":"　　在一个春寒料峭的日子里，河面上漂浮着些许浮冰。米奇（沃尔特·迪斯尼 Walt Disney 配音）和女朋友米妮（玛西丽特·加纳 Marcellite Garner 配音）带着爱犬布鲁托（品托·考维格 Pinto Colvig 配音）在郊外散步。这时候，布鲁托意外发现河面上漂过来的还在蠕动着的口袋。米奇他们将口袋捞上来，里面竟然都是刚出生不久的小猫！究竟是哪个狠心的人将这群无辜的小生灵扔入河中，企图剥夺它们孱弱的生命啊！善良的米奇和米妮将小猫们带回家中，为它们取暖、梳理毛发、准备食物。一旁的布鲁托也感到高兴，可是他心里邪恶的一面却跳出来，警告小猫们正夺取主人对布鲁托的爱；而善良的一面则叮咛布鲁托要善待这群小生命。 \r\n　　布鲁托该怎样选择呢？","name":"Mickey's Pal Pluto","name_cn":"米奇的好朋友布鲁托","tags":[{"name":"剧场版","count":3,"total_cont":0},{"name":"短片","count":2,"total_cont":0},{"name":"1933","count":2,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"迪士尼","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"1930s","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"米奇的好朋友布鲁托"},{"key":"上映年度","value":"1933-02-18"},{"key":"片长","value":"8分钟"},{"key":"语言","value":"英语"},{"key":"IMDb链接","value":"tt0024332"},{"key":"类型","value":"喜剧  / 短片 / 家庭"},{"key":"制片国家/地区","value":"美国"},{"key":"导演","value":"Burt Gillett"},{"key":"主演","value":"Pinto Colvig / 华特·迪斯尼 / Marcellite Garner"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":7,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":3,"8":1,"9":0,"10":0},"score":6.6},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":1,"collect":18,"doing":0},"id":133772,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]