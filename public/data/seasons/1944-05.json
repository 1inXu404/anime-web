[{"date":"1944-05-06","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a4/99/262701_V3ISc.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a4/99/262701_V3ISc.jpg","large":"https://lain.bgm.tv/pic/cover/l/a4/99/262701_V3ISc.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a4/99/262701_V3ISc.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a4/99/262701_V3ISc.jpg"},"summary":"　　超级无聊的一天，坏坏的汤姆将小老鼠杰瑞绑起来，头顶苹果置于对面柜子上，玩起了飞镖游戏。他花样百出，乐在其中，却不知杰瑞大汗淋漓，几乎吓破了胆。这时候一封电报从门缝塞了进来，上面写道汤姆从古怪的哈瑞特阿姨那里继承了一笔高达100万美金的遗产。汤姆起初没反应过来，当他再次读过电报后，兴奋地在屋子里翻起跟头。懵懵懂懂的杰瑞走上前也读了一遍电报，随后也如汤姆一般大翻跟头。原来遗嘱中有一条附加条款，那就是汤姆绝对不可伤害任何生命——甚至一只老鼠也不行。在此之后，百万富猫的消息占领各大报纸头条，汤姆趾高气扬搬进纽约派克大街的豪华公寓，当然他的老冤家杰瑞也乘势发迹。 \r\n　　碍于遗嘱中的条款，汤姆不得不忍受杰瑞各种嚣张举止……","name":"The Million Dollar Cat","name_cn":"百万富翁","tags":[{"name":"短片","count":21,"total_cont":0},{"name":"猫和老鼠","count":9,"total_cont":0},{"name":"欧美","count":8,"total_cont":0},{"name":"1944","count":8,"total_cont":0},{"name":"美国","count":4,"total_cont":0},{"name":"MGM","count":2,"total_cont":0},{"name":"60年代前","count":2,"total_cont":0},{"name":"米高梅","count":2,"total_cont":0},{"name":"先驱","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"7(+2)","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"百万富翁"},{"key":"上映年度","value":"1944-05-06"},{"key":"片长","value":"7分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":36,"count":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":4,"7":19,"8":9,"9":2,"10":0},"score":7.1},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":7,"collect":88,"doing":2},"id":262701,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]