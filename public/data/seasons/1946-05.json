[{"date":"1946-05-18","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/0e/53/262833_rjSq9.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/0e/53/262833_rjSq9.jpg","large":"https://lain.bgm.tv/pic/cover/l/0e/53/262833_rjSq9.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/0e/53/262833_rjSq9.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/0e/53/262833_rjSq9.jpg"},"summary":"　　平静的一天，急促的敲门声惊醒了杰瑞的美梦。他打开房门，没有见到任何人影，却在脚下发现一个提篮。篮中是一个嗷嗷待哺的幼鼠，名叫尼波斯（Nibbles），便条中写道请喂尼波斯牛奶喝。面对眼前这个无助的小家伙，杰瑞只得担负起照顾他的重任。幸运的是房间里正好有一盘牛奶，不幸的是盘子却在熟睡的汤姆的面前。尼波斯初生牛犊不怕虎，眼睛里只有牛奶没有老猫，他的鲁莽行为吓坏了杰瑞，虽然尝试用各种办法避过汤姆得到牛奶，可是终究暴露了踪迹。 \r\n　　小气的汤姆当然不会拱手将牛奶让给别人，他想方设法整治骚扰他的“小偷们”，混战由此展开……","name":"The Milky Waif","name_cn":"吃奶的小孤儿","tags":[{"name":"短片","count":19,"total_cont":0},{"name":"猫和老鼠","count":11,"total_cont":0},{"name":"欧美","count":10,"total_cont":0},{"name":"1946","count":6,"total_cont":0},{"name":"早于1980年","count":3,"total_cont":0},{"name":"米高梅","count":2,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"美国","count":2,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"威廉·汉纳","count":1,"total_cont":0},{"name":"Joseph.Barbera","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"5(0)","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"William.Hanna","count":1,"total_cont":0},{"name":"童年","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0},{"name":"鼠来晚餐","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"吃奶的小孤儿"},{"key":"别名","value":[{"v":"噩梦成真"}]},{"key":"上映年度","value":"1946年5月18日"},{"key":"片长","value":"7分钟"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":39,"count":{"1":0,"2":0,"3":0,"4":0,"5":3,"6":7,"7":19,"8":8,"9":2,"10":0},"score":7},"total_episodes":0,"collection":{"on_hold":0,"dropped":6,"wish":3,"collect":87,"doing":1},"id":262833,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2}]