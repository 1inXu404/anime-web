[{"date":"1988-01-23","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/28/af/314000_M0e8p.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/28/af/314000_M0e8p.jpg","large":"https://lain.bgm.tv/pic/cover/l/28/af/314000_M0e8p.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/28/af/314000_M0e8p.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/28/af/314000_M0e8p.jpg"},"summary":"クメンを脱出したキリコとフィアナのシャトルは、何者かによって無人の戦艦へと収容されていた。戦艦Ｘの内部で安息の一時を過ごす二人の前にレッドショルダーマーチが鳴り響く。己の過去に直面させられ、精神を病んでいくキリコ。\r\n　やがて、惑星サンサに不時着した戦艦Ｘの前に、イプシロン率いるAT部隊が迫る。戦艦Ｘを爆発させることによって逃れたキリコとフィアナはゴウトたちと再会、彼らとともに再生武器商人のアジトに身を寄せる。だが、イプシロン隊とバララント軍の攻撃が開始され、キリコはゴウトたちと別れてしまう。ヂヂリウムを確保するため、バララント軍の残した補給基地を目指し、フィアナを背負って荒野を行くキリコ。その後を、キリコに恩讐の念を抱くゾフィーが追う。\r\n谷口守泰の作画による新オープニング、塩山紀生の作画による新エンディングに注目。","name":"装甲騎兵ボトムズ サンサ","name_cn":"装甲骑兵 山萨","tags":[{"name":"OVA","count":11,"total_cont":0},{"name":"1988","count":5,"total_cont":0},{"name":"SUNRISE","count":4,"total_cont":0},{"name":"高橋良輔","count":3,"total_cont":0},{"name":"科幻","count":2,"total_cont":0},{"name":"サンライズ","count":2,"total_cont":0},{"name":"总集篇","count":2,"total_cont":0},{"name":"robo","count":2,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"1988年1月","count":1,"total_cont":0},{"name":"装甲騎兵ボトムズ","count":1,"total_cont":0},{"name":"1980-1989","count":1,"total_cont":0},{"name":"机战","count":1,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"高桥良辅","count":1,"total_cont":0},{"name":"1988年","count":1,"total_cont":0},{"name":"日本动画","count":1,"total_cont":0},{"name":"机甲","count":1,"total_cont":0},{"name":"原創","count":1,"total_cont":0},{"name":"郷田ほづみ","count":1,"total_cont":0},{"name":"吉川惣司","count":1,"total_cont":0},{"name":"萝卜","count":1,"total_cont":0},{"name":"五武冬史","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"装甲骑兵 山萨"},{"key":"别名","value":[{"v":"Soukou Kihei Votoms: Sunsa"}]},{"key":"话数","value":"1"},{"key":"发售日","value":"1988年1月23日"},{"key":"官方网站","value":"https://www.sunrise-inc.co.jp/work/det