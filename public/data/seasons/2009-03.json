ll":"https://lain.bgm.tv/r/200/pic/cover/l/fa/a3/53386_78zsm.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/fa/a3/53386_78zsm.jpg","large":"https://lain.bgm.tv/pic/cover/l/fa/a3/53386_78zsm.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/fa/a3/53386_78zsm.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/fa/a3/53386_78zsm.jpg"},"rating":{"rank":4039,"total":85,"score":6.5,"count":{"1":2,"2":1,"3":1,"4":2,"5":7,"6":23,"7":34,"8":11,"9":2,"10":2}},"tags":[{"name":"欧美","count":24},{"name":"OVA","count":23},{"name":"2009","count":18},{"name":"短片","count":18},{"name":"美国","count":8},{"name":"dc","count":8},{"name":"漫画改","count":7},{"name":"漫改","count":6},{"name":"美国动画","count":5},{"name":"MikeSmith","count":3}],"eps":1,"collection":{"wish":29,"collect":138,"doing":1,"on_hold":3,"dropped":9}},{"id":579370,"type":2,"name":"LaMB禁錮天使","name_cn":"LaMB禁锢天使","summary":"　　《LaMB无声天使》，是一部Animax原创制作的动画。导演是程亮弼。编剧是Carmelo S. J. Juinio，并于2009年3月于全亚洲播出。 它也是为首个Animax Asia制作的高清动画。本作品取自2007年泛亚洲动画剧本比赛（Animax Awards，台湾称为Animax动画大赏）泛亚特别赏之受赏作品，作者为菲律宾业余作家Carmelo Juinio。法国和加拿大乐队简单计划（Simple Plan）和美国乐队五次方乐团（The Click Five）将会有两首不同的歌曲（I Can Wait Forever和Summertime），作为动画的主题曲。台湾及香港于2009年3月24日起，星期二晚间十点在Animax播出。2009年9月1日起，台湾、香港及东南亚Animax陆续播出《LaMB Redux》（LaMB 禁锢天使　再起动），每集2分钟，共22集。本动画于2009年10月16日荣获第44届金钟奖最佳动画影片奖，评审表示，该作选材新颖，且风格设计、导演手法和技术表现上都具有极佳的表现。\r\n　　故事讲述在环境恶劣的沙漠星球席诺，当地发明了一种新的监禁制度“禁锢计划”。这种虚拟的奴隶制度透过特殊囚衣“禁锢衣”惩处重罪犯，令他们在丧失自由的情况下仍能为社会提供生产力。这班重罪犯被称为“禁锢天使”。“禁锢计划”令社会不再需要监狱及死刑。这个制度同时引发争议，席诺的市民对禁锢计划是否道德并未达成共识。2位主角夏娃（Eve）及杰克·葛斯沃（Jack Griswold）对抗“禁锢计划”无形监狱的制度。夏娃原本是一名科学家，可惜由她带领的科学实验发生意外并造成大量人命伤亡，所以被判成为“禁锢天使”。杰克则是一名从其他星球来访的科学家，为了忘记已故的妻子，拼命把自己沉醉于工作中。辗转间他无意地被卷入“禁锢天使”和无形监狱的政治之中，并与夏娃产生一段浪漫的爱情。  ","date":"2009-03-24","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/77/59/579370_b7UcF.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/77/59/579370_b7UcF.jpg","large":"https://lain.bgm.tv/pic/cover/l/77/59/579370_b7UcF.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/77/59/579370_b7UcF.jpg","commo