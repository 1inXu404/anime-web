錄影帶，但是心細的影迷立刻發現有幾幕被刪掉了！為此還向迪士尼提出抗議…至於美國則在１９９８年首度發行錄影帶，發行的則是當初完整的版本。","name":"The Black Cauldron","name_cn":"黑神锅传奇","tags":[{"name":"欧美","count":7,"total_cont":0},{"name":"迪士尼","count":6,"total_cont":0},{"name":"Disney","count":5,"total_cont":0},{"name":"1985","count":4,"total_cont":0},{"name":"剧场版","count":2,"total_cont":0},{"name":"动画电影","count":2,"total_cont":0},{"name":"美国","count":2,"total_cont":0},{"name":"TedBerman","count":1,"total_cont":0},{"name":"GrantBardsley","count":1,"total_cont":0},{"name":"劇場版","count":1,"total_cont":0},{"name":"RichardRich","count":1,"total_cont":0},{"name":"映画","count":1,"total_cont":0},{"name":"1986","count":1,"total_cont":0},{"name":"美国动画","count":1,"total_cont":0},{"name":"20世纪","count":1,"total_cont":0},{"name":"アニメ映画","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"黑神锅传奇"},{"key":"别名","value":[{"v":"Taran and the Magic Cauldron"},{"v":"黑神鍋"}]},{"key":"上映年度","value":"1985-07-24(美国) / 1986-10-19(中国大陆)"},{"key":"片长","value":"80 分钟"},{"key":"导演","value":"Ted Berman、Richard Rich"},{"key":"编剧","value":"Al Winston、Art Stevens、David Jonas、Joe Hale、Peter Young、Richard Rich、Rosemary Anne Sisson、Roy Edward Disney、Roy Morita、Ted Berman、Vance Gerry"},{"key":"主演","value":"Grant Bardsley、Susan Sheridan、弗雷迪·琼斯、奈杰尔·霍桑、Arthur Malet"},{"key":"话数","value":"1"},{"key":"音乐","value":"Elmer Bernstei"},{"key":"制片人","value":"Joe Hale"},{"key":"执行制片人","value":"Ron Miller"}],"rating":{"rank":0,"total":11,"count":{"1":0,"2":2,"3":0,"4":1,"5":2,"6":5,"7":1,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":3,"dropped":5,"wish":11,"collect":20,"doing":1},"id":66238,"eps":1,"meta_tags":["剧场版","欧美"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1985-07-23","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/e6/30/79946_0dm2A.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/e6/30/79946_0dm2A.jpg","large":"https://lain.bgm.tv/pic/cover/l/e6/30/79946_0dm2A.jpg","medium":"https