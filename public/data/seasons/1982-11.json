[{"date":"1982-11-19","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/01/32/113268_WJ4U4.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/01/32/113268_WJ4U4.jpg","large":"https://lain.bgm.tv/pic/cover/l/01/32/113268_WJ4U4.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/01/32/113268_WJ4U4.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/01/32/113268_WJ4U4.jpg"},"summary":"她是世界上最后一只孤独的独角兽（米亚·法罗 Mia Farrow配音），一直平静地生活在一片美丽的森林里。为了找寻失散的同伴，她毅然离开了熟悉的森林，踏上了寻找同类的旅程。一路上，她与人类朋友一个年轻的魔法师施曼德里克（艾伦·阿金 Alan Arkin配音）和一个热情的江湖侠女莫利（黛咪·格兰姆斯 Tammy Grimes配音）结伴同行。途中，变成人类少女的独角兽与李尔王子（杰夫·布里吉斯 Jeff Bridges配音）深深相爱。终于，经历种种磨难与环环险境，他们合力解救出被囚禁的独角兽们。她又回到了属于她的森林里，自由地生活着。 \r\n　　本部魔幻动画片《最后的独角兽》改编自美国作家彼得·S·毕格创作的同名魔幻小说《最后的独角兽》，影片的剧本也由彼得·S·毕格亲自执笔。1982年，美国Rankin/Bass公司为英国ITC电视公司制作了这部动画电影，在公映后获得了巨大的成功，成为经典的动画片之一。","name":"The Last Unicorn","name_cn":"最后的独角兽","tags":[{"name":"欧美","count":10,"total_cont":0},{"name":"动画电影","count":5,"total_cont":0},{"name":"剧场版","count":5,"total_cont":0},{"name":"最后的独角兽","count":4,"total_cont":0},{"name":"1982","count":3,"total_cont":0},{"name":"歌舞","count":2,"total_cont":0},{"name":"自身存在意义","count":2,"total_cont":0},{"name":"童年","count":2,"total_cont":0},{"name":"非日本动画","count":2,"total_cont":0},{"name":"海洋真好","count":2,"total_cont":0},{"name":"恋爱","count":2,"total_cont":0},{"name":"动作不流畅","count":2,"total_cont":0},{"name":"OP","count":2,"total_cont":0},{"name":"旅途","count":1,"total_cont":0},{"name":"20世纪","count":1,"total_cont":0},{"name":"爱情","count":1,"total_cont":0},{"name":"Arthur.Rankin","count":1,"total_cont":0},{"name":"动物拟人","count":1,"total_cont":0},{"name":"英国","count":1,"total_cont":0},{"name":"7","count":1,"total_cont":0},{"name":"记忆模糊","count":1,"total_cont":0},{"name":"童年印象","count":1,"total_cont":0},{"name":"Jules.Bass","count":1,"total_cont":0},{"name":"劇場版","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"最后的独角兽"},{"key":"别名","value":[{"v":"独角飞马"},{"v":"最后独角兽"}]},{"key":"上映年度","value":"1982-11-19"},{"key":"片长","v