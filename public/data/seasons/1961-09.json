[{"id":634850,"type":2,"name":"Switchin' Kitten","name_cn":"猫狗互换","summary":"　　狂风暴雨，电闪雷鸣。在崎岖蜿蜒的山道上，一辆马车左突右撞，惊现非常。在某个拐角处，马车突然甩下一个布口袋。那里是搭车而来的汤姆，他大声抗议马车师傅的粗鲁，不过全然没有用处，于是只得提着皮包赶路。不远处有一个阴森古堡，那里住着邪恶的博士和他的老鼠助手杰瑞。他们发明了一台奇怪的机器，可以将不同动物的身体互换。这时，汤姆辗转来到古堡，他看到安然倚在墙角休息的杰瑞，准备抓住他美食一顿，可是拥有猫的身体的大狗成为杰瑞最忠实的保镖，决不允许汤姆欺负他的朋友。\r\n　　倒霉的汤姆遭到一连串的打击……","date":"1961-09-07","images":null,"rating":{"rank":0,"total":2,"score":5.5,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":0,"7":1,"8":0,"9":0,"10":0}},"tags":[{"name":"短片","count":2},{"name":"猫和老鼠","count":1},{"name":"剧场版","count":1},{"name":"1960s","count":1}],"eps":0,"collection":{"wish":0,"collect":4,"doing":0,"on_hold":0,"dropped":0}},{"id":475153,"type":2,"name":"かぐや姫","name_cn":"辉夜姬","summary":"本片获第14届戛纳电影节主竞赛单元短片金棕榈提名","date":"1961-09-14","images":null,"rating":{"rank":0,"total":4,"score":6.5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":2,"7":0,"8":0,"9":1,"10":0}},"tags":[{"name":"短片","count":3},{"name":"1961","count":2},{"name":"定格动画","count":1},{"name":"日本动画","count":1},{"name":"学研","count":1},{"name":"日本","count":1}],"eps":0,"collection":{"wish":4,"collect":7,"doing":3,"on_hold":0,"dropped":1}}]