[{"date":"1947-02-24","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/1e/e3/219911_6gC5o.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/1e/e3/219911_6gC5o.jpg","large":"https://lain.bgm.tv/pic/cover/l/1e/e3/219911_6gC5o.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/1e/e3/219911_6gC5o.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/1e/e3/219911_6gC5o.jpg"},"summary":"熊猫安迪和啄木鸟伍迪为农庄的动物们做出了精彩的钢琴演出，演奏的曲目是《肖邦波兰舞曲》。\r\n\r\n本片是环球影业发行的“微型音乐剧”(Musical Miniatures)系列中的一集，同为环球影业发行且同样由沃特·蓝兹担任制片人的动画短片系列《熊猫安迪》(Andy Panda)的主角安迪和\"Cartunes\"系列的主角之一啄木鸟伍迪联袂出演。\r\n\r\n本片参评1946年度第19届奥斯卡最佳动画短片奖并获提名。同年参评作品中同样以知名角色演奏钢琴曲为题材的还有米高梅发行的《猫和老鼠》(Tom and Jerry)系列的《猫儿协奏曲》(Cat Concerto)和华纳兄弟发行的《快乐旋律》(Merrie Melodies)的《兔子狂想曲》(Rhapsody Rabbit)，这两部影片因剧情和桥段类似以及选曲相同（李斯特的《第2号匈牙利狂想曲》），从而卷入了至今悬而未决的抄袭争议之中。","name":"Musical Moments from Chopin","name_cn":"肖邦音乐时光","tags":[{"name":"短片","count":4,"total_cont":0},{"name":"1947","count":3,"total_cont":0},{"name":"环球影业","count":1,"total_cont":0},{"name":"音乐短片","count":1,"total_cont":0},{"name":"欧美","count":1,"total_cont":0},{"name":"美国","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"无","count":1,"total_cont":0},{"name":"古典乐","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"肖邦音乐时光"},{"key":"上映年度","value":"1947年2月24日"},{"key":"片长","value":"8分"},{"key":"IMDB","value":"tt0038413"},{"key":"语言","value":"英语"},{"key":"制片国家/地区","value":"美国"},{"key":"类型","value":"喜剧 / 动画 / 短片 / 音乐 / 家庭"},{"key":"制片人","value":"Walter Lantz"},{"key":"导演","value":"Dick Lundy"},{"key":"编剧","value":"Ben Hardaway, Milt Schaffer"},{"key":"动画","value":"Laverne Harding, Les Kline, Emery Hawkins, Myron Henry Natwick"},{"key":"音乐","value":"Darrel Calker"},{"key":"背景美术","value":"Fred Brunish"},{"key":"动画制作","value":"Walter Lantz Productions"},{"key":"发行","value":"Universal Pictures"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":2,"count":{"1":0,"2":0,"3":0,"4":1,"5":0,"6":1,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":0,"collection":{"on_hold":0,"dropped":4,"wish":3,"collect":9,"doing":1},"id":219911,"eps":1,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1947-02-22","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c3/9c/262836_PX33G.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c3/9c/262836_PX33G.jpg","large":"https://lain.bgm.tv/pic/cover/l/c3/9c/262836_PX33G.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c3/9c/262836_PX33G.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c3/9c/262836_PX33G.jpg"},"summary":"　　在郊外一片寂静安宁的所在，坐落着一个私人领地。领地内的池塘里许多的鱼儿生活于此，这自然引起无数钓鱼爱好者的关注。主人当然不会任由人们随便垂钓，他设下无数警示牌，更安排了大狗史派克在门口蹲守。只不过，一向好耍小聪明的汤姆趁史派克睡觉的时候偷偷溜进私人领地，其间还被做梦的史派克咬了一口，幸亏他表现机敏才没被大狗发现行踪。 \r\n　　来到湖边，汤姆打开自己的用具箱，小老鼠杰瑞竟然也是他的一枚鱼饵。虽然满不情愿，杰瑞还是被汤姆扔进河里，被迫于饥饿的鱼儿搏斗，其中还有一条凶恶的大鱼。为了逃命，杰瑞想尽一切办法，他甚至唤醒了沉睡的史派克…… ","name":"Cat Fishin'","name_cn":"猫钓鱼","tags":[{"name":"短片","count":18,"total_cont":0},{"name":"猫和老鼠","count":10,"total_cont":0},{"name":"欧美","count":9,"total_cont":0},{"name":"1947","count":5,"total_cont":0},{"name":"米高梅","count":3,"total_cont":0},{"name":"美国","count":3,"total_cont":0},{"name":"童年","count":3,"total_cont":0},{"name":"1940s","count":2,"total_cont":0},{"name":"William.Hanna","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"原创","count":1,"total_cont":0},{"name":"Joseph.Barbera","count":1,"total_cont":0},{"name":"7(+2)","count":1,"total_cont":0},{"name":"Short_film","count":1,"total_cont":0},{"name":"1940-1949","count":1,"total_cont":0},{"name":"Short","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"猫钓鱼"},{"key":"别名","value":[{"v":"猫儿钓鱼记"}]},{"key":"上映年度","value":"1947年2月22日"},{"key":"片长","value":"7分46秒"},{"key":"话数","value":"1"}],"rating":{"rank":0,"total":41,"count":{"1":0,"2":0,"3":1,"4":0,"5":1,"6":6,"7":21,"8":9,"9":2,"10":1},"score":7.1},"total_episodes":0,"collection":{"on_hold":0,"dropped":5,"wish":5,"collect":95,"doing":1},"id":262836,"eps":1,"meta_tags":[