[{"date":"1952-10-18","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/ee/fe/634625_j9a7k.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/ee/fe/634625_j9a7k.jpg","large":"https://lain.bgm.tv/pic/cover/l/ee/fe/634625_j9a7k.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/ee/fe/634625_j9a7k.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/ee/fe/634625_j9a7k.jpg"},"summary":"　　伴随着南洋小岛曼妙的乐曲，新的故事拉开序幕。镜头转到海滨旁的一艘远洋邮轮上，船长向水手汤姆发出指示，绝对不允许有老鼠出现在这艘新船上，否则汤姆将丢掉饭碗。汤姆斯毫不敢怠慢，随即在甲板上巡逻起来。正在此时，杰瑞拎着行李准备登船，他将前往某个度假胜地旅游。可是刚刚登上舷梯，就被扔回岸上。作为客人竟遭到如此待遇，杰瑞自然不肯就此认输，他三番五次登船，和汤姆展开拉锯战。\r\n　　汽笛声响起，轮船正式起航，而这对冤家的战争才刚刚开始。与此同时，船上还放起了猫和老鼠的系列电影，笑声充斥影院每个角落……","name":"Cruise Cat","name_cn":"行船猫","tags":[{"name":"短片","count":2,"total_cont":0},{"name":"1950s","count":1,"total_cont":0},{"name":"剧场版","count":1,"total_cont":0},{"name":"猫和老鼠","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"行船猫"},{"key":"上映年度","value":"1952年10月18日"},{"key":"片长","value":"7分钟"},{"key":"IMDb","value":"tt0044522"}],"rating":{"rank":0,"total":5,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":1,"7":3,"8":0,"9":0,"10":0},"score":6.4},"total_episodes":0,"collection":{"on_hold":0,"dropped":0,"wish":1,"collect":7,"doing":0},"id":634625,"eps":0,"meta_tags":["剧场版"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},{"date":"1952-10-10","platform":"剧场版","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/a5/99/524046_s5T0F.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/a5/99/524046_s5T0F.jpg","large":"https://lain.bgm.tv/pic/cover/l/a5/99/524046_s5T0F.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/a5/99/524046_s5T0F.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/a5/99/524046_s5T0F.jpg"},"summary":"When the nephews come to Donald's house in their Halloween costumes he dumps water on them and laughs at his trick. A witch sees this and decides to help the kids. By magic she gives Donald a bad time and the kids finally get their treats.","name":"Trick or treat","name_cn"